term>\n  <code meaning=\"superior\" value=\"RID5822\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T25_64\">\n <term>\n  <code meaning=\"left\" value=\"RID5824\" scheme=\"RadLex\">\n </term>\n <term>\n  <code meaning=\"inferior\" value=\"RID5823\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T25_86\">\n <term>\n  <code meaning=\"left atrium\" value=\"RID1390\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T25_93\">\n <term>\n  <code meaning=\"intraluminal\" value=\"RID11135\" scheme=\"RadLex\">\n </term>\n <term>\n  <code meaning=\"thrombus\" value=\"RID5037\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T25_99\">\n <term>\n  <code meaning=\"set of coronary arteries\" value=\"RID28727\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T25_105\">\n <term>\n  <code meaning=\"set of pulmonary arteries\" value=\"RID28586\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T25_107\">\n <term>\n  <code meaning=\"diameter\" value=\"RID13432\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T25_109\">\n <term>\n  <code meaning=\"pulmonary embolism\" value=\"RID4834\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T25_114\">\n <term>\n  <code meaning=\"thoracic aorta\" value=\"RID879\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T25_116\">\n <term>\n  <code meaning=\"lungs\" value=\"RID13437\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T25_118\">\n <term>\n  <code meaning=\"upper abdomen\" value=\"RID29990\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T25_120\">\n <term>\n  <code meaning=\"image quality\" value=\"RID10\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T25_121\">\n <term>\n  <code meaning=\"exemplary quality\" value=\"RID11\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T25_122\">\n <term>\n  <code meaning=\"diagnostic quality\" value=\"RID12\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T25_223\">\n <term>\n  <code meaning=\"impression section\" value=\"RID13170\" scheme=\"RadLex\">\n </term>\n</entry>\n</coded_content>\n</template_attributes>\n-->\n</script>\n<title>CT Pulmonary Veins</title>\n</head>\n<body>\n<section data-section-name=\"Procedure\">\n<header class=\"level1\">CT Pulmonary Veins</header>\n<p>\n<textarea id=\"T25_2\" name=\"Procedure\"> </textarea>\n</p>\n<p>\n<label for=\"T25_11\">IV contrast:</label>\n<input type=\"text\" id=\"T25_11\" name=\"Contrast agent\" value=\"\"/>\n<input type=\"number\" id=\"T25_11_dose\" name=\"Contrast dose\" data-field-units=\"mL\" />\n<label for=\"T25_11_dose\">mL</label>\n</p>\n<p>\n<label for=\"T25_12\">Complication:</label>\n<input type=\"text\" id=\"T25_12\" name=\"Complication\" value=\"None.\"/>\n</p>\n<p>\n<label for=\"T25_15\">CT dose index-volume:</label>\n<input type=\"number\" id=\"T25_15\" name=\"CT dose index-volume\" data-field-units=\"mGy\" min=\"\" max=\"\"/> \n<label for=\"T25_15\">mGy</label>\n</p>\n<p>\n<label for=\"T25_16\">CT dose length:</label>\n<input type=\"number\" id=\"T25_16\" name=\"CT dose length\" data-field-units=\"mGy cm\" min=\"\" max=\"\"/> \n<label for=\"T25_16\">mGy cm</label>\n</p>\n</section>\n<section data-section-name=\"Clinical information\">\n<header class=\"level1\">Clinical information</header>\n<p>\n<textarea id=\"T25_17\" name=\"Clinical information\"> </textarea>\n</p>\n</section>\n<section data-section-name=\"Comparison\">\n<header class=\"level1\">Comparison</header>\n<p>\n<textarea id=\"T25_28\" name=\"Comparison\">None. </textarea>\n</p>\n</section>\n<section data-section-name=\"Findings\">\n<header class=\"level1\">Findings</header>\n<section data-section-name=\"Technical findings\">\n<header class=\"level2\">Technical findings</header>\n<p>\n<label for=\"T25_31\">Baseline cardiac rhythm:</label>\n<select id=\"T25_31\" name=\"Baseline cardiac rhythm\">\n<option id=\"T25_31_32\" name=\"Sinus rhythm\" value=\"Sinus rhythm\">Sinus rhythm</option>\n<option id=\"T25_31_33\" name=\"Atrial fibrillation\" value=\"Atrial fibrillation\">Atrial fibrillation</option>\n</select>\n</p>\n<p>\n<label for=\"T25_34\">Examination quality:</label>\n<select id=\"T25_34\" name=\"Examination quality\">\n<option id=\"T25_34.1\" name=\"Excellent\" value=\"Excellent\">Excellent</option>\n<option id=\"T25_34.2\" name=\"Good\" value=\"Good\">Good</option>\n<option id=\"T25_34.3\" name=\"Fair\" value=\"Fair\">Fair</option>\n<option id=\"T25_34.4\" name=\"Poor\" value=\"Poor\">Poor</option>\n<option id=\"T25_34.5\" name=\"Nondiagnostic\" value=\"Nondiagnostic\">Nondiagnostic</option>\n</select>\n</p>\n<p>\n<label for=\"T25_40\">Limitations:</label>\n<input type=\"text\" id=\"T25_40\" name=\"Limitations\" value=\"None.\"/>\n</p>\n</section>\n<section data-section-name=\"Pulmonary veins\">\n<header class=\"level2\">Pulmonary veins</header>\n<p>\nThere are\n<input type=\"number\" id=\"T25_50\" name=\"right pulmonary veins\"/> right pulmonary vein ostia\nand\n<input type=\"number\" id=\"T25_51\" name=\"left pulmonary veins\"/> left pulmonary vein ostia\ninto the left atrium.\n</p>\n<p>\n<label for=\"T25_53\">Pulmonary vein stenosis:</label>\n<input type=\"text\" id=\"T25_53\" name=\"Pulmonary vein stenosis\" value=\"None.\"/>\n</p>\n<p>Pulmonary vein diameters</p>\n<p>\n<label for=\"T25_55\">Right superior:</label>\n<input type=\"text\" id=\"T25_55\" name=\"Right superior\" value=\"\"/> \n<label for=\"T25_55\">mm</label>\n</p>\n<p>\n<label for=\"T25_58\">Right inferior:</label>\n<input type=\"text\" id=\"T25_58\" name=\"Right inferior\" value=\"\"/> \n<label for=\"T25_58\">mm</label>\n</p>\n<p>\n<label for=\"T25_61\">Left superior:</label>\n<input type=\"text\" id=\"T25_61\" name=\"Left superior\" value=\"\"/> \n<label for=\"T25_61\">mm</label>\n</p>\n<p>\n<label for=\"T25_64\">Left inferior:</label>\n<input type=\"text\" id=\"T25_64\" name=\"Left inferior\" value=\"\"/> \n<label for=\"T25_64\">mm</label>\n</p>\n</section>\n<section data-section-name=\"Heart\">\n<header class=\"level2\">Heart</header>\n<p>\n<label for=\"T25_86\">Left atrium size:</label>\n<input type=\"text\" id=\"T25_86\" name=\"Left atrium size\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T25_93\">Left atrium lumen:</label>\n<input type=\"text\" id=\"T25_93\" name=\"Left atrium lumen\" value=\"Normal opacification. No intraluminal thrombus.\"/>\n</p>\n<p>\n<label for=\"T25_99\">Coronary arteries:</label>\n<input type=\"text\" id=\"T25_99\" name=\"Coronary arteries\" value=\"Normal. \"/>\n</p>\n<p>\n<label for=\"T25_102\">IVC anomalies:</label>\n<input type=\"text\" id=\"T25_102_text\" name=\"IVC anomalies\" value=\"None.\"/>\n</p>\n</section>\n<section data-section-name=\"Pulmonary arteries\">\n<header class=\"level2\">Pulmonary arteries</header>\n<p>\n<label for=\"T25_105\">Pulmonary artery caliber:</label>\n<input type=\"text\" id=\"T25_105\" name=\"Pulmonary artery caliber\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T25_107\">Pulmonary artery diameter:</label>\n<input type=\"text\" id=\"T25_107\" name=\"Pulmonary artery diameter\" value=\"Normal. \"/>\n</p>\n<p>\n<label for=\"T25_109\">Pulmonary emboli:</label>\n<input type=\"text\" id=\"T25_109\" name=\"Pulmonary emboli\" value=\"None.\"/>\n</p>\n</section>\n<section data-section-name=\"Other findings\">\n<header class=\"level2\">Other findings</header>\n<p>\n<label for=\"T25_114\">Thoracic aorta:</label>\n<input type=\"text\" id=\"T25_114\" name=\"Thoracic aorta\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T25_116\">Lungs:</label>\n<input type=\"text\" id=\"T25_116\" name=\"Lungs\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T25_118\">Upper abdomen:</label>\n<input type=\"text\" id=\"T25_118\" name=\"Upper abdomen\" value=\"Normal.\"/>\n</p>\n</section>\n</section>\n<section data-section-name=\"Impression\">\n<header class=\"level1\">Impression</header>\n<p>\n<label for=\"T25_120\">Pulmonary venous anatomy:</label>\n<input type=\"text\" id=\"T25_120\" name=\"Pulmonary venous anatomy\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T25_121\">Pulmonary vein stenosis:</label>\n<input type=\"text\" id=\"T25_121\" name=\"Pulmonary vein stenosis\" value=\"None.\"/>\n</p>\n<p>\n<label for=\"T25_122\">Left atrial or appendageal thrombus:</label>\n<input type=\"text\" id=\"T25_122\" name=\"Pulmonary venous anatomy\" value=\"None.\"/>\n</p>\n<p>\n<textarea id=\"T25_223\" name=\"Impression\"> </textarea>\n</p>\n</section>\n</body>\n</html>\n",

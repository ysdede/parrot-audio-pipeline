    "templateData": "<html><head><meta charset=\"UTF-8\"><meta content=\"base ct orbit contrast\" name=\"dcterms.title\"><meta content=\"65127c70-d5e6-448a-898b-4f70b64a239e\" name=\"dcterms.identifier\"><meta content=\"en\" name=\"dcterms.language\"><meta content=\"2019-01-31\" name=\"dcterms.date\"><meta content=\"Nuance System\" name=\"dcterms.creator\"><title>base ct orbit contrast</title></head><body><section data-section-name=\"CT ORBITS WITH CONTRAST\"><header class=\"Level1\">CT ORBITS WITH CONTRAST</header><p><label>HISTORY:</label><input type=\"text\" name=\"Patient Age\" value=\"Patient Age\"></p><p><label> old </label><input type=\"text\" name=\"Patient Gender\" value=\"Patient Gender\"></p><p><label>, </label><input type=\"text\" name=\"history\" value=\"orbital pain, evaluate for infection\"></p></section><section data-section-name=\"TECHNIQUE:\"><header class=\"Level1\">TECHNIQUE:</header><p><label>CT images of the orbits were acquired with </label><input type=\"number\" name=\"contrast dose\"><label>mL Omnipaque 300 intravenous contrast.</label></p><p><label>CTDI: </label><input type=\"number\" name=\"CTDI\"><label>mGy</label></p><p><label>DLP: </label><input type=\"number\" name=\"DLP\"><label>mGy-cm</label></p><p><label>COMPARISON: </label><input type=\"text\" name=\"comparison\" value=\"None available\"></p></section><section data-section-name=\"FINDINGS:\"><header class=\"Level1\">FINDINGS:</header><p><label>ORBITS: </label><input type=\"text\" name=\"orbits\" value=\"No evidence of globe hemorrhage or lens dislocation. No retrobulbar hematoma or radio-opaque foreign body. Normal symmetric rectus muscles.\"></p><p><label> </label><input type=\"text\" name=\"enhancement\" value=\"No abnormal enhancement. No post-septal edema, inflammation, or fluid collections.\"></p><p><label>BONES: </label><input type=\"text\" name=\"bones\" value=\"No fracture.\"></p><p><label>VISUALIZED BRAIN PARENCHYMA: </label><input type=\"text\" name=\"brain\" value=\"No obvious mass effect or herniation.\"></p><p><label>OTHER: </label><input type=\"text\" name=\"other\" value=\"None.\"></p></section><section data-section-name=\"IMPRESSION:\"><header class=\"Level1\">IMPRESSION:</header><p><textarea name=\"impression\">Normal CT orbits.</textarea></p></section></body></html>",

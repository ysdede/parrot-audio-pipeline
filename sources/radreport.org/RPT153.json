">Both knees</option>\n</select>\n<input type=\"number\" id=\"T153_3\" name=\"Number of views\" min=\"1\" max=\"10\" step=\"1\" />\n<label for=\"T153_3\">views</label>\n</p>\n<p>\n<input type=\"text\" name=\"Procedure\" />\n</p>\n</section>\n<section data-section-name=\"Clinical information\">\n<header class=\"level1\">Clinical information</header>\n<p>\n<textarea id=\"T153_8\" name=\"Clinical information\">Total knee arthroplasty. </textarea>\n</p>\n</section>\n<section data-section-name=\"Comparison\">\n<header class=\"level1\">Comparison</header>\n<p>\n<textarea id=\"T153_9\" name=\"Comparison\">None. </textarea>\n</p>\n</section>\n<section data-section-name=\"Findings\">\n<header class=\"level1\">Findings</header>\n<p>\n<input type=\"text\" id=\"T153_12\" name=\"Arthroplasty\" value=\"A total knee arthroplasty is present.\"/>\n</p>\n<p>\n<label for=\"T153_13\">Alignment:</label>\n<input type=\"text\" id=\"T153_14\" name=\"Alignment\" value=\"The prosthesis is in normal alignment.\"/></p>\n<p>\n<label for=\"T153_19\">Complication:</label>\n<input type=\"text\" id=\"T153_19\" name=\"Complication\" value=\"There is no evidence of loosening or fracture.\"/>\n</p>\n</section>\n<section data-section-name=\"Impression\">\n<header class=\"level1\">Impression</header>\n<p>\n<textarea id=\"T153_20\" name=\"Comparison\">Total knee arthroplasty in normal alignment. </textarea>\n</p>\n</section>\n</body>\n</html>\n",

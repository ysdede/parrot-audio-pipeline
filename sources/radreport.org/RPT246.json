    "templateData": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\"/>\n<meta content=\"Parathyroid SPECT\" name=\"dcterms.title\"/>\n<meta content=\"Parathyroid SPECT template :: Authored by Imani F\" name=\"dcterms.description\"/>\n<meta content=\"http://www.radreport.org/template/0000246\" name=\"dcterms.identifier\"/>\n<meta content=\"en\" name=\"dcterms.language\"/>\n<meta content=\"IMAGE_REPORT_TEMPLATE\" name=\"dcterms.type\"/>\n<meta content=\"Radiological Society of North America (RSNA)\" name=\"dcterms.publisher\"/>\n<meta content=\"May be used gratis, subject to license agreement\" name=\"dcterms.rights\"/>\n<meta content=\"http://www.radreport.org/license.pdf\" name=\"dcterms.license\"/>\n<meta content=\"2012-09-17\" name=\"dcterms.date\"/>\n<meta content=\"Imani F\" name=\"dcterms.creator\"/>\n\n<meta content=\"Chadalavada SC [editor]\" name=\"dcterms.contributor\"/>\n<meta content=\"UCLA Health System (UCLA)\" name=\"dcterms.contributor\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"IHE_Template_Style.css\"/>\n<!-- The absolute link to the CSS file is http://www.radreport.org/html/IHE_Template_Style.css -->\n<script type=\"text/xml\">\r\n<!--\r\n<template_attributes>\n<top-level-flag>true</top-level-flag>\n<status>ACTIVE</status>\n<coding_schemes>\n <coding_scheme name=\"RadLex\" designator=\"2.16.840.1.113883.6.256\" />\n <coding_scheme name=\"SNOMEDCT\" designator=\"2.16.840.1.113883.6.96\" />\n <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\" />\n</coding_schemes>\n<term>\n <code meaning=\"adenoma\" value=\"RID4211\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"parathyroid gland\" value=\"RID7587\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"Tc-99m sestamibi\" value=\"RID11749\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"technetium\" value=\"RID11846\" scheme=\"RadLex\">\n</term>\n<coded_content>\n<entry ORIGTXT=\"T246_2\">\n <term>\n  <code meaning=\"procedure\" value=\"RID1559\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T246_5\">\n  <term>\n  <code meaning=\"Clinical information\" value=\"55752-0\" scheme=\"LOINC\">\n </term>\n</entry>\n<entry ORIGTXT=\"T246_7\">\n <term>\n  <code meaning=\"comparison\" value=\"RID28483\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T246_18\">\n <term>\n  <code meaning=\"impression section\" value=\"RID13170\" scheme=\"RadLex\">\n </term>\n</entry>\n</coded_content>\n</template_attributes>\r\n-->\r\n</script>\n<title>Parathyroid SPECT</title>\n</head>\n<body>\n<section data-section-name=\"Procedure\">\n<header class=\"level1\">Parathyroid SPECT</header>\n<p>\n<textarea id=\"T246_2\" name=\"Procedure\">Following injection of 99mTc sestamibi and approximately 10 minute delay, anterior projection images of the neck and chest were obtained. After a two-hour delay, repeat anterior projection images of the neck were acquired. SPECT images of the neck and chest were obtained and reconstructed in three axes.</textarea>\n</p>\n\n<p>\n<label for=\"T246_4\">Dose</label>\n<input type=\"number\" id=\"T246_4\" name=\"Dose\" value=\"22\"/> <label for=\"T246_4\">mCi</label>\n</p>\n\n</section>\n<section data-section-name=\"Clinical information\">\n<header class=\"level1\">Clinical information</header>\n<p>\n<textarea id=\"T246_5\" name=\"Clinical information\">Hyperparathyroidism. Evaluate for parathyroid adenoma.</textarea>\n</p>\n\n</section>\n<section data-section-name=\"Comparison\">\n<header class=\"level1\">Comparison</header>\n<p>\n<textarea id=\"T246_7\" name=\"Comparison\">None. </textarea>\n</p>\n</section>\n<section data-section-name=\"Findings\">\n<header class=\"level1\">Findings</header>\n<p>\n<label for=\"T246_10\">Thyroid tracer washout:</label>\n<input type=\"text\" id=\"T246_10\" name=\"Thyroid tracer washout\" value=\"Delayed images demonstrate near-complete tracer washout from the thyroid.\"/>\n</p>\n<p>\n<label for=\"T246_11\">Parathyroid uptake:</label>\n<input type=\"text\" id=\"T246_11\" name=\"Parathyroid uptake\" value=\"None. The two-hour delayed images do not demonstrate any focal abnormal persistent uptake in the region of the parathyroid glands to suggest parathyroid adenoma.\"/>\n</p>\n<p>\n<label for=\"T246_17\">Normal uptake:</label>\n<input type=\"text\" id=\"T246_17\" name=\"Normal uptake\" value=\"There is physiological tracer uptake in the myocardium, liver, salivary glands, and thyroid gland.\"/>\n</p>\n</section>\n<section data-section-name=\"Impression\">\n<header class=\"level1\">Impression:</header>\n<p>\n<textarea id=\"T246_18\" name=\"Impression\">Normal parathyroid imaging study. No evidence for mediastinal uptake to suggest mediastinal parathyroid adenoma.</textarea>\n</p>\n</section>\n</body>\n</html>\n",

    "templateData": "<!DOCTYPE html>\n<html>\n    <head>\n        <title>Cervical Cancer Staging MRI</title>\n        <meta charset=\"UTF-8\" />\n        <meta name=\"dcterms.identifier\" content=\"d264c0e3-148b-4598-997e-b1640a7a8925\" />\n        <meta name=\"dcterms.title\" content=\"Cervical Cancer Staging MRI\" />\n        <meta name=\"dcterms.description\" content=\"\" />\n        <meta name=\"dcterms.type\" content=\"IMAGE_REPORT_TEMPLATE\" />\n        <meta name=\"dcterms.language\" content=\"en\" />\n        <meta name=\"dcterms.publisher\" content=\"ESR\" />\n        <meta name=\"dcterms.rights\" content=\"May be used freely, subject to license agreement\" />\n        <meta name=\"dcterms.license\" content=\"http://www.radreport.org/license.pdf\" />\n        <meta name=\"dcterms.date\" content=\"2017-10-06\" />\n        <meta name=\"dcterms.creator\" content=\"Teresa Margarida Cunha, MD\" />\n        <meta name=\"dcterms.contributor\" content=\"Rita Lucas, MD\" />\n        <script type=\"text/xml\">\n            <template_attributes>\n                <coded_content>\n                    <coding_schemes>\n                        <coding_scheme name=\"RADLEX\" designator=\"2.16.840.1.113883.6.256\"></coding_scheme>\n                    </coding_schemes>\n                    <entry origtxt=\"SELECTION_LIST_1507302917915\">\n                        <term>\n                            <code meaning=\"cervix of uterus\" value=\"RID308\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1507302917915_0\">\n                        <term>\n                            <code meaning=\"exophytic\" value=\"RID6263\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1507302917915_1\">\n                        <term>\n                            <code meaning=\"exophytic\" value=\"RID6263\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1507302917915_2\">\n                        <term>\n                            <code meaning=\"infiltrative\" value=\"RID6282\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1507302917915_3\">\n                        <term>\n                            <code meaning=\"infiltrative\" value=\"RID6282\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1507302917932\">\n                        <term>\n                            <code meaning=\"pelvic wall\" value=\"RID30760\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"impressionText\">\n                        <term>\n                            <code meaning=\"impression section\" value=\"RID13170\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SECTION_HEADER_1507309430454\">\n                        <term>\n                            <code meaning=\"left ovary\" value=\"RID32830\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SECTION_HEADER_1507309430451\">\n                        <term>\n                            <code meaning=\"right ovary\" value=\"RID32829\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1475789858931\">\n                        <term>\n                            <code meaning=\"endometrium\" value=\"RID30958\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"comparisonsText\">\n                        <term>\n                            <code meaning=\"comparison\" value=\"RID28483\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1507302917929\">\n                        <term>\n                            <code meaning=\"rectal\" value=\"RID11181\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1507302917903\">\n                        <term>\n                            <code meaning=\"uterus\" value=\"RID302\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1507302917903_0\">\n                        <term>\n                            <code meaning=\"anteverted\" value=\"RID38806\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1507302917903_1\">\n                        <term>\n                            <code meaning=\"retroverted\" value=\"RID38807\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1507302917903_2\">\n                        <term>\n                            <code meaning=\"retroflexed\" value=\"RID39240\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1507302917903_3\">\n                        <term>\n                            <code meaning=\"displaced\" value=\"RID5840\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1507302917903_4\">\n                        <term>\n                            <code meaning=\"displaced\" value=\"RID5840\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1507302917924\">\n                        <term>\n                            <code meaning=\"wall of urinary bladder\" value=\"RID30135\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"clinicalInformationText\">\n                        <term>\n                            <code meaning=\"clinical information section\" value=\"RID13166\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1475789858893\">\n                        <term>\n                            <code meaning=\"procedure\" value=\"RID1559\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1507309430457\">\n                        <term>\n                            <code meaning=\"ascites\" value=\"RID1541\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                </coded_content>\n            </template_attributes>\n        </script>\n    </head>\n    <body>\n        <section id=\"procedureInformation\" class=\"level1\" data-section-name=\"Procedure Information\">\n            <header class=\"level1\">\n                Procedure Information\n            </header>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1475789858893\">Procedure Description:</label>\n                <select id=\"SELECTION_LIST_1475789858893\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Enhanced MRI Pelvis\">\n                    <option id=\"SELECTION_LIST_1475789858893_0\" value=\"Enhanced MRI Pelvis\" name=\"SELECTION_LIST_1475789858893\" selected=\"\">Enhanced MRI Pelvis</option>\n                    <option id=\"SELECTION_LIST_1475789858893_1\" value=\"Unenhanced MRI Pelvis\" name=\"SELECTION_LIST_1475789858893\">Unenhanced MRI Pelvis</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1507302917883\">Technique:</label>\n                <select multiple=\"multiple\" id=\"SELECTION_LIST_1507302917883\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"T2-weighted images of the pelvis in axial, sagittal and axial oblique (perpendicular to the cervical canal long axis)\">\n                    <option id=\"SELECTION_LIST_1507302917883_0\" value=\"T2-weighted images of the pelvis in axial, sagittal and axial oblique (perpendicular to the cervical canal long axis)\" name=\"SELECTION_LIST_1507302917883\" selected=\"\">T2-weighted images of the pelvis in axial, sagittal and axial oblique (perpendicular to the cervical canal long axis)</option>\n                    <option id=\"SELECTION_LIST_1507302917883_1\" value=\"T1-weighted images of the pelvis in axial plane\" name=\"SELECTION_LIST_1507302917883\">T1-weighted images of the pelvis in axial plane</option>\n                    <option id=\"SELECTION_LIST_1507302917883_2\" value=\"T2-weighted images of the abdomen and DWI studies for abdomen and pelvis were also obtained\" name=\"SELECTION_LIST_1507302917883\">T2-weighted images of the abdomen and DWI studies for abdomen and pelvis were also obtained</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1507302917888\">Post contrast imaging:</label>\n                <select id=\"SELECTION_LIST_1507302917888\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Pre and non-dynamic post contrast imaging of the pelvis was performed\">\n                    <option id=\"SELECTION_LIST_1507302917888_0\" value=\"Pre and non-dynamic post contrast imaging of the pelvis was performed\" name=\"SELECTION_LIST_1507302917888\" selected=\"\">Pre and non-dynamic post contrast imaging of the pelvis was performed</option>\n                    <option id=\"SELECTION_LIST_1507302917888_1\" value=\"Pre and dynamic post contrast imaging of the pelvis was performed\" name=\"SELECTION_LIST_1507302917888\">Pre and dynamic post contrast imaging of the pelvis was performed</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1507302917891\">MR Field Strength:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"Tesla (T)\" id=\"NUMBER_1507302917891\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    Tesla (T)\n                </span>\n            </p>\n            <p title=\"Name of contrast agent used\">\n                <label for=\"TEXT_1507302917892\">Contrast agent administered before and after fat suppressed T1-weighted imaging:</label>\n                <input type=\"text\" id=\"TEXT_1507302917892\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\" value=\"\" />\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1507302917893\">Amount of contrast agent used:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"ml\" id=\"NUMBER_1507302917893\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    ml\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1507302917878\">Image Quality:</label>\n                <input list=\"SELECTION_LIST_1507302917878_LIST\" id=\"SELECTION_LIST_1507302917878\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Satisfactory\" />\n                <datalist id=\"SELECTION_LIST_1507302917878_LIST\">\n                    <option id=\"SELECTION_LIST_1507302917878_0\" value=\"Satisfactory\" name=\"SELECTION_LIST_1507302917878\" selected=\"\">Satisfactory</option>\n                    <option id=\"SELECTION_LIST_1507302917878_1\" value=\"Degraded by motion\" name=\"SELECTION_LIST_1507302917878\">Degraded by motion</option>\n                </datalist>\n            </p>\n        </section>\n        <section id=\"clinicalInformation\" class=\"level1\" data-section-name=\"Clinical Information\">\n            <header class=\"level1\">\n                Clinical Information\n            </header>\n            <p title=\"\">\n                <label for=\"clinicalInformationText\">Clinical Indication:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"clinicalInformationText\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Cervical cancer staging</textarea>\n            </p>\n        </section>\n        <section id=\"comparisons\" class=\"level1\" data-section-name=\"Comparison\">\n            <header class=\"level1\">\n                Comparison\n            </header>\n            <p title=\"\">\n                <label for=\"comparisonsText\">Comparison study:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"comparisonsText\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">None available</textarea>\n            </p>\n        </section>\n        <section id=\"findings\" class=\"level1\" data-section-name=\"Findings\">\n            <header class=\"level1\">\n                Findings\n            </header>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1507302917903\">Uterus:</label>\n                <input list=\"SELECTION_LIST_1507302917903_LIST\" id=\"SELECTION_LIST_1507302917903\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Anteverted\" />\n                <datalist id=\"SELECTION_LIST_1507302917903_LIST\">\n                    <option id=\"SELECTION_LIST_1507302917903_0\" value=\"Anteverted\" name=\"SELECTION_LIST_1507302917903\" selected=\"\">Anteverted</option>\n                    <option id=\"SELECTION_LIST_1507302917903_1\" value=\"Retroverted\" name=\"SELECTION_LIST_1507302917903\">Retroverted</option>\n                    <option id=\"SELECTION_LIST_1507302917903_2\" value=\"Retroflexed\" name=\"SELECTION_LIST_1507302917903\">Retroflexed</option>\n                    <option id=\"SELECTION_LIST_1507302917903_3\" value=\"Displaced to the right\" name=\"SELECTION_LIST_1507302917903\">Displaced to the right</option>\n                    <option id=\"SELECTION_LIST_1507302917903_4\" value=\"Displaced to the left\" name=\"SELECTION_LIST_1507302917903\">Displaced to the left</option>\n                </datalist>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1475789858929\">Uterus size (qualitative):</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1475789858929\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">normal in size</textarea>\n            </p>\n            <p title=\"cm x cm x cm\">\n                <label for=\"TEXT_1507302917909\">Uterus Measuring:</label>\n                <input type=\"text\" id=\"TEXT_1507302917909\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\" value=\"\" />\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1475789858931\">Endometrium:</label>\n                <select id=\"SELECTION_LIST_1475789858931\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Normal\">\n                    <option id=\"SELECTION_LIST_1475789858931_0\" value=\"Normal\" name=\"SELECTION_LIST_1475789858931\" selected=\"\">Normal</option>\n                    <option id=\"SELECTION_LIST_1475789858931_1\" value=\"Abnormal\" name=\"SELECTION_LIST_1475789858931\">Abnormal</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1475789858934\">Maximum width of the endometrium:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"mm\" id=\"NUMBER_1475789858934\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    mm\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1475789858935\">Junctional zone:</label>\n                <select id=\"SELECTION_LIST_1475789858935\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"There is no adenomyosis. \">\n                    <option id=\"SELECTION_LIST_1475789858935_0\" value=\"There is no adenomyosis.\" name=\"SELECTION_LIST_1475789858935\">There is no adenomyosis.</option>\n                    <option id=\"SELECTION_LIST_1475789858935_1\" value=\"There is mild adenomyosis.\" name=\"SELECTION_LIST_1475789858935\">There is mild adenomyosis.</option>\n                    <option id=\"SELECTION_LIST_1475789858935_2\" value=\"There is moderate adenomyosis.\" name=\"SELECTION_LIST_1475789858935\">There is moderate adenomyosis.</option>\n                    <option id=\"SELECTION_LIST_1475789858935_3\" value=\"There is severe adenomyosis.\" name=\"SELECTION_LIST_1475789858935\">There is severe adenomyosis.</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1475789858940\">Outer Myometrium:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1475789858940\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There are no leiomyomas.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1507302917915\">Cervix:</label>\n                <input list=\"SELECTION_LIST_1507302917915_LIST\" id=\"SELECTION_LIST_1507302917915\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Exophytic Tumour not extending to the isthmus, body of the uterus, or vagina\" />\n                <datalist id=\"SELECTION_LIST_1507302917915_LIST\">\n                    <option id=\"SELECTION_LIST_1507302917915_0\" value=\"Exophytic Tumour not extending to the isthmus, body of the uterus, or vagina\" name=\"SELECTION_LIST_1507302917915\" selected=\"\">Exophytic Tumour not extending to the isthmus, body of the uterus, or vagina</option>\n                    <option id=\"SELECTION_LIST_1507302917915_1\" value=\"Exophytic Tumour which extends to the isthmus, body of the uterus, or vagina\" name=\"SELECTION_LIST_1507302917915\">Exophytic Tumour which extends to the isthmus, body of the uterus, or vagina</option>\n                    <option id=\"SELECTION_LIST_1507302917915_2\" value=\"Infiltrative Tumour not extending to the isthmus, body of the uterus, or vagina\" name=\"SELECTION_LIST_1507302917915\">Infiltrative Tumour not extending to the isthmus, body of the uterus, or vagina</option>\n                    <option id=\"SELECTION_LIST_1507302917915_3\" value=\"Infiltrative Tumour which extends to the isthmus, body of the uterus, or vagina\" name=\"SELECTION_LIST_1507302917915\">Infiltrative Tumour which extends to the isthmus, body of the uterus, or vagina</option>\n                </datalist>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1507302917920\">Tumour measurement:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1507302917920\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">   cm x    cm of the larger axis</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1507302917921\">Parametria:</label>\n                <input list=\"SELECTION_LIST_1507302917921_LIST\" id=\"SELECTION_LIST_1507302917921\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"There is parametrial invasion.\" />\n                <datalist id=\"SELECTION_LIST_1507302917921_LIST\">\n                    <option id=\"SELECTION_LIST_1507302917921_0\" value=\"There is parametrial invasion.\" name=\"SELECTION_LIST_1507302917921\" selected=\"\">There is parametrial invasion.</option>\n                    <option id=\"SELECTION_LIST_1507302917921_1\" value=\"There is no parametrial invasion.\" name=\"SELECTION_LIST_1507302917921\">There is no parametrial invasion.</option>\n                </datalist>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1507302917924\">Bladder Wall:</label>\n                <input list=\"SELECTION_LIST_1507302917924_LIST\" id=\"SELECTION_LIST_1507302917924\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"There is no bladder wall invasion.\" />\n                <datalist id=\"SELECTION_LIST_1507302917924_LIST\">\n                    <option id=\"SELECTION_LIST_1507302917924_0\" value=\"There is bladder wall invasion.\" name=\"SELECTION_LIST_1507302917924\">There is bladder wall invasion.</option>\n                    <option id=\"SELECTION_LIST_1507302917924_1\" value=\"There is no bladder wall invasion.\" name=\"SELECTION_LIST_1507302917924\" selected=\"\">There is no bladder wall invasion.</option>\n                </datalist>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1507302917929\">Rectal Wall:</label>\n                <input list=\"SELECTION_LIST_1507302917929_LIST\" id=\"SELECTION_LIST_1507302917929\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"There is no rectal wall invasion.\" />\n                <datalist id=\"SELECTION_LIST_1507302917929_LIST\">\n                    <option id=\"SELECTION_LIST_1507302917929_0\" value=\"There is rectal wall invasion.\" name=\"SELECTION_LIST_1507302917929\">There is rectal wall invasion.</option>\n                    <option id=\"SELECTION_LIST_1507302917929_1\" value=\"There is no rectal wall invasion.\" name=\"SELECTION_LIST_1507302917929\" selected=\"\">There is no rectal wall invasion.</option>\n                </datalist>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1507302917932\">Pelvic Wall:</label>\n                <input list=\"SELECTION_LIST_1507302917932_LIST\" id=\"SELECTION_LIST_1507302917932\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"There is no pelvic wall invasion.\" />\n                <datalist id=\"SELECTION_LIST_1507302917932_LIST\">\n                    <option id=\"SELECTION_LIST_1507302917932_0\" value=\"There is pelvic wall invasion.\" name=\"SELECTION_LIST_1507302917932\">There is pelvic wall invasion.</option>\n                    <option id=\"SELECTION_LIST_1507302917932_1\" value=\"There is no pelvic wall invasion.\" name=\"SELECTION_LIST_1507302917932\" selected=\"\">There is no pelvic wall invasion.</option>\n                </datalist>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1507302917935\">Lymph Nodes:</label>\n                <input list=\"SELECTION_LIST_1507302917935_LIST\" id=\"SELECTION_LIST_1507302917935\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"The lymph nodes are normal in size.\" />\n                <datalist id=\"SELECTION_LIST_1507302917935_LIST\">\n                    <option id=\"SELECTION_LIST_1507302917935_0\" value=\"The lymph nodes are normal in size.\" name=\"SELECTION_LIST_1507302917935\" selected=\"\">The lymph nodes are normal in size.</option>\n                    <option id=\"SELECTION_LIST_1507302917935_1\" value=\"The lymph nodes are enlarged; probably reactive.\" name=\"SELECTION_LIST_1507302917935\">The lymph nodes are enlarged; probably reactive.</option>\n                </datalist>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1507302917938\">Hydronephrosis:</label>\n                <input list=\"SELECTION_LIST_1507302917938_LIST\" id=\"SELECTION_LIST_1507302917938\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"There is no hydronephrosis present.\" />\n                <datalist id=\"SELECTION_LIST_1507302917938_LIST\">\n                    <option id=\"SELECTION_LIST_1507302917938_0\" value=\"Hydronephrosis is present.\" name=\"SELECTION_LIST_1507302917938\">Hydronephrosis is present.</option>\n                    <option id=\"SELECTION_LIST_1507302917938_1\" value=\"There is no hydronephrosis present.\" name=\"SELECTION_LIST_1507302917938\" selected=\"\">There is no hydronephrosis present.</option>\n                </datalist>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1507309430450\">Distant metastasis:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1507309430450\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n            <section id=\"SECTION_HEADER_1507309430451\" class=\"level2\" data-section-name=\"Right ovary:\">\n                <header class=\"level2\">\n                    Right ovary:\n                </header>\n                <p title=\"\">\n                    <label for=\"TEXT_1507309430452\">Size:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1507309430452\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">    cm  x    cm  x    cm</textarea>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1507309430453\">Image location:</label>\n                    <input type=\"text\" id=\"TEXT_1507309430453\" name=\"\" data-field-type=\"TEXT\" data-field-co
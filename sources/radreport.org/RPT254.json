    "templateData": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\"/>\n<meta content=\"Endoscopic Retrograde Pancreaticogram (ERP)\" name=\"dcterms.title\"/>\n<meta content=\"Endoscopic Retrograde Pancreaticogram (ERP) template :: Authored by Marn CE\" name=\"dcterms.description\"/>\n<meta content=\"http://www.radreport.org/template/0000254\" name=\"dcterms.identifier\"/>\n<meta content=\"en\" name=\"dcterms.language\"/>\n<meta content=\"IMAGE_REPORT_TEMPLATE\" name=\"dcterms.type\"/>\n<meta content=\"Radiological Society of North America (RSNA)\" name=\"dcterms.publisher\"/>\n<meta content=\"May be used gratis, subject to license agreement\" name=\"dcterms.rights\"/>\n<meta content=\"http://www.radreport.org/license.pdf\" name=\"dcterms.license\"/>\n<meta content=\"2012-12-10\" name=\"dcterms.date\"/>\n<meta content=\"Marn CE\" name=\"dcterms.creator\"/>\n<meta content=\"Kahn CE Jr [editor]\" name=\"dcterms.contributor\"/>\n<meta content=\"Medical College of Wisconsin (MCW)\" name=\"dcterms.contributor\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"IHE_Template_Style.css\"/>\n<!-- The absolute link to the CSS file is http://www.radreport.org/html/IHE_Template_Style.css -->\n<script type=\"text/xml\">\n<!--\n<template_attributes>\n<top-level-flag>true</top-level-flag>\n<status>ACTIVE</status>\n<coding_schemes>\n <coding_scheme name=\"RadLex\" designator=\"2.16.840.1.113883.6.256\" />\n <coding_scheme name=\"SNOMEDCT\" designator=\"2.16.840.1.113883.6.96\" />\n <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\" />\n</coding_schemes>\n<term>\n <code meaning=\"pancreatic duct\" value=\"RID176\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"projection radiography\" value=\"RID10345\" scheme=\"RadLex\">\n</term>\n<coded_content>\n<entry ORIGTXT=\"T254_2\">\n <term>\n  <code meaning=\"procedure\" value=\"RID1559\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T254_3\">\n  <term>\n  <code meaning=\"Clinical information\" value=\"55752-0\" scheme=\"LOINC\">\n </term>\n</entry>\n<entry ORIGTXT=\"T254_4\">\n <term>\n  <code meaning=\"comparison\" value=\"RID28483\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T254_6\">\n  <term>\n  <code meaning=\"Radiology Study observation (narrative)\" value=\"18782-3\" scheme=\"LOINC\">\n </term>\n</entry>\n<entry ORIGTXT=\"T254_7\">\n <term>\n  <code meaning=\"impression section\" value=\"RID13170\" scheme=\"RadLex\">\n </term>\n</entry>\n</coded_content>\n</template_attributes>\n-->\n</script>\n<title>Endoscopic Retrograde Pancreaticogram (ERP)</title>\n</head>\n<body>\n<section data-section-name=\"Procedure\">\n<header class=\"level1\">Endoscopic Retrograde Pancreaticogram (ERP)</header>\n<p>\n<textarea id=\"T254_2\" name=\"Procedure\">Images are submitted for review from endoscopic retrograde pancreaticogram (ERP) performed by the GI lab. Endoscope is passed in an antegrade fashion, and the tip of the endoscope lies in the second portion of the duodenum. The distal pancreatic duct is cannulated, and contrast injected in retrograde fashion. </textarea>\n</p>\n</section>\n<section data-section-name=\"Clinical information\">\n<header class=\"level1\">Clinical information</header>\n<p>\n<textarea id=\"T254_3\" name=\"Clinical information\"> </textarea>\n</p>\n</section>\n<section data-section-name=\"Comparison\">\n<header class=\"level1\">Comparison</header>\n<p>\n<textarea id=\"T254_4\" name=\"Comparison\">None. </textarea>\n</p>\n</section>\n<section data-section-name=\"Findings\">\n<header class=\"level1\">Findings</header>\n<p>\n<textarea id=\"T254_6\" name=\"Findings\"></textarea>\n</p>\n<p>\n<label for=\"X1\">Fluoroscopy time:</label>\n<input type=\"number\" name=\"Fluoroscopy time\" id=\"X1\" min=\"\" step=\"0.1\" data-field-units=\"minutes\" /> minutes\n</p>\n</section>\n<section data-section-name=\"Impression\">\n<header class=\"level1\">Impression</header>\n<p>\n<textarea id=\"T254_7\" name=\"Impression\"> </textarea>\n</p>\n<p>Please see the GI procedure note for further details.</p>\n</section>\n</body>\n</html>\n",

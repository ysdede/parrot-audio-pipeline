    "templateData": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\"/>\n<meta content=\"CT Facial Bones\" name=\"dcterms.title\"/>\n<meta content=\"CT Facial Bones template :: Authored by Kahn CE Jr\" name=\"dcterms.description\"/>\n<meta content=\"http://www.radreport.org/template/0000181\" name=\"dcterms.identifier\"/>\n<meta content=\"en\" name=\"dcterms.language\"/>\n<meta content=\"IMAGE_REPORT_TEMPLATE\" name=\"dcterms.type\"/>\n<meta content=\"Radiological Society of North America (RSNA)\" name=\"dcterms.publisher\"/>\n<meta content=\"May be used gratis, subject to license agreement\" name=\"dcterms.rights\"/>\n<meta content=\"http://www.radreport.org/license.pdf\" name=\"dcterms.license\"/>\n<meta content=\"2012-05-29\" name=\"dcterms.date\"/>\n<meta content=\"Kahn CE Jr\" name=\"dcterms.creator\"/>\n\n<meta content=\"Kahn CE Jr [editor]\" name=\"dcterms.contributor\"/>\n<meta content=\"Medical College of Wisconsin (MCW)\" name=\"dcterms.contributor\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"IHE_Template_Style.css\"/>\n<!-- The absolute link to the CSS file is http://www.radreport.org/html/IHE_Template_Style.css -->\n<script type=\"text/xml\">\r\n<!--\r\n<template_attributes>\n<top-level-flag>true</top-level-flag>\n<status>ACTIVE</status>\n<coding_schemes>\n <coding_scheme name=\"RadLex\" designator=\"2.16.840.1.113883.6.256\" />\n <coding_scheme name=\"SNOMEDCT\" designator=\"2.16.840.1.113883.6.96\" />\n <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\" />\n</coding_schemes>\n<term>\n <code meaning=\"face\" value=\"RID13284\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"fracture\" value=\"RID4650\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"injury due to mechanical trauma\" value=\"RID4630\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"paranasal sinuses\" value=\"RID28579\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"set of facial bones\" value=\"RID28570\" scheme=\"RadLex\">\n</term>\n<coded_content>\n<entry ORIGTXT=\"T181_3\">\n  <term>\n  <code meaning=\"Clinical information\" value=\"55752-0\" scheme=\"LOINC\">\n </term>\n</entry>\n<entry ORIGTXT=\"T181_4\">\n <term>\n  <code meaning=\"comparison\" value=\"RID28483\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T181_11\">\n <term>\n  <code meaning=\"impression section\" value=\"RID13170\" scheme=\"RadLex\">\n </term>\n</entry>\n</coded_content>\n</template_attributes>\r\n-->\r\n</script>\n<title>CT Facial Bones</title>\n</head>\n<body>\n<section data-section-name=\"Procedure\">\n<header class=\"level1\">CT Facial Bones</header>\n</section>\n<section data-section-name=\"Clinical information\">\n<header class=\"level1\">Clinical information</header>\n<p>\n<textarea id=\"T181_3\" name=\"Clinical information\"> </textarea>\n</p>\n</section>\n<section data-section-name=\"Comparison\">\n<header class=\"level1\">Comparison</header>\n<p>\n<textarea id=\"T181_4\" name=\"Comparison\">None. </textarea>\n</p>\n</section>\n<section data-section-name=\"Findings\">\n<header class=\"level1\">Findings</header>\n<p>\n<label for=\"T181_7\">Facial bones:</label>\n<textarea id=\"T181_7\" name=\"Findings\">No facial bone fracture is evident. </textarea>\n</p>\n<p>\n<label for=\"T181_9\">Other structures:</label>\n<textarea id=\"T181_9\" name=\"Other structures\">Visualized paranasal sinuses are well-aerated. No evidence of abnormal air-fluid levels. Bilateral mastoids also appear unremarkable. Both globes, extraocular muscles, optic nerves and retrobulbar fat appears normal. Visualized upper aerodigestive tract appears normal. Mandible and bilateral temporomandibular joints appear normal. </textarea>\n</p>\n</section>\n<section data-section-name=\"Impression\">\n<header class=\"level1\">Impression</header>\n<p>\n<textarea id=\"T181_11\" name=\"Impression\">No evidence of fracture or dislocation in facial bones. </textarea>\n</p>\n</section>\n</body>\n</html>\n",

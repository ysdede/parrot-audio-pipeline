" id=\"T16_18\" name=\"Location\" value=\"\"/>\n<label for=\"T16_44\">(series</label>\n<input type=\"number\" id=\"T16_44\" name=\"Series\" data-field-units=\"\" min=\"\" max=\"\"/> \n<label for=\"T16_45\">, image</label>\n<input type=\"number\" id=\"T16_45\" name=\"Image\" data-field-units=\"\" min=\"\" max=\"\"/> \n)</p>\n<p>\n<label for=\"T16_46\">Shape:</label>\n<select id=\"T16_46\" name=\"Shape\">\n<option id=\"T16_46_47\" name=\"Spiculated\" value=\"Spiculated\">Spiculated</option>\n<option id=\"T16_46_48\" name=\"Round\" value=\"Round\">Round</option>\n<option id=\"T16_46_49\" name=\"Smoothly marginated\" value=\"Smoothly marginated\">Smoothly marginated</option>\n</select>\n</p>\n<p>\n<label for=\"T16_50\">Internal consistency:</label>\n<select id=\"T16_50\" name=\"Internal consistency\">\n<option id=\"T16_50_51\" name=\"Centrally calcified\" value=\"Centrally calcified\">Centrally calcified</option>\n<option id=\"T16_50_52\" name=\"Peripherally calcified\" value=\"Peripherally calcified\">Peripherally calcified</option>\n<option id=\"T16_50_53\" name=\"Ground glass\" value=\"Ground glass\">Ground glass</option>\n<option id=\"T16_50_54\" name=\"Fatty\" value=\"Fatty\">Fatty</option>\n</select>\n</p>\n</section>\n<section data-section-name=\"Local extent\">\n<header class=\"level2\">Local extent</header>\n<p>\n<label for=\"T16_56\">Pleural surface:</label>\n<input type=\"text\" id=\"T16_56\" name=\"Pleural surface\" value=\"No involvement.\"/>\n</p>\n<p>\n<label for=\"T16_59\">Chest wall:</label>\n<input type=\"text\" id=\"T16_59\" name=\"Chest wall\" value=\"No involvement.\"/>\n</p>\n<p>\n<label for=\"T16_62\">Airway:</label>\n<input type=\"text\" id=\"T16_62\" name=\"Airway\" value=\"No involvement.\"/>\n</p>\n<p>\n<label for=\"T16_65\">Vessels:</label>\n<input type=\"text\" id=\"T16_99\" name=\"Vessels\" value=\"No involvement.\"/>\n</p>\n<p>\n<label for=\"T16_68\">Nerves:</label>\n<input type=\"text\" id=\"T16_68\" name=\"Nerves\" value=\"No involvement.\"/>\n</p>\n</section>\n<section data-section-name=\"Regional extent\">\n<header class=\"level2\">Regional extent</header>\n<p>\n<label for=\"T16_71\">Lymph nodes:</label>\n<input type=\"text\" id=\"T16_71\" name=\"Lymph nodes\" value=\"No adenopathy.\"/>\n</p>\n<p>\n<label for=\"T16_74\">Distant metastases (chest and upper abdomen):</label>\n<input type=\"text\" id=\"T16_74\" name=\"Metastases\" value=\"None. \"/>\n</p>\n</section>\n<section data-section-name=\"Other findings\">\n<header class=\"level2\">Other findings</header>\n<p>\n<textarea id=\"T16_98\" name=\"Other findings\">None. </textarea>\n</p>\n</section>\n</section>\n<section data-section-name=\"Impression\">\n<header class=\"level1\">Impression</header>\n<p>\n<textarea id=\"T16_79\" name=\"Impression\"> </textarea>\n</p>\n</section>\n</body>\n</html>\n",

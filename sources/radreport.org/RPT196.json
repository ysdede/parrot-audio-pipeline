    "templateData": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\"/>\n<meta content=\"US Thyroid FNA\" name=\"dcterms.title\"/>\n<meta content=\"US Thyroid FNA template :: Authored by Kahn CE Jr\" name=\"dcterms.description\"/>\n<meta content=\"http://www.radreport.org/template/0000196\" name=\"dcterms.identifier\"/>\n<meta content=\"en\" name=\"dcterms.language\"/>\n<meta content=\"IMAGE_REPORT_TEMPLATE\" name=\"dcterms.type\"/>\n<meta content=\"Radiological Society of North America (RSNA)\" name=\"dcterms.publisher\"/>\n<meta content=\"May be used gratis, subject to license agreement\" name=\"dcterms.rights\"/>\n<meta content=\"http://www.radreport.org/license.pdf\" name=\"dcterms.license\"/>\n<meta content=\"2012-05-29\" name=\"dcterms.date\"/>\n<meta content=\"Kahn CE Jr\" name=\"dcterms.creator\"/>\n\n<meta content=\"Kahn CE Jr [editor]\" name=\"dcterms.contributor\"/>\n<meta content=\"Medical College of Wisconsin (MCW)\" name=\"dcterms.contributor\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"IHE_Template_Style.css\"/>\n<!-- The absolute link to the CSS file is http://www.radreport.org/html/IHE_Template_Style.css -->\n<script type=\"text/xml\">\r\n<!--\r\n<template_attributes>\n<top-level-flag>true</top-level-flag>\n<status>ACTIVE</status>\n<coding_schemes>\n <coding_scheme name=\"RadLex\" designator=\"2.16.840.1.113883.6.256\" />\n <coding_scheme name=\"SNOMEDCT\" designator=\"2.16.840.1.113883.6.96\" />\n <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\" />\n</coding_schemes>\n<term>\n <code meaning=\"fine-needle aspiration\" value=\"RID12933\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"thyroid gland\" value=\"RID7578\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"ultrasound\" value=\"RID10326\" scheme=\"RadLex\">\n</term>\n<coded_content>\n<entry ORIGTXT=\"T196_9\">\n  <term>\n  <code meaning=\"Clinical information\" value=\"55752-0\" scheme=\"LOINC\">\n </term>\n</entry>\n<entry ORIGTXT=\"T196_10\">\n <term>\n  <code meaning=\"comparison\" value=\"RID28483\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T196_16\">\n <term>\n  <code meaning=\"impression section\" value=\"RID13170\" scheme=\"RadLex\">\n </term>\n</entry>\n</coded_content>\n</template_attributes>\r\n-->\r\n</script>\n<title>US Thyroid FNA</title>\n</head>\n<body>\n<section data-section-name=\"Procedure\">\n<header class=\"level1\">US Thyroid FNA</header>\n<p>\n<label for=\"T196_3\">Consent:</label>\n<input type=\"text\" id=\"T196_3\" name=\"Consent\" value=\"The procedure, with its potential risks and complications, was discussed with the patient, including the option of not performing the procedure. Verbal and written consent was obtained. \"/>\n</p>\n<p>\n<label for=\"T196_4\">Time-out:</label>\n<input type=\"text\" id=\"T196_4\" name=\"Time-out\" value=\"A time-out was observed to confirm the correct patient, procedure, and site.\"/>\n</p>\n<p>\n<label for=\"T196_5\">Localization:</label>\n<input type=\"text\" id=\"T196_5\" name=\"Localization\" value=\"With the patient in supine position, the target nodule was identified by ultrasound. A skin site was marked, and the skin was prepped and draped in usual sterile fashion.\"/>\n</p>\n<p>\n<label for=\"T196_6\">Location:</label>\n<input type=\"text\" id=\"T196_6\" name=\"Location\" value=\"\"/>\n</p>\n<p>\n<label for=\"T196_8\">Needle(s)</label>\n<input type=\"number\" id=\"T196_8\" name=\"Needle\" data-field-units=\"Ga\" min=\"\" max=\"\"/> <label for=\"T196_8\">Ga</label>\n</p>\n</section>\n<section data-section-name=\"Clinical information\">\n<header class=\"level1\">Clinical information</header>\n<p>\n<textarea id=\"T196_9\" name=\"Clinical information\"> </textarea>\n</p>\n</section>\n<section data-section-name=\"Comparison\">\n<header class=\"level1\">Comparison</header>\n<p>\n<textarea id=\"T196_10\" name=\"Comparison\">None. </textarea>\n</p>\n</section>\n<section data-section-name=\"Findings\">\n<header class=\"level1\">Findings</header>\n<p>\n<label for=\"T196_7\">Number of passes:</label>\n<input type=\"number\" id=\"T196_7\" name=\"Number of passes\" data-field-units=\"\" min=\"\" max=\"\"/> \n</p>\n<p>\n<label for=\"T196_13\">Adequacy:</label>\n<input type=\"text\" id=\"T196_13\" name=\"Adequacy\" value=\"A cytotechnologist present on-site determined the sample to be adequate.\"/>\n</p>\n<p>\n<label for=\"T196_14\">Complications:</label>\n<input type=\"text\" id=\"T196_14\" name=\"Complications\" value=\"None. \"/>\n</p>\n</section>\n<section data-section-name=\"Impression\">\n<header class=\"level1\">Impression</header>\n<p>\n<textarea id=\"T196_16\" name=\"Impression\">Ultrasound-guided fine needle aspiration of thyroid nodule. </textarea>\n</p>\n</section>\n</body>\n</html>\n",

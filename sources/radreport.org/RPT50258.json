    "templateData": "<!DOCTYPE html>\n<html>\n    <head>\n        <title>Endometrial Cancer Staging CT</title>\n        <meta charset=\"UTF-8\" />\n        <meta name=\"dcterms.identifier\" content=\"50b433f3-87e3-453a-aefd-6ae03fb49f98\" />\n        <meta name=\"dcterms.title\" content=\"Endometrial Cancer Staging CT\" />\n        <meta name=\"dcterms.description\" content=\"\" />\n        <meta name=\"dcterms.type\" content=\"IMAGE_REPORT_TEMPLATE\" />\n        <meta name=\"dcterms.language\" content=\"en\" />\n        <meta name=\"dcterms.publisher\" content=\"ESR\" />\n        <meta name=\"dcterms.rights\" content=\"May be used freely, subject to license agreement\" />\n        <meta name=\"dcterms.license\" content=\"http://www.radreport.org/license.pdf\" />\n        <meta name=\"dcterms.date\" content=\"2017-10-06\" />\n        <meta name=\"dcterms.creator\" content=\"Teresa Margarida Cunha, MD\" />\n        <meta name=\"dcterms.contributor\" content=\"Rita Lucas, MD\" />\n        <script type=\"text/xml\">\n            <template_attributes>\n                <coded_content>\n                    <coding_schemes>\n                        <coding_scheme name=\"RADLEX\" designator=\"2.16.840.1.113883.6.256\"></coding_scheme>\n                    </coding_schemes>\n                    <entry origtxt=\"SELECTION_LIST_1476396306210\">\n                        <term>\n                            <code meaning=\"procedure\" value=\"RID1559\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"impressionText\">\n                        <term>\n                            <code meaning=\"impression section\" value=\"RID13170\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1476396508599\">\n                        <term>\n                            <code meaning=\"endometrium\" value=\"RID30958\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476397006685\">\n                        <term>\n                            <code meaning=\"set of ovaries\" value=\"RID39537\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476396306213\">\n                        <term>\n                            <code meaning=\"clinical information section\" value=\"RID13166\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476397006690\">\n                        <term>\n                            <code meaning=\"ascites\" value=\"RID1541\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"comparisonsText\">\n                        <term>\n                            <code meaning=\"comparison\" value=\"RID28483\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                </coded_content>\n            </template_attributes>\n        </script>\n    </head>\n    <body>\n        <section id=\"procedureInformation\" class=\"level1\" data-section-name=\"Procedure Information\">\n            <header class=\"level1\">\n                Procedure Information\n            </header>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476396306210\">Procedure Description:</label>\n                <select id=\"SELECTION_LIST_1476396306210\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Enhanced abdomen and pelvis CT\">\n                    <option id=\"SELECTION_LIST_1476396306210_0\" value=\"Enhanced abdomen and pelvis CT\" name=\"SELECTION_LIST_1476396306210\" selected=\"\">Enhanced abdomen and pelvis CT</option>\n                    <option id=\"SELECTION_LIST_1476396306210_1\" value=\"Unenhanced abdomen and pelvis CT\" name=\"SELECTION_LIST_1476396306210\">Unenhanced abdomen and pelvis CT</option>\n                </select>\n            </p>\n          <p title=\"\">\n                <label for=\"TEXT_1476396306214\">Technique:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476396306214\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Helical CT of the abdomen and pelvis before and after IV contrast administration. Sagittal and coronal reconstructions.</textarea>\n            </p>\n        </section>\n        <section id=\"clinicalInformation\" class=\"level1\" data-section-name=\"Clinical Information\">\n            <header class=\"level1\">\n                Clinical Information\n            </header>\n            <p title=\"\">\n                <label for=\"TEXT_1476396306213\">Clinical Indication:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476396306213\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Endometrium cancer staging</textarea>\n            </p>\n        </section>\n        <section id=\"comparisons\" class=\"level1\" data-section-name=\"Comparison\">\n            <header class=\"level1\">\n                Comparison\n            </header>\n            <p title=\"\">\n                <label for=\"comparisonsText\">Comparison study:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"comparisonsText\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">None available</textarea>\n            </p>\n        </section>\n        <section id=\"findings\" class=\"level1\" data-section-name=\"Findings\">\n            <header class=\"level1\">\n                Findings\n            </header>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476397006695\">Uterus:</label>\n                <select id=\"SELECTION_LIST_1476397006695\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Anteverted\">\n                    <option id=\"SELECTION_LIST_1476397006695_0\" value=\"Anteverted\" name=\"SELECTION_LIST_1476397006695\" selected=\"\">Anteverted</option>\n                    <option id=\"SELECTION_LIST_1476397006695_1\" value=\"Retroverted\" name=\"SELECTION_LIST_1476397006695\">Retroverted</option>\n                    <option id=\"SELECTION_LIST_1476397006695_2\" value=\"Retroflexed\" name=\"SELECTION_LIST_1476397006695\">Retroflexed</option>\n                    <option id=\"SELECTION_LIST_1476397006695_3\" value=\"Displaced to left\" name=\"SELECTION_LIST_1476397006695\">Displaced to left</option>\n                    <option id=\"SELECTION_LIST_1476397006695_4\" value=\"Displaced to right\" name=\"SELECTION_LIST_1476397006695\">Displaced to right</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476397260855\">Size:</label>\n                <input type=\"text\" id=\"TEXT_1476397260855\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\" value=\"Normal in size\" />\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476397260856\">Measuring:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"cm\" id=\"NUMBER_1476397260856\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    cm\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476396508599\">Endometrium:</label>\n                <select id=\"SELECTION_LIST_1476396508599\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Tumor visible\">\n                    <option id=\"SELECTION_LIST_1476396508599_0\" value=\"Tumor visible\" name=\"SELECTION_LIST_1476396508599\" selected=\"\">Tumor visible</option>\n                    <option id=\"SELECTION_LIST_1476396508599_1\" value=\"Tumor not visible\" name=\"SELECTION_LIST_1476396508599\">Tumor not visible</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476397006684\">Tumor measurement:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"cm\" id=\"NUMBER_1476397006684\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    cm\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476397006685\">Ovaries:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476397006685\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There are no pelvic masses.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476397006686\">Lymph nodes:</label>\n                <select id=\"SELECTION_LIST_1476397006686\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Normal size\">\n                    <option id=\"SELECTION_LIST_1476397006686_0\" value=\"Normal size\" name=\"SELECTION_LIST_1476397006686\" selected=\"\">Normal size</option>\n                    <option id=\"SELECTION_LIST_1476397006686_1\" value=\"Enlarged; probably reactive\" name=\"SELECTION_LIST_1476397006686\">Enlarged; probably reactive</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476397006689\">Hepatic lesions:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476397006689\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476397006690\">Ascites:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476397006690\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no ascites</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476397006691\">Peritoneal implants:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476397006691\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There are no peritoneal implants</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476397006692\">Bone lesions:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476397006692\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There are no bone lesions.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476397006693\">Other distant metastasis:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476397006693\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">None</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476397006694\">Other findings:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476397006694\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n        </section>\n        <section id=\"impression\" class=\"level1\" data-section-name=\"Impression\">\n            <header class=\"level1\">\n                Impression\n            </header>\n            <p title=\"\">\n                <label for=\"impressionText\">Impression:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"impressionText\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n        </section>\n    </body>\n</html>\n",

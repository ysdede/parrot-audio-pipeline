    "templateData": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\"/>\n<meta content=\"Hysterosalpingogram\" name=\"dcterms.title\"/>\n<meta content=\"Hysterosalpingogram template :: Authored by Kahn CE Jr\" name=\"dcterms.description\"/>\n<meta content=\"http://www.radreport.org/template/0000184\" name=\"dcterms.identifier\"/>\n<meta content=\"en\" name=\"dcterms.language\"/>\n<meta content=\"IMAGE_REPORT_TEMPLATE\" name=\"dcterms.type\"/>\n<meta content=\"Radiological Society of North America (RSNA)\" name=\"dcterms.publisher\"/>\n<meta content=\"May be used gratis, subject to license agreement\" name=\"dcterms.rights\"/>\n<meta content=\"http://www.radreport.org/license.pdf\" name=\"dcterms.license\"/>\n<meta content=\"2012-05-29\" name=\"dcterms.date\"/>\n<meta content=\"Kahn CE Jr\" name=\"dcterms.creator\"/>\n\n<meta content=\"Kahn CE Jr [editor]\" name=\"dcterms.contributor\"/>\n<meta content=\"Medical College of Wisconsin (MCW)\" name=\"dcterms.contributor\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"IHE_Template_Style.css\"/>\n<!-- The absolute link to the CSS file is http://www.radreport.org/html/IHE_Template_Style.css -->\n<script type=\"text/xml\">\r\n<!--\r\n<template_attributes>\n<top-level-flag>true</top-level-flag>\n<status>ACTIVE</status>\n<coding_schemes>\n <coding_scheme name=\"RadLex\" designator=\"2.16.840.1.113883.6.256\" />\n <coding_scheme name=\"SNOMEDCT\" designator=\"2.16.840.1.113883.6.96\" />\n <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\" />\n</coding_schemes>\n<coded_content>\n</coded_content>\n</template_attributes>\r\n-->\r\n</script>\n<title>Hysterosalpingogram</title>\n</head>\n<body>\n<section data-section-name=\"Procedure\">\n<header class=\"level1\">Hysterosalpingogram</header>\n<p>\n<textarea id=\"T184_2\" name=\"Procedure\">The cervical opening was cannulated by the gynecologist. Then under fluoroscopic guidance, water-soluble contrast was injected in a retrograde fashion.</textarea>\n</p>\n</section>\n<section data-section-name=\"Clinical information\">\n<header class=\"level1\">Clinical information</header>\n<p>\n<textarea id=\"T184_6\" name=\"Clinical information\">Infertility. </textarea>\n</p>\n</section>\n<section data-section-name=\"Comparison\">\n<header class=\"level1\">Comparison</header>\n<p>\n<textarea id=\"T184_8\" name=\"Comparison\">None. </textarea>\n</p>\n</section>\n<section data-section-name=\"Findings\">\n<header class=\"level1\">Findings</header>\n<p>\n<textarea id=\"T184_10\" name=\"Findings\">The uterus fills normally, with no evidence of contour abnormality, filling defect, septum, stricture, mass, or bicornuate configuration. The bilateral uterine tubes are normal and patent with normal rapid spillage of contrast into the peritoneum. </textarea>\n</p>\n<p>\n<label for=\"T184_5\">Fluoroscopy time:</label>\n<input type=\"number\" id=\"T184_5\" name=\"Fluoroscopy time\" data-field-units=\"minutes\" min=\"0\" step=\"0.1\"/> minutes\n</p>\n</section>\n<section data-section-name=\"Impression\">\n<header class=\"level1\">Impression</header>\n<p>\n<textarea id=\"T184_12\" name=\"Impression\">Normal hysterosalpingogram. </textarea>\n</p>\n</section>\n</body>\n</html>\n",

    "templateData": "<!DOCTYPE html>\n<html>\n    <head>\n        <title>Ovarian Cancer Follow-Up CT</title>\n        <meta charset=\"UTF-8\" />\n        <meta name=\"dcterms.identifier\" content=\"e6166d34-cd99-430a-813e-7a6be4a340d7\" />\n        <meta name=\"dcterms.title\" content=\"Ovarian Cancer Follow-Up CT\" />\n        <meta name=\"dcterms.description\" content=\"\" />\n        <meta name=\"dcterms.type\" content=\"IMAGE_REPORT_TEMPLATE\" />\n        <meta name=\"dcterms.language\" content=\"en\" />\n        <meta name=\"dcterms.publisher\" content=\"ESR\" />\n        <meta name=\"dcterms.rights\" content=\"May be used freely, subject to license agreement\" />\n        <meta name=\"dcterms.license\" content=\"http://www.radreport.org/license.pdf\" />\n        <meta name=\"dcterms.date\" content=\"2017-10-06\" />\n        <meta name=\"dcterms.creator\" content=\"Teresa Margarida Cunha, MD\" />\n        <meta name=\"dcterms.contributor\" content=\"Rita Lucas, MD\" />\n        <script type=\"text/xml\">\n            <template_attributes>\n                <coded_content>\n                    <coding_schemes>\n                        <coding_scheme name=\"RADLEX\" designator=\"2.16.840.1.113883.6.256\"></coding_scheme>\n                    </coding_schemes>\n                    <entry origtxt=\"TEXT_1476398574763\">\n                        <term>\n                            <code meaning=\"intravenous contrast\" value=\"RID49553\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476398574764\">\n                        <term>\n                            <code meaning=\"oral contrast\" value=\"RID35817\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476398574765\">\n                        <term>\n                            <code meaning=\"pleural effusion\" value=\"RID34539\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1476398574775\">\n                        <term>\n                            <code meaning=\"vagina\" value=\"RID325\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476398574767\">\n                        <term>\n                            <code meaning=\"set of ovaries\" value=\"RID39537\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"impressionText\">\n                        <term>\n                            <code meaning=\"impression section\" value=\"RID13170\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"procedureInformationText\">\n                        <term>\n                            <code meaning=\"procedure\" value=\"RID1559\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476398574793\">\n                        <term>\n                            <code meaning=\"hydronephrosis\" value=\"RID34393\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476398574794\">\n                        <term>\n                            <code meaning=\"ascites\" value=\"RID1541\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"comparisonsText\">\n                        <term>\n                            <code meaning=\"comparison\" value=\"RID28483\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1476398574781\">\n                        <term>\n                            <code meaning=\"rectum\" value=\"RID163\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1476398574787\">\n                        <term>\n                            <code meaning=\"liver\" value=\"RID58\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"clinicalInformationText\">\n                        <term>\n                            <code meaning=\"clinical information\" value=\"RID13166\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1476398574769\">\n                        <term>\n                            <code meaning=\"uterus\" value=\"RID302\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                </coded_content>\n            </template_attributes>\n        </script>\n    </head>\n    <body>\n        <section id=\"procedureInformation\" class=\"level1\" data-section-name=\"Procedure Information\">\n            <header class=\"level1\">\n                Procedure Information\n            </header>\n            <p title=\"\">\n                <label for=\"procedureInformationText\">Procedure Description</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"procedureInformationText\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Helical acquisition from the base of the lungs to the inguinal region. Sagittal and coronal reconstructions.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476398574763\">IV contrast:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476398574763\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476398574764\">Oral contrast:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476398574764\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Oral contrast was administered.</textarea>\n            </p>\n        </section>\n        <section id=\"clinicalInformation\" class=\"level1\" data-section-name=\"Clinical Information\">\n            <header class=\"level1\">\n                Clinical Information\n            </header>\n            <p title=\"\">\n                <label for=\"clinicalInformationText\">Clinical Information:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"clinicalInformationText\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Ovarian cancer follow-up</textarea>\n            </p>\n        </section>\n        <section id=\"comparisons\" class=\"level1\" data-section-name=\"Comparison\">\n            <header class=\"level1\">\n                Comparison\n            </header>\n            <p title=\"\">\n                <label for=\"comparisonsText\">Comparison study:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"comparisonsText\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">None available</textarea>\n            </p>\n        </section>\n        <section id=\"findings\" class=\"level1\" data-section-name=\"Findings\">\n            <header class=\"level1\">\n                Findings\n            </header>\n            <p title=\"\">\n                <label for=\"findingsText\">Cardiophrenic lymph nodes:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"findingsText\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Cardiophrenic lymph nodes with a short-axis diameter of &gt;5 mm.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476398574765\">Pleural effusion:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476398574765\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no pleural effusion.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476398574766\">Pleural implants:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476398574766\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There are no pleural implants.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476398574767\">Ovaries:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476398574767\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476398574768\">Residual tumor measuring:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"cm\" id=\"NUMBER_1476398574768\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    cm\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476398574769\">Uterus:</label>\n                <select id=\"SELECTION_LIST_1476398574769\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Invaded\">\n                    <option id=\"SELECTION_LIST_1476398574769_0\" value=\"Invaded\" name=\"SELECTION_LIST_1476398574769\" selected=\"\">Invaded</option>\n                    <option id=\"SELECTION_LIST_1476398574769_1\" value=\"Not invaded\" name=\"SELECTION_LIST_1476398574769\">Not invaded</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476398574772\">Cervix:</label>\n                <select id=\"SELECTION_LIST_1476398574772\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Invaded\">\n                    <option id=\"SELECTION_LIST_1476398574772_0\" value=\"Invaded\" name=\"SELECTION_LIST_1476398574772\" selected=\"\">Invaded</option>\n                    <option id=\"SELECTION_LIST_1476398574772_1\" value=\"Not Invaded\" name=\"SELECTION_LIST_1476398574772\">Not Invaded</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476398574775\">Vagina:</label>\n                <select id=\"SELECTION_LIST_1476398574775\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Invaded\">\n                    <option id=\"SELECTION_LIST_1476398574775_0\" value=\"Invaded\" name=\"SELECTION_LIST_1476398574775\" selected=\"\">Invaded</option>\n                    <option id=\"SELECTION_LIST_1476398574775_1\" value=\"Not invaded\" name=\"SELECTION_LIST_1476398574775\">Not invaded</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476398574778\">Bladder:</label>\n                <select id=\"SELECTION_LIST_1476398574778\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Invaded\">\n                    <option id=\"SELECTION_LIST_1476398574778_0\" value=\"Invaded\" name=\"SELECTION_LIST_1476398574778\" selected=\"\">Invaded</option>\n                    <option id=\"SELECTION_LIST_1476398574778_1\" value=\"Not invaded\" name=\"SELECTION_LIST_1476398574778\">Not invaded</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476398574781\">Rectum:</label>\n                <select id=\"SELECTION_LIST_1476398574781\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Invaded\">\n                    <option id=\"SELECTION_LIST_1476398574781_0\" value=\"Invaded\" name=\"SELECTION_LIST_1476398574781\" selected=\"\">Invaded</option>\n                    <option id=\"SELECTION_LIST_1476398574781_1\" value=\"Not invaded\" name=\"SELECTION_LIST_1476398574781\">Not invaded</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476398574784\">Abdominal/Pelvic wall:</label>\n                <select id=\"SELECTION_LIST_1476398574784\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Invaded\">\n                    <option id=\"SELECTION_LIST_1476398574784_0\" value=\"Invaded\" name=\"SELECTION_LIST_1476398574784\" selected=\"\">Invaded</option>\n                    <option id=\"SELECTION_LIST_1476398574784_1\" value=\"Not invaded\" name=\"SELECTION_LIST_1476398574784\">Not invaded</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476398574787\">Liver:</label>\n                <select id=\"SELECTION_LIST_1476398574787\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Parenchyma/perihepatic metastases\">\n                    <option id=\"SELECTION_LIST_1476398574787_0\" value=\"Parenchyma/perihepatic metastases\" name=\"SELECTION_LIST_1476398574787\" selected=\"\">Parenchyma/perihepatic metastases</option>\n                    <option id=\"SELECTION_LIST_1476398574787_1\" value=\"Serosal invasive metastases\" name=\"SELECTION_LIST_1476398574787\">Serosal invasive metastases</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476398574792\">Bowel:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476398574792\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476398574793\">Hydronephrosis:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476398574793\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no hydronephrosis.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476398574794\">Ascites:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476398574794\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no ascites.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476398574795\">Site and amount of ascites:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476398574795\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476398574796\">Lymph nodes:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476398574796\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There are no lymph nodes with a short-axis diameter of &gt;1 cm, or suspicious clusters of smaller lymph nodes</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476398574797\">Venous obstruction/thrombosis:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476398574797\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no venous obstruction/thrombosis.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476398574798\">Bones:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476398574798\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Normal</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476398574799\">Other findings:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476398574799\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n        </section>\n        <section id=\"impression\" class=\"level1\" data-section-name=\"Impression\">\n            <header class=\"level1\">\n                Impression\n            </header>\n            <p title=\"\">\n                <label for=\"impressionText\">Impression:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"impressionText\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n        </section>\n    </body>\n</html>\n",

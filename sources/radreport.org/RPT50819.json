    "templateData": "<!DOCTYPE html>\n<html>\n    <head>\n        <title>CT Upper Extremity</title>\n        <meta charset=\"UTF-8\" />\n        <meta name=\"dcterms.identifier\" content=\"b7ff6336-850f-4e06-9a98-1d4163d7f10f\" />\n        <meta name=\"dcterms.title\" content=\"CT Upper Extremity\" />\n        <meta name=\"dcterms.description\" content=\"\" />\n        <meta name=\"dcterms.type\" content=\"IMAGE_REPORT_TEMPLATE\" />\n        <meta name=\"dcterms.language\" content=\"en\" />\n        <meta name=\"dcterms.publisher\" content=\"\" />\n        <meta name=\"dcterms.rights\" content=\"May be used freely, subject to license agreement\" />\n        <meta name=\"dcterms.license\" content=\"http://www.radreport.org/license.pdf\" />\n        <meta name=\"dcterms.date\" content=\"2020-06-23\" />\n        <meta name=\"dcterms.creator\" content=\"Arghavan Sharifi\" />\n        <script type=\"text/xml\">\n            <template_attributes>\n                <coded_content>\n                    <coding_schemes>\n                        <coding_scheme name=\"RADLEX\" designator=\"2.16.840.1.113883.6.256\"></coding_scheme>\n                        <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\"></coding_scheme>\n                    </coding_schemes>\n                    <entry origtxt=\"findings\">\n                        <term>\n                            <code meaning=\"Procedure Findings\" value=\"59776-5\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"procedureInformation\">\n                        <term>\n                            <code meaning=\"Current Imaging Procedure Description\" value=\"55111-9\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"comparisons\">\n                        <term>\n                            <code meaning=\"Radiology Comparison Study\" value=\"18834-2\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"impression\">\n                        <term>\n                            <code meaning=\"Impressions\" value=\"19005-8\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"clinicalInformation\">\n                        <term>\n                            <code meaning=\"Clinical Information\" value=\"55752-0\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                </coded_content>\n            </template_attributes>\n        </script>\n    </head>\n    <body>\n        <section id=\"procedureInformation\" class=\"level1\" data-section-name=\"Procedure Information\">\n            <header class=\"level1\">\n                Procedure Information\n            </header>\n            <p title=\"\">\n                <label for=\"procedureInformationText\">Exam</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"procedureInformationText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">3D volume rendered segmented and anatomically corrected scapular plane images and measurements enclosed for pre-surgical planning. </textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1586361996399\">Technique</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1586361996399\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Multislice CT examination was performed of the (laterality) shoulder with multiplanar reconstructions displayed in multiple window settings. Imaging was performed without IV contrast material. 3D imaging was reconstructed on an independent workstation with scapular plane reconstructions for measurements.</textarea>\n            </p>\n        </section>\n        <section id=\"clinicalInformation\" class=\"level1\" data-section-name=\"Clinical Information\">\n            <header class=\"level1\">\n                Clinical Information\n            </header>\n            <p title=\"\">\n                <label for=\"clinicalInformationText\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"clinicalInformationText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n        </section>\n        <section id=\"comparisons\" class=\"level1\" data-section-name=\"Comparison\">\n            <header class=\"level1\">\n                Comparison\n            </header>\n            <p title=\"\">\n                <label for=\"comparisonsText\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"comparisonsText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n        </section>\n        <section id=\"findings\" class=\"level1\" data-section-name=\"Findings\">\n            <header class=\"level1\">\n                Findings\n            </header>\n            <p title=\"\">\n                <label for=\"findingsText\">Bone and joint findings</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"findingsText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1586361996400\">Acromial arch findings</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1586361996400\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"RADIO_1586361996401\">Acromial arch shape</label>\n                <span id=\"RADIO_1586361996401\" name=\"\" data-field-type=\"RADIO\" data-field-completion-action=\"NONE\" value=\"\">\n                    <br />\n                    <input id=\"RADIO_1586361996401_0\" type=\"radio\" name=\"RADIO_1586361996401\" value=\"Curved\" checked=\"\">Curved</input>\n                    <br />\n                    <input id=\"RADIO_1586361996401_1\" type=\"radio\" name=\"RADIO_1586361996401\" value=\"Flat\">Flat</input>\n                    <br />\n                    <input id=\"RADIO_1586361996401_2\" type=\"radio\" name=\"RADIO_1586361996401\" value=\"Convex\">Convex</input>\n                    <br />\n                    <input id=\"RADIO_1586361996401_3\" type=\"radio\" name=\"RADIO_1586361996401\" value=\"Hooked\">Hooked</input>\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"RADIO_1586361996411\">Acromial arch downsloping location</label>\n                <span id=\"RADIO_1586361996411\" name=\"\" data-field-type=\"RADIO\" data-field-completion-action=\"NONE\" value=\"\">\n                    <br />\n                    <input id=\"RADIO_1586361996411_0\" type=\"radio\" name=\"RADIO_1586361996411\" value=\"Lateral\" checked=\"\">Lateral</input>\n                    <br />\n                    <input id=\"RADIO_1586361996411_1\" type=\"radio\" name=\"RADIO_1586361996411\" value=\"Anterior\">Anterior</input>\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"RADIO_1586361996414\">Acromial arch subacromial spur detection</label>\n                <span id=\"RADIO_1586361996414\" name=\"\" data-field-type=\"RADIO\" data-field-completion-action=\"NONE\" value=\"\">\n                    <br />\n                    <input id=\"RADIO_1586361996414_0\" type=\"radio\" name=\"RADIO_1586361996414\" value=\"Absent\" checked=\"\">Absent</input>\n                    <br />\n                    <input id=\"RADIO_1586361996414_1\" type=\"radio\" name=\"RADIO_1586361996414\" value=\"Present\">Present</input>\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"RADIO_1586361996419\">Acromial arch subacromial spur type</label>\n                <span id=\"RADIO_1586361996419\" name=\"\" data-field-type=\"RADIO\" data-field-completion-action=\"NONE\" value=\"\">\n                    <br />\n                    <input id=\"RADIO_1586361996419_0\" type=\"radio\" name=\"RADIO_1586361996419\" value=\"Keel\" checked=\"\">Keel</input>\n                    <br />\n                    <input id=\"RADIO_1586361996419_1\" type=\"radio\" name=\"RADIO_1586361996419\" value=\"Heel\">Heel</input>\n                    <br />\n                    <input id=\"RADIO_1586361996419_2\" type=\"radio\" name=\"RADIO_1586361996419\" value=\"Traction\">Traction</input>\n                    <br />\n                    <input id=\"RADIO_1586361996419_3\" type=\"radio\" name=\"RADIO_1586361996419\" value=\"Bird-beak type\">Bird-beak type</input>\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"RADIO_1586361996424\">Acromial arch acromioclavicular joint osteoarthrosis severity</label>\n                <span id=\"RADIO_1586361996424\" name=\"\" data-field-type=\"RADIO\" data-field-completion-action=\"NONE\" value=\"\">\n                    <br />\n                    <input id=\"RADIO_1586361996424_0\" type=\"radio\" name=\"RADIO_1586361996424\" value=\"Mild\" checked=\"\">Mild</input>\n                    <br />\n                    <input id=\"RADIO_1586361996424_1\" type=\"radio\" name=\"RADIO_1586361996424\" value=\"Moderate\">Moderate</input>\n                    <br />\n                    <input id=\"RADIO_1586361996424_2\" type=\"radio\" name=\"RADIO_1586361996424\" value=\"Severe\">Severe</input>\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"RADIO_1586361996428\">Acromial arch os acromiale detection</label>\n                <span id=\"RADIO_1586361996428\" name=\"\" data-field-type=\"RADIO\" data-field-completion-action=\"NONE\" value=\"\">\n                    <br />\n                    <input id=\"RADIO_1586361996428_0\" type=\"radio\" name=\"RADIO_1586361996428\" value=\"Absent\" checked=\"\">Absent</input>\n                    <br />\n                    <input id=\"RADIO_1586361996428_1\" type=\"radio\" name=\"RADIO_1586361996428\" value=\"Present\">Present</input>\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"RADIO_1586361996431\">Acromial arch os acromiale type</label>\n                <span id=\"RADIO_1586361996431\" name=\"\" data-field-type=\"RADIO\" data-field-completion-action=\"NONE\" value=\"\">\n                    <br />\n                    <input id=\"RADIO_1586361996431_0\" type=\"radio\" name=\"RADIO_1586361996431\" value=\"Pre\" checked=\"\">Pre</input>\n                    <br />\n                    <input id=\"RADIO_1586361996431_1\" type=\"radio\" name=\"RADIO_1586361996431\" value=\"Meso\">Meso</input>\n                    <br />\n                    <input id=\"RADIO_1586361996431_2\" type=\"radio\" name=\"RADIO_1586361996431\" value=\"Meta\">Meta</input>\n                    <br />\n                    <input id=\"RADIO_1586361996431_3\" type=\"radio\" name=\"RADIO_1586361996431\" value=\"Basi\">Basi</input>\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1586361996436\">Glenohumeral joint findings</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1586361996436\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"RADIO_1586361996444\">Glenohumeral joint osteoarthrosis severity</label>\n                <span id=\"RADIO_1586361996444\" name=\"\" data-field-type=\"RADIO\" data-field-completion-action=\"NONE\" value=\"\">\n                    <br />\n                    <input id=\"RADIO_1586361996444_0\" type=\"radio\" name=\"RADIO_1586361996444\" value=\"Mild\" checked=\"\">Mild</input>\n                    <br />\n                    <input id=\"RADIO_1586361996444_1\" type=\"radio\" name=\"RADIO_1586361996444\" value=\"Moderate\">Moderate</input>\n                    <br />\n                    <input id=\"RADIO_1586361996444_2\" type=\"radio\" name=\"RADIO_1586361996444\" value=\"Severe\">Severe</input>\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1586361996448\">Glenoid bone stock measure</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"cm\" id=\"NUMBER_1586361996448\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    cm\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1586436181641\">Modified Walch class type</label>\n                <select id=\"SELECTION_LIST_1586436181641\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"A1\">\n                    <option id=\"SELECTION_LIST_1586436181641_0\" value=\"A1\" name=\"SELECTION_LIST_1586436181641\" selected=\"\">A1</option>\n                    <option id=\"SELECTION_LIST_1586436181641_1\" value=\"A2\" name=\"SELECTION_LIST_1586436181641\">A2</option>\n                    <option id=\"SELECTION_LIST_1586436181641_2\" value=\"B1\" name=\"SELECTION_LIST_1586436181641\">B1</option>\n                    <option id=\"SELECTION_LIST_1586436181641_3\" value=\"B2\" name=\"SELECTION_LIST_1586436181641\">B2</option>\n                    <option id=\"SELECTION_LIST_1586436181641_4\" value=\"B3\" name=\"SELECTION_LIST_1586436181641\">B3</option>\n                    <option id=\"SELECTION_LIST_1586436181641_5\" value=\"C\" name=\"SELECTION_LIST_1586436181641\">C</option>\n                    <option id=\"SELECTION_LIST_1586436181641_6\" value=\"D\" name=\"SELECTION_LIST_1586436181641\">D</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1586361996443\">Glenoid version anteversion measure</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"Degree\" id=\"NUMBER_1586361996443\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    Degree\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1586361996449\">Glenoid version retroversion measure</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"Degree\" id=\"NUMBER_1586361996449\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    Degree\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1586361996450\">Anterior glenoid bone loss measure</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"mm\" id=\"NUMBER_1586361996450\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    mm\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1586361996451\">Mid glenoid bone loss measure</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"mm\" id=\"NUMBER_1586361996451\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    mm\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1586361996452\">Posterior glenoid bone loss measure</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"mm\" id=\"NUMBER_1586361996452\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    mm\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1586361996453\">Humeral head medialization measure</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"mm\" id=\"NUMBER_1586361996453\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    mm\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1586361996454\">Muscle and tendon findings</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1586361996454\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1586361996455\">Vessel findings</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1586361996455\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1586361996456\">Other incidental findings</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1586361996456\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n        </section>\n        <section id=\"impression\" class=\"level1\" data-section-name=\"Impression\">\n            <header class=\"level1\">\n                Impression\n            </header>\n            <p title=\"\">\n                <label for=\"impressionText\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"impressionText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n        </section>\n    </body>\n</html>\n",

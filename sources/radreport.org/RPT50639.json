    "templateData": "<html><head><meta charset=\"UTF-8\"><meta content=\"base mri brain mra head\" name=\"dcterms.title\"><meta content=\"01936f43-245a-4c4e-9e4c-231f8e4f1c88\" name=\"dcterms.identifier\"><meta content=\"en\" name=\"dcterms.language\"><meta content=\"2019-01-31\" name=\"dcterms.date\"><meta content=\"Nuance System\" name=\"dcterms.creator\"><title>base mri brain mra head</title></head><body><section data-section-name=\"MRI AND MRA BRAIN WITHOUT CONTRAST\"><header class=\"Level1\">MRI AND MRA BRAIN WITHOUT CONTRAST</header><p><label>HISTORY:</label><input type=\"text\" name=\"Patient Age\" value=\"Patient Age\"></p><p><label> old </label><input type=\"text\" name=\"Patient Gender\" value=\"Patient Gender\"></p><p><label>, </label><select name=\"history\"><option name=\"\" value=\"\" selected=\"\">headache.</option><option name=\"\" value=\"\" selected=\"\">stroke symptoms.</option></select></p></section><section data-section-name=\"TECHNIQUE:\"><header class=\"Level1\">TECHNIQUE:</header><p><label>MR images of the brain and MRA images of the head were acquired without intravenous contrast.</label><br><label>COMPARISON: </label><input type=\"text\" name=\"Comparison\" value=\"None available.\"></p></section><section data-section-name=\"FINDINGS:\"><header class=\"Level1\">FINDINGS:</header><p><label>MRI BRAIN</label><br><label>BRAIN PARENCHYMA: </label><input type=\"text\" name=\"infarct-hemorrhage\" value=\"No acute infarct or hemorrhage. No mass effect or herniation.\"></p><p><label> </label><select name=\"white matter\"><option name=\"Normal\" value=\"Normal\" selected=\"\">Signal intensities are within normal limits for age.</option><option name=\"Mild\" value=\"Mild\">Mild white matter chronic small vessel ischemic changes.</option><option name=\"Moderate\" value=\"Moderate\">Moderate white matter chronic small vessel ischemic changes.</option><option name=\"Severe\" value=\"Severe\">Severe white matter chronic small vessel ischemic changes.</option></select></p><p><label> </label><br><label>VENTRICLES/EXTRA-AXIAL SPACES: </label><input type=\"text\" name=\"ventricles-extra-axial\" value=\"No hydrocephalus or extra-axial fluid collections.\"></p><p><label>FLOW VOIDS: </label><select name=\"flow voids\"><option name=\"\" value=\"\">Intact.</option><option name=\"\" value=\"\">Not well assessed.</option></select></p><p><label>EXTRACRANIAL STRUCTURES: </label><input type=\"text\" name=\"extracranial\" value=\"Visualized structures are normal.\"></p><p><label>MRA HEAD: </label><input type=\"text\" name=\"aneurysm\" value=\"No aneurysm.\"></p><p><label> </label><input type=\"text\" name=\"stenosis\" value=\"No occlusion or hemodynamically significant stenosis.\"></p></section><section data-section-name=\"IMPRESSION:\"><header class=\"Level1\">IMPRESSION:</header><p><label>1. </label><input type=\"text\" name=\"brain\" value=\"Normal MRI brain.\"></p><p><label>2. </label><input type=\"text\" name=\"mra head\" value=\"Normal MRA head.\"></p></section></body></html>",

ture\" value=\"RID15989\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459351523893\">\n                        <term>\n                            <code meaning=\"fluid\" value=\"RID1547\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459351523894\">\n                        <term>\n                            <code meaning=\"musculoskeletal system\" value=\"RID13209\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459351523875\">\n                        <term>\n                            <code meaning=\"right kidney\" value=\"RID29662\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459351523877\">\n                        <term>\n                            <code meaning=\"left kidney\" value=\"RID29663\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"impressionText\">\n                        <term>\n                            <code meaning=\"normal\" value=\"RID13173\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459351523878\">\n                        <term>\n                            <code meaning=\"right ureter\" value=\"RID30844\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459351523879\">\n                        <term>\n                            <code meaning=\"left ureter\" value=\"RID30845\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"procedureInformation\">\n                        <term>\n                            <code meaning=\"Current Imaging Procedure Description\" value=\"55111-9\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"comparisons\">\n                        <term>\n                            <code meaning=\"Radiology Comparison Study\" value=\"18834-2\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"impression\">\n                        <term>\n                            <code meaning=\"Impressions\" value=\"19005-8\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"clinicalInformation\">\n                        <term>\n                            <code meaning=\"Clinical Information\" value=\"55752-0\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459351523890\">\n                        <term>\n                            <code meaning=\"lung\" value=\"RID1301\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                </coded_content>\n            </template_attributes>\n        </script>\n    </head>\n    <body>\n        <section id=\"procedureInformation\" class=\"level1\" data-section-name=\"Procedure Information\">\n            <header class=\"level1\">\n                Procedure Information\n            </header>\n            <p title=\"\">\n                <label for=\"TEXT_1459351523867\">Technique:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459351523867\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">5 mm helical images of the abdomen pelvis were obtained without contrast. Next, nonionic intravenous contrast was administered, in a split dose fashion so that evaluation of the renal parenchyma and urinary tract could be acquired in one sequence. Please note that the contrast delivery was optimized for assessment of the GU system, and thus that evaluation of the remaining non-renal solid visceral organs is suboptimal; similarly, assessment of the bowel and retroperitoneum is limited without oral contrast. Please note that the contrast delivery was optimized for assessment of the GU system, and thus that evaluation of the remaining non-renal solid visceral organs is suboptimal; similarly, assessment of the bowel and retroperitoneum is limited without oral contrast.</textarea>\n            </p>\n        </section>\n        <section id=\"clinicalInformation\" class=\"level1\" data-section-name=\"Clinical Information\">\n            <header class=\"level1\">\n                Clinical Information\n            </header>\n            <p title=\"\">\n                <label for=\"TEXT_1459351523872\">Indication:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459351523872\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">None.</textarea>\n            </p>\n        </section>\n        <section id=\"comparisons\" class=\"level1\" data-section-name=\"Comparison\">\n            <header class=\"level1\">\n                Comparison\n            </header>\n            <p title=\"\">\n                <label for=\"TEXT_1459351523871\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459351523871\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">None.</textarea>\n            </p>\n        </section>\n        <section id=\"findings\" class=\"level1\" data-section-name=\"Findings\">\n            <header class=\"level1\">\n                Findings\n            </header>\n            <section id=\"SECTION_HEADER_1459351523873\" class=\"level2\" data-section-name=\"GU\">\n                <header class=\"level2\">\n                    GU\n                </header>\n                <p title=\"\">\n                    <label for=\"TEXT_1459351523875\">Right Kidney:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459351523875\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1459351523877\">Left Kidney:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459351523877\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1459351523878\">Right Ureter:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459351523878\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1459351523879\">Left Ureter:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459351523879\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1459351523880\">Bladder:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459351523880\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n                </p>\n            </section>\n            <section id=\"SECTION_HEADER_1459351523881\" class=\"level2\" data-section-name=\"Non-GU (limited evaluation per above)\">\n                <header class=\"level2\">\n                    Non-GU (limited evaluation per above)\n                </header>\n                <p title=\"\">\n                    <label for=\"TEXT_1459351523882\">Liver:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459351523882\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1459351523883\">Gallbladder and Bile Ducts:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459351523883\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1459351523884\">Adrenals:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459351523884\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1459351523885\">Spleen:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459351523885\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1459351523886\">Pancreas:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459351523886\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1459351523887\">Pelvic CT Findings:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459351523887\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1459351523888\">Bowel:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459351523888\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1459351523889\">Mesentery/Peritoneum:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459351523889\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1459351523890\">Lung windows through the lung base:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459351523890\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1459351523891\">Bone Windows:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459351523891\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1459351523892\">Vasculature:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459351523892\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1459351523893\">Fluid:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459351523893\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1459351523894\">Soft Tissues:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459351523894\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n                </p>\n            </section>\n            <p title=\"\">\n                <label for=\"TEXT_1519184979838\">Additional Findings:</label>\n                <input type=\"text\" id=\"TEXT_1519184979838\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\" value=\"None.\" />\n            </p>\n        </section>\n        <section id=\"impression\" class=\"level1\" data-section-name=\"Impression\">\n            <header class=\"level1\">\n                Impression\n            </header>\n            <p title=\"\">\n                <label for=\"impressionText\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"impressionText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n            </p>\n        </section>\n    </body>\n</html>\n",

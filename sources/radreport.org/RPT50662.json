    "templateData": "<html><head><meta charset=\"UTF-8\"><meta content=\"base mri orbits contrast\" name=\"dcterms.title\"><meta content=\"33143313-e239-444e-99bd-268db075a9b9\" name=\"dcterms.identifier\"><meta content=\"en\" name=\"dcterms.language\"><meta content=\"2019-01-31\" name=\"dcterms.date\"><meta content=\"Nuance System\" name=\"dcterms.creator\"><title>base mri orbits contrast</title></head><body><section data-section-name=\"MRI ORBITS AND BRAIN WITHOUT AND WITH CONTRAST\"><header class=\"Level1\">MRI ORBITS AND BRAIN WITHOUT AND WITH CONTRAST</header><p><label>HISTORY:</label><input type=\"text\" name=\"Patient Age\" value=\"Patient Age\"></p><p><label> old </label><input type=\"text\" name=\"Patient Gender\" value=\"Patient Gender\"></p><p><label>, </label><select name=\"history\"><option name=\"\" value=\"\" selected=\"\">orbital pain</option><option name=\"\" value=\"\" selected=\"\">orbital mass</option><option name=\"\" value=\"\" selected=\"\">optic nerve atrophy</option><option name=\"\" value=\"\" selected=\"\">optic neuritis</option></select></p></section><section data-section-name=\"TECHNIQUE:\"><header class=\"Level1\">TECHNIQUE:</header><p><label>MR images of the orbits and brain were acquired without and with </label><input type=\"number\" name=\"contrast dose\"><label>mL Gadavist intravenous contrast.</label></p><p><label>COMPARISON: </label><input type=\"text\" name=\"Comparison\" value=\"None available.\"></p></section><section data-section-name=\"FINDINGS:\"><header class=\"Level1\">FINDINGS:</header><p><label>GLOBES: </label><input type=\"text\" name=\"globes\" value=\"Normal.\"></p><p><label>LACRIMAL GLANDS: </label><input type=\"text\" name=\"lacrimal glands\" value=\"Normal.\"></p><p><label>RETROBULBAR FAT: </label><input type=\"text\" name=\"retrobulbar fat\" value=\"No mass or inflammatory change.\"></p><p><label>EXTRAOCULAR MUSCLES: </label><input type=\"text\" name=\"extraocular muscles\" value=\"Normal bulk and signal intensity.\"></p><p><label>OPTIC PATHWAY: </label><input type=\"text\" name=\"optic pathway\" value=\"Optic nerves, chiasm, and tracts are normal. No abnormalities involving the optic radiations or occipital lobes.\"></p><p><label>CAVERNOUS SINUSES: </label><input type=\"text\" name=\"cavernous sinuses\" value=\"Normal.\"></p><p><label>CRANIAL NERVES AND BRAINSTEM: </label><input type=\"text\" name=\"cranial nerves/brainstem\" value=\"Normal. No abnormal enhancement.\"></p><p><label>REMAINING BRAIN PARENCHYMA: </label><input type=\"text\" name=\"infarct-hemorrhage\" value=\"No acute infarct or hemorrhage. No mass effect or herniation.\"></p><p><label> </label><select name=\"white matter\"><option name=\"Normal\" value=\"Normal\" selected=\"\">Signal intensities are within normal limits for age.</option><option name=\"Mild\" value=\"Mild\">Mild white matter chronic small vessel ischemic changes.</option><option name=\"Moderate\" value=\"Moderate\">Moderate white matter chronic small vessel ischemic changes.</option><option name=\"Severe\" value=\"Severe\">Severe white matter chronic small vessel ischemic changes.</option></select></p><p><label> </label><input type=\"text\" name=\"enhancement?\" value=\"No abnormal enhancement.\"></p><p><label> </label><br><label>VENTRICLES/EXTRA-AXIAL SPACES: </label><input type=\"text\" name=\"ventricles-extra-axial\" value=\"No hydrocephalus or extra-axial fluid collections.\"></p><p><label>FLOW VOIDS: </label><select name=\"flow voids\"><option name=\"\" value=\"\">Intact.</option><option name=\"\" value=\"\">Not well assessed.</option></select></p><p><label>OTHER: </label><input type=\"text\" name=\"other\" value=\"None.\"></p></section><section data-section-name=\"IMPRESSION:\"><header class=\"Level1\">IMPRESSION:</header><p><textarea name=\"impression\">Normal MRI brain and orbits.</textarea></p></section></body></html>",

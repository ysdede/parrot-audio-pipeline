    "templateData": "<!DOCTYPE html>\n<html>\n    <head>\n        <title>First Trimester Sonogram</title>\n        <meta charset=\"UTF-8\" />\n        <meta name=\"dcterms.identifier\" content=\"d9839602-3aff-4f54-9940-6545823018ec\" />\n        <meta name=\"dcterms.title\" content=\"First Trimester Sonogram\" />\n        <meta name=\"dcterms.description\" content=\"\" />\n        <meta name=\"dcterms.type\" content=\"IMAGE_REPORT_TEMPLATE\" />\n        <meta name=\"dcterms.language\" content=\"en\" />\n        <meta name=\"dcterms.publisher\" content=\"University of Utah\" />\n        <meta name=\"dcterms.rights\" content=\"May be used freely, subject to license agreement\" />\n        <meta name=\"dcterms.license\" content=\"http://www.radreport.org/license.pdf\" />\n        <meta name=\"dcterms.date\" content=\"2018-03-12\" />\n        <meta name=\"dcterms.creator\" content=\"Marta E. Heilbrun, MD\" />\n        <script type=\"text/xml\">\n            <template_attributes>\n                <coded_content>\n                    <coding_schemes>\n                        <coding_scheme name=\"RADLEX\" designator=\"2.16.840.1.113883.6.256\"></coding_scheme>\n                        <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\"></coding_scheme>\n                    </coding_schemes>\n                    <entry origtxt=\"findings\">\n                        <term>\n                            <code meaning=\"Procedure Findings\" value=\"59776-5\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SECTION_HEADER_1459361640288\">\n                        <term>\n                            <code meaning=\"fetal biophysical profile\" value=\"RID49841\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"NUMBER_1459361640289\">\n                        <term>\n                            <code meaning=\"sacrum\" value=\"RID2509\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"NUMBER_1459361640284\">\n                        <term>\n                            <code meaning=\"right ovary\" value=\"RID32829\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"NUMBER_1459361640285\">\n                        <term>\n                            <code meaning=\"left ovary\" value=\"RID32830\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459361640278\">\n                        <term>\n                            <code meaning=\"indication\" value=\"RID49442\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"impressionText\">\n                        <term>\n                            <code meaning=\"normal\" value=\"RID13173\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459361640286\">\n                        <term>\n                            <code meaning=\"uterus\" value=\"RID302\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459361640287\">\n                        <term>\n                            <code meaning=\"fluid\" value=\"RID1547\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"procedureInformation\">\n                        <term>\n                            <code meaning=\"Current Imaging Procedure Description\" value=\"55111-9\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"comparisons\">\n                        <term>\n                            <code meaning=\"Radiology Comparison Study\" value=\"18834-2\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"impression\">\n                        <term>\n                            <code meaning=\"Impressions\" value=\"19005-8\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"clinicalInformation\">\n                        <term>\n                            <code meaning=\"Clinical Information\" value=\"55752-0\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                </coded_content>\n            </template_attributes>\n        </script>\n    </head>\n    <body>\n        <section id=\"procedureInformation\" class=\"level1\" data-section-name=\"Procedure Information\">\n            <header class=\"level1\">\n                Procedure Information\n            </header>\n            <p title=\"\">\n                <label for=\"TEXT_1476459004254\">Technique:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476459004254\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">First trimester sonogram.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1459361640277\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459361640277\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">The pelvis was scanned using transabdominal and endovaginal technique.</textarea>\n            </p>\n        </section>\n        <section id=\"clinicalInformation\" class=\"level1\" data-section-name=\"Clinical Information\">\n            <header class=\"level1\">\n                Clinical Information\n            </header>\n            <p title=\"\">\n                <label for=\"TEXT_1459361640278\">Indication:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459361640278\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">None.</textarea>\n            </p>\n            <section id=\"SECTION_HEADER_1459361640281\" class=\"level2\" data-section-name=\"Age by LMP is:\">\n                <header class=\"level2\">\n                    Age by LMP is:\n                </header>\n                <p title=\"\">\n                    <label for=\"NUMBER_1459361640282\">Weeks:</label>\n                    <span>\n                        <input type=\"number\" step=\"1.0\" data-field-units=\"\" id=\"NUMBER_1459361640282\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    </span>\n                </p>\n                <p title=\"\">\n                    <label for=\"NUMBER_1459361640283\">Days:</label>\n                    <span>\n                        <input type=\"number\" step=\"1.0\" data-field-units=\"\" id=\"NUMBER_1459361640283\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    </span>\n                </p>\n            </section>\n        </section>\n        <section id=\"comparisons\" class=\"level1\" data-section-name=\"Comparison\">\n            <header class=\"level1\">\n                Comparison\n            </header>\n            <p title=\"\">\n                <label for=\"comparisonsText\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"comparisonsText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">None.</textarea>\n            </p>\n        </section>\n        <section id=\"findings\" class=\"level1\" data-section-name=\"Findings\">\n            <header class=\"level1\">\n                Findings\n            </header>\n            <p title=\"\">\n                <label for=\"findingsText\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"findingsText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Endovaginal sonography demonstrates a single living intrauterine gestation. A normal appearing secondary yolk sac is identified. The appearance of the embryo and gestation is normal for age.  Both ovaries were identified and appear normal.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1459361640284\">The right ovary measures:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"cm\" id=\"NUMBER_1459361640284\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    cm\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1459361640285\">The left ovary measures:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"cm\" id=\"NUMBER_1459361640285\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    cm\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1459361640286\">Uterus:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459361640286\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">No abnormal adnexal masses.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1459361640287\">Fluid:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459361640287\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">No free fluid.</textarea>\n            </p>\n            <section id=\"SECTION_HEADER_1459361640288\" class=\"level2\" data-section-name=\"Fetal Biometry:\">\n                <header class=\"level2\">\n                    Fetal Biometry:\n                </header>\n                <p title=\"\">\n                    <label for=\"NUMBER_1459361640289\">Mean Sac Diameter:</label>\n                    <span>\n                        <input type=\"number\" step=\"1.0\" data-field-units=\"mm\" id=\"NUMBER_1459361640289\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                        mm\n                    </span>\n                </p>\n                <p title=\"\">\n                    <label for=\"NUMBER_1459361640290\">Weeks:</label>\n                    <span>\n                        <input type=\"number\" step=\"1.0\" data-field-units=\"\" id=\"NUMBER_1459361640290\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    </span>\n                </p>\n                <p title=\"\">\n                    <label for=\"NUMBER_1459361640291\">Crown rump length:</label>\n                    <span>\n                        <input type=\"number\" step=\"1.0\" data-field-units=\"cm\" id=\"NUMBER_1459361640291\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                        cm\n                    </span>\n                </p>\n                <p title=\"\">\n                    <label for=\"NUMBER_1459361640292\">Weeks:</label>\n                    <span>\n                        <input type=\"number\" step=\"1.0\" data-field-units=\"\" id=\"NUMBER_1459361640292\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    </span>\n                </p>\n            </section>\n            <p title=\"\">\n                <label for=\"TEXT_1520484096199\">Additional Findings:</label>\n                <input type=\"text\" id=\"TEXT_1520484096199\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\" value=\"None.\" />\n            </p>\n        </section>\n        <section id=\"impression\" class=\"level1\" data-section-name=\"Impression\">\n            <header class=\"level1\">\n                Impression\n            </header>\n            <p title=\"\">\n                <label for=\"impressionText\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"impressionText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1459361640293\">Single living intrauterine gestation with estimated gestational age by CRL of:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"weeks +/- 8%\" id=\"NUMBER_1459361640293\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    weeks +/- 8%\n                </span>\n            </p>\n        </section>\n    </body>\n</html>\n",

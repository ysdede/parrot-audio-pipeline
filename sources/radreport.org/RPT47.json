    "templateData": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\"/>\n<meta content=\"Cardiac MRI: Right Heart Failure\" name=\"dcterms.title\"/>\n<meta content=\"Cardiac MRI: Right Heart Failure template :: Authored by Jacobs JE, et al.\" name=\"dcterms.description\"/>\n<meta content=\"http://www.radreport.org/template/0000047\" name=\"dcterms.identifier\"/>\n<meta content=\"en\" name=\"dcterms.language\"/>\n<meta content=\"IMAGE_REPORT_TEMPLATE\" name=\"dcterms.type\"/>\n<meta content=\"Radiological Society of North America (RSNA)\" name=\"dcterms.publisher\"/>\n<meta content=\"May be used gratis, subject to license agreement\" name=\"dcterms.rights\"/>\n<meta content=\"http://www.radreport.org/license.pdf\" name=\"dcterms.license\"/>\n<meta content=\"2012-07-19\" name=\"dcterms.date\"/>\n<meta content=\"Jacobs JE, et al.\" name=\"dcterms.creator\"/>\n<meta content=\"Kahn CE Jr [editor]\" name=\"dcterms.contributor\"/>\n<meta content=\"North American Society for Cardiac Imaging (NASCI)\" name=\"dcterms.contributor\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"IHE_Template_Style.css\"/>\n<!-- The absolute link to the CSS file is http://www.radreport.org/html/IHE_Template_Style.css -->\n<script type=\"text/xml\">\n<!--\n<template_attributes>\n<top-level-flag>true</top-level-flag>\n<status>ACTIVE</status>\n<coding_schemes>\n <coding_scheme name=\"RadLex\" designator=\"2.16.840.1.113883.6.256\" />\n <coding_scheme name=\"SNOMEDCT\" designator=\"2.16.840.1.113883.6.96\" />\n <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\" />\n</coding_schemes>\n<term>\n <code meaning=\"heart\" value=\"RID1385\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"magnetic resonance imaging\" value=\"RID10312\" scheme=\"RadLex\">\n</term>\n<coded_content>\n<entry ORIGTXT=\"T47_2\">\n <term>\n  <code meaning=\"procedure\" value=\"RID1559\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T47_11\">\n <term>\n  <code meaning=\"clinical information\" value=\"RID13166\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T47_12\">\n <term>\n  <code meaning=\"comparison\" value=\"RID28483\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T47_37\">\n <term>\n  <code meaning=\"aortic valve\" value=\"RID1394\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T47_38\">\n <term>\n  <code meaning=\"normal\" value=\"RID13173\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T47_63\">\n <term>\n  <code meaning=\"shunt\" value=\"RID4969\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T47_84\">\n <term>\n  <code meaning=\"impression section\" value=\"RID13170\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T47_85\">\n <term>\n  <code meaning=\"global\" value=\"RID5693\" scheme=\"RadLex\">\n </term>\n <term>\n  <code meaning=\"function\" value=\"RID28812\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T47_86\">\n <term>\n  <code meaning=\"normal\" value=\"RID13173\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T47_87\">\n <term>\n  <code meaning=\"mild\" value=\"RID5671\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T47_88\">\n <term>\n  <code meaning=\"moderate\" value=\"RID5672\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T47_89\">\n <term>\n  <code meaning=\"severe\" value=\"RID5673\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T47_90\">\n <term>\n  <code meaning=\"global\" value=\"RID5693\" scheme=\"RadLex\">\n </term>\n <term>\n  <code meaning=\"function\" value=\"RID28812\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T47_91\">\n <term>\n  <code meaning=\"normal\" value=\"RID13173\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T47_92\">\n <term>\n  <code meaning=\"mild\" value=\"RID5671\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T47_93\">\n <term>\n  <code meaning=\"moderate\" value=\"RID5672\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T47_94\">\n <term>\n  <code meaning=\"severe\" value=\"RID5673\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T47_95\">\n <term>\n  <code meaning=\"intracardiac\" value=\"RID11113\" scheme=\"RadLex\">\n </term>\n <term>\n  <code meaning=\"shunt\" value=\"RID4969\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T47_98\">\n <term>\n  <code meaning=\"valvular heart disease\" value=\"RID3260\" scheme=\"RadLex\">\n </term>\n</entry>\n</coded_content>\n</template_attributes>\n-->\n</script>\n<title>Cardiac MRI: Right Heart Failure</title>\n</head>\n<body>\n<section data-section-name=\"Procedure\">\n<header class=\"level1\">Cardiac MRI: Right Heart Failure</header>\n<p>\n<textarea id=\"T47_2\" name=\"Procedure\"> </textarea>\n</p>\n</section>\n<section data-section-name=\"Clinical information\">\n<header class=\"level1\">Clinical information</header>\n<p>\n<textarea id=\"T47_11\" name=\"Clinical information\"> </textarea>\n</p>\n</section>\n<section data-section-name=\"Comparison\">\n<header class=\"level1\">Comparison</header>\n<p>\n<textarea id=\"T47_12\" name=\"Comparison\">None. </textarea>\n</p>\n</section>\n<section data-section-name=\"Findings\">\n<header class=\"level1\">Findings</header>\n<section data-section-name=\"Left ventricular measurements\">\n<header class=\"level2\">Left ventricular measurements</header>\n<p>\n<label for=\"T47_16\">End Diastolic Diameter:</label>\n<input type=\"number\" id=\"T47_16\" name=\"End Diastolic Diameter\" data-field-units=\"mm\" min=\"\" max=\"\"/>\n<label for=\"T47_16\"> mm (normal, 36-56 mm)</label>\n</p>\n<p>\n<label for=\"T47_17\">Ejection Fraction:</label>\n<input type=\"number\" id=\"T47_17\" name=\"Ejection Fraction\" data-field-units=\"%\" min=\"\" max=\"\"/>\n<label for=\"T47_17\"> % (normal: male = 56-78%; female = 56-78%)</label>\n</p>\n<p>\n<label for=\"T47_18\">Stroke Volume:</label>\n<input type=\"number\" id=\"T47_18\" name=\"Stroke Volume\" data-field-units=\"ml\" min=\"\" max=\"\"/>\n<label for=\"T47_18\"> ml</label>\n</p>\n<p>\n<label for=\"T47_19\">End Diastolic Volume:</label>\n<input type=\"number\" id=\"T47_19\" name=\"End Diastolic Volume\" data-field-units=\"ml\" min=\"\" max=\"\"/>\n<label for=\"T47_19\"> mL (normal: male = 77-195 mL; female = 52-141 mL)</label>\n</p>\n<p>\n<label for=\"T47_20\">Indexed End Diastolic Volume:</label>\n<input type=\"number\" id=\"T47_20\" name=\"Indexed End Diastolic Volume\" data-field-units=\"mL/m2\" min=\"\" max=\"\"/> \n<label for=\"T47_20\"> mL/m2</label>\n</p>\n<p>\n<label for=\"T47_21\">End Systolic Volume:</label>\n<input type=\"number\" id=\"T47_21\" name=\"End Systolic Volume\" data-field-units=\"ml\" min=\"\" max=\"\"/>\n<label for=\"T47_21\"> mL (normal: male = 19-72 mL; female = 13-51 mL)</label>\n</p>\n<p>\n<label for=\"T47_22\">Indexed End Systolic Volume:</label>\n<input type=\"number\" id=\"T47_22\" name=\"Indexed End Systolic Volume\" data-field-units=\"mL/m2\" min=\"\" max=\"\"/> \n<label for=\"T47_22\"> mL/m2</label>\n</p>\n<p>\n<label for=\"T47_23\">Cardiac output:</label>\n<input type=\"number\" id=\"T47_23\" name=\"Cardiac output\" data-field-units=\" L/min \" min=\"\" max=\"\"/> \n<label for=\"T47_23\"> L/min (normal: male = 2.82-8.82 L/min; female = 2.7-6.0 l/min)</label>\n</p>\n<p>\n<label for=\"T47_24\">Cardiac Index:</label>\n<input type=\"number\" id=\"T47_24\" name=\"Cardiac Index\" data-field-units=\"L/min/m2\" min=\"\" max=\"\"/> \n<label for=\"T47_24\"> L/min/m2</label>\n</p>\n<p>\n<label for=\"T47_25\">Index values are normalized to body surface area (BSA) of </label>\n<input type=\"number\" id=\"T47_25\" name=\"body surface area\" data-field-units=\"\" min=\"\" max=\"\"/> \n<label for=\"T47_25\"> m2</label>\n</p>\n</section>\n\n<section data-section-name=\"Right ventricular measurements\">\n<header class=\"level2\">Right ventricular measurements</header>\n<p>\n<label for=\"T47_27\">End Diastolic Diameter:</label>\n<input type=\"number\" id=\"T47_27\" name=\"End Diastolic Diameter\" data-field-units=\"mm\" min=\"\" max=\"\"/>\n<label for=\"T47_27\"> mm (normal: male 25-46 mm; female 21-39)</label>\n</p>\n<p>\n<label for=\"T47_28\">Ejection Fraction:</label>\n<input type=\"number\" id=\"T47_28\" name=\"Ejection Fraction\" data-field-units=\"%\" min=\"\" max=\"\"/>\n<label for=\"T47_28\"> % (normal: male = 47-74%;  female = 47-80%)</label>\n</p>\n<p>\n<label for=\"T47_29\">Stroke Volume:</label>\n<input type=\"number\" id=\"T47_29\" name=\"Stroke Volume\" data-field-units=\"ml\" min=\"\" max=\"\"/>\n<label for=\"T47_29\"> mL (normal: male = 52-138 mL; female = 35-98 mL)</label>\n</p>\n<p>\n<label for=\"T47_30\">End Diastolic Volume:</label>\n<input type=\"number\" id=\"T47_30\" name=\"End Diastolic Volume\" data-field-units=\"ml\" min=\"\" max=\"\"/>\n<label for=\"T47_30\"> mL  (normal: male = 88-227 mL; female = 58-154 mL)</label>\n</p>\n<p>\n<label for=\"T47_31\">Indexed End Diastolic Volume:</label>\n<input type=\"number\" id=\"T47_31\" name=\"Indexed End Diastolic Volume\" data-field-units=\"mL/m2\" min=\"\" max=\"\"/>\n<label for=\"T47_31\"> mL/m2</label>\n</p>\n<p>\n<label for=\"T47_32\">End Systolic Volume:</label>\n<input type=\"number\" id=\"T47_32\" name=\"End Systolic Volume\" data-field-units=\"ml\" min=\"\" max=\"\"/>\n<label for=\"T47_32\"> mL (normal: male = 23-105 mL; female = 12-68 mL)</label>\n</p>\n<p>\n<label for=\"T47_33\">Indexed End Systolic Volume:</label>\n<input type=\"number\" id=\"T47_33\" name=\"Indexed End Systolic Volume\" data-field-units=\"mL/m2\" min=\"\" max=\"\"/>\n<label for=\"T47_33\"> mL/m2</label>\n</p>\n<p>\n<label for=\"T47_34\">Cardiac Output:</label>\n<input type=\"number\" id=\"T47_34\" name=\"Cardiac Output\" data-field-units=\" L/min \" min=\"\" max=\"\"/> \n<label for=\"T47_34\"> L/min (normal: male = 2.8-8.82 L/min; female = 2.7-6.0 L/min)</label>\n</p>\n<p>\n<label for=\"T47_35\">Cardiac Index:</label>\n<input type=\"number\" id=\"T47_35\" name=\"Cardiac Index\" data-field-units=\"L/min/m2\" min=\"\" max=\"\"/>\n<label for=\"T47_35\"> L/min/m2  (normal: male = 1.74-4.2 L/min/m2; female = 1.8-3.8 L/min/m2)</label>\n</p>\n</section>\n\n<section data-section-name=\"Valves\">\n<header class=\"level2\">Valves</header>\n<p>\n<label for=\"T47_37\">Aortic valve:</label>\n<input type=\"text\" id=\"T47_37\" name=\"Aortic valve\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T47_38\">Aortic forward volume:</label>\n<input type=\"number\" id=\"T47_38\" name=\"Aortic forward volume\" value=\"\"/>\n<label for=\"T47_38\">mL</label>\n</p>\n<p>\n<label for=\"T47_999\">Aortic regurgitant volume:</label>\n<input type=\"number\" id=\"T47_999\" name=\"Aortic regurgitant volume\" value=\"\"/>\n<label for=\"T47_999\">mL</label>\n</p>\n<p>\n<label for=\"T47_998\">Aortic valve area:</label>\n<input type=\"number\" id=\"T47_998\" name=\"Aortic valve area\" value=\"\"/>\n<label for=\"T47_998\">cm2 {&lt; 1.0 cm2 severe; 1.0-1.5 cm2 moderate; 1.5-2.0 cm2 mild; &gt; 2.0 cm2 normal}</label>\n</p>\n<p>\n<label for=\"T47_997\">Mitral valve:</label>\n<input type=\"text\" id=\"T47_997\" name=\"Mitral valve\" value=\"Normal. \"/>\n</p>\n<p>\n<label for=\"T47_996\">Mitral regurgitant volume:</label>\n<input type=\"number\" id=\"T47_996\" name=\"Mitral regurgitant volume\" value=\"\"/>\n<label for=\"T47_996\">mL</label>\n</p>\n<p>\n<label for=\"T47_995\">Mitral regurgitant fraction:</label>\n<input type=\"number\" id=\"T47_995\" name=\"Mitral regurgitant fraction\" value=\"\"/>\n<label for=\"T47_995\">% mL</label>\n</p>\n<p>\n<label for=\"T47_994\">Pulmonic valve:</label>\n<input type=\"text\" id=\"T47_994\" name=\"Pulmonic valve\" value=\"Normal. \"/>\n<label for=\"T47_994\">mL</label>\n</p>\n<p>\n<label for=\"T47_993\">Pulmonic forward volume:</label>\n<input type=\"number\" id=\"T47_993\" name=\"Pulmonic forward volume\" value=\"\"/>\n<label for=\"T47_993\">mL</label>\n</p>\n<p>\n<label for=\"T47_992\">Pulmonic regurgitant volume:</label>\n<input type=\"number\" id=\"T47_992\" name=\"Pulmonic regurgitant volume\" value=\"\"/>\n<label for=\"T47_992\">mL</label>\n</p>\n<p>\n<label for=\"T47_991\">Tricuspid valve:</label>\n<input type=\"text\" id=\"T47_991\" name=\"Tricuspid valve\" value=\"Normal. \"/>\n</p>\n</section>\n\n<section data-section-name=\"Shunt information\">\n<header class=\"level2\">Shunt information</header>\n<p>\n<textarea id=\"T47_63\" name=\"Shunt information\">No intracardiac shunt is present.</textarea>\n</p>\n<p>\n<label for=\"T47_990\">Qp:Qs ratio:</label>\n<input id=\"T47_990\" name=\"Qs ratio\" type=\"number\" value=\"\"/>\n</p>\n</section>\n\n<section data-section-name=\"Other findings\">\n<header class=\"level2\">Other findings</header>\n<p>\n<textarea id=\"T47_76\" name=\"T47_76\">None.</textarea>\n</p>\n</section>\n</section>\n<section data-section-name=\"Impression\">\n<header class=\"level1\">Impression</header>\n<p>\n<label for=\"T47_85\">Global systolic LV function:</label>\n<select id=\"T47_85\" name=\"Global systolic LV function\">\n<option id=\"T47_86\" name=\"Normal\" value=\"Normal\">Normal</option>\n<option id=\"T47_87\" name=\"Mildly impaired\" value=\"Mildly impaired\">Mildly impaired</option>\n<option id=\"T47_88\" name=\"Moderately impaired\" value=\"Moderately impaired\">Moderately impaired</option>\n<option id=\"T47_89\" name=\"Severely impaired\" value=\"Severely impaired\">Severely impaired</option>\n</select>\n</p>\n<p>\n<label for=\"T47_90\">Global systolic RV function:</label>\n<select id=\"T47_90\" name=\"Global systolic RV function\">\n<option id=\"T47_91\" name=\"Normal\" value=\"Normal\">Normal</option>\n<option id=\"T47_92\" name=\"Mildly impaired\" value=\"Mildly impaired\">Mildly impaired</option>\n<option id=\"T47_93\" name=\"Moderately impaired\" value=\"Moderately impaired\">Moderately impaired</option>\n<option id=\"T47_94\" name=\"Severely impaired\" value=\"Severely impaired\">Severely impaired</option>\n</select>\n</p>\n<p>\n<label for=\"T47_95\">Intracardiac shunt:</label>\n<input type=\"text\" id=\"T47_95\" name=\"Intracardiac shunt\" value=\"None.\"/>\n</p>\n<p>\n<label for=\"T47_98\">Valvular disease:</label>\n<input type=\"text\" id=\"T47_98\" name=\"Valvular disease\" value=\"Absent.\"/>\n</p>\n<p>\n<textarea id=\"T47_84\" name=\"Impression\"> </textarea>\n</p>\n</section>\n</body>\n</html>\n",

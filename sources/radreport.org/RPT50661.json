    "templateData": "<html><head><meta charset=\"UTF-8\"><meta content=\"base mri neck contrast\" name=\"dcterms.title\"><meta content=\"9cc6bdfe-d748-4816-9547-5e93a06d41fb\" name=\"dcterms.identifier\"><meta content=\"en\" name=\"dcterms.language\"><meta content=\"2019-01-31\" name=\"dcterms.date\"><meta content=\"Nuance System\" name=\"dcterms.creator\"><title>base mri neck contrast</title></head><body><section data-section-name=\"MRI NECK WITHOUT AND WITH CONTRAST\"><header class=\"Level1\">MRI NECK WITHOUT AND WITH CONTRAST</header><p><label>HISTORY:</label><input type=\"text\" name=\"Patient Age\" value=\"Patient Age\"></p><p><label> old </label><input type=\"text\" name=\"Patient Gender\" value=\"Patient Gender\"></p><p><label>, </label><input type=\"text\" name=\"history\" value=\"neck mass.\"></p></section><section data-section-name=\"TECHNIQUE:\"><header class=\"Level1\">TECHNIQUE:</header><p><label>MR images of the neck were acquired without and with </label><input type=\"number\" name=\"contrast dose\"><label>mL Gadavist intravenous contrast.</label></p><p><label>COMPARISON: </label><input type=\"text\" name=\"Comparison\" value=\"None available.\"></p></section><section data-section-name=\"FINDINGS:\"><header class=\"Level1\">FINDINGS:</header><p><label>PHARYNGEAL MUCOSA: </label><input type=\"text\" name=\"pharyngeal mucosa\" value=\"Normal nasopharynx, oropharynx and hypopharynx.\"></p><p><label>ORAL CAVITY: </label><input type=\"text\" name=\"oral cavity\" value=\"Normal including tongue and floor of mouth.\"></p><p><label>LARYNX: </label><input type=\"text\" name=\"larynx\" value=\"Normal supraglottic, glottic and subglottic larynx.\"></p><p><label>LYMPH NODES: </label><input type=\"text\" name=\"nodes\" value=\"No suspicious lymph nodes.\"></p><p><label>SALIVARY GLANDS: </label><input type=\"text\" name=\"salivary glands\" value=\"Normal parotid, submandibular and sublingual glands.\"></p><p><label>THYROID: </label><input type=\"text\" name=\"thyroid\" value=\"Normal.\"></p><p><label>FLOW VOIDS AND CAROTID SPACE: </label><input type=\"text\" name=\"flow voids and carotid space\" value=\"Normal.\"></p><p><label>BONES: </label><input type=\"text\" name=\"bones\" value=\"No significant abnormality.\"></p><p><label>OTHER: </label><input type=\"text\" name=\"other\" value=\"None.\"></p></section><section data-section-name=\"IMPRESSION:\"><header class=\"Level1\">IMPRESSION:</header><p><textarea name=\"impression\">Normal MRI neck.</textarea></p></section></body></html>",

    "templateData": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\"/>\n<meta content=\"Kidney GFR\" name=\"dcterms.title\"/>\n<meta content=\"Kidney GFR template :: Authored by Imani F\" name=\"dcterms.description\"/>\n<meta content=\"http://www.radreport.org/template/0000175\" name=\"dcterms.identifier\"/>\n<meta content=\"en\" name=\"dcterms.language\"/>\n<meta content=\"IMAGE_REPORT_TEMPLATE\" name=\"dcterms.type\"/>\n<meta content=\"Radiological Society of North America (RSNA)\" name=\"dcterms.publisher\"/>\n<meta content=\"May be used gratis, subject to license agreement\" name=\"dcterms.rights\"/>\n<meta content=\"http://www.radreport.org/license.pdf\" name=\"dcterms.license\"/>\n<meta content=\"2012-05-29\" name=\"dcterms.date\"/>\n<meta content=\"Imani F\" name=\"dcterms.creator\"/>\n<meta content=\"Kahn CE Jr [editor]\" name=\"dcterms.contributor\"/>\n<meta content=\"UCLA Health System (UCLA)\" name=\"dcterms.contributor\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"IHE_Template_Style.css\"/>\n<!-- The absolute link to the CSS file is http://www.radreport.org/html/IHE_Template_Style.css -->\n<script type=\"text/xml\">\n<!--\n<template_attributes>\n<top-level-flag>true</top-level-flag>\n<status>ACTIVE</status>\n<coding_schemes>\n <coding_scheme name=\"RadLex\" designator=\"2.16.840.1.113883.6.256\" />\n <coding_scheme name=\"SNOMEDCT\" designator=\"2.16.840.1.113883.6.96\" />\n <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\" />\n</coding_schemes>\n<coded_content>\n</coded_content>\n</template_attributes>\n-->\n</script>\n<title>Kidney GFR</title>\n</head>\n<body>\n<section data-section-name=\"Procedure\">\n<header class=\"level1\">Radionuclide Glomerular Filtration Rate</header>\n<p>\n<textarea id=\"T175_2\" name=\"Procedure\">After IV injection of radiopharmaceutical, blood samples were obtained at two, three, and four hours from the contralateral arm vein and measured in a well counter.  The estimated glomerular filtration rate was calculated assuming a one-compartment model. </textarea>\n</p>\n<p>\n<label for=\"T175_3\">Radiopharmaceutical:</label>\n<input type=\"text\" id=\"T175_3\" name=\"\" value=\"I-125 sodium iothalmate\"/>\n</p>\n<p>\n<label for=\"T175_4\">Dose:</label>\n<input type=\"number\" id=\"T175_4\" name=\"Dose\" value=\"2\"/> mCi\n</p>\n</section>\n<section data-section-name=\"Clinical information\">\n<header class=\"level1\">Clinical information</header>\n<p>\n<textarea id=\"T175_5\" name=\"Clinical information\">Elevated creatinine. Evaluation of glomerular filtration rate. </textarea>\n</p>\n</section>\n<section data-section-name=\"Comparison\">\n<header class=\"level1\">Comparison</header>\n<p>\n<textarea id=\"T175_6\" name=\"Comparison\">None. </textarea>\n</p>\n</section>\n<section data-section-name=\"Findings\">\n<header class=\"level1\">Findings</header>\n<p>\n<label for=\"T175_9\">Glomerular Filtration Rate (GFR):</label>\n<input type=\"number\" id=\"T175_9\" name=\"GFR\" data-field-units=\"ml/min\" min=\"0\" max=\"\"/> ml/min\n</p>\n<p>\n<label for=\"T175_10\">Adjusted GFR:</label>\n<input type=\"number\" id=\"T175_10\" name=\"Adjusted GFR\" data-field-units=\"ml/min/1.73 m2\" min=\"0\" max=\"\"/> ml/min/1.73 m2\n</p>\n</section>\n<section data-section-name=\"Impression\">\n<header class=\"level1\">Impression</header>\n<p>\n<textarea id=\"T175_11\" name=\"Impression\"> </textarea>\n</p>\n</section>\n</body>\n</html>\n",

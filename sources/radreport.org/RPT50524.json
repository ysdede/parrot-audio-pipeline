ta-field-type=\"RADIO\" data-field-completion-action=\"NONE\" value=\"\">\n                    <br />\n                    <input id=\"RADIO_1519757620630_0\" type=\"radio\" name=\"RADIO_1519757620630\" value=\"BI-RADS 0: Mammography incomplete\">BI-RADS 0: mammography incomplete</input>\n                    <br />\n                    <input id=\"RADIO_1519757620630_1\" type=\"radio\" name=\"RADIO_1519757620630\" value=\"BI-RADS 1: Negative\" checked=\"\">BI-RADS 1: negative</input>\n                    <br />\n                    <input id=\"RADIO_1519757620630_2\" type=\"radio\" name=\"RADIO_1519757620630\" value=\"BI-RADS 2: Benign\">BI-RADS 2: benign</input>\n                    <br />\n                    <input id=\"RADIO_1519757620630_3\" type=\"radio\" name=\"RADIO_1519757620630\" value=\"BI-RADS 3: Probably benign\">BI-RADS 3: probably benign</input>\n                    <br />\n                    <input id=\"RADIO_1519757620630_4\" type=\"radio\" name=\"RADIO_1519757620630\" value=\"BI-RADS 4A: ~2%, Low suspicion for malignancy\">BI-RADS 4A: ~2%, low suspicion for malignancy</input>\n                    <br />\n                    <input id=\"RADIO_1519757620630_5\" type=\"radio\" name=\"RADIO_1519757620630\" value=\"BI-RADS 4B: ~10%, Intermediate suspicion of malignancy\">BI-RADS 4B: ~10%, intermediate suspicion of malignancy</input>\n                    <br />\n                    <input id=\"RADIO_1519757620630_6\" type=\"radio\" name=\"RADIO_1519757620630\" value=\"BI-RADS 4C: ~50%, Moderate concern, but not classic for malignancy\">BI-RADS 4C: ~50%, moderate concern, but not classic for malignancy</input>\n                    <br />\n                    <input id=\"RADIO_1519757620630_7\" type=\"radio\" name=\"RADIO_1519757620630\" value=\"BI-RADS 5: Highly suggestive of malignancy\">BI-RADS 5: highly suggestive of malignancy</input>\n                    <br />\n                    <input id=\"RADIO_1519757620630_8\" type=\"radio\" name=\"RADIO_1519757620630\" value=\"BI-RADS 6: Known biopsy - proven malignancy\">BI-RADS 6: known biopsy - proven malignancy</input>\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1519874421184\">Journal Reference:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1519874421184\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">https://www.acr.org/-/media/ACR/Files/RADS/BI-RADS/Mammography-Reporting.pdf</textarea>\n            </p>\n        </section>\n    </body>\n</html>\n",

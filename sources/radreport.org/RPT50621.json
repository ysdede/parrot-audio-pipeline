    "templateData": "<html><head><meta charset=\"UTF-8\"><meta content=\"base ctv head\" name=\"dcterms.title\"><meta content=\"1526ebe3-db36-4d00-a1f4-6a39a94d9a7c\" name=\"dcterms.identifier\"><meta content=\"en\" name=\"dcterms.language\"><meta content=\"2019-01-31\" name=\"dcterms.date\"><meta content=\"Nuance System\" name=\"dcterms.creator\"><title>base ctv head</title></head><body><section data-section-name=\"CT VENOGRAM HEAD WITH CONTRAST\"><header class=\"Level1\">CT VENOGRAM HEAD WITH CONTRAST</header><p><label>HISTORY:</label><input type=\"text\" name=\"Patient Age\" value=\"Patient Age\"></p><p><label> old </label><input type=\"text\" name=\"Patient Gender\" value=\"Patient Gender\"></p><p><label>, </label><input type=\"text\" name=\"history\" value=\"headache, evaluate for venous thrombosis\"></p></section><section data-section-name=\"TECHNIQUE:\"><header class=\"Level1\">TECHNIQUE:</header><p><label>CT images of the head were acquired with </label><input type=\"number\" name=\"contrast dose\"><label>mL Omnipaque 350 intravenous contrast.</label></p><p><label>CTDI: </label><input type=\"number\" name=\"CTDI\"><label>mGy</label></p><p><label>DLP: </label><input type=\"number\" name=\"DLP\"><label>mGy-cm</label></p><p><label>COMPARISON: </label><input type=\"text\" name=\"comparison\" value=\"None available\"></p></section><section data-section-name=\"FINDINGS:\"><header class=\"Level1\">FINDINGS:</header><p><label>VENOUS SYSTEM: </label><input type=\"text\" name=\"veins\" value=\"Patent dural venous sinuses.\"></p><p><label>BRAIN PARENCHYMA: </label><input type=\"text\" name=\"hemorrhage/mass- if hemorrhage, use autotext 'hemorrhage'\" value=\"No acute hemorrhage. No mass effect or herniation.\"></p><p><label> </label><input type=\"text\" name=\"grey-white\" value=\"Gray-white differentiation is maintained.\"></p><p><label> </label><select name=\"white matter\"><option name=\"\" value=\"\">White matter is within normal limits for age.</option><option name=\"\" value=\"\">White matter chronic small vessel ischemic changes.</option></select></p><p><label> </label><input type=\"text\" name=\"enhancement?\" value=\"No abnormal enhancement.\"></p><p><label>VENTRICLES/EXTRA-AXIAL SPACES: </label><input type=\"text\" name=\"ventricles/extra-axial\" value=\"No hydrocephalus or extra-axial fluid collections.\"></p><p><label>EXTRACRANIAL STRUCTURES: </label><input type=\"text\" name=\"extracranial\" value=\"Normal bones and soft tissues. Visualized paranasal sinuses and mastoids are clear.\"></p></section><section data-section-name=\"IMPRESSION:\"><header class=\"Level1\">IMPRESSION:</header><p><textarea name=\"impression\">Normal CT venogram head.</textarea></p></section></body></html>",

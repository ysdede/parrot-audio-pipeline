    "templateData": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\"/>\n<meta content=\"Kidney DMSA\" name=\"dcterms.title\"/>\n<meta content=\"Kidney DMSA template :: Authored by Imani F\" name=\"dcterms.description\"/>\n<meta content=\"http://www.radreport.org/template/0000173\" name=\"dcterms.identifier\"/>\n<meta content=\"en\" name=\"dcterms.language\"/>\n<meta content=\"IMAGE_REPORT_TEMPLATE\" name=\"dcterms.type\"/>\n<meta content=\"Radiological Society of North America (RSNA)\" name=\"dcterms.publisher\"/>\n<meta content=\"May be used gratis, subject to license agreement\" name=\"dcterms.rights\"/>\n<meta content=\"http://www.radreport.org/license.pdf\" name=\"dcterms.license\"/>\n<meta content=\"2012-05-29\" name=\"dcterms.date\"/>\n<meta content=\"Imani F\" name=\"dcterms.creator\"/>\n<meta content=\"Kahn CE Jr [editor]\" name=\"dcterms.contributor\"/>\n<meta content=\"UCLA Health System (UCLA)\" name=\"dcterms.contributor\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"IHE_Template_Style.css\"/>\n<!-- The absolute link to the CSS file is http://www.radreport.org/html/IHE_Template_Style.css -->\n<script type=\"text/xml\">\n<!--\n<template_attributes>\n<top-level-flag>true</top-level-flag>\n<status>ACTIVE</status>\n<coding_schemes>\n <coding_scheme name=\"RadLex\" designator=\"2.16.840.1.113883.6.256\" />\n <coding_scheme name=\"SNOMEDCT\" designator=\"2.16.840.1.113883.6.96\" />\n <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\" />\n</coding_schemes>\n<term>\n <code meaning=\"function\" value=\"RID28812\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"kidney\" value=\"RID205\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"Tc-99m succimer\" value=\"RID11750\" scheme=\"RadLex\">\n</term>\n<coded_content>\n<entry ORIGTXT=\"T173_2\">\n <term>\n  <code meaning=\"procedure\" value=\"RID1559\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T173_5\">\n <term>\n  <code meaning=\"clinical information\" value=\"RID13166\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T173_6\">\n <term>\n  <code meaning=\"comparison\" value=\"RID28483\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T173_8\">\n <term>\n  <code meaning=\"observations section\" value=\"RID28486\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T173_14\">\n <term>\n  <code meaning=\"impression section\" value=\"RID13170\" scheme=\"RadLex\">\n </term>\n</entry>\n</coded_content>\n</template_attributes>\n-->\n</script>\n<title>Kidney DMSA</title>\n</head>\n<body>\n<section data-section-name=\"Procedure\">\n<header class=\"level1\">Kidney DMSA</header>\n<p>\n<textarea id=\"T173_2\" name=\"Procedure\">Following intravenous administration of Tc-99m DMSA, posterior and right and left posterior oblique projection images of the kidneys were acquired. </textarea>\n</p>\n<p>\n<label for=\"T173_4\">Dose:</label>\n<input type=\"number\" id=\"T173_4\" name=\"Dose\" value=\"2\"/> mCi\n</p>\n</section>\n<section data-section-name=\"Clinical information\">\n<header class=\"level1\">Clinical information</header>\n<p>\n<textarea id=\"T173_5\" name=\"Clinical information\"> </textarea>\n</p>\n</section>\n<section data-section-name=\"Comparison\">\n<header class=\"level1\">Comparison</header>\n<p>\n<textarea id=\"T173_6\" name=\"Comparison\">None. </textarea>\n</p>\n</section>\n<section data-section-name=\"Findings\">\n<header class=\"level1\">Findings</header>\n<section data-section-name=\"Morphology\">\n<header class=\"level2\">Morphology</header>\n<p>\n<textarea id=\"T173_8\" name=\"Findings\">Both kidneys are identified and are normal in position. Uptake is homogeneous throughout the kidneys. There is no evidence of horseshoe kidney or ectopic kidney. </textarea>\n</p>\n</section>\n<section data-section-name=\"Function\">\n<header class=\"level2\">Function</header>\n<p>\n<label for=\"T173_12\">Right kidney:</label>\n<input type=\"number\" id=\"T173_12\" name=\"Right kidney\" data-field-units=\"%\" min=\"0\" max=\"100\" step=\"1\" /> %\n</p>\n<p>\n<label for=\"T173_13\">Left kidney:</label>\n<input type=\"number\" id=\"T173_13\" name=\"Left kidney\" data-field-units=\"%\" min=\"0\" max=\"100\" step=\"1\" /> %\n</p>\n</section>\n</section>\n<section data-section-name=\"Impression\">\n<header class=\"level1\">Impression</header>\n<p>\n<textarea id=\"T173_14\" name=\"Impression\">Normal. </textarea>\n</p>\n</section>\n</body>\n</html>\n",

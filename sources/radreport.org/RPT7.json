t type=\"text\" id=\"T7_20\" name=\"Complications\" value=\"None. \"/>\n</p>\n</section>\n<section data-section-name=\"Clinical information\">\n<header class=\"level1\">Clinical information</header>\n<p>\n<textarea id=\"T7_26\" name=\"Clinical information\">Coronary artery disease risk assessment. </textarea>\n</section>\n<section data-section-name=\"Comparison\">\n<header class=\"level1\">Comparison</header>\n<p>\n<textarea id=\"T7_32\" name=\"Comparison\">None. </textarea>\n</p>\n</section>\n<section data-section-name=\"Findings\">\n<header class=\"level1\">Findings</header>\n<section data-section-name=\"Technical quality\">\n<header class=\"level2\">Technical quality</header>\n<p>\n<label for=\"T7_35\">Examination quality:</label>\n<select id=\"T7_35\" name=\"Examination quality\">\n<option id=\"T7_36\" name=\"Excellent\" value=\"Excellent\">Excellent</option>\n<option id=\"T7_37\" name=\"Good\" value=\"Good\">Good</option>\n<option id=\"T7_38\" name=\"Fair\" value=\"Fair\">Fair</option>\n<option id=\"T7_39\" name=\"Poor\" value=\"Poor\">Poor</option>\n<option id=\"T7_40\" name=\"Nondiagnostic\" value=\"Nondiagnostic\">Nondiagnostic</option>\n</select>\n</p>\n<p>\n<label for=\"T7_41\">Limitation:</label>\n<select id=\"T7_41\" name=\"Limitation\" multiple=\"multiple\">\n<option id=\"T7_none\" name=\"None\" value=\"None\" selected>None</option>\n<option id=\"T7_42\" name=\"Misregistration artifacts\" value=\"Misregistration artifacts\">Misregistration artifacts</option>\n<option id=\"T7_43\" name=\"Patient motion\" value=\"Patient motion\">Patient motion</option>\n<option id=\"T7_44\" name=\"Calcium blooming artifacts\" value=\"Calcium blooming artifacts\">Calcium blooming artifacts</option>\n<option id=\"T7_45\" name=\"Metal artifact\" value=\"Metal artifact\">Metal artifact</option>\n<option id=\"T7_46\" name=\"Arrhythmia\" value=\"Arrhythmia\">Arrhythmia</option>\n</select>\n</p>\n</section>\n<section data-section-name=\"Overall scores\">\n<header class=\"level2\">Overall scores</header>\n<p>\n<label for=\"T7_47\">Agatston score:</label>\n<input type=\"number\" id=\"T7_47\" name=\"Agatston score\" value=\"\"/>\n</p>\n<p>\n<label for=\"T7_49\">Total calcium score:</label>\n<input type=\"number\" id=\"T7_49\" name=\"Total calcium score\" data-field-units=\"\" min=\"\" max=\"\"/> \n</p>\n<p>\n<label for=\"T7_50\">Total volume score:</label>\n<input type=\"number\" id=\"T7_50\" name=\"Total volume score\" data-field-units=\"mm3\" min=\"\" max=\"\"/> <label for=\"T7_50\">mm3</label>\n</p>\n<p>\n<label for=\"T7_51\">Percentile:</label>\n<input type=\"number\" id=\"T7_51\" name=\"Percentile\" data-field-units=\"%\" min=\"0\" max=\"100\"/> <label for=\"T7_51\">%</label>\n</p>\n</section>\n<section data-section-name=\"Artery scores\">\n<header class=\"level2\">Artery scores</header>\n<p>\n<label for=\"T7_53\">Left main coronary artery:</label>\n<input type=\"number\" id=\"T7_53\" name=\"Left main coronary artery\" data-field-units=\"\" min=\"\" max=\"\"/> \n</p>\n<p>\n<label for=\"T7_54\">Left anterior descending artery:</label>\n<input type=\"number\" id=\"T7_54\" name=\"Left anterior descending artery\" data-field-units=\"\" min=\"\" max=\"\"/> \n</p>\n<p>\n<label for=\"T7_55\">Left circumflex artery:</label>\n<input type=\"number\" id=\"T7_55\" name=\"Left circumflex artery\" data-field-units=\"\" min=\"\" max=\"\"/> \n</p>\n<p>\n<label for=\"T7_56\">Right coronary artery:</label>\n<input type=\"number\" id=\"T7_56\" name=\"Right coronary artery\" data-field-units=\"\" min=\"\" max=\"\"/> \n</p>\n</section>\n<section data-section-name=\"Other findings\">\n<header class=\"level2\">Other findings</header>\n<p>\n<label for=\"T7_57\">Cardiac chambers:</label>\n<input type=\"text\" id=\"T7_57\" name=\"Cardiac chambers\" value=\"Normal. \"/>\n</p>\n<p>\n<label for=\"T7_59\">Cardiac valves:</label>\n<input type=\"text\" id=\"T7_59\" name=\"Cardiac valves\" value=\"Normal. \"/>\n</p>\n<p>\n<label for=\"T7_61\">Thoracic aorta:</label>\n<input type=\"text\" id=\"T7_61\" name=\"Thoracic aorta\" value=\"Normal. \"/>\n</p>\n<p>\n<label for=\"T7_63\">Lungs:</label>\n<input type=\"text\" id=\"T7_63\" name=\"Lungs\" value=\"Normal. \"/>\n</p>\n<p>\n<label for=\"T7_65\">Upper abdomen:</label>\n<input type=\"text\" id=\"T7_65\" name=\"Upper abdomen\" value=\"Normal. \"/>\n</p>\n</section>\n</section>\n<section data-section-name=\"Impression\">\n<header class=\"level1\">Impression</header>\n<p>\n<textarea id=\"T7_79\" name=\"Impression\"> </textarea>\n</p>\n</section>\n</body>\n</html>\n",

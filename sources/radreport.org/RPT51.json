lume):</label>\n<input type=\"text\" id=\"T51_8\" name=\"T51_8\" value=\"None.\"/>\n</p>\n</section>\n<section data-section-name=\"Clinical information\">\n<header class=\"level1\">Clinical information</header>\n<p>\n<textarea id=\"T51_16\" name=\"Clinical information\"> </textarea>\n</p>\n</section>\n<section data-section-name=\"Comparison\">\n<header class=\"level1\">Comparison</header>\n<p>\n<textarea id=\"T51_20\" name=\"Comparison\">None. </textarea>\n</p>\n</section>\n<section data-section-name=\"Findings\">\n<header class=\"level1\">Findings</header>\n<p>\n<label for=\"T51_33\">Image quality:</label>\n<input type=\"text\" id=\"T51_33\" name=\"T51_33\" value=\"Satisfactory.\"/>\n</p>\n<p>\n<label for=\"T51_36\">Small bowel distension:</label>\n<input type=\"text\" id=\"T51_36\" name=\"T51_36\" value=\"Satisfactory.\"/>\n</p>\n<p>\n<label for=\"T51_45\">Peristalsis:</label>\n<input type=\"text\" id=\"T51_45\" name=\"T51_45\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T51_48\">Bowel wall thickening:</label>\n<input type=\"text\" id=\"T51_48\" name=\"T51_48\" value=\"None.\"/>\n</p>\n<p>\n<label for=\"T51_51\">Location</label>\n<input type=\"text\" id=\"T51_51\" name=\"T51_51\" value=\"\"/>\n</p>\n<p>\n<label for=\"T51_52\">Length</label>\n<input type=\"number\" id=\"T51_52\" name=\"T51_52\" data-field-units=\"cm\" min=\"\" max=\"\"/> cm\n</p>\n<p>\n<label for=\"T51_53\">Skip lesions:</label>\n<input type=\"text\" id=\"T51_53\" name=\"T51_53\" value=\"None.\"/>\n</p>\n<p>\n<label for=\"T51_60\">Enhancement:</label>\n<input type=\"text\" id=\"T51_60\" name=\"T51_60\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T51_63\">Appearance</label>\n<select id=\"T51_63\" name=\"T51_63\">\n<option id=\"T51_63_64\" name=\"T51_63_64\" value=\"Homogeneous\">Homogeneous</option>\n<option id=\"T51_63_65\" name=\"T51_63_65\" value=\"Layered\">Layered</option>\n</select>\n<input type=\"text\" id=\"T51_63_text\" name=\"T51_63_text\" value=\"\"/>\n</p>\n<p>\n<label for=\"T51_66\">Fistula</label>\n<select id=\"T51_66\" name=\"T51_66\">\n<option id=\"T51_66_67\" name=\"T51_66_67\" value=\"Absent\">Absent</option>\n<option id=\"T51_66_68\" name=\"T51_66_68\" value=\"Present\">Present</option>\n</select>\n<input type=\"text\" id=\"T51_66_text\" name=\"T51_66_text\" value=\"\"/>\n</p>\n<p>\n<label for=\"T51_69\">Abscess</label>\n<select id=\"T51_69\" name=\"T51_69\">\n<option id=\"T51_69_70\" name=\"T51_69_70\" value=\"Absent\">Absent</option>\n<option id=\"T51_69_71\" name=\"T51_69_71\" value=\"Present\">Present</option>\n</select>\n<input type=\"text\" id=\"T51_69_text\" name=\"T51_69_text\" value=\"\"/>\n</p>\n<p>\n<label for=\"T51_72\">Anal fissure:</label>\n<input type=\"text\" id=\"T51_72\" name=\"T51_72\" value=\"None.\"/>\n</p>\n<p>\n<label for=\"T51_75\">Adenopathy:</label>\n<input type=\"text\" id=\"T51_75\" name=\"T51_75\" value=\"None.\"/>\n</p>\n<p>\n<label for=\"T51_78\">Stomach:</label>\n<input type=\"text\" id=\"T51_78\" name=\"T51_78\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T51_80\">Duodenum:</label>\n<input type=\"text\" id=\"T51_80\" name=\"T51_80\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T51_82\">Colon:</label>\n<input type=\"text\" id=\"T51_82\" name=\"T51_82\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T51_84\">Liver:</label>\n<input type=\"text\" id=\"T51_84\" name=\"T51_84\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T51_86\">Gallbladder:</label>\n<input type=\"text\" id=\"T51_86\" name=\"T51_86\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T51_88\">Pancreas:</label>\n<input type=\"text\" id=\"T51_88\" name=\"T51_88\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T51_90\">Spleen:</label>\n<input type=\"text\" id=\"T51_90\" name=\"T51_90\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T51_92\">Adrenals glands:</label>\n<input type=\"text\" id=\"T51_92\" name=\"T51_92\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T51_94\">Kidneys:</label>\n<input type=\"text\" id=\"T51_94\" name=\"T51_94\" value=\"Normal.\"/>\n
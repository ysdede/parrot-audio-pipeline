    "templateData": "<!DOCTYPE html>\n<html>\n    <head>\n        <title>US Pelvis</title>\n        <meta charset=\"UTF-8\" />\n        <meta name=\"dcterms.identifier\" content=\"45488469-97c1-47ff-961d-9ee96f2d0040\" />\n        <meta name=\"dcterms.title\" content=\"US Pelvis\" />\n        <meta name=\"dcterms.description\" content=\"\" />\n        <meta name=\"dcterms.type\" content=\"IMAGE_REPORT_TEMPLATE\" />\n        <meta name=\"dcterms.language\" content=\"en\" />\n        <meta name=\"dcterms.publisher\" content=\"University of Utah\" />\n        <meta name=\"dcterms.rights\" content=\"May be used freely, subject to license agreement\" />\n        <meta name=\"dcterms.license\" content=\"http://www.radreport.org/license.pdf\" />\n        <meta name=\"dcterms.date\" content=\"2018-03-12\" />\n        <meta name=\"dcterms.creator\" content=\"Marta E. Heilbrun, MD\" />\n        <script type=\"text/xml\">\n            <template_attributes>\n                <coded_content>\n                    <coding_schemes>\n                        <coding_scheme name=\"RADLEX\" designator=\"2.16.840.1.113883.6.256\"></coding_scheme>\n                        <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\"></coding_scheme>\n                    </coding_schemes>\n                    <entry origtxt=\"SECTION_HEADER_1459362482768\">\n                        <term>\n                            <code meaning=\"uterus\" value=\"RID302\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459362482780\">\n                        <term>\n                            <code meaning=\"mass\" value=\"RID3874\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"findings\">\n                        <term>\n                            <code meaning=\"Procedure Findings\" value=\"59776-5\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459362482776\">\n                        <term>\n                            <code meaning=\"right ovary\" value=\"RID32829\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"impressionText\">\n                        <term>\n                            <code meaning=\"normal\" value=\"RID13173\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459362482774\">\n                        <term>\n                            <code meaning=\"endometrium\" value=\"RID30958\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"clinicalInformationText\">\n                        <term>\n                            <code meaning=\"indication\" value=\"RID49442\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SECTION_HEADER_1459362482775\">\n                        <term>\n                            <code meaning=\"uterine adnexa\" value=\"RID294\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459362482781\">\n                        <term>\n                            <code meaning=\"fluid\" value=\"RID1547\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459362482771\">\n                        <term>\n                            <code meaning=\"parenchyma\" value=\"RID5978\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"procedureInformation\">\n                        <term>\n                            <code meaning=\"Current Imaging Procedure Description\" value=\"55111-9\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459362482778\">\n                        <term>\n                            <code meaning=\"left ovary\" value=\"RID32830\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"comparisons\">\n                        <term>\n                            <code meaning=\"Radiology Comparison Study\" value=\"18834-2\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"impression\">\n                        <term>\n                            <code meaning=\"Impressions\" value=\"19005-8\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"clinicalInformation\">\n                        <term>\n                            <code meaning=\"Clinical Information\" value=\"55752-0\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                </coded_content>\n            </template_attributes>\n        </script>\n    </head>\n    <body>\n        <section id=\"procedureInformation\" class=\"level1\" data-section-name=\"Procedure Information\">\n            <header class=\"level1\">\n                Procedure Information\n            </header>\n            <p title=\"\">\n                <label for=\"TEXT_1459362482767\">Technique:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459362482767\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Both transabdominal and endovaginal techniques were employed.</textarea>\n            </p>\n        </section>\n        <section id=\"clinicalInformation\" class=\"level1\" data-section-name=\"Clinical Information\">\n            <header class=\"level1\">\n                Clinical Information\n            </header>\n            <p title=\"\">\n                <label for=\"clinicalInformationText\">Indication:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"clinicalInformationText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">None.</textarea>\n            </p>\n        </section>\n        <section id=\"comparisons\" class=\"level1\" data-section-name=\"Comparison\">\n            <header class=\"level1\">\n                Comparison\n            </header>\n            <p title=\"\">\n                <label for=\"comparisonsText\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"comparisonsText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">None.</textarea>\n            </p>\n        </section>\n        <section id=\"findings\" class=\"level1\" data-section-name=\"Findings\">\n            <header class=\"level1\">\n                Findings\n            </header>\n            <section id=\"SECTION_HEADER_1459362482768\" class=\"level2\" data-section-name=\"Uterus\">\n                <header class=\"level2\">\n                    Uterus\n                </header>\n                <p title=\"\">\n                    <label for=\"TEXT_1459362482769\">Position:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459362482769\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\"></textarea>\n                </p>\n                <p title=\"\">\n                    <label for=\"NUMBER_1459362482770\">Size:</label>\n                    <span>\n                        <input type=\"number\" step=\"1.0\" data-field-units=\"cm\" id=\"NUMBER_1459362482770\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                        cm\n                    </span>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1459362482771\">The uterine parenchyma is:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459362482771\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Homogenous without fibroids.</textarea>\n                </p>\n            </section>\n            <p title=\"\">\n                <label for=\"TEXT_1459362482774\">The Endometrium- The Endometrial Stripe:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459362482774\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">No abnormal fluid collections in the endometrial cavity, no obvious mass, and no abnormal blood flow within the endometrium by Doppler.</textarea>\n            </p>\n            <section id=\"SECTION_HEADER_1459362482775\" class=\"level2\" data-section-name=\"Adnexa\">\n                <header class=\"level2\">\n                    Adnexa\n                </header>\n                <p title=\"\">\n                    <label for=\"TEXT_1459362482776\">Right Ovary:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459362482776\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">The right ovary is identified and appears normal.</textarea>\n                </p>\n                <p title=\"\">\n                    <label for=\"NUMBER_1459362482777\">Size:</label>\n                    <span>\n                        <input type=\"number\" step=\"1.0\" data-field-units=\"cm\" id=\"NUMBER_1459362482777\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                        cm\n                    </span>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1459362482778\">Left Ovary:</label>\n                    <input type=\"text\" id=\"TEXT_1459362482778\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\" value=\"The left ovary is identified and appears normal.\" />\n                </p>\n                <p title=\"\">\n                    <label for=\"NUMBER_1459362482779\">Size:</label>\n                    <span>\n                        <input type=\"number\" step=\"1.0\" data-field-units=\"cm\" id=\"NUMBER_1459362482779\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                        cm\n                    </span>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1459362482780\">Mass:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459362482780\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">No abnormal adnexal masses.</textarea>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1459362482781\">Fluid:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459362482781\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">There is no abnormal fluid in the pelvis.</textarea>\n                </p>\n            </section>\n            <p title=\"\">\n                <label for=\"TEXT_1476459232292\">Additional findings:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476459232292\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">None.</textarea>\n            </p>\n        </section>\n        <section id=\"impression\" class=\"level1\" data-section-name=\"Impression\">\n            <header class=\"level1\">\n                Impression\n            </header>\n            <p title=\"\">\n                <label for=\"impressionText\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"impressionText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n            </p>\n        </section>\n    </body>\n</html>\n",

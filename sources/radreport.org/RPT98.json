    "templateData": "<!DOCTYPE html>\n<!-- saved from url=(0040)http://www.radreport.org/convert/rtf.php -->\n<html><head>\n<meta charset=\"UTF-8\">\n<meta content=\"US Liver - TIPS\" name=\"dcterms.title\">\n<meta content=\"US Liver - TIPS report template\" name=\"dcterms.description\">\n<meta content=\"http://www.radreport.org/template/0000098\" name=\"dcterms.identifier\">\n<meta content=\"en\" name=\"dcterms.language\">\n<meta content=\"IMAGE_REPORT_TEMPLATE\" name=\"dcterms.type\">\n<meta content=\"Radiological Society of North America (RSNA)\" name=\"dcterms.publisher\">\n<meta content=\"May be used gratis, subject to license agreement\" name=\"dcterms.rights\">\n<meta content=\"http://www.radreport.org/license.pdf\" name=\"dcterms.license\">\n<meta content=\"2014-05-01\" name=\"dcterms.date\">\n<meta content=\"Tolat P, Kahn CE Jr\" name=\"dcterms.creator\">\n\n<meta content=\"Kahn CE Jr [editor]\" name=\"dcterms.contributor\">\n<meta content=\"Medical College of Wisconsin (MCW)\" name=\"dcterms.contributor\">\n<link rel=\"stylesheet\" type=\"text/css\" href=\"IHE_Template_Style.css\">\n<!-- The absolute link to the CSS file is http://www.radreport.org/html/IHE_Template_Style.css -->\n<script type=\"text/xml\">\r\n<!--\r\n<template_attributes>\n<top-level-flag>true</top-level-flag>\n<status>ACTIVE</status>\n<coding_schemes>\n <coding_scheme name=\"RadLex\" designator=\"2.16.840.1.113883.6.256\" />\n <coding_scheme name=\"SNOMEDCT\" designator=\"2.16.840.1.113883.6.96\" />\n <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\" />\n</coding_schemes>\n<coded_content>\n</coded_content>\n</template_attributes>\r\n-->\r\n</script>\n<title>US Liver - TIPS</title>\n</head>\n<body>\n<section data-section-name=\"Procedure\">\n<header class=\"level1\">US Liver - TIPS Evaluation</header>\n</section>\n<section data-section-name=\"Clinical information\">\n<header class=\"level1\">Clinical information</header>\n<p>\n<textarea id=\"T98_001\" name=\"Clinical information\">Evaluate TIPS patency and flow.</textarea>\n</p>\n</section>\n<section data-section-name=\"Comparison\">\n<header class=\"level1\">Comparison</header>\n<p>\n<textarea id=\"T98_002\" name=\"Comparison\">None. </textarea>\n</p>\n</section>\n<section data-section-name=\"Findings\">\n<header class=\"level1\">Findings</header>\n<section data-section-name=\"Liver\">\n<header class=\"level2\">Liver</header>\n<p>\n<label for=\"T98_003\">Liver morphology:</label>\n<input type=\"text\" id=\"T98_003\" name=\"Liver\" value=\"Cirrhosis.  No focal lesion.\" />\n</p>\n<p>\n<label for=\"T98_004\">Ascites:</label>\n<select id=\"T98_004\" name=\"Ascites\">\n<option id=\"T98_005\" name=\"None\" value=\"None\">None</option>\n<option id=\"T98_006\" name=\"Trace\" value=\"Trace\">Trace</option>\n<option id=\"T98_007\" name=\"Mild\" value=\"Mild\">Mild</option>\n<option id=\"T98_008\" name=\"Moderate\" value=\"Moderate\">Moderate</option>\n<option id=\"T98_009\" name=\"Severe\" value=\"Severe\">Severe</option>\n</select>\n<select id=\"T98_010\" name=\"Change in ascites\">\n<option id=\"T98_011\" name=\".\" value=\".\">.</option>\n<option id=\"T98_012\" name=\"unchanged\" value=\"unchanged\">unchanged</option>\n<option id=\"T98_013\" name=\"new\" value=\"new\">new</option>\n<option id=\"T98_014\" name=\"increased\" value=\"increased\">increased</option>\n<option id=\"T98_015\" name=\"decreased\" value=\"decreased\">decreased</option>\n</select>\n</p>\n<p>\n<label for=\"T98_016\">Main portal vein:</label>\n<input type=\"text\" id=\"T98_016\" name=\"Main portal vein\" value=\"Patent with ANTEGRADE flow.\" />\n</p>\n<p>\n<label for=\"T98_017\">Left portal vein:</label>\n<input type=\"text\" id=\"T98_017\" name=\"Left portal vein\" value=\"Patent with expected RETROGRADE flow.\"/>\n</p>\n<p>\n<label for=\"T98_018\">Hepatic artery:</label>\n<input type=\"text\" id=\"T98_018\" name=\"Hepatic artery\" value=\"Patent with normal flow characteristics.\"/>\n</p>\n<p>\n<label for=\"T98_019\">Hepatic veins:</label>\n<input type=\"text\" id=\"T98_019\" name=\"Hepatic veins\" value=\"Patent with normal flow hemodynamics.\"/>\n</p>\n</section>\n<section data-section-name=\"Peak velocities - Current examination\">\n<header class=\"level2\">Peak velocities - Current examination</header>\n<p>\n<label for=\"T98_020\">Main portal vein:</label>\n<input type=\"number\" id=\"T98_020\" name=\"Main portal vein\"/> <label for=\"T98_020\">cm/s</label>\n</p>\n<p>\n<label for=\"T98_021\">TIPS portal-vein end:</label>\n<input type=\"number\" id=\"T98_021\" name=\"Portal vein end\"/> <label for=\"T98_021\">cm/s</label>\n</p>\n<p>\n<label for=\"T98_022\">Mid-TIPS:</label>\n<input type=\"number\" id=\"T98_022\" name=\"Mid-TIPS\"/> <label for=\"T98_022\">cm/s</label>\n</p>\n<p>\n<label for=\"T98_023\">TIPS hepatic-vein end:</label>\n<input type=\"number\" id=\"T98_023\" name=\"Hepatic vein end\"/> <label for=\"T98_023\">cm/s</label>\n</p>\n</section>\n<section data-section-name=\"Peak velocities - Prior examination\">\n<header class=\"level2\">Peak velocities - Prior examination</header>\n<p>\n<label for=\"T98_024\">Main portal vein:</label>\n<input type=\"number\" id=\"T98_024\" name=\"Prior Main portal vein\"/> <label for=\"T98_024\">cm/s</label>\n</p>\n<p>\n<label for=\"T98_025\">TIPS portal-vein end:</label>\n<input type=\"number\" id=\"T98_025\" name=\"Prior Portal vein end\"/> <label for=\"T98_025\">cm/s</label>\n</p>\n<p>\n<label for=\"T98_026\">Mid-TIPS:</label>\n<input type=\"number\" id=\"T98_026\" name=\"Prior Mid-TIPS\"/> <label for=\"T98_026\">cm/s</label>\n</p>\n<p>\n<label for=\"T98_027\">TIPS hepatic-vein end:</label>\n<input type=\"number\" id=\"T98_027\" name=\"Prior Hepatic vein end\"/> <label for=\"T98_027\">cm/s</label>\n</p>\n</section>\n<section data-section-name=\"Spleen\">\n<header class=\"level2\">Spleen</header>\n<p>\n<label for=\"T98_028\">Spleen length:</label>\n<input type=\"number\" id=\"T98_028\" name=\"Spleen length\" value=\"\"/> <label for=\"T98_028\">cm.</label>\n</p>\n<p>\n<label for=\"T98_029\">Splenic vein:</label>\n<input type=\"text\" id=\"T98_029\" name=\"Splenic vein\" value=\"Patent with antegrade flow.\"/>\n</p>\n</section>\n<section data-section-name=\"Other findings\">\n<header class=\"level2\">Other findings</header>\n<p>\n<textarea id=\"T98_030\" name=\"Other findings\">None.</textarea>\n</p>\n</section>\n</section>\n<section data-section-name=\"Impression\">\n<header class=\"level1\">Impression</header>\n<p>\n<textarea id=\"T98_031\" name=\"Impression\">Patent TIPS.  No evidence of stenosis.</textarea>\n</p>\n</section>\n\n</body></html>",

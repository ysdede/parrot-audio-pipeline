4953\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1601992445362\">\n                        <term>\n                            <code meaning=\"alignment\" value=\"http://radlex.org/RID/RID38801\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"CHECKBOX_1601992445350_0\">\n                        <term>\n                            <code meaning=\"none\" value=\"http://radlex.org/RID/RID28454\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"CHECKBOX_1601992445350_2\">\n                        <term>\n                            <code meaning=\"anterolateral\" value=\"http://radlex.org/RID/RID38810\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"CHECKBOX_1601992445350_3\">\n                        <term>\n                            <code meaning=\"posterolateral\" value=\"http://radlex.org/RID/RID39143\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"CHECKBOX_1601992445350_4\">\n                        <term>\n                            <code meaning=\"posteromedial\" value=\"http://radlex.org/RID/RID39142\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"CHECKBOX_1601992445339\">\n                        <term>\n                            <code meaning=\"fracture\" value=\"http://radlex.org/RID/RID4650\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"CHECKBOX_1601992445339_0\">\n                        <term>\n                            <code meaning=\"depression fracture\" value=\"http://radlex.org/RID/RID6344\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"CHECKBOX_1601992445339_1\">\n                        <term>\n                            <code meaning=\"displacement\" value=\"http://radlex.org/RID/RID4751\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"CHECKBOX_1601992445339_3\">\n                        <term>\n                            <code meaning=\"open fracture\" value=\"http://radlex.org/RID/RID6343\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"procedureInformation\">\n                        <term>\n                            <code meaning=\"Current Imaging Procedure Description\" value=\"55111-9\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"RADIO_1601992445379\">\n                        <term>\n                            <code meaning=\"lipohemarthrosis\" value=\"http://radlex.org/RID/RID4704\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"RADIO_1601992445379_0\">\n                        <term>\n                            <code meaning=\"present\" value=\"http://radlex.org/RID/RID28472\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"RADIO_1601992445379_1\">\n                        <term>\n                            <code meaning=\"absent\" value=\"http://radlex.org/RID/RID28473\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"comparisons\">\n                        <term>\n                            <code meaning=\"Radiology Comparison Study\" value=\"18834-2\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"impression\">\n                        <term>\n                            <code meaning=\"Impressions\" value=\"19005-8\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"clinicalInformation\">\n                        <term>\n                            <code meaning=\"Clinical Information\" value=\"55752-0\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"RADIO_1601992445364\">\n                        <term>\n                            <code meaning=\"effusion\" value=\"http://radlex.org/RID/RID4872\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"RADIO_1601992445364_0\">\n                        <term>\n                            <code meaning=\"none\" value=\"http://radlex.org/RID/RID28454\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"RADIO_1601992445364_1\">\n                        <term>\n                            <code meaning=\"small\" value=\"http://radlex.org/RID/RID5774\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"RADIO_1601992445364_2\">\n                        <term>\n                            <code meaning=\"moderate\" value=\"http://radlex.org/RID/RID5672\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"RADIO_1601992445364_3\">\n                        <term>\n                            <code meaning=\"large\" value=\"http://radlex.org/RID/RID5778\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"RADIO_1601992445384\">\n                        <term>\n                            <code meaning=\"Baker cyst\" value=\"http://radlex.org/RID/RID3892\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"RADIO_1601992445384_0\">\n                        <term>\n                            <code meaning=\"none\" value=\"http://radlex.org/RID/RID28454\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"RADIO_1601992445384_1\">\n                        <term>\n                            <code meaning=\"small\" value=\"http://radlex.org/RID/RID5774\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"RADIO_1601992445384_2\">\n                        <term>\n                            <code meaning=\"moderate\" value=\"http://radlex.org/RID/RID5672\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"RADIO_1601992445384_3\">\n                        <term>\n                            <code meaning=\"large\" value=\"http://radlex.org/RID/RID5778\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                </coded_content>\n            </template_attributes>\n        </script>\n    </head>\n    <body>\n        <section id=\"procedureInformation\" class=\"level1\" data-section-name=\"Procedure Information\">\n            <header class=\"level1\">\n                Procedure Information\n            </header>\n            <p title=\"\">\n                <label for=\"procedureInformationText\">Technique</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"procedureInformationText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Thin section transaxial computed tomographic imaging of the knee was performed without intravenous contrast. Sagittal and coronal reconstructions were also created.</textarea>\n            </p>\n        </section>\n        <section id=\"clinicalInformation\" class=\"level1\" data-section-name=\"Clinical Information\">\n            <header class=\"level1\">\n                Clinical Information\n            </header>\n            <p title=\"\">\n                <label for=\"clinicalInformationText\">History</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"clinicalInformationText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Knee pain.</textarea>\n            </p>\n        </section>\n        <section id=\"comparisons\" class=\"level1\" data-section-name=\"Comparison\">\n            <header class=\"level1\">\n                Comparison\n            </header>\n            <p title=\"\">\n                <label for=\"comparisonsText\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"comparisonsText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n        </section>\n        <section id=\"findings\" class=\"level1\" data-section-name=\"Findings\">\n            <header class=\"level1\">\n                Findings\n            </header>\n            <p title=\"\">\n                <label for=\"findingsText\">Fracture</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"findingsText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"CHECKBOX_1601480313577\">Type of fracture</label>\n                <span id=\"CHECKBOX_1601480313577\" name=\"\" data-field-type=\"CHECKBOX\" data-field-completion-action=\"NONE\" value=\"\">\n                    <br />\n                    <input id=\"CHECKBOX_1601480313577_0\" type=\"checkbox\" name=\"CHECKBOX_1601480313577\" value=\"femoral condyle\">femoral condyle</input>\n                    <br />\n                    <input id=\"CHECKBOX_1601480313577_1\" type=\"checkbox\" name=\"CHECKBOX_1601480313577\" value=\"tibial plateau\">tibial plateau</input>\n                    <br />\n                    <input id=\"CHECKBOX_1601480313577_2\" type=\"checkbox\" name=\"CHECKBOX_1601480313577\" value=\"proximal fibula\">proximal fibula</input>\n                    <br />\n                    <input id=\"CHECKBOX_1601480313577_3\" type=\"checkbox\" name=\"CHECKBOX_1601480313577\" value=\"patella\">patella</input>\n                    <br />\n                    <input id=\"CHECKBOX_1601480313577_4\" type=\"checkbox\" name=\"CHECKBOX_1601480313577\" value=\"other\">other</input>\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"CHECKBOX_1601992445339\">Fracture features</label>\n                <span id=\"CHECKBOX_1601992445339\" name=\"\" data-field-type=\"CHECKBOX\" data-field-completion-action=\"NONE\" value=\"\">\n                    <br />\n                    <input id=\"CHECKBOX_1601992445339_0\" type=\"checkbox\" name=\"CHECKBOX_1601992445339\" value=\"articular depression\">articular depression</input>\n                    <br />\n                    <input id=\"CHECKBOX_1601992445339_1\" type=\"checkbox\" name=\"CHECKBOX_1601992445339\" value=\"displacement\">displacement</input>\n                    <br />\n                    <input id=\"CHECKBOX_1601992445339_2\" type=\"checkbox\" name=\"CHECKBOX_1601992445339\" value=\"angulation\">angulation</input>\n                    <br />\n                    <input id=\"CHECKBOX_1601992445339_3\" type=\"checkbox\" name=\"CHECKBOX_1601992445339\" value=\"open fracture\">open fracture</input>\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"CHECKBOX_1601992445344\">Associated soft tissue injuries</label>\n                <span id=\"CHECKBOX_1601992445344\" name=\"\" data-field-type=\"CHECKBOX\" data-field-completion-action=\"NONE\" value=\"\">\n                    <br />\n                    <input id=\"CHECKBOX_1601992445344_0\" type=\"checkbox\" name=\"CHECKBOX_1601992445344\" value=\"wound or blister\">wound or blister</input>\n                    <br />\n                    <input id=\"CHECKBOX_1601992445344_1\" type=\"checkbox\" name=\"CHECKBOX_1601992445344\" value=\"ligament injury\">ligament injury</input>\n                    <br />\n                    <input id=\"CHECKBOX_1601992445344_2\" type=\"checkbox\" name=\"CHECKBOX_1601992445344\" value=\"meniscus injury\">meniscus injury</input>\n                    <br />\n                    <input id=\"CHECKBOX_1601992445344_3\" type=\"checkbox\" name=\"CHECKBOX_1601992445344\" value=\"neurovascular injury\">neurovascular injury</input>\n                    <br />\n                    <input id=\"CHECKBOX_1601992445344_4\" type=\"checkbox\" name=\"CHECKBOX_1601992445344\" value=\"compartment syndrome\">compartment syndrome</input>\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"CHECKBOX_1601992445350\">Columns involved if tibial plateau fracture</label>\n                <span id=\"CHECKBOX_1601992445350\" name=\"\" data-field-type=\"CHECKBOX\" data-field-completion-action=\"NONE\" value=\"\">\n                    <br />\n                    <input id=\"CHECKBOX_1601992445350_0\" type=\"checkbox\" name=\"CHECKBOX_1601992445350\" value=\"none\">none</input>\n                    <br />\n                    <input id=\"CHECKBOX_1601992445350_1\" type=\"checkbox\" name=\"CHECKBOX_1601992445350\" value=\"anteromedial (medial column)\">anteromedial (medial column)</input>\n                    <br />\n                    <input id=\"CHECKBOX_1601992445350_2\" type=\"checkbox\" name=\"CHECKBOX_1601992445350\" value=\"anterolateral (lateral column)\">anterolateral (lateral column)</input>\n                    <br />\n                    <input id=\"CHECKBOX_1601992445350_3\" type=\"checkbox\" name=\"CHECKBOX_1601992445350\" value=\"posterolateral (posterior column)\">posterolateral (posterior column)</input>\n                    <br />\n                    <input id=\"CHECKBOX_1601992445350_4\" type=\"checkbox\" name=\"CHECKBOX_1601992445350\" value=\"posteromedial (posterior column)\">posteromedial (posterior column)</input>\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"CHECKBOX_1601992445356\">Three column classification if tibial plateau fracture</label>\n                <span id=\"CHECKBOX_1601992445356\" name=\"\" data-field-type=\"CHECKBOX\" data-field-completion-action=\"NONE\" value=\"\">\n                    <br />\n                    <input id=\"CHECKBOX_1601992445356_0\" type=\"checkbox\" name=\"CHECKBOX_1601992445356\" value=\"zero column\">zero column</input>\n                    <br />\n                    <input id=\"CHECKBOX_1601992445356_1\" type=\"checkbox\" name=\"CHECKBOX_1601992445356\" value=\"one column\">one column</input>\n                    <br />\n                    <input id=\"CHECKBOX_1601992445356_2\" type=\"checkbox\" name=\"CHECKBOX_1601992445356\" value=\"two column\">two column</input>\n                    <br />\n                    <input id=\"CHECKBOX_1601992445356_3\" type=\"checkbox\" name=\"CHECKBOX_1601992445356\" value=\"three column\">three column</input>\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1601992445361\">Additional bone findings</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1601992445361\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1601992445362\">Alignment</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1601992445362\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1601992445363\">Joint spaces</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1601992445363\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"RADIO_1601992445364\">Knee joint effusion</label>\n                <span id=\"RADIO_1601992445364\" name=\"\" data-field-type=\"RADIO\" data-field-completion-action=\"NONE\" value=\"\">\n                    <br />\n                    <input id=\"RADIO_1601992445364_0\" type=\"radio\" name=\"RADIO_1601992445364\" value=\"none\" checked=\"\">none</input>\n                    <br />\n                    <input id=\"RADIO_1601992445364_1\" type=\"radio\" name=\"RADIO_1601992445364\" value=\"small\">small</input>\n                    <br />\n                    <input id=\"RADIO_1601992445364_2\" type=\"radio\" name=\"RADIO_1601992445364\" value=\"moderate\">moderate</input>\n                    <br />\n                    <input id=\"RADIO_1601992445364_3\" type=\"radio\" name=\"RADIO_1601992445364\" value=\"large\">large</input>\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"RADIO_1601992445379\">Lipohemarthrosis</label>\n                <span id=\"RADIO_1601992445379\" name=\"\" data-field-type=\"RADIO\" data-field-completion-action=\"NONE\" value=\"\">\n                    <br />\n                    <input id=\"RADIO_1601992445379_0\" type=\"radio\" name=\"RADIO_1601992445379\" value=\"present\" checked=\"\">present</input>\n                    <br />\n                    <input id=\"RADIO_1601992445379_1\" type=\"radio\" name=\"RADIO_1601992445379\" value=\"absent\">absent</input>\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1601992445382\">Extensor mechanism</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1601992445382\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Intact</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1601992445383\">Ligaments</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1601992445383\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"RADIO_1601992445384\">Baker\u2019s cyst</label>\n                <span id=\"RADIO_1601992445384\" name=\"\" data-field-type=\"RADIO\" data-field-completion-action=\"NONE\" value=\"\">\n                    <br />\n                    <input id=\"RADIO_1601992445384_0\" type=\"radio\" name=\"RADIO_1601992445384\" value=\"none\" checked=\"\">none</input>\n                    <br />\n                    <input id=\"RADIO_1601992445384_1\" type=\"radio\" name=\"RADIO_1601992445384\" value=\"small\">small</input>\n                    <br />\n                    <input id=\"RADIO_1601992445384_2\" type=\"radio\" name=\"RADIO_1601992445384\" value=\"moderate\">moderate</input>\n                    <br />\n                    <input id=\"RADIO_1601992445384_3\" type=\"radio\" name=\"RADIO_1601992445384\" value=\"large\">large</input>\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1601992445389\">Soft tissue</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1601992445389\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n        </section>\n        <section id=\"impression\" class=\"level1\" data-section-name=\"Impression\">\n            <header class=\"level1\">\n                Impression\n            </header>\n            <p title=\"\">\n                <label for=\"impressionText\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"impressionText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal CT examination of the knee.</textarea>\n            </p>\n        </section>\n    </body>\n</html>\n",

    "templateData": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\"/>\n<meta content=\"Cystogram\" name=\"dcterms.title\"/>\n<meta content=\"Cystogram template :: Authored by Kahn CE Jr\" name=\"dcterms.description\"/>\n<meta content=\"http://www.radreport.org/template/0000222\" name=\"dcterms.identifier\"/>\n<meta content=\"en\" name=\"dcterms.language\"/>\n<meta content=\"IMAGE_REPORT_TEMPLATE\" name=\"dcterms.type\"/>\n<meta content=\"Radiological Society of North America (RSNA)\" name=\"dcterms.publisher\"/>\n<meta content=\"May be used gratis, subject to license agreement\" name=\"dcterms.rights\"/>\n<meta content=\"http://www.radreport.org/license.pdf\" name=\"dcterms.license\"/>\n<meta content=\"2012-06-08\" name=\"dcterms.date\"/>\n<meta content=\"Kahn CE Jr\" name=\"dcterms.creator\"/>\n\n<meta content=\"Kahn CE Jr [editor]\" name=\"dcterms.contributor\"/>\n<meta content=\"Medical College of Wisconsin (MCW)\" name=\"dcterms.contributor\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"IHE_Template_Style.css\" />\n<!-- The absolute link to the CSS file is http://www.radreport.org/html/IHE_Template_Style.css -->\n<script type=\"text/xml\">\r\n<!--\r\n<template_attributes>\n<top-level-flag>true</top-level-flag>\n<status>ACTIVE</status>\n<coding_schemes>\n <coding_scheme name=\"RadLex\" designator=\"2.16.840.1.113883.6.256\" />\n <coding_scheme name=\"SNOMEDCT\" designator=\"2.16.840.1.113883.6.96\" />\n <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\" />\n</coding_schemes>\n<term>\n <code meaning=\"cystography\" value=\"RID34878\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"urinary bladder\" value=\"RID237\" scheme=\"RadLex\">\n</term>\n<coded_content>\n<entry ORIGTXT=\"T222_2\">\n <term>\n  <code meaning=\"procedure\" value=\"RID1559\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T222_5\">\n  <term>\n  <code meaning=\"Clinical information\" value=\"55752-0\" scheme=\"LOINC\">\n </term>\n</entry>\n<entry ORIGTXT=\"T222_6\">\n <term>\n  <code meaning=\"comparison\" value=\"RID28483\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T222_12\">\n <term>\n  <code meaning=\"impression section\" value=\"RID13170\" scheme=\"RadLex\">\n </term>\n</entry>\n</coded_content>\n</template_attributes>\r\n-->\r\n</script>\n<title>Cystogram</title>\n</head>\n<body>\n<section data-section-name=\"Procedure\">\n<header class=\"level1\">Cystogram</header>\n<p>\n<textarea id=\"T222_2\" name=\"Procedure\">Fluoroscopically-guided cystogram was performed with Omnipaque contrast infused through the indwelling Foley catheter using sterile technique.</textarea>\n</p>\n</section>\n<section data-section-name=\"Clinical information\">\n<header class=\"level1\">Clinical information</header>\n<p>\n<textarea id=\"T222_5\" name=\"Clinical information\"></textarea>\n</p>\n</section>\n<section data-section-name=\"Comparison\">\n<header class=\"level1\">Comparison</header>\n<p>\n<textarea id=\"T222_6\" name=\"Comparison\" >None.</textarea>\n</p>\n</section>\n<section data-section-name=\"Findings\">\n<header class=\"level1\">Findings</header>\n<section data-section-name=\"Initial radiograph\">\n<header class=\"level2\">Initial radiograph</header>\n<p>\n<textarea id=\"T222_9\" name=\"Initial radiograph\">Normal bowel gas pattern. No abnormal calcification.</textarea>\n</p>\n</section>\n<section data-section-name=\"Urinary bladder\">\n<header class=\"level2\">Urinary bladder</header>\n<p>\n<textarea id=\"T222_10\" name=\"Urinary bladder\">Normal contour. No irregularity, mass effect, filling defect, or extravasation.</textarea>\n</p>\n</section>\n<section data-section-name=\"Ureters\">\n<header class=\"level2\">Ureters</header>\n<p>\n<textarea id=\"T222_10B\" name=\"Ureters\">No reflux into the ureters.</textarea>\n</p>\n</section>\n<section data-section-name=\"Postvoid image\">\n<header class=\"level2\">Postvoid image</header>\n<p>\n<textarea id=\"T222_11\" name=\"Postvoid image\" >Small amount of residual contrast in the bladder.</textarea>\n</p>\n</section>\n</section>\n<section data-section-name=\"Impression\">\n<header class=\"level1\">Impression</header>\n<p>\n<!-- <label for=\"T222_12\">Impression</label> -->\n<textarea id=\"T222_12\" name=\"Impression\">Normal cystogram.</textarea>\n</p>\n</section>\n</body>\n</html>\n",

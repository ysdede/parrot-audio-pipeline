    "templateData": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\"/>\n<meta content=\"MR Brachial Plexus\" name=\"dcterms.title\"/>\n<meta content=\"MR Brachial Plexus template\" name=\"dcterms.description\"/>\n<meta content=\"http://www.radreport.org/template/0000044\" name=\"dcterms.identifier\"/>\n<meta content=\"en\" name=\"dcterms.language\"/>\n<meta content=\"IMAGE_REPORT_TEMPLATE\" name=\"dcterms.type\"/>\n<meta content=\"Radiological Society of North America (RSNA)\" name=\"dcterms.publisher\"/>\n<meta content=\"May be used gratis, subject to license agreement\" name=\"dcterms.rights\"/>\n<meta content=\"http://www.radreport.org/license.pdf\" name=\"dcterms.license\"/>\n<meta content=\"2012-07-16\" name=\"dcterms.date\"/>\n<meta content=\"Kahn CE Jr\" name=\"dcterms.creator\"/>\n<meta content=\"Kahn CE Jr [editor]\" name=\"dcterms.contributor\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"IHE_Template_Style.css\"/>\n<!-- The absolute link to the CSS file is http://www.radreport.org/html/IHE_Template_Style.css -->\n<script type=\"text/xml\">\n<!--\n<template_attributes>\n<top-level-flag>true</top-level-flag>\n<status>ACTIVE</status>\n<coding_schemes>\n <coding_scheme name=\"RadLex\" designator=\"2.16.840.1.113883.6.256\" />\n <coding_scheme name=\"SNOMEDCT\" designator=\"2.16.840.1.113883.6.96\" />\n <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\" />\n</coding_schemes>\n<term>\n <code meaning=\"brachial plexus\" value=\"RID7202\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"magnetic resonance imaging\" value=\"RID10312\" scheme=\"RadLex\">\n</term>\n<coded_content>\n<entry ORIGTXT=\"T44_2\">\n <term>\n  <code meaning=\"procedure\" value=\"RID1559\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T44_7\">\n <term>\n  <code meaning=\"contrast agent\" value=\"RID11582\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T44_12\">\n <term>\n  <code meaning=\"clinical information\" value=\"RID13166\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T44_13\">\n <term>\n  <code meaning=\"comparison\" value=\"RID28483\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T44_23\">\n <term>\n  <code meaning=\"spinal cord\" value=\"RID7361\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T44_84\">\n <term>\n  <code meaning=\"set of cords of brachial nerve plexus\" value=\"RID16503\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T44_123\">\n <term>\n  <code meaning=\"set of ribs\" value=\"RID28591\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T44_330\">\n <term>\n  <code meaning=\"impression section\" value=\"RID13170\" scheme=\"RadLex\">\n </term>\n</entry>\n</coded_content>\n</template_attributes>\n-->\n</script>\n<title>MR Brachial Plexus</title>\n</head>\n<body>\n<section data-section-name=\"Procedure\">\n<header class=\"level1\">MR Brachial Plexus</header>\n<p>\n<textarea id=\"T44_2\" name=\"Procedure\">High resolution MRI was performed of the brachial plexus employing MR neurography techniques using multiplanar 3-D anatomical and fluid-sensitive sequences.</textarea>\n</p>\n<p>\n<label for=\"T44_7\">IV Contrast:</label>\n<input type=\"text\" id=\"T44_7\" name=\"IV Contrast\" value=\"None.\"/>\n</p>\n</section>\n<section data-section-name=\"Clinical information\">\n<header class=\"level1\">Clinical information</header>\n<p>\n<textarea id=\"T44_12\" name=\"Clinical information\"> </textarea>\n</p>\n</section>\n<section data-section-name=\"Comparison\">\n<header class=\"level1\">Comparison</header>\n<p>\n<textarea id=\"T44_13\" name=\"Comparison\">None. </textarea>\n</p>\n</section>\n<section data-section-name=\"Findings\">\n<header class=\"level1\">Findings</header>\n\n<section data-section-name=\"Spinal cord\">\n<header class=\"level2\">Spinal cord</header>\n<p>\n<textarea id=\"T44_23\" name=\"Spinal cord\">Normal caliber and signal of visualized spinal cord.</textarea>\n</p>\n</section>\n\n<section data-section-name=\"Brachial plexus\">\n<header class=\"level2\">Brachial plexus</header>\n<p>\n<label for=\"T44_33\">Roots:</label>\n<input type=\"text\" id=\"T44_33\" name=\"Roots\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T44_50\">Trunks:</label>\n<input type=\"text\" id=\"T44_50\" name=\"Trunks\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T44_67\">Divisions:</label>\n<input type=\"text\" id=\"T44_67\" name=\"Divisions\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T44_84\">Cords:</label>\n<input type=\"text\" id=\"T44_84\" name=\"Cords\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T44_101\">Branches:</label>\n<input type=\"text\" id=\"T44_101\" name=\"Branches\" value=\"Normal.\"/>\n</p>\n</section>\n\n<section data-section-name=\"Muscles and tendons\">\n<header class=\"level2\">Muscles and tendons</header>\n<p>\n<textarea id=\"T44_997\" name=\"Muscles and tendons\">Normal scalenes.</textarea>\n</p>\n</section>\n<section data-section-name=\"Bones\">\n<header class=\"level2\">Bones</header>\n<p>\n<label for=\"T44_123\">Cervical ribs:</label>\n<input type=\"text\" id=\"T44_123\" name=\"Cervical ribs\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T44_126\">C7 transverse processes:</label>\n<input type=\"text\" id=\"T44_126\" name=\"C7 transverse processes\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T44_129\">Marrow signal:</label>\n<input type=\"text\" id=\"T44_129\" name=\"Marrow signal\" value=\"Normal.\"/>\n</p>\n</section>\n<section data-section-name=\"Joints\">\n<header class=\"level2\">Joints</header>\n<p>\n<textarea id=\"T44_999\" name=\"Joints\">Normal cervical spine articulations, sternoclavicular joints, acromioclavicular joints, and glenohumeral joints.</textarea>\n</p>\n</section>\n\n<section data-section-name=\"Thoracic outlet and cervicothoracic junction\">\n<header class=\"level2\">Thoracic outlet and cervicothoracic junction</header>\n<p>\n<textarea id=\"T44_998\" name=\"Thoracic outlet and cervicothoracic junction\">Normal interscalene triangle, costoclavicular space, and retropectoralis minor space.</textarea>\n</p>\n</section>\n<section data-section-name=\"Other findings\">\n<header class=\"level2\">Other findings</header>\n<p>\n<textarea id=\"T44_166\" name=\"Other findings\">No vascular abnormality, mass, or other significant finding.</textarea>\n</p>\n</section>\n</section>\n<section data-section-name=\"Impression\">\n<header class=\"level1\">Impression</header>\n<p>\n<textarea id=\"T44_330\" name=\"Impression\"> </textarea>\n</p>\n</section>\n</body>\n</html>\n",

erm>\n</entry>\n<entry ORIGTXT=\"T73_26\">\n <term>\n  <code meaning=\"mild\" value=\"RID5671\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T73_27\">\n <term>\n  <code meaning=\"moderate\" value=\"RID5672\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T73_28\">\n <term>\n  <code meaning=\"severe\" value=\"RID5673\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T73_29\">\n <term>\n  <code meaning=\"effusion\" value=\"RID4872\" scheme=\"RadLex\">\n </term>\n <term>\n  <code meaning=\"distal radioulnar joint\" value=\"RID2203\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T73_35\">\n <term>\n  <code meaning=\"scapholunate ligament\" value=\"RID2259\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T73_40\">\n <term>\n  <code meaning=\"lunotriquetral ligament\" value=\"RID2260\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T73_45\">\n <term>\n  <code meaning=\"triangular fibrocartilage\" value=\"RID2223\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T73_52\">\n <term>\n  <code meaning=\"facet\" value=\"RID6118\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T73_109\">\n <term>\n  <code meaning=\"carpal tunnel\" value=\"RID2314\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T73_110\">\n <term>\n  <code meaning=\"median nerve\" value=\"RID7246\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T73_125\">\n <term>\n  <code meaning=\"Guyon canal\" value=\"RID2316\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T73_148\">\n <term>\n  <code meaning=\"set of bones\" value=\"RID28569\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T73_150\">\n <term>\n  <code meaning=\"muscle organ\" value=\"RID13196\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T73_152\">\n <term>\n  <code meaning=\"vasculature of organ\" value=\"RID15990\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T73_310\">\n <term>\n  <code meaning=\"impression section\" value=\"RID13170\" scheme=\"RadLex\">\n </term>\n</entry>\n</coded_content>\n</template_attributes>\n-->\n</script>\n<title>MR Wrist</title>\n</head>\n<body>\n<section data-section-name=\"Procedure\">\n<header class=\"level1\">MR Wrist</header>\n<p>\n<textarea id=\"T73_2\" name=\"Procedure\">Axial proton density and T2, coronal proton density, and sagittal T1 and proton density images of the wrist were obtained. </textarea>\n</p>\n<p>\n<label>Field strength:</label>\n<input id=\"T73_998\" name=\"Field strength\" type=\"number\" value=\"1.5\" data-field-units=\"T\"/> T\n</p>\n<p>\n<label for=\"T73_4\">Site:</label>\n<select id=\"T73_4\" name=\"Site\">\n<option id=\"T73_5\" name=\"Right wrist\" value=\"Right wrist\">Right wrist</option>\n<option id=\"T73_6\" name=\"Left wrist\" value=\"Left wrist\">Left wrist</option>\n</select>\n</p>\n<p>\n<label>IV contrast (agent and volume):</label>\n<input id=\"T73_999\" name=\"IV contrast\" type=\"text\" value=\"None.\" />\n</p>\n\n</section>\n<section data-section-name=\"Clinical information\">\n<header class=\"level1\">Clinical information</header>\n<p>\n<textarea id=\"T73_7\" name=\"Clinical information\"> </textarea>\n</p>\n</section>\n<section data-section-name=\"Comparison\">\n<header class=\"level1\">Comparison</header>\n<p>\n<textarea id=\"T73_8\" name=\"Comparison\">None. </textarea>\n</p>\n</section>\n<section data-section-name=\"Findings\">\n<header class=\"level1\">Findings</header>\n<section data-section-name=\"Alignment\">\n<header class=\"level2\">Alignment</header>\n<p>\n<label for=\"T73_14\">Ulnar variance:</label>\n<select id=\"T73_14\" name=\"Ulnar variance\">\n<option id=\"T73_15\" name=\"None\" value=\"None\">None.</option>\n<option id=\"T73_16\" name=\"Positive\" value=\"Positive\">Positive ulnar variance.</option>\n<option id=\"T73_17\" name=\"Negative\" value=\"Negative\">Negative ulnar variance.</option>\n</select>\n</p>\n<p>\n<label for=\"T73_18\">Distal radioulnar joint</label>\n<input type=\"text\" id=\"T73_18\" name=\"Distal radioulnar joint\" value=\"Congruent.\"/>\n</p>\n<p>\n<label for=\"T73_20\">Carpal instability:</label>\n<select id=\"T73_20\" name=\"Carpal instability\">\n<option id=\"T73_21\" name=\"None\" value=\"None\">None</option>\n<option id=\"T73_22\" name=\"VISI\" value=\"VISI\">VISI</option>\n<option id=\"T73_23\" name=\"DISI\" value=\"DISI\">DISI</option>\n</select>\n</p>\n</section>\n<section data-section-name=\"Fluid\">\n<header class=\"level2\">Fluid</header>\n<p>\n<label for=\"T73_24\">Carpus effusion:</label>\n<select id=\"T73_24\" name=\"Carpus effusion\">\n<option id=\"T73_25\" name=\"None\" value=\"None\">None</option>\n<option id=\"T73_26\" name=\"Mild\" value=\"Mild\">Mild</option>\n<option id=\"T73_27\" name=\"Moderate\" value=\"Moderate\">Moderate</option>\n<option id=\"T73_28\" name=\"Severe\" value=\"Severe\">Severe</option>\n</select>\n</p>\n<p>\n<label for=\"T73_29\">Distal radioulnar joint effusion:</label>\n<select id=\"T73_29\" name=\"Distal radioulnar joint effusion\">\n<option id=\"T73_29_30\" name=\"None\" value=\"None\">None</option>\n<option id=\"T73_29_31\" name=\"Mild\" value=\"Mild\">Mild</option>\n<option id=\"T73_29_32\" name=\"Moderate\" value=\"Moderate\">Moderate</option>\n<option id=\"T73_29_33\" name=\"Severe\" value=\"Severe\">Severe</option>\n</select>\n</p>\n</section>\n<section data-section-name=\"Intrinsic ligaments\">\n<header class=\"level2\">Intrinsic ligaments</header>\n<p>\n<label for=\"T73_35\">Scapholunate ligament:</label>\n<input type=\"text\" id=\"T73_35\" name=\"Scapholunate ligament\" value=\"Intact.\"/>\n</p>\n<p>\n<label for=\"T73_40\">Lunotriquetral ligament:</label>\n<input type=\"text\" id=\"T73_40\" name=\"Lunotriquetral ligament\" value=\"Intact.\"/>\n</p>\n<p>\n<label for=\"T73_45\">Triangular fibrocartilage:</label>\n<input type=\"text\" id=\"T73_45\" name=\"Triangular fibrocartilage\" value=\"Intact.\"/>\n</p>\n<p>\n<label for=\"T73_52\">Lunate facet:</label>\n<select id=\"T73_52\" name=\"Lunate facet\">\n<option id=\"T73_52_53\" name=\"Yes\" value=\"Yes\">Yes</option>\n<option id=\"T73_52_54\" name=\"No\" value=\"No\">No</option>\n</select>\n</p>\n<p>\n<label for=\"T73_55\">Hamate-lunate facet:</label>\n<input type=\"text\" id=\"T73_55\" name=\"Hamate-lunate facet\" value=\"Normal.\"/>\n</p>\n</section>\n<section data-section-name=\"Extensor compartment\">\n<header class=\"level2\">Extensor compartment</header>\n<p>\n<label for=\"T73_67\">I:</label>\n<select id=\"T73_69_69\" name=\"I\">\n<option id=\"T73_69_70\" name=\"Normal\" value=\"Normal\">Normal.</option>\n<option id=\"T73_69_71\" name=\"Mild\" value=\"Mild\">Mild tendinosis.</option>\n<option id=\"T73_69_72\" name=\"Moderate\" value=\"Moderate\">Moderate tendinosis.</option>\n<option id=\"T73_69_73\" name=\"Severe\" value=\"Severe\">Severe tendinosis.</option>\n</select>\n</p>\n<p>\n<label for=\"T73_74\">II:</label>\n<select id=\"T73_69_169\" name=\"II\">\n<option id=\"T73_69_170\" name=\"Normal\" value=\"Normal\">Normal.</option>\n<option id=\"T73_69_171\" name=\"Mild\" value=\"Mild\">Mild tendinosis.</option>\n<option id=\"T73_69_172\" name=\"Moderate\" value=\"Moderate\">Moderate tendinosis.</option>\n<option id=\"T73_69_173\" name=\"Severe\" value=\"Severe\">Severe tendinosis.</option>\n</select>\n</p>\n<p>\n<label for=\"T73_81\">III:</label>\n<select id=\"T73_69_269\" name=\"III\">\n<option id=\"T73_69_270\" name=\"Normal\" value=\"Normal\">Normal.</option>\n<option id=\"T73_69_271\" name=\"Mild\" value=\"Mild\">Mild tendinosis.</option>\n<option id=\"T73_69_272\" name=\"Moderate\" value=\"Moderate\">Moderate tendinosis.</option>\n<option id=\"T73_69_273\" name=\"Severe\" value=\"Severe\">Severe tendinosis.</option>\n</select>\n</p>\n<p>\n<label for=\"T73_88\">IV:</label>\n<select id=\"T73_69_369\" name=\"IV\">\n<option id=\"T73_69_370\" name=\"Normal\" value=\"Normal\">Normal.</option>\n<option id=\"T73_69_371\" name=\"Mild\" value=\"Mild\">Mild tendinosis.</option>\n<option id=\"T73_69_372\" name=\"Moderate\" value=\"Moderate\">Moderate tendinosis.</option>\n<option id=\"T73_69_373\" name=\"Severe\" value=\"Severe\">Severe tendinosis.</option>\n</select>\n</p>\n<p>\n<label for=\"T73_95\">V:</label>\n<select id=\"T73_69_469\" name=\"V\">\n<option id=\"T73_69_470\" name=\"Normal\" value=\"Normal\">Normal.</option>\n<option id=\"T73_69_471\" name=\"Mild\" value=\"Mild\">Mild tendinosis.</option>\n<option id=\"T73_69_472\" name=\"Moderate\" value=\"Moderate\">Moderate tendinosis.</option>\n<option id=\"T73_69_473\" name=\"Severe\" value=\"Severe\">Severe tendinosis.</option>\n</select>\n</p>\n<p>\n<label for=\"T73_102\">VI:</label>\n<select id=\"T73_69_569\" name=\"VI\">\n<option id=\"T73_69_570\" name=\"Normal\" value=\"Normal\">Normal.</option>\n<option id=\"T73_69_571\" name=\"Mild\" value=\"Mild\">Mild tendinosis.</option>\n<option id=\"T73_69_572\" name=\"Moderate\" value=\"Moderate\">Moderate tendinosis.</option>\n<option id=\"T73_69_573\" name=\"Severe\" value=\"Severe\">Severe tendinosis.</option>\n</select>\n</p>\n</section>\n<section data-section-name=\"Flexor compartment\">\n<header class=\"level2\">Flexor compartment</header>\n<p>\n<label for=\"T73_109\">Carpal tunnel:</label>\n<input type=\"text\" id=\"T73_109\" name=\"Carpal tunnel\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T73_110\">Median nerve:</label>\n<input type=\"text\" id=\"T73_110\" name=\"Median nerve\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T73_997\">Flexor retinaculum:</label>\n<input type=\"text\" id=\"T73_997\" name=\"Flexor retinaculum\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T73_996\">Flexor tendons:</label>\n<input type=\"text\" id=\"T73_996\" name=\"Flexor tendons\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T73_125\">Guyon canal:</label>\n<input type=\"text\" id=\"T73_125\" name=\"Guyon canal\" value=\"Normal.\"/>\n</p>\n</section>\n<section data-section-name=\"Articulations\">\n<header class=\"level2\">Articulations</header>\n<p>\n<label for=\"T73_127\">Thumb carpometacarpal joint:</label>\n<select id=\"T73_129_129\" name=\"Thumb carpometacarpal joint\">\n<option id=\"T73_129_130\" name=\"Normal\" value=\"Normal\">Normal.</option>\n<option id=\"T73_129_131\" name=\"Mild\" value=\"Mild\">Mild osteoarthritis.</option>\n<option id=\"T73_129_132\" name=\"Moderate\" value=\"Moderate\">Moderate osteoarthritis.</option>\n<option id=\"T73_129_133\" name=\"Severe\" value=\"Severe\">Severe osteoarthritis.</option>\n</select>\n</p>\n<p>\n<label for=\"T73_134\">Scaphotrapezotrapezoidal joint:</label>\n<select id=\"T73_129_229\" name=\"Scaphotrapezotrapezoidal joint\">\n<option id=\"T73_129_230\" name=\"Normal\" value=\"Normal\">Normal.</option>\n<option id=\"T73_129_231\" name=\"Mild\" value=\"Mild\">Mild osteoarthritis.</option>\n<option id=\"T73_129_232\" name=\"Moderate\" value=\"Moderate\">Moderate osteoarthritis.</option>\n<option id=\"T73_129_233\" name=\"Severe\" value=\"Severe\">Severe osteoarthritis.</option>\n</select>\n</p>\n<p>\n<label for=\"T73_141\">Pisiform-triquetral joint:</label>\n<select id=\"T73_129_329\" name=\"Pisiform-triquetral joint\">\n<option id=\"T73_129_330\" name=\"Normal\" value=\"Normal\">Normal.</option>\n<option id=\"T73_129_331\" name=\"Mild\" value=\"Mild\">Mild osteoarthritis.</option>\n<option id=\"T73_129_332\" name=\"Moderate\" value=\"Moderate\">Moderate osteoarthritis.</option>\n<option id=\"T73_129_333\" name=\"Severe\" value=\"Severe\">Severe osteoarthritis.</option>\n</select>\n</p>\n</section>\n<section data-section-name=\"Other findings\">\n<header class=\"level2\">Other findings</header>\n\n<p>\n<label for=\"T73_148\">Bones:</label>\n<input type=\"text\" id=\"T73_148\" name=\"Bones\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T73_150\">Muscles:</label>\n<input type=\"text\" id=\"T73_150\" name=\"Muscles\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T73_152\">Vessels:</label>\n<input type=\"text\" id=\"T73_152\" name=\"Vessels\" value=\"Normal.\"/>\n</p>\n</sec
    "templateData": "<!DOCTYPE html>\n<html>\n    <head>\n        <title>Chest CT ILD</title>\n        <meta charset=\"UTF-8\" />\n        <meta name=\"dcterms.identifier\" content=\"f93007a9-1312-4c1d-b736-9aa5d14ed240\" />\n        <meta name=\"dcterms.title\" content=\"Chest CT ILD\" />\n        <meta name=\"dcterms.description\" content=\"\" />\n        <meta name=\"dcterms.type\" content=\"IMAGE_REPORT_TEMPLATE\" />\n        <meta name=\"dcterms.language\" content=\"en\" />\n        <meta name=\"dcterms.publisher\" content=\"University of Utah\" />\n        <meta name=\"dcterms.rights\" content=\"May be used freely, subject to license agreement\" />\n        <meta name=\"dcterms.license\" content=\"http://www.radreport.org/license.pdf\" />\n        <meta name=\"dcterms.date\" content=\"2018-05-20\" />\n        <meta name=\"dcterms.creator\" content=\"Thomas Winter\" />\n        <script type=\"text/xml\">\n            <template_attributes>\n                <coded_content>\n                    <coding_schemes>\n                        <coding_scheme name=\"RADLEX\" designator=\"2.16.840.1.113883.6.256\"></coding_scheme>\n                        <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\"></coding_scheme>\n                    </coding_schemes>\n                    <entry origtxt=\"findings\">\n                        <term>\n                            <code meaning=\"Procedure Findings\" value=\"59776-5\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"impressionText\">\n                        <term>\n                            <code meaning=\"normal\" value=\"RID13173\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"clinicalInformationText\">\n                        <term>\n                            <code meaning=\"indication\" value=\"RID49442\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"findingsText\">\n                        <term>\n                            <code meaning=\"parenchyma\" value=\"RID5978\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1526851355249\">\n                        <term>\n                            <code meaning=\"upper abdomen\" value=\"RID29990\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1526851355247\">\n                        <term>\n                            <code meaning=\"chest wall\" value=\"RID2468\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"procedureInformation\">\n                        <term>\n                            <code meaning=\"Current Imaging Procedure Description\" value=\"55111-9\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1526851355246\">\n                        <term>\n                            <code meaning=\"mediastinum\" value=\"RID1384\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1526851355245\">\n                        <term>\n                            <code meaning=\"heart\" value=\"RID1385\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"comparisons\">\n                        <term>\n                            <code meaning=\"Radiology Comparison Study\" value=\"18834-2\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"impression\">\n                        <term>\n                            <code meaning=\"Impressions\" value=\"19005-8\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"clinicalInformation\">\n                        <term>\n                            <code meaning=\"Clinical Information\" value=\"55752-0\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                </coded_content>\n            </template_attributes>\n        </script>\n    </head>\n    <body>\n        <section id=\"procedureInformation\" class=\"level1\" data-section-name=\"Procedure Information\">\n            <header class=\"level1\">\n                Procedure Information\n            </header>\n            <p title=\"\">\n                <label for=\"procedureInformationText\">Technique:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"procedureInformationText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Volumetric Inspiratory (Axial 5mm and 1mm; Coronal and Sagittal 2mm); and Non-Volumetric Expiratory (Axial 1mm) series were acquired.</textarea>\n            </p>\n        </section>\n        <section id=\"clinicalInformation\" class=\"level1\" data-section-name=\"Clinical Information\">\n            <header class=\"level1\">\n                Clinical Information\n            </header>\n            <p title=\"\">\n                <label for=\"clinicalInformationText\">Indication:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"clinicalInformationText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Evaluation for interstitial lung and small airways disease.</textarea>\n            </p>\n        </section>\n        <section id=\"comparisons\" class=\"level1\" data-section-name=\"Comparison\">\n            <header class=\"level1\">\n                Comparison\n            </header>\n            <p title=\"\">\n                <label for=\"comparisonsText\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"comparisonsText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">None.</textarea>\n            </p>\n        </section>\n        <section id=\"findings\" class=\"level1\" data-section-name=\"Findings\">\n            <header class=\"level1\">\n                Findings\n            </header>\n            <p title=\"\">\n                <label for=\"findingsText\">Pulmonary parenchyma, airways, vessels, and pleural spaces:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"findingsText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">No findings of diffuse infiltrative parenchymal, obstructive airways, or cystic lung disease are present. The vessels are normal in caliber. No pleural space disease is present.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1526851355245\">Heart and Pericardium:</label>\n                <input type=\"text\" id=\"TEXT_1526851355245\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\" value=\"The cardiac chambers are normal in size. No pericardial abnormality is present.\" />\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1526851355246\">Mediastinum and Hila:</label>\n                <input type=\"text\" id=\"TEXT_1526851355246\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\" value=\"No mediastinal mass is present. No enlarged lymph nodes are present.\" />\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1526851355247\">Osseous Structures and Chest Wall:</label>\n                <input type=\"text\" id=\"TEXT_1526851355247\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\" value=\"No pathologic osseous or soft-tissue process is present.\" />\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1526851355248\">Lower Neck:</label>\n                <input type=\"text\" id=\"TEXT_1526851355248\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\" value=\"No actionable nodule is present in the imaged portions of the thyroid lobes.\" />\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1526851355249\">Upper Abdomen:</label>\n                <input type=\"text\" id=\"TEXT_1526851355249\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\" value=\"No pathologic process is present in the imaged portion of the upper abdomen.\" />\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1526851355250\">Additional Findings:</label>\n                <input type=\"text\" id=\"TEXT_1526851355250\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\" value=\"None.\" />\n            </p>\n        </section>\n        <section id=\"impression\" class=\"level1\" data-section-name=\"Impression\">\n            <header class=\"level1\">\n                Impression\n            </header>\n            <p title=\"\">\n                <label for=\"impressionText\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"impressionText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n            </p>\n        </section>\n    </body>\n</html>\n",

    "templateData": "<!DOCTYPE html>\n<html>\n    <head>\n        <title>Chest CT PE</title>\n        <meta charset=\"UTF-8\" />\n        <meta name=\"dcterms.identifier\" content=\"f75e33c5-d271-473e-93e4-1823543ac713\" />\n        <meta name=\"dcterms.title\" content=\"Chest CT PE\" />\n        <meta name=\"dcterms.description\" content=\"\" />\n        <meta name=\"dcterms.type\" content=\"IMAGE_REPORT_TEMPLATE\" />\n        <meta name=\"dcterms.language\" content=\"en\" />\n        <meta name=\"dcterms.publisher\" content=\"University of Utah Department of Radiology and Imaging Sciences\" />\n        <meta name=\"dcterms.rights\" content=\"May be used freely, subject to license agreement\" />\n        <meta name=\"dcterms.license\" content=\"http://www.radreport.org/license.pdf\" />\n        <meta name=\"dcterms.date\" content=\"2018-11-01\" />\n        <meta name=\"dcterms.creator\" content=\"Howard Mann\" />\n        <meta name=\"dcterms.contributor\" content=\"Leif Jensen\" />\n        <meta name=\"dcterms.contributor\" content=\"Phil Caliguiri\" />\n        <meta name=\"dcterms.contributor\" content=\"Marta Heilbrun\" />\n        <script type=\"text/xml\">\n            <template_attributes>\n                <coded_content>\n                    <coding_schemes>\n                        <coding_scheme name=\"RADLEX\" designator=\"2.16.840.1.113883.6.256\"></coding_scheme>\n                        <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\"></coding_scheme>\n                    </coding_schemes>\n                    <entry origtxt=\"SELECTION_LIST_1459372832911\">\n                        <term>\n                            <code meaning=\"upper abdomen\" value=\"RID29990\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459372832909\">\n                        <term>\n                            <code meaning=\"neck\" value=\"RID7488\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"findings\">\n                        <term>\n                            <code meaning=\"Procedure Findings\" value=\"59776-5\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459372832897\">\n                        <term>\n                            <code meaning=\"indication\" value=\"RID49442\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"procedureInformation\">\n                        <term>\n                            <code meaning=\"Current Imaging Procedure Description\" value=\"55111-9\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459372832906\">\n                        <term>\n                            <code meaning=\"heart\" value=\"RID1385\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"comparisons\">\n                        <term>\n                            <code meaning=\"Radiology Comparison Study\" value=\"18834-2\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459372832905\">\n                        <term>\n                            <code meaning=\"pleural space\" value=\"RID1363\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"impression\">\n                        <term>\n                            <code meaning=\"Impressions\" value=\"19005-8\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459372832908\">\n                        <term>\n                            <code meaning=\"osseous\" value=\"RID6336\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"clinicalInformation\">\n                        <term>\n                            <code meaning=\"Clinical Information\" value=\"55752-0\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459372832907\">\n                        <term>\n                            <code meaning=\"mediastinum\" value=\"RID1384\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459372832904\">\n                        <term>\n                            <code meaning=\"lungs\" value=\"RID13437\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459372832903\">\n                        <term>\n                            <code meaning=\"set of pulmonary arteries\" value=\"RID28586\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                </coded_content>\n            </template_attributes>\n        </script>\n    </head>\n    <body>\n        <section id=\"procedureInformation\" class=\"level1\" data-section-name=\"Procedure Information\">\n            <header class=\"level1\">\n                Procedure Information\n            </header>\n            <p title=\"\">\n                <label for=\"procedureInformationText\">Technique:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"procedureInformationText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Contrast enhanced multidetector-row chest computed tomography. PULMONARY ANGIOGRAPHY PROTOCOL: 80-100 ml of Isovue-370 were administered intravenously using a bolus-tracking technique centered on the main pulmonary artery. Axial (5mm; 2mm; 1mm); coronal and sagittal (2mm) series were acquired.</textarea>\n            </p>\n        </section>\n        <section id=\"clinicalInformation\" class=\"level1\" data-section-name=\"Clinical Information\">\n            <header class=\"level1\">\n                Clinical Information\n            </header>\n            <p title=\"\">\n                <label for=\"TEXT_1459372832897\">Indication:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459372832897\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Evaluation for pulmonary embolism.</textarea>\n            </p>\n        </section>\n        <section id=\"comparisons\" class=\"level1\" data-section-name=\"Comparison\">\n            <header class=\"level1\">\n                Comparison\n            </header>\n            <p title=\"\">\n                <label for=\"comparisonsText\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"comparisonsText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">None.</textarea>\n            </p>\n        </section>\n        <section id=\"findings\" class=\"level1\" data-section-name=\"Findings\">\n            <header class=\"level1\">\n                Findings\n            </header>\n            <section id=\"SECTION_HEADER_1459372832898\" class=\"level2\" data-section-name=\"Study Quality\">\n                <header class=\"level2\">\n                    Study Quality\n                </header>\n                <p title=\"\">\n                    <label for=\"SELECTION_LIST_1459372832899\">This examination for the diagnosis of pulmonary embolism is:</label>\n                    <select id=\"SELECTION_LIST_1459372832899\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Adequate.\">\n                        <option id=\"SELECTION_LIST_1459372832899_0\" value=\"Adequate.\" name=\"SELECTION_LIST_1459372832899\" selected=\"\">Adequate.</option>\n                        <option id=\"SELECTION_LIST_1459372832899_1\" value=\"Suboptimal.\" name=\"SELECTION_LIST_1459372832899\">Suboptimal.</option>\n                        <option id=\"SELECTION_LIST_1459372832899_2\" value=\"Inadequate.\" name=\"SELECTION_LIST_1459372832899\">Inadequate.</option>\n                    </select>\n                </p>\n            </section>\n            <p title=\"\">\n                <label for=\"TEXT_1459372832903\">Pulmonary Arteries:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459372832903\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1459372832904\">Pulmonary Parenchyma and Airways:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459372832904\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">No pulmonary parenchymal or airway process is present.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1459372832905\">Pleural Spaces:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459372832905\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">No pneumothorax or pleural fluid is present.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1459372832906\">Heart and Pericardium:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459372832906\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">The cardiac chambers are normal in size. No pericardial abnormality is present.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1459372832907\">Mediastinum and Hila:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459372832907\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">No mediastinal mass is present. No enlarged lymph nodes are present.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1459372832908\">Osseous Structures and Chest Wall:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459372832908\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">No pathologic osseous or soft-tissue process is present.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1459372832909\">Lower Neck:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459372832909\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">No actionable nodule is present in the imaged portions of the thyroid lobes.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1459372832911\">Upper Abdomen:</label>\n                <select id=\"SELECTION_LIST_1459372832911\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"No pathological process is present in the imaged portion of the upper abdomen.\">\n                    <option id=\"SELECTION_LIST_1459372832911_0\" value=\"No pathological process is present in the imaged portion of the upper abdomen.\" name=\"SELECTION_LIST_1459372832911\" selected=\"\">No pathological process is present in the imaged portion of the upper abdomen.</option>\n                    <option id=\"SELECTION_LIST_1459372832911_1\" value=\"Imaged findings in the abdomen and pelvis are reported separately\" name=\"SELECTION_LIST_1459372832911\">Imaged findings in the abdomen and pelvis are reported separately</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476459995156\">Additional Findings:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476459995156\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">None.</textarea>\n            </p>\n        </section>\n        <section id=\"impression\" class=\"level1\" data-section-name=\"Impression\">\n            <header class=\"level1\">\n                Impression\n            </header>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1459372832914\"></label>\n                <select id=\"SELECTION_LIST_1459372832914\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"No acute pulmonary embolism is present.\">\n                    <option id=\"SELECTION_LIST_1459372832914_0\" value=\"Acute pulmonary embolism is present. Emboli are present in segmental and more proximal arteries. \" name=\"SELECTION_LIST_1459372832914\">Acute pulmonary embolism is present. Emboli are present in segmental and more proximal arteries. </option>\n                    <option id=\"SELECTION_LIST_1459372832914_1\" value=\"No acute pulmonary embolism is present.\" name=\"SELECTION_LIST_1459372832914\" selected=\"\">No acute pulmonary embolism is present.</option>\n                    <option id=\"SELECTION_LIST_1459372832914_2\" value=\"Acute pulmonary embolism is present. Emboli are confined to subsegmental arteries. \" name=\"SELECTION_LIST_1459372832914\">Acute pulmonary embolism is present. Emboli are confined to subsegmental arteries. </option>\n                </select>\n            </p>\n        </section>\n    </body>\n</html>\n",

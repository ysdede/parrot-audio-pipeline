 </entry>\n                </coded_content>\n            </template_attributes>\n        </script>\n    </head>\n    <body>\n        <section id=\"procedureInformation\" class=\"level1\" data-section-name=\"Procedure Information\">\n            <header class=\"level1\">\n                Procedure Information\n            </header>\n            <p title=\"\">\n                <label for=\"RADIO_1519929720013\">Modality</label>\n                <span id=\"RADIO_1519929720013\" name=\"\" data-field-type=\"RADIO\" data-field-completion-action=\"NONE\" value=\"\">\n                    <br />\n                    <input id=\"RADIO_1519929720013_0\" type=\"radio\" name=\"RADIO_1519929720013\" value=\"CT\" checked=\"\">CT</input>\n                    <br />\n                    <input id=\"RADIO_1519929720013_1\" type=\"radio\" name=\"RADIO_1519929720013\" value=\"MRI\">MRI</input>\n                </span>\n            </p>\n        </section>\n        <section id=\"clinicalInformation\" class=\"level1\" data-section-name=\"Clinical Information\">\n            <header class=\"level1\">\n                Clinical Information\n            </header>\n            <p title=\"\">\n                <label for=\"clinicalInformationText\">Text:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"clinicalInformationText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n        </section>\n        <section id=\"comparisons\" class=\"level1\" data-section-name=\"Comparison\">\n            <header class=\"level1\">\n                Comparison\n            </header>\n            <p title=\"\">\n                <label for=\"comparisonsText\">Prior Study(s):</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"comparisonsText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n        </section>\n        <section id=\"findings\" class=\"level1\" data-section-name=\"Findings\">\n            <header class=\"level1\">\n                Findings\n            </header>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1519871265381\">Tumor in vein</label>\n                <select id=\"SELECTION_LIST_1519871265381\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"1 : Present\">\n                    <option id=\"SELECTION_LIST_1519871265381_0\" value=\"1 : Present\" name=\"SELECTION_LIST_1519871265381\" selected=\"\">1 : Present</option>\n                    <option id=\"SELECTION_LIST_1519871265381_1\" value=\"0 : Absent\" name=\"SELECTION_LIST_1519871265381\">0 : Absent</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1519871265389\">Diameter</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"mm\" id=\"NUMBER_1519871265389\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    mm\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1519871265390\">Capsule appearance</label>\n                <select id=\"SELECTION_LIST_1519871265390\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Present : Capsule appearance\">\n                    <option id=\"SELECTION_LIST_1519871265390_0\" value=\"Present : Capsule appearance\" name=\"SELECTION_LIST_1519871265390\" selected=\"\">Present : Capsule appearance</option>\n                    <option id=\"SELECTION_LIST_1519871265390_1\" value=\"Absent : No capsule appearance\" name=\"SELECTION_LIST_1519871265390\">Absent : No capsule appearance</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1519871265393\">Threshold growth</label>\n                <select id=
    "templateData": "<!DOCTYPE html>\n<html>\n    <head>\n        <title>Internal Auditory Canal Postoperative</title>\n        <meta charset=\"UTF-8\" />\n        <meta name=\"dcterms.identifier\" content=\"bbf1ef41-de00-496d-8ef6-88776e837204\" />\n        <meta name=\"dcterms.title\" content=\"Internal Auditory Canal Postoperative\" />\n        <meta name=\"dcterms.description\" content=\"\" />\n        <meta name=\"dcterms.type\" content=\"IMAGE_REPORT_TEMPLATE\" />\n        <meta name=\"dcterms.language\" content=\"en\" />\n        <meta name=\"dcterms.publisher\" content=\"\" />\n        <meta name=\"dcterms.rights\" content=\"May be used freely, subject to license agreement\" />\n        <meta name=\"dcterms.license\" content=\"http://www.radreport.org/license.pdf\" />\n        <meta name=\"dcterms.date\" content=\"2021-03-01\" />\n        <meta name=\"dcterms.creator\" content=\"Hugo Tames\" />\n        <script type=\"text/xml\">\n            <template_attributes>\n                <coded_content>\n                    <coding_schemes>\n                        <coding_scheme name=\"RADLEX\" designator=\"2.16.840.1.113883.6.256\"></coding_scheme>\n                        <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\"></coding_scheme>\n                    </coding_schemes>\n                    <entry origtxt=\"findings\">\n                        <term>\n                            <code meaning=\"Procedure Findings\" value=\"59776-5\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"procedureInformation\">\n                        <term>\n                            <code meaning=\"Current Imaging Procedure Description\" value=\"55111-9\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"comparisonsText\">\n                        <term>\n                            <code meaning=\"comparison report\" value=\"http://radlex.org/RID/RID13168\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"comparisons\">\n                        <term>\n                            <code meaning=\"Radiology Comparison Study\" value=\"18834-2\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"impression\">\n                        <term>\n                            <code meaning=\"Impressions\" value=\"19005-8\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"clinicalInformation\">\n                        <term>\n                            <code meaning=\"Clinical Information\" value=\"55752-0\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                </coded_content>\n            </template_attributes>\n        </script>\n    </head>\n    <body>\n        <section id=\"procedureInformation\" class=\"level1\" data-section-name=\"Procedure Information\">\n            <header class=\"level1\">\n                Procedure Information\n            </header>\n            <p title=\"\">\n                <label for=\"procedureInformationText\">Technique</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"procedureInformationText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">MR images of the temporal bones were acquired without and with paramagnetic intravenous contrast.</textarea>\n            </p>\n        </section>\n        <section id=\"clinicalInformation\" class=\"level1\" data-section-name=\"Clinical Information\">\n            <header class=\"level1\">\n                Clinical Information\n            </header>\n            <p title=\"Describe the reason for the study. \">\n                <label for=\"clinicalInformationText\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"clinicalInformationText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Follow-up of resection of internal auditory canal schwannoma.</textarea>\n            </p>\n        </section>\n        <section id=\"comparisons\" class=\"level1\" data-section-name=\"Comparison\">\n            <header class=\"level1\">\n                Comparison\n            </header>\n            <p title=\"\">\n                <label for=\"comparisonsText\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"comparisonsText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">None available.</textarea>\n            </p>\n        </section>\n        <section id=\"findings\" class=\"level1\" data-section-name=\"Findings\">\n            <header class=\"level1\">\n                Findings\n            </header>\n            <p title=\"\">\n                <label for=\"RADIO_1612290336167\">Surgical approach</label>\n                <span id=\"RADIO_1612290336167\" name=\"\" data-field-type=\"RADIO\" data-field-completion-action=\"NONE\" value=\"\">\n                    <br />\n                    <input id=\"RADIO_1612290336167_0\" type=\"radio\" name=\"RADIO_1612290336167\" value=\"retrosigmoid\">retrosigmoid</input>\n                    <br />\n                    <input id=\"RADIO_1612290336167_1\" type=\"radio\" name=\"RADIO_1612290336167\" value=\"translabyrinthine\">translabyrinthine</input>\n                    <br />\n                    <input id=\"RADIO_1612290336167_2\" type=\"radio\" name=\"RADIO_1612290336167\" value=\"middle cranial fossa\">middle cranial fossa</input>\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"RADIO_1612454209160\">Surgical approach laterality</label>\n                <span id=\"RADIO_1612454209160\" name=\"\" data-field-type=\"RADIO\" data-field-completion-action=\"NONE\" value=\"\">\n                    <br />\n                    <input id=\"RADIO_1612454209160_0\" type=\"radio\" name=\"RADIO_1612454209160\" value=\"left\" checked=\"\">left</input>\n                    <br />\n                    <input id=\"RADIO_1612454209160_1\" type=\"radio\" name=\"RADIO_1612454209160\" value=\"right\">right</input>\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"RADIO_1612290336172\">Graft utilized</label>\n                <span id=\"RADIO_1612290336172\" name=\"\" data-field-type=\"RADIO\" data-field-completion-action=\"NONE\" value=\"\">\n                    <br />\n                    <input id=\"RADIO_1612290336172_0\" type=\"radio\" name=\"RADIO_1612290336172\" value=\"yes\" checked=\"\">yes</input>\n                    <br />\n                    <input id=\"RADIO_1612290336172_1\" type=\"radio\" name=\"RADIO_1612290336172\" value=\"no\">no</input>\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"CHECKBOX_1612290336175\">Internal auditory canal (IAC) and Cerebellopontine angle (CAP)</label>\n                <span id=\"CHECKBOX_1612290336175\" name=\"\" data-field-type=\"CHECKBOX\" data-field-completion-action=\"NONE\" value=\"\">\n                    <br />\n                    <input id=\"CHECKBOX_1612290336175_0\" type=\"checkbox\" name=\"CHECKBOX_1612290336175\" value=\"no areas of abnormal enhancement\" checked=\"\">no areas of abnormal enhancement</input>\n                    <br />\n                    <input id=\"CHECKBOX_1612290336175_1\" type=\"checkbox\" name=\"CHECKBOX_1612290336175\" value=\"linear enhancement around walls related to inflammatory changes\">linear enhancement around walls related to inflammatory changes</input>\n                    <br />\n                    <input id=\"CHECKBOX_1612290336175_2\" type=\"checkbox\" name=\"CHECKBOX_1612290336175\" value=\"nodular enhancement\">nodular enhancement</input>\n                    <br />\n                    <input id=\"CHECKBOX_1612290336175_3\" type=\"checkbox\" name=\"CHECKBOX_1612290336175\" value=\"7th and 8th nerves are normal\">7th and 8th nerves are normal</input>\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"RADIO_1614272633025\">Nodular location</label>\n                <span id=\"RADIO_1614272633025\" name=\"\" data-field-type=\"RADIO\" data-field-completion-action=\"NONE\" value=\"\">\n                    <br />\n                    <input id=\"RADIO_1614272633025_0\" type=\"radio\" name=\"RADIO_1614272633025\" value=\"internal auditory canal\" checked=\"\">internal auditory canal</input>\n                    <br />\n                    <input id=\"RADIO_1614272633025_1\" type=\"radio\" name=\"RADIO_1614272633025\" value=\"cerebellopontine angle (CPA)\">cerebellopontine angle (CPA)</input>\n                    <br />\n                    <input id=\"RADIO_1614272633025_2\" type=\"radio\" name=\"RADIO_1614272633025\" value=\"internal auditory canal and cerebellopontine angle (CPA)\">internal auditory canal and cerebellopontine angle (CPA)</input>\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1612290336198\">Additional nodular information</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1612290336198\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1614272633015\">Nodule length</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"mm\" id=\"NUMBER_1614272633015\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    mm\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1614272633016\">Nodule width</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"mm\" id=\"NUMBER_1614272633016\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    mm\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1614272633017\">Nodule height</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"mm\" id=\"NUMBER_1614272633017\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    mm\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"CHECKBOX_1612290336201\">Signs of complications</label>\n                <span id=\"CHECKBOX_1612290336201\" name=\"\" data-field-type=\"CHECKBOX\" data-field-completion-action=\"NONE\" value=\"\">\n                    <br />\n                    <input id=\"CHECKBOX_1612290336201_0\" type=\"checkbox\" name=\"CHECKBOX_1612290336201\" value=\"intracranial hemorrhage\" checked=\"\">intracranial hemorrhage</input>\n                    <br />\n                    <input id=\"CHECKBOX_1612290336201_1\" type=\"checkbox\" name=\"CHECKBOX_1612290336201\" value=\"acute infarct\">acute infarct</input>\n                    <br />\n                    <input id=\"CHECKBOX_1612290336201_2\" type=\"checkbox\" name=\"CHECKBOX_1612290336201\" value=\"cerebrospinal fluid leak\">cerebrospinal fluid leak</input>\n                    <br />\n                    <input id=\"CHECKBOX_1612290336201_3\" type=\"checkbox\" name=\"CHECKBOX_1612290336201\" value=\"labyrinthine fistula\">labyrinthine fistula</input>\n                    <br />\n                    <input id=\"CHECKBOX_1612290336201_4\" type=\"checkbox\" name=\"CHECKBOX_1612290336201\" value=\"meningitis\">meningitis</input>\n                    <br />\n                    <input id=\"CHECKBOX_1612290336201_5\" type=\"checkbox\" name=\"CHECKBOX_1612290336201\" value=\"thrombosis of venous dural sinuses\">thrombosis of venous dural sinuses</input>\n                    <br />\n                    <input id=\"CHECKBOX_1612290336201_6\" type=\"checkbox\" name=\"CHECKBOX_1612290336201\" value=\"thrombosis of internal jugular vein\">thrombosis of internal jugular vein</input>\n                    <br />\n                    <input id=\"CHECKBOX_1612290336201_7\" type=\"checkbox\" name=\"CHECKBOX_1612290336201\" value=\"encephalocele\">encephalocele</input>\n                    <br />\n                    <input id=\"CHECKBOX_1612290336201_8\" type=\"checkbox\" name=\"CHECKBOX_1612290336201\" value=\"absent\">absent</input>\n                </span>\n            </p>\n            <p title=\"Succinctly describe other findings.\">\n                <label for=\"TEXT_1612290336209\">Brain parenchyma findings</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1612290336209\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"CHECKBOX_1612290336210\">Lobe atrophy</label>\n                <span id=\"CHECKBOX_1612290336210\" name=\"\" data-field-type=\"CHECKBOX\" data-field-completion-action=\"NONE\" value=\"\">\n                    <br />\n                    <input id=\"CHECKBOX_1612290336210_0\" type=\"checkbox\" name=\"CHECKBOX_1612290336210\" value=\"none\" checked=\"\">none</input>\n                    <br />\n                    <input id=\"CHECKBOX_1612290336210_1\" type=\"checkbox\" name=\"CHECKBOX_1612290336210\" value=\"cerebellar\">cerebellar</input>\n                    <br />\n                    <input id=\"CHECKBOX_1612290336210_2\" type=\"checkbox\" name=\"CHECKBOX_1612290336210\" value=\"temporal\">temporal</input>\n                </span>\n            </p>\n            <p title=\"Describe hydrocephalus.\">\n                <label for=\"TEXT_1612290336214\">Ventricles</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1612290336214\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">No hydrocephalus or extra-axial fluid collections.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"CHECKBOX_1612290336215\">Cochlea</label>\n                <span id=\"CHECKBOX_1612290336215\" name=\"\" data-field-type=\"CHECKBOX\" data-field-completion-action=\"NONE\" value=\"\">\n                    <br />\n                    <input id=\"CHECKBOX_1612290336215_0\" type=\"checkbox\" name=\"CHECKBOX_1612290336215\" value=\"normal signal intensity\" checked=\"\">normal signal intensity</input>\n                    <br />\n                    <input id=\"CHECKBOX_1612290336215_1\" type=\"checkbox\" name=\"CHECKBOX_1612290336215\" value=\"normal morphology\">normal morphology</input>\n                    <br />\n                    <input id=\"CHECKBOX_1612290336215_2\" type=\"checkbox\" name=\"CHECKBOX_1612290336215\" value=\"enhancement of labyrinthine structures\">enhancement of labyrinthine structures</input>\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"CHECKBOX_1612454209113\">Vestibule and semicircular canals</label>\n                <span id=\"CHECKBOX_1612454209113\" name=\"\" data-field-type=\"CHECKBOX\" data-field-completion-action=\"NONE\" value=\"\">\n                    <br />\n                    <input id=\"CHECKBOX_1612454209113_0\" type=\"checkbox\" name=\"CHECKBOX_1612454209113\" value=\"normal signal intensity \" checked=\"\">normal signal intensity </input>\n                    <br />\n                    <input id=\"CHECKBOX_1612454209113_1\" type=\"checkbox\" name=\"CHECKBOX_1612454209113\" value=\"normal morphology\">normal morphology</input>\n                    <br />\n                    <input id=\"CHECKBOX_1612454209113_2\" type=\"checkbox\" name=\"CHECKBOX_1612454209113\" value=\"resection of vestibule and semicircular canals\">resection of vestibule and semicircular canals</input>\n                    <br />\n                    <input id=\"CHECKBOX_1612454209113_3\" type=\"checkbox\" name=\"CHECKBOX_1612454209113\" value=\"enhancement of labyrinthine structures\">enhancement of labyrinthine structures</input>\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1612290336219\">Other findings</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1612290336219\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n        </section>\n        <section id=\"impression\" class=\"level1\" data-section-name=\"Impression\">\n            <header class=\"level1\">\n                Impression\n            </header>\n            <p title=\"Summarize the postoperative changes and complications.\">\n                <label for=\"impressionText\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"impressionText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">No signs of persistent or recurrent lesion.</textarea>\n            </p>\n            <p title=\"Describe localization that requires close follow-up/suggestive of residual/recurrent lesion.\">\n                <label for=\"TEXT_1612290336220\">Nodular enhancement</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1612290336220\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n        </section>\n    </body>\n</html>\n",

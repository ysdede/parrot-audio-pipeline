<term>\n                            <code meaning=\"proximal superior mesenteric lymph node group\" value=\"RID31970\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"procedureInformation\">\n                        <term>\n                            <code meaning=\"Current Imaging Procedure Description\" value=\"55111-9\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"comparisons\">\n                        <term>\n                            <code meaning=\"Radiology Comparison Study\" value=\"18834-2\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"impression\">\n                        <term>\n                            <code meaning=\"Impressions\" value=\"19005-8\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459557754075\">\n                        <term>\n                            <code meaning=\"inferior mesenteric artery\" value=\"RID939\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459557754076\">\n                        <term>\n                            <code meaning=\"ureteric segment of right renal artery\" value=\"RID38168\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459557754073\">\n                        <term>\n                            <code meaning=\"celiac artery\" value=\"RID906\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459557754074\">\n                        <term>\n                            <code meaning=\"superior mesenteric artery\" value=\"RID927\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459557754077\">\n                        <term>\n                            <code meaning=\"left renal artery\" value=\"RID37860\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459557754110\">\n                        <term>\n                            <code meaning=\"spleen\" value=\"RID86\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SECTION_HEADER_1459559313825\">\n                        <term>\n                            <code meaning=\"normal\" value=\"RID13173\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459557754082\">\n                        <term>\n                            <code meaning=\"common iliac artery\" value=\"RID944\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459557754083\">\n                        <term>\n                            <code meaning=\"internal iliac artery\" value=\"RID945\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459557754086\">\n                        <term>\n                            <code meaning=\"common iliac artery\" value=\"RID944\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459557754087\">\n                        <term>\n                            <code meaning=\"internal iliac artery\" value=\"RID945\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459557754084\">\n                        <term>\n                            <code meaning=\"external iliac artery\" value=\"RID957\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459557754088\">\n                        <term>\n                            <code meaning=\"external iliac artery\" value=\"RID957\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SECTION_HEADER_1459557754071\">\n                        <term>\n                            <code meaning=\"abdominal aorta\" value=\"RID905\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"clinicalInformation\">\n                        <term>\n                            <code meaning=\"Clinical Information\" value=\"55752-0\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                </coded_content>\n            </template_attributes>\n        </script>\n    </head>\n    <body>\n        <section id=\"procedureInformation\" class=\"level1\" data-section-name=\"Procedure Information\">\n            <header class=\"level1\">\n                Procedure Information\n            </header>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1459559313837\">Technique:</label>\n                <select id=\"SELECTION_LIST_1459559313837\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Helical scan mode images were obtained through the abdomen and pelvis following the protocol administration of nonionic intravenous contrast material and postive oral contrast material. Coronal and sagittal images were created at the CT scanner.\">\n                    <option id=\"SELECTION_LIST_1459559313837_0\" value=\"Helical scan mode images were obtained through the abdomen and pelvis following the protocol administration of nonionic intravenous contrast material and postive oral contrast material. Coronal and sagittal images were created at the CT scanner.\" name=\"SELECTION_LIST_1459559313837\" selected=\"\">Helical scan mode images were obtained through the abdomen and pelvis following the protocol administration of nonionic intravenous contrast material and postive oral contrast material. Coronal and sagittal images were created at the CT scanner.</option>\n                    <option id=\"SELECTION_LIST_1459559313837_1\" value=\"CT of the abdomen and pelvis was performed at an outside institution. Study is performed on initial. Over read is provided on followup.\" name=\"SELECTION_LIST_1459559313837\">CT of the abdomen and pelvis was performed at an outside institution. Study is performed on initial. Over read is provided on followup.</option>\n                    <option id=\"SELECTION_LIST_1459559313837_2\" value=\"Thin slice helical scan mode CTA of the abdomen and pelvis with bilateral lower extremity runoff was performed according to protocol. Multiplanar and 3-D reformatted images were created.\" name=\"SELECTION_LIST_1459559313837\">Thin slice helical scan mode CTA of the abdomen and pelvis with bilateral lower extremity runoff was performed according to protocol. Multiplanar and 3-D reformatted images were created.</option>\n                    <option id=\"SELECTION_LIST_1459559313837_3\" value=\"Thin slice helical scan mode CTA of the abdomen and pelvis was performed according to protocol. Multiplanar and 3-D reformatted images were created.\" name=\"SELECTION_LIST_1459559313837\">Thin slice helical scan mode CTA of the abdomen and pelvis was performed according to protocol. Multiplanar and 3-D reformatted images were created.</option>\n                </select>\n            </p>\n        </section>\n        <section id=\"clinicalInformation\" class=\"level1\" data-section-name=\"Clinical Information\">\n            <header class=\"level1\">\n                Clinical Information\n            </header>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1459559313828\">Indication:</label>\n                <select id=\"SELECTION_LIST_1459559313828\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Free flap.\">\n                    <option id=\"SELECTION_LIST_1459559313828_0\" value=\"Free flap.\" name=\"SELECTION_LIST_1459559313828\" selected=\"\">Free flap.</option>\n                    <option id=\"SELECTION_LIST_1459559313828_1\" value=\"Peripheral vascular disease.\" name=\"SELECTION_LIST_1459559313828\">Peripheral vascular disease.</option>\n                </select>\n            </p>\n        </section>\n        <section id=\"comparisons\" class=\"level1\" data-section-name=\"Comparison\">\n            <header class=\"level1\">\n                Comparison\n            </header>\n            <p title=\"\">\n                <label for=\"comparisonsText\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"comparisonsText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">None.</textarea>\n            </p>\n        </section>\n        <section id=\"findings\" class=\"level1\" data-section-name=\"Findings\">\n            <header class=\"level1\">\n                Findings\n            </header>\n            <section id=\"SECTION_HEADER_1459557754069\" class=\"level2\" data-section-name=\"Vascular:\">\n                <header class=\"level2\">\n                    Vascular:\n                </header>\n            </section>\n            <section id=\"SECTION_HEADER_1459557754070\" class=\"level2\" data-section-name=\"Abdominal Station:\">\n                <header class=\"level2\">\n                    Abdominal Station:\n                </header>\n                <section id=\"SECTION_HEADER_1459557754071\" class=\"level2\" data-section-name=\"Abdominal Aorta:\">\n                    <header class=\"level2\">\n                        Abdominal Aorta:\n                    </header>\n                    <p title=\"\">\n                        <label for=\"NUMBER_1459557754072\">Maximum diameter of the aorta:</label>\n                        <span>\n                            <input type=\"number\" step=\"1.0\" data-field-units=\"cm\" id=\"NUMBER_1459557754072\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                            cm\n                        </span>\n                    </p>\n                </section>\n                <p title=\"\">\n                    <label for=\"TEXT_1459557754073\">Celiac:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459557754073\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">No significant stenosis.</textarea>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1459557754074\">SMA:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459557754074\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">No significant stenosis.</textarea>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1459557754075\">IMA:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459557754075\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Patent with flow.</textarea>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1459557754076\">Right Renal artery:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459557754076\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Patent without significant ostial or flow-limiting stenosis.</textarea>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1459557754077\">Left Renal artery:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459557754077\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Patent without significant ostial or flow-limiting stenosis.</textarea>\n                </p>\n            </section>\n            <section id=\"SECTION_HEADER_1459557754078\" class=\"level2\" data-section-name=\"Pelvic Station:\">\n                <header class=\"level2\">\n                    Pelvic Station:\n                </header>\n                <section id=\"SECTION_HEADER_1459557754081\" class=\"level2\" data-section-name=\"Right Iliac:\">\n                    <header class=\"level2\">\n                        Right Iliac:\n                    </header>\n                    <p title=\"\">\n                        <label for=\"TEXT_1459557754082\">Common iliac artery:</label>\n                        <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459557754082\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">The common iliac artery is patent without aneurysm.</textarea>\n                    </p>\n                    <p title=\"\">\n                        <label for=\"TEXT_1459557754083\">Internal iliac artery:</label>\n                        <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459557754083\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">There is flow within the internal iliac artery.</textarea>\n                    </p>\n                    <p title=\"\">\n                        <label for=\"TEXT_1459557754084\">External iliac artery:</label>\n                        <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459557754084\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">There is flow within the external iliac artery.</textarea>\n                    </p>\n                </section>\n                <section id=\"SECTION_HEADER_1459557754085\" class=\"level2\" data-section-name=\"Left Iliac:\">\n                    <header class=\"level2\">\n                        Left Iliac:\n                    </header>\n                    <p title=\"\">\n                        <label for=\"TEXT_1459557754086\">Common iliac artery:</label>\n                        <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459557754086\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">The common iliac artery is patent without aneurysm.</textarea>\n                    </p>\n                    <p title=\"\">\n                        <label for=\"TEXT_1459557754087\">Internal iliac artery:</label>\n                        <input type=\"text\" id=\"TEXT_1459557754087\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\" value=\"There is flow within the internal iliac artery.\" />\n                    </p>\n                    <p title=\"\">\n                        <label for=\"TEXT_1459557754088\">External iliac artery:</label>\n                        <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459557754088\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">There is flow within the external iliac artery.</textarea>\n                    </p>\n                </section>\n            </section>\n            <section id=\"SECTION_HEADER_1459557754089\" class=\"level2\" data-section-name=\"Lower Extremity:\">\n                <header class=\"level2\">\n                    Lower Extremity:\n                </header>\n                <section id=\"SECTION_HEADER_1459557754091\" class=\"level2\" data-section-name=\"Right:\">\n                    <header class=\"level2\">\n                        Right:\n                    </header>\n                    <p title=\"\">\n                        <label for=\"TEXT_1459557754092\">Common femoral artery:</label>\n                        <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459557754092\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">The common femoral artery is patent with some atherosclerotic plaque but not apparent flow-limiting stenosis.</textarea>\n                    </p>\n                    <p title=\"\">\n                        <label for=\"TEXT_1459557754093\">Profunda femoral artery:</label>\n                        <input type=\"text\" id=\"TEXT_1459557754093\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\" value=\"The profunda femoral artery is patent with some atherosclerotic plaque but not apparent flow-limiting stenosis.\" />\n                    </p>\n                    <p title=\"\">\n                        <label for=\"TEXT_1459557754094\">Superficial femoral artery:</label>\n                        <input type=\"text\" id=\"TEXT_1459557754094\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\" value=\"The superficial femoral artery is patent without flow-limiting stenosis.\" />\n                    </p>\n                    <p title=\"\">\n                        <label for=\"TEXT_1459557754095\">Popliteal artery:</label>\n                        <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459557754095\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Popliteal artery is patent without flow-limiting stenosis or aneurysm.</textarea>\n                    </p>\n                    <p title=\"\">\n                        <label for=\"TEXT_1459557754096\">Tibioperoneal trunk</label>\n                        <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459557754096\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">The tibioperoneal trunk is patent.</textarea>\n                    </p>\n                </section>\n                <section id=\"SECTION_HEADER_1459557754097\" class=\"level2\" data-section-name=\"Left:\">\n                    <header class=\"level2\">\n                        Left:\n                    </header>\n                    <p title=\"\">\n                        <label for=\"TEXT_1459557754098\">Common femoral artery:</label>\n                        <input type=\"text\" id=\"TEXT_1459557754098\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\" value=\"The common femoral artery is patent with some atherosclerotic plaque but not apparent flow-limiting stenosis.\" />\n                    </p>\n                    <p title=\"\">\n                        <label for=\"TEXT_1459557754099\">Profunda femoral artery:</label>\n                        <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459557754099\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">The profunda femoral artery is patent with some atherosclerotic plaque but not apparent flow-limiting stenosis.</textarea>\n                    </p>\n                    <p title=\"\">\n                        <label for=\"TEXT_1459557754100\">Superficial femoral artery:</label>\n                        <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459557754100\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">The superficial femoral artery is patent without flow-limiting stenosis.</textarea>\n                    </p>\n                    <p title=\"\">\n                        <label for=\"TEXT_1459557754101\">Popliteal artery:</label>\n                        <input type=\"text\" id=\"TEXT_1459557754101\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\" value=\"Popliteal artery is patent without flow-limiting stenosis or aneurysm.\" />\n                    </p>\n                    <p title=\"\">\n                        <label for=\"TEXT_1459557754102\">Tibioperoneal trunk:</label>\n                        <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459557754102\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">The tibioperoneal trunk is patent.</textarea>\n                    </p>\n                </section>\n            </section>\n            <section id=\"SECTION_HEADER_1459557754103\" class=\"level2\" data-section-name=\"Nonvascular:\">\n                <header class=\"level2\">\n                    Nonvascular:\n                </header>\n                <p title=\"\">\n                    <label for=\"TEXT_1459557754104\">Lung bases:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459557754104\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Clear, without airspace disease.</textarea>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1459557754105\">Liver:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459557754105\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">No focal mass lesions. No intrahepatic biliary ductal dilatation.</textarea>\n                </p>\n                <p title=\"\">\n                    <label for=\"SELECTION_LIST_1459557754106\">Gallbladder:</label>\n                    <select id=\"SELECTION_LIST_1459557754106\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"The CT appearance is normal.\">\n                        <option id=\"SELECTION_LIST_1459557754106_0\" value=\"The CT appearance is normal.\" name=\"SELECTION_LIST_1459557754106\" selected=\"\">The CT appearance is normal.</option>\n                        <option id=\"SELECTION_LIST_1459557754106_1\" value=\"Surgically absent.\" name=\"SELECTION_LIST_1459557754106\">Surgically absent.</option>\n                        <option id=\"SELECTION_LIST_1459557754106_2\" value=\"Cholelithiasis without cholecystitis\" name=\"SELECTION_LIST_1459557754106\">Cholelithiasis without cholecystitis</option>\n                    </select>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1459557754110\">Spleen:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459557754110\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1459559313817\">Pancreas:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459559313817\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal CT appearance.</textarea>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1459559313818\">Adrenals:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459559313818\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">No nodules.</textarea>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1459559313819\">Kidneys:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459559313819\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">No solid lesions. No calculi. No hydroureteronephrosis.</textarea>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1459559313820\">Nodes:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459559313820\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Scattered small abdominal nodes, none meeting CT criteria for pathologic enlargement.</textarea>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1459559313821\">Bowel, bladder, and pelvic organs:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459559313821\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">The visualized bowel, bladder and pelvic organs are without significant abnormality.</textarea>\n                </p>\n                <p title=\"\">\n                    <label for=\"SELECTION_LIST_1459559313822\">Musculoskeletal:</label>\n                    <select id=\"SELECTION_LIST_1459559313822\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Normal.\">\n                        <option id=\"SELECTION_LIST_1459559313822_0\" value=\"Normal.\" name=\"SELECTION_LIST_1459559313822\" selected=\"\">Normal.</option>\n                        <option id=\"SELECTION_LIST_1459559313822_1\" value=\"No osseous regions. Specifically, no traumatic or other abnormality of either fibula.\" name=\"SELECTION_LIST_1459559313822\">No osseous regions. Specifically, no traumatic or other abnormality of either fibula.</option>\n                    </select>\n                </p>\n            </section>\n            <p title=\"\">\n                <label for=\"TEXT_1476470020630\">Additional findings:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476470020630\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">None.</textarea>\n            </p>\n        </section>\n        <section id=\"impression\" class=\"level1\" data-section-name=\"Impression\">\n            <header class=\"level1\">\n                Impression\n            </header>\n            <section id=\"SECTION_HEADER_1459559313825\" class=\"level2\" data-section-name=\"\">\n                <header class=\"level2\">\n                </header>\n                <p title=\"\">\n                    <label for=\"TEXT_1459559313826\">Right leg:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459559313826\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">No significant stenosis with three-vessel runoff.</textarea>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1459559313827\">Left leg:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459559313827\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">No significant stenosis with three-vessel runoff.</textarea>\n                </p>\n            </section>\n        </section>\n    </body>\n</html>\n",

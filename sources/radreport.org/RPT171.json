    "templateData": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\"/>\n<meta content=\"Gastric Emptying\" name=\"dcterms.title\"/>\n<meta content=\"Gastric Emptying template :: Authored by Imani F\" name=\"dcterms.description\"/>\n<meta content=\"http://www.radreport.org/template/0000171\" name=\"dcterms.identifier\"/>\n<meta content=\"en\" name=\"dcterms.language\"/>\n<meta content=\"IMAGE_REPORT_TEMPLATE\" name=\"dcterms.type\"/>\n<meta content=\"Radiological Society of North America (RSNA)\" name=\"dcterms.publisher\"/>\n<meta content=\"May be used gratis, subject to license agreement\" name=\"dcterms.rights\"/>\n<meta content=\"http://www.radreport.org/license.pdf\" name=\"dcterms.license\"/>\n<meta content=\"2012-06-19\" name=\"dcterms.date\"/>\n<meta content=\"Imani F\" name=\"dcterms.creator\"/>\n<meta content=\"Kahn CE Jr [editor]\" name=\"dcterms.contributor\"/>\n<meta content=\"UCLA Health System (UCLA)\" name=\"dcterms.contributor\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"IHE_Template_Style.css\" />\n<!-- The absolute link to the CSS file is http://www.radreport.org/html/IHE_Template_Style.css -->\n<script type=\"text/xml\">\n<!--\n<template_attributes>\n<top-level-flag>true</top-level-flag>\n<status>ACTIVE</status>\n<coding_schemes>\n <coding_scheme name=\"RadLex\" designator=\"2.16.840.1.113883.6.256\" />\n <coding_scheme name=\"SNOMEDCT\" designator=\"2.16.840.1.113883.6.96\" />\n <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\" />\n</coding_schemes>\n<term>\n <code meaning=\"delayed emptying\" value=\"RID5244\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"gastric outlet obstruction\" value=\"RID4967\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"gastroparesis\" value=\"RID5255\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"stomach\" value=\"RID114\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"Tc-99m sulfur colloid\" value=\"RID11751\" scheme=\"RadLex\">\n</term>\n<coded_content>\n<entry ORIGTXT=\"T171_2\">\n <term>\n  <code meaning=\"procedure\" value=\"RID1559\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T171_5\">\n <term>\n  <code meaning=\"clinical information\" value=\"RID13166\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T171_6\">\n <term>\n  <code meaning=\"comparison\" value=\"RID28483\" scheme=\"RadLex\">\n </term>\n</entry>\n</coded_content>\n</template_attributes>\n-->\n</script>\n<title>Gastric Emptying</title>\n</head>\n<body>\n<section data-section-name=\"Procedure\">\n<header class=\"level1\">Gastric Emptying</header>\n<p>\n<textarea id=\"T171_2\" name=\"Procedure\" style=\"height:5em;\" >Following administration of food, radiolabeled with technetium-99m sulfur colloid, projection images of the abdomen were obtained at 15-minute intervals out to 60 minutes. When possible, both anterior and posterior projection images were obtained to allow the calculation of the geometric mean activity.</textarea>\n</p>\n<p>\n<label for=\"T171_4\">Tc-99m sulfur colloid</label>\n<input type=\"number\" id=\"T171_4\" name=\"dose\" value=\"1\" data-field-units=\"mCi\" />\n<label for=\"T171_4\">mCi</label>\n</p>\n</section>\n<section data-section-name=\"Clinical information\">\n<header class=\"level1\">Clinical information</header>\n<p>\n<textarea id=\"T171_5\" name=\"Clinical information\" ></textarea>\n</p>\n</section>\n<section data-section-name=\"Comparison\">\n<header class=\"level1\">Comparison</header>\n<p>\n<textarea id=\"T171_6\" name=\"Comparison\" >None.</textarea></p>\n</section>\n<section data-section-name=\"Findings\">\n<header class=\"level1\">Findings</header>\n<p>\n<label for=\"T171_9\">Clearance:</label>\n<input type=\"number\" id=\"T171_9\" name=\"Clearance\" data-field-units=\"%\" min=\"0\" max=\"100\" step=\"1\" />\n<label for=\"T171_9\">%</label>\n</p>\n<p>\n<label for=\"T171_10\">Half-life:</label>\n<input type=\"number\" id=\"T171_10\" name=\"Half-life\" data-field-units=\"min\" min=\"0\" max=\"\"/>\n<label for=\"T171_10\">min</label>\n</p>\n<p>\n<label for=\"T171_11\">Gastroesophagel reflux:</label>\n<input type=\"text\" id=\"T171_11\" name=\"Gastroesophagel reflux\" value=\"None. \"/>\n</p>\n</section>\n<section data-section-name=\"Impression\">\n<header class=\"level1\">Impression</header>\n<p>\n<label for=\"T171_14\">Gastric emptying: </label>\n<input type=\"text\" id=\"T171_14\" name=\"Gastric emptying\" value=\"Normal. \" />\n</p>\n<p>\n<label for=\"T171_19\">Gastroesophageal reflux: </label>\n<input type=\"text\" id=\"T171_19\" name=\"Gastroesophageal reflux\" value=\"None. \" />\n</p>\n</section>\n</body>\n</html>\n",

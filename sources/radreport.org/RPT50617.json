    "templateData": "<html><head><meta charset=\"UTF-8\"><meta content=\"base cta head neck\" name=\"dcterms.title\"><meta content=\"3d345b89-e626-4684-8fd5-38b09f16961d\" name=\"dcterms.identifier\"><meta content=\"en\" name=\"dcterms.language\"><meta content=\"2019-01-31\" name=\"dcterms.date\"><meta content=\"Nuance System\" name=\"dcterms.creator\"><title>base cta head neck</title></head><body><section data-section-name=\"CT ANGIOGRAM HEAD AND NECK WITH CONTRAST\"><header class=\"Level1\">CT ANGIOGRAM HEAD AND NECK WITH CONTRAST</header><p><label>HISTORY:</label><input type=\"text\" name=\"Patient Age\" value=\"Patient Age\"></p><p><label> old </label><input type=\"text\" name=\"Patient Gender\" value=\"Patient Gender\"></p><p><label>, </label><input type=\"text\" name=\"history\" value=\"stroke symptoms\"></p></section><section data-section-name=\"TECHNIQUE:\"><header class=\"Level1\">TECHNIQUE:</header><p><label>CT angiogram images of the head and neck were acquired with </label><input type=\"number\" name=\"contrast dose\"><label>mL Omnipaque 350 intravenous contrast. Multiplanar reformations were obtained.</label></p><p><label>CTDI: </label><input type=\"number\" name=\"CTDI\"><label>mGy</label></p><p><label>DLP: </label><input type=\"number\" name=\"DLP\"><label>mGy-cm</label></p><p><label>COMPARISON: </label><input type=\"text\" name=\"comparison\" value=\"None available\"></p></section><section data-section-name=\"FINDINGS:\"><header class=\"Level1\">FINDINGS:</header><p><label>CTA HEAD: </label><input type=\"text\" name=\"stenosis\" value=\"No occlusion or hemodynamically significant stenosis.\"></p><p><label> </label><input type=\"text\" name=\"aneurysm\" value=\"No aneurysm.\"></p></section><section data-section-name=\"CTA NECK\"><header class=\"Level1\">CTA NECK</header><p><label>GREAT VESSELS: </label><input type=\"text\" name=\"great vessels\" value=\"Visualized segments are patent.\"></p><p><label>RIGHT ICA: </label><select name=\"right ICA\"><option name=\"\" value=\"\">No stenosis</option><option name=\"\" value=\"\">Less than 50%</option><option name=\"\" value=\"\">50-69%</option><option name=\"\" value=\"\">70-99%</option><option name=\"\" value=\"\">Occluded</option></select></p><p><label> by NASCET criteria at the carotid bifurcation. </label><input type=\"text\" name=\"dissection?\" value=\"No dissection.\"></p><p><label>LEFT ICA: </label><select name=\"left ICA\"><option name=\"\" value=\"\">No stenosis</option><option name=\"\" value=\"\">Less than 50%</option><option name=\"\" value=\"\">50-69%</option><option name=\"\" value=\"\">70-99%</option><option name=\"\" value=\"\">Occluded</option></select></p><p><label> by NASCET criteria at the carotid bifurcation. </label><input type=\"text\" name=\"dissection?\" value=\"No dissection.\"></p><p><label>VERTEBRAL ARTERIES: </label><input type=\"text\" name=\"vertebral\" value=\"Patent extracranial segments.\"></p><p><label> </label><input type=\"text\" name=\"dissection\" value=\"No dissection.\"></p><p><label>OTHER: </label><input type=\"text\" name=\"other\" value=\"Visualized lung apices are clear. No neck mass or suspicious lymph nodes. Bones demonstrate no significant abnormality.\"></p></section><section data-section-name=\"IMPRESSION:\"><header class=\"Level1\">IMPRESSION:</header><p><textarea name=\"cta head\">Normal CT angiogram head.</textarea></p><p><textarea name=\"cta neck\">Normal CT angiogram neck.</textarea></p></section></body></html>",

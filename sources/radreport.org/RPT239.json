    "templateData": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\"/>\n<meta content=\"CT Pelvis\" name=\"dcterms.title\"/>\n<meta content=\"CT Pelvis template :: Authored by Lakhani P\" name=\"dcterms.description\"/>\n<meta content=\"http://www.radreport.org/template/0000239\" name=\"dcterms.identifier\"/>\n<meta content=\"en\" name=\"dcterms.language\"/>\n<meta content=\"IMAGE_REPORT_TEMPLATE\" name=\"dcterms.type\"/>\n<meta content=\"Radiological Society of North America (RSNA)\" name=\"dcterms.publisher\"/>\n<meta content=\"May be used gratis, subject to license agreement\" name=\"dcterms.rights\"/>\n<meta content=\"http://www.radreport.org/license.pdf\" name=\"dcterms.license\"/>\n<meta content=\"2012-08-03\" name=\"dcterms.date\"/>\n<meta content=\"Lakhani P\" name=\"dcterms.creator\"/>\n\n<meta content=\"Kahn CE Jr [editor]\" name=\"dcterms.contributor\"/>\n<meta content=\"Thomas Jefferson University (TJU)\" name=\"dcterms.contributor\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"IHE_Template_Style.css\"/>\n<!-- The absolute link to the CSS file is http://www.radreport.org/html/IHE_Template_Style.css -->\n<script type=\"text/xml\">\r\n<!--\r\n<template_attributes>\n<top-level-flag>true</top-level-flag>\n<status>ACTIVE</status>\n<coding_schemes>\n <coding_scheme name=\"RadLex\" designator=\"2.16.840.1.113883.6.256\" />\n <coding_scheme name=\"SNOMEDCT\" designator=\"2.16.840.1.113883.6.96\" />\n <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\" />\n</coding_schemes>\n<term>\n <code meaning=\"computed tomography\" value=\"RID10321\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"pelvis\" value=\"RID2507\" scheme=\"RadLex\">\n</term>\n<coded_content>\n<entry ORIGTXT=\"T239_8\">\n  <term>\n  <code meaning=\"Clinical information\" value=\"55752-0\" scheme=\"LOINC\">\n </term>\n</entry>\n<entry ORIGTXT=\"T239_9\">\n <term>\n  <code meaning=\"comparison\" value=\"RID28483\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T239_20\">\n <term>\n  <code meaning=\"impression section\" value=\"RID13170\" scheme=\"RadLex\">\n </term>\n</entry>\n</coded_content>\n</template_attributes>\r\n-->\r\n</script>\n<title>CT Pelvis</title>\n</head>\n<body>\n<section data-section-name=\"Procedure\">\n<header class=\"level1\">CT Pelvis</header>\n<p>\n<label for=\"T239_4\">IV contrast:</label>\n<input type=\"text\" id=\"T239_4\" name=\"IV contrast\" value=\"None.\"/>\n</p>\n<p>\n<label for=\"T239_3\">Oral contrast:</label>\n<input type=\"text\" id=\"T239_3\" name=\"Oral contrast\" value=\"Oral contrast was administered.\"/>\n</p>\n</section>\n<section data-section-name=\"Clinical information\">\n<header class=\"level1\">Clinical information</header>\n<p>\n<textarea id=\"T239_8\" name=\"Clinical information\"> </textarea>\n</p>\n</section>\n<section data-section-name=\"Comparison\">\n<header class=\"level1\">Comparison</header>\n<p>\n<textarea id=\"T239_9\" name=\"Comparison\">None. </textarea>\n</p>\n</section>\n<section data-section-name=\"Findings\">\n<header class=\"level1\">Findings</header>\n<p>\n<label for=\"T239_13\">Reproductive organs:</label>\n<input type=\"text\" id=\"T239_13\" name=\"Reproductive organs\" value=\"No pelvic masses.\"/>\n</p>\n<p>\n<label for=\"T239_14\">Ureters:</label>\n<input type=\"text\" id=\"T239_14\" name=\"Ureters\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T239_15\">Bladder:</label>\n<input type=\"text\" id=\"T239_15\" name=\"Bladder\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T239_16\">Bowel:</label>\n<input type=\"text\" id=\"T239_16\" name=\"Bowel\" value=\"Normal caliber.\"/>\n</p>\n<p>\n<label for=\"T239_17\">Peritoneum:</label>\n<input type=\"text\" id=\"T239_17\" name=\"Peritoneum\" value=\"No ascites or free air; no fluid collection.\"/>\n</p>\n<p>\n<label for=\"T239_18\">Vessels:</label>\n<input type=\"text\" id=\"T239_18\" name=\"Vessels\" value=\"Atherosclerotic changes.\"/>\n</p>\n<p>\n<label for=\"T239_19\">Bones:</label>\n<input type=\"text\" id=\"T239_19\" name=\"Bones\" value=\"Normal.\"/>\n</p>\n</section>\n<section data-section-name=\"Impression\">\n<header class=\"level1\">Impression</header>\n<p>\n<textarea id=\"T239_20\" name=\"Impression\"> </textarea>\n</p>\n</section>\n</body>\n</html>\n",

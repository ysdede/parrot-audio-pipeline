    "templateData": "<!DOCTYPE html>\n<html>\n    <head>\n        <title>CT Body Liver</title>\n        <meta charset=\"UTF-8\" />\n        <meta name=\"dcterms.identifier\" content=\"97cbc41d-6f08-4f30-8cb5-fc0e3fb44588\" />\n        <meta name=\"dcterms.title\" content=\"CT Body Liver\" />\n        <meta name=\"dcterms.description\" content=\"\" />\n        <meta name=\"dcterms.type\" content=\"IMAGE_REPORT_TEMPLATE\" />\n        <meta name=\"dcterms.language\" content=\"en\" />\n        <meta name=\"dcterms.publisher\" content=\"Medical College of Wisconsin\" />\n        <meta name=\"dcterms.rights\" content=\"May be used freely, subject to license agreement\" />\n        <meta name=\"dcterms.license\" content=\"http://www.radreport.org/license.pdf\" />\n        <meta name=\"dcterms.date\" content=\"2016-05-26\" />\n        <meta name=\"dcterms.creator\" content=\"\" />\n        <script type=\"text/xml\">\n            <template_attributes>\n                <coded_content>\n                    <coding_schemes>\n                        <coding_scheme name=\"RADLEX\" designator=\"2.16.840.1.113883.6.256\"></coding_scheme>\n                    </coding_schemes>\n                    <entry origtxt=\"SELECTION_LIST_1463544191587_0\">\n                        <term>\n                            <code meaning=\"present\" value=\"RID28472\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1463544191587_1\">\n                        <term>\n                            <code meaning=\"absent\" value=\"RID28473\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SECTION_HEADER_1463544191555\">\n                        <term>\n                            <code meaning=\"liver parenchyma\" value=\"RID49459\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"impressionText\">\n                        <term>\n                            <code meaning=\"impression section\" value=\"RID13170\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1463544191631\">\n                        <term>\n                            <code meaning=\"vasculature\" value=\"RID15989\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1463544191540\">\n                        <term>\n                            <code meaning=\"oral contrast\" value=\"RID35817\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"comparisonsText\">\n                        <term>\n                            <code meaning=\"comparison\" value=\"RID28483\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1463544191582\">\n                        <term>\n                            <code meaning=\"atherosclerosis\" value=\"RID39049\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1463544191582_0\">\n                        <term>\n                            <code meaning=\"present\" value=\"RID28472\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1463544191582_1\">\n                        <term>\n                            <code meaning=\"absent\" value=\"RID28473\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"clinicalInformationText\">\n                        <term>\n                            <code meaning=\"clinical information\" value=\"RID13166\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1463544191628\">\n                        <term>\n                            <code meaning=\"kidney\" value=\"RID205\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1463544191629\">\n                        <term>\n                            <code meaning=\"gastrointestinal tract\" value=\"RID94\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1463544191626\">\n                        <term>\n                            <code meaning=\"spleen\" value=\"RID86\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1463544191627\">\n                        <term>\n                            <code meaning=\"set of adrenal glands\" value=\"RID28752\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1463544191625\">\n                        <term>\n                            <code meaning=\"pancreas\" value=\"RID170\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1463544191572_0\">\n                        <term>\n                            <code meaning=\"right hepatic artery\" value=\"RID918\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1463544191572_1\">\n                        <term>\n                            <code meaning=\"left hepatic artery\" value=\"RID916\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1463544191561_0\">\n                        <term>\n                            <code meaning=\"normal\" value=\"RID13173\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1463544191606_0\">\n                        <term>\n                            <code meaning=\"none\" value=\"RID28454\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SECTION_HEADER_1463544191581\">\n                        <term>\n                            <code meaning=\"vascular disease\" value=\"RID46041\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1463544191592_0\">\n                        <term>\n                            <code meaning=\"normal\" value=\"RID13173\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                </coded_content>\n            </template_attributes>\n        </script>\n    </head>\n    <body>\n        <section id=\"procedureInformation\" class=\"level1\" data-section-name=\"Procedure Information\">\n            <header class=\"level1\">\n                Procedure Information\n            </header>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1463544191529\">Examination:</label>\n                <select id=\"SELECTION_LIST_1463544191529\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"PROHIBIT\" value=\"CT angiography abdomen with IV contrast and postprocess imaging.\">\n                    <option id=\"SELECTION_LIST_1463544191529_0\" value=\"CT angiography abdomen with IV contrast and postprocess imaging.\" name=\"SELECTION_LIST_1463544191529\" selected=\"\">CT angiography abdomen with IV contrast and postprocess imaging.</option>\n                    <option id=\"SELECTION_LIST_1463544191529_1\" value=\"CT abdomen with IV and oral contrast.\" name=\"SELECTION_LIST_1463544191529\">CT abdomen with IV and oral contrast.</option>\n                </select>\n            </p>\n            <section id=\"SECTION_HEADER_1463544191532\" class=\"level2\" data-section-name=\"Technique:\">\n                <header class=\"level2\">\n                    Technique:\n                </header>\n                <p title=\"\">\n                    <label for=\"NUMBER_1463544191535\">IV contrast:</label>\n                    <span>\n                        <input type=\"number\" step=\"1.0\" data-field-units=\"mL\" id=\"NUMBER_1463544191535\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"ALERT\" value=\"125\" />\n                        mL\n                    </span>\n                </p>\n                <p title=\"\">\n                    <label for=\"SELECTION_LIST_1463544191536\"></label>\n                    <select id=\"SELECTION_LIST_1463544191536\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"ALERT\" value=\"Omnipaque 350\">\n                        <option id=\"SELECTION_LIST_1463544191536_0\" value=\"Omnipaque 350\" name=\"SELECTION_LIST_1463544191536\" selected=\"\">Omnipaque 350</option>\n                        <option id=\"SELECTION_LIST_1463544191536_1\" value=\"Visipaque 320\" name=\"SELECTION_LIST_1463544191536\">Visipaque 320</option>\n                        <option id=\"SELECTION_LIST_1463544191536_2\" value=\"Isovue 370\" name=\"SELECTION_LIST_1463544191536\">Isovue 370</option>\n                    </select>\n                </p>\n                <p title=\"\">\n                    <label for=\"SELECTION_LIST_1463544191540\">Oral contrast:</label>\n                    <select id=\"SELECTION_LIST_1463544191540\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"PROHIBIT\" value=\"None.\">\n                        <option id=\"SELECTION_LIST_1463544191540_0\" value=\"None.\" name=\"SELECTION_LIST_1463544191540\" selected=\"\">None.</option>\n                        <option id=\"SELECTION_LIST_1463544191540_1\" value=\"Oral contrast was given.\" name=\"SELECTION_LIST_1463544191540\">Oral contrast was given.</option>\n                        <option id=\"SELECTION_LIST_1463544191540_2\" value=\"Water was given as enteric contrast.\" name=\"SELECTION_LIST_1463544191540\">Water was given as enteric contrast.</option>\n                        <option id=\"SELECTION_LIST_1463544191540_3\" value=\"VoLumen was given as enteric contrast.\" name=\"SELECTION_LIST_1463544191540\">VoLumen was given as enteric contrast.</option>\n                    </select>\n                </p>\n                <p title=\"\">\n                    <label for=\"SELECTION_LIST_1463544191545\">Technique comments:</label>\n                    <select id=\"SELECTION_LIST_1463544191545\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"PROHIBIT\" value=\"Standard technique.\">\n                        <option id=\"SELECTION_LIST_1463544191545_0\" value=\"Standard technique.\" name=\"SELECTION_LIST_1463544191545\" selected=\"\">Standard technique.</option>\n                        <option id=\"SELECTION_LIST_1463544191545_1\" value=\"Dual-energy technique, with monochromatic and material-decomposition images.\" name=\"SELECTION_LIST_1463544191545\">Dual-energy technique, with monochromatic and material-decomposition images.</option>\n                        <option id=\"SELECTION_LIST_1463544191545_2\" value=\"Dual-phase imaging of the abdomen\" name=\"SELECTION_LIST_1463544191545\">Dual-phase imaging of the abdomen</option>\n                        <option id=\"SELECTION_LIST_1463544191545_3\" value=\"Dual-phase with equilibrium imaging of the abdomen.\" name=\"SELECTION_LIST_1463544191545\">Dual-phase with equilibrium imaging of the abdomen.</option>\n                        <option id=\"SELECTION_LIST_1463544191545_4\" value=\"CT angiography through the abdomen, with image acquisitions in the early arterial, late arterial, and hepatic venous phases. Multiple reformatted images were created by the 3D lab.\" name=\"SELECTION_LIST_1463544191545\">CT angiography through the abdomen, with image acquisitions in the early arterial, late arterial, and hepatic venous phases. Multiple reformatted images were created by the 3D lab.</option>\n                    </select>\n                </p>\n            </section>\n        </section>\n        <section id=\"clinicalInformation\" class=\"level1\" data-section-name=\"Clinical Information\">\n            <header class=\"level1\">\n                Clinical Information\n            </header>\n            <p title=\"\">\n                <label for=\"clinicalInformationText\">Clinical Information:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"clinicalInformationText\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"PROHIBIT\">Potential live liver donor. Examination for presurgical planning.</textarea>\n            </p>\n        </section>\n        <section id=\"comparisons\" class=\"level1\" data-section-name=\"Comparison\">\n            <header class=\"level1\">\n                Comparison\n            </header>\n            <p title=\"\">\n                <label for=\"comparisonsText\">Comparison:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"comparisonsText\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"PROHIBIT\">None.</textarea>\n            </p>\n        </section>\n        <section id=\"findings\" class=\"level1\" data-section-name=\"Findings\">\n            <header class=\"level1\">\n                Findings\n            </header>\n            <p title=\"\">\n                <label for=\"TEXT_1463544191551\">Findings:</label>\n                <input type=\"text\" id=\"TEXT_1463544191551\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\" value=\"\" />\n            </p>\n            <section id=\"SECTION_HEADER_1463544191555\" class=\"level2\" data-section-name=\"Liver parenchyma:\">\n                <header class=\"level2\">\n                    Liver parenchyma:\n                </header>\n                <p title=\"\">\n                    <label for=\"TEXT_1463544191556\"></label>\n                    <input type=\"text\" id=\"TEXT_1463544191556\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"PROHIBIT\" value=\"No focal liver lesion.\" />\n                </p>\n            </section>\n            <section id=\"SECTION_HEADER_1463544191557\" class=\"level2\" data-section-name=\"Hepatic Arterial System:\">\n                <header class=\"level2\">\n                    Hepatic Arterial System:\n                </header>\n                <p title=\"\">\n                    <label for=\"SELECTION_LIST_1463544191561\">Arterial anatomy:</label>\n                    <select id=\"SELECTION_LIST_1463544191561\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"PROHIBIT\" value=\"Normal (Type II).\">\n                        <option id=\"SELECTION_LIST_1463544191561_0\" value=\"Normal (Type II).\" name=\"SELECTION_LIST_1463544191561\" selected=\"\">Normal (Type II).</option>\n                        <option id=\"SELECTION_LIST_1463544191561_1\" value=\"Right hepatic artery replaced to SMA.\" name=\"SELECTION_LIST_1463544191561\">Right hepatic artery replaced to SMA.</option>\n                        <option id=\"SELECTION_LIST_1463544191561_2\" value=\"Hepatic artery completely replaced to SMA.\" name=\"SELECTION_LIST_1463544191561\">Hepatic artery completely replaced to SMA.</option>\n                        <option id=\"SELECTION_LIST_1463544191561_3\" value=\"Accessory right hepatic artery.\" name=\"SELECTION_LIST_1463544191561\">Accessory right hepatic artery.</option>\n                        <option id=\"SELECTION_LIST_1463544191561_4\" value=\"Accessory left hepatic artery.\" name=\"SELECTION_LIST_1463544191561\">Accessory left hepatic artery.</option>\n                    </select>\n                </p>\n                <p title=\"\">\n                    <label for=\"SELECTION_LIST_1463544191572\">Origin of the middle hepatic artery (i.e. segment 4 hepatic artery):</label>\n                    <select id=\"SELECTION_LIST_1463544191572\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"PROHIBIT\" value=\"Right hepatic artery.\">\n                        <option id=\"SELECTION_LIST_1463544191572_0\" value=\"Right hepatic artery.\" name=\"SELECTION_LIST_1463544191572\" selected=\"\">Right hepatic artery.</option>\n                        <option id=\"SELECTION_LIST_1463544191572_1\" value=\"Left hepatic artery.\" name=\"SELECTION_LIST_1463544191572\">Left hepatic artery.</option>\n                        <option id=\"SELECTION_LIST_1463544191572_2\" value=\"Both right and left hepatic arteries.\" name=\"SELECTION_LIST_1463544191572\">Both right and left hepatic arteries.</option>\n                        <option id=\"SELECTION_LIST_1463544191572_3\" value=\"Unidentifiable.\" name=\"SELECTION_LIST_1463544191572\">Unidentifiable.</option>\n                    </select>\n                </p>\n                <p title=\"\">\n                    <label for=\"NUMBER_1463544191577\">Diameter of the right hepatic artery at origin:</label>\n                    <span>\n                        <input type=\"number\" step=\"1.0\" data-field-units=\"mm\" id=\"NUMBER_1463544191577\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"ALERT\" value=\"\" />\n                        mm\n                    </span>\n                </p>\n                <p title=\"\">\n                    <label for=\"NUMBER_1463544191578\">Diameter of the right heaptic artery at the level of branching into the middle hepatic artery:</label>\n                    <span>\n                        <input type=\"number\" step=\"1.0\" data-field-units=\"mm\" id=\"NUMBER_1463544191578\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                        mm\n                    </span>\n                </p>\n                <p title=\"\">\n                    <label for=\"NUMBER_1463544191579\">Diameter of the left hepatic artery at origin:</label>\n                    <span>\n                        <input type=\"number\" step=\"1.0\" data-field-units=\"mm\" id=\"NUMBER_1463544191579\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"PROHIBIT\" value=\"\" />\n                        mm\n                    </span>\n                </p>\n                <p title=\"\">\n                    <label for=\"NUMBER_1463544191580\">Diameter of the left hepatic artery at the level of the branching into middle hepatic artery:</label>\n                    <span>\n                        <input type=\"number\" step=\"1.0\" data-field-units=\"mm\" id=\"NUMBER_1463544191580\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                        mm\n                    </span>\n                </p>\n            </section>\n            <section id=\"SECTION_HEADER_1463544191581\" class=\"level2\" data-section-name=\"Vascular disease:\">\n                <header class=\"level2\">\n                    Vascular disease:\n                </header>\n                <p title=\"\">\n                    <label for=\"SELECTION_LIST_1463544191582\">Atherosclerosis:</label>\n                    <select id=\"SELECTION_LIST_1463544191582\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"PROHIBIT\" value=\"Present.\">\n                        <option id=\"SELECTION_LIST_1463544191582_0\" value=\"Present.\" name=\"SELECTION_LIST_1463544191582\" selected=\"\">Present.</option>\n                        <option id=\"SELECTION_LIST_1463544191582_1\" value=\"Absent.\" name=\"SELECTION_LIST_1463544191582\">Absent.</option>\n                    </select>\n                </p>\n                <p title=\"\">\n                    <label for=\"SELECTION_LIST_1463544191587\">Celiac artery compression by the median arcuate ligament:</label>\n                    <select id=\"SELECTION_LIST_1463544191587\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"PROHIBIT\" value=\"Present.\">\n                        <option id=\"SELECTION_LIST_1463544191587_0\" value=\"Present.\" name=\"SELECTION_LIST_1463544191587\" selected=\"\">Present.</option>\n                        <option id=\"SELECTION_LIST_1463544191587_1\" value=\"Absent.\" name=\"SELECTION_LIST_1463544191587\">Absent.</option>\n                    </select>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1463544191590\">Other:</label>\n                    <input type=\"text\" id=\"TEXT_1463544191590\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\" value=\"None.\" />\n                </p>\n            </section>\n            <section id=\"SECTION_HEADER_1463544191591\" class=\"level2\" data-section-name=\"Portal Venous System:\">\n                <header class=\"level2\">\n                    Portal Venous System:\n                </header>\n                <p title=\"\">\n                    <label for=\"SELECTION_LIST_1463544191592\">Portal Vein System:</label>\n                    <select id=\"SELECTION_LIST_1463544191592\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"PROHIBIT\" value=\"Normal.\">\n                        <option id=\"SELECTION_LIST_1463544191592_0\" value=\"Normal.\" name=\"SELECTION_LIST_1463544191592\" selected=\"\">Normal.</option>\n                        <option id=\"SELECTION_LIST_1463544191592_1\" value=\"Trifurcation (right anterior, right posterior, and left portal veins).\" name=\"SELECTION_LIST_1463544191592\">Trifurcation (right anterior, right posterior, and left portal veins).</option>\n                        <option id=\"SELECTION_LIST_1463544191592_2\" value=\"Right anterior portal vein arises from left portal vein.\" name=\"SELECTION_LIST_1463544191592\">Right anterior portal vein arises from left portal vein.</option>\n                        <option id=\"SELECTION_LIST_1463544191592_3\" value=\"Segment 4 portal vein arises from right anterior vein.\" name=\"SELECTION_LIST_1463544191592\">Segment 4 portal vein arises from right anterior vein.</option>\n                        <option id=\"SELECTION_LIST_1463544191592_4\" value=\"Right anterior portal vein arises from segment 4 portal vein.\" name=\"SELECTION_LIST_1463544191592\">Right anterior portal vein arises from segment 4 portal vein.</option>\n                        <option id=\"SELECTION_LIST_1463544191592_5\" value=\"Absence of main bifurcation, with main left portal vein arising from the right anterior portal vein.\" name=\"SELECTION_LIST_1463544191592\">Absence of main bifurcation, with main left portal vein arising from the right anterior portal vein.</option>\n                    </select>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1463544191600\">Portal and mesenteric vein patency:</label>\n                    <input type=\"text\" id=\"TEXT_1463544191600\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"PROHIBIT\" value=\"Normally patent.\" />\n                </p>\n            </section>\n            <section id=\"SECTION_HEADER_1463544191601\" class=\"level2\" data-section-name=\"Hepatic Venous System:\">\n                <header class=\"level2\">\n                    Hepatic Venous System:\n                </header>\n                <p title=\"\">\n                    <label for=\"SELECTION_LIST_1463544191603\">Presence of an accessory right hepatic vein, also known as right inferior hepatic or short hepatic vein (larger than 5 mm in diameter):</label>\n                    <select id=\"SELECTION_LIST_1463544191603\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"PROHIBIT\" value=\"Please describe nature of accessory right hepatic vein.\">\n                        <option id=\"SELECTION_LIST_1463544191603_0\" value=\"Please describe nature of accessory right hepatic vein.\" name=\"SELECTION_LIST_1463544191603\" selected=\"\">Please describe nature of accessory right hepatic vein.</option>\n                        <option id=\"SELECTION_LIST_1463544191603_1\" value=\"Absent.\" name=\"SELECTION_LIST_1463544191603\">Absent.</option>\n                    </select>\n                </p>\n                <p title=\"\">\n                    <label for=\"SELECTION_LIST_1463544191606\">Anterior sector (segment 5/8) hepatic veins draining into the middle hepatic vein greater than 5 mm in diameter:</label>\n                    <input list=\"SELECTION_LIST_1463544191606_LIST\" id=\"SELECTION_LIST_1463544191606\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"PROHIBIT\" value=\"None- None.\" />\n                    <datalist id=\"SELECTION_LIST_1463544191606_LIST\">\n                        <option id=\"SELECTION_LIST_1463544191606_0\" value=\"None- None.\" name=\"SELECTION_LIST_1463544191606\" selected=\"\">None- None.</option>\n                        <option id=\"SELECTION_LIST_1463544191606_1\" value=\"Segment 5 and 8- Segment 5 and 8.\" name=\"SELECTION_LIST_1463544191606\">Segment 5 and 8- Segment 5 and 8.</option>\n                        <option id=\"SELECTION_LIST_1463544191606_2\" value=\"Other- Other (specify)\" name=\"SELECTION_LIST_1463544191606\">Other- Other (specify)</option>\n                        <option id=\"SELECTION_LIST_1463544191606_3\" value=\"Segment 5- Segment 5 only.\" name=\"SELECTION_LIST_1463544191606\">Segment 5- Segment 5 only.</option>\n                        <option id=\"SELECTION_LIST_1463544191606_4\" value=\"Segment 8- Segment 8 only.\" name=\"SELECTION_LIST_1463544191606\">Segment 8- Segment 8 only.</option>\n                    </datalist>\n                </p>\n                <p title=\"\">\n                    <label for=\"SELECTION_LIST_1463544191612\">Presence of significant (greater than 5 mm in diameter) accessory vein in between the middle hepatic and left hepatic veins: </label>\n                    <select id=\"SELECTION_LIST_1463544191612\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"PROHIBIT\" value=\"No- No.\">\n                        <option id=\"SELECTION_LIST_1463544191612_0\" value=\"No- No.\" name=\"SELECTION_LIST_1463544191612\" selected=\"\">No- No.</option>\n                        <option id=\"SELECTION_LIST_1463544191612_1\" value=\"Yes- Yes.\" name=\"SELECTION_LIST_1463544191612\">Yes- Yes.</option>\n                    </select>\n                </p>\n            </section>\n            <section id=\"SECTION_HEADER_1463544191615\" class=\"level2\" data-section-name=\"Bilary System:\">\n                <header class=\"level2\">\n                    Bilary System:\n                </header>\n                <p title=\"\">\n                    <label for=\"TEXT_1463544191616\"></label>\n                    <input type=\"text\" id=\"TEXT_1463544191616\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"PROHIBIT\" value=\"Please see accompanying MRI report for biliary anatomy detail. No biliary dilatation seen.\" />\n                </p>\n            </section>\n            <section id=\"SECTION_HEADER_1463544191617\" class=\"level2\" data-section-name=\"Liver Volumes and Size:\">\n                <header class=\"level2\">\n                    Liver Volumes and Size:\n                </header>\n                <p title=\"\">\n                    <label for=\"NUMBER_1463544191618\">Total liver volume:</label>\n                    <span>\n                        <input type=\"number\" step=\"1.0\" data-field-units=\"mL\" id=\"NUMBER_1463544191618\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"PROHIBIT\" value=\"\" />\n                        mL\n                    </span>\n                </p>\n                <p title=\"\">\n                    <label for=\"NUMBER_1463544191619\">Right liver volume (Please indicate segments which were included in this measurement):</label>\n                    <span>\n                        <input type=\"number\" step=\"1.0\" data-field-units=\"mL\" id=\"NUMBER_1463544191619\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"PROHIBIT\" value=\"\" />\n                        mL\n                    </span>\n                </p>\n                <p title=\"\">\n                    <label for=\"NUMBER_1463544191620\">Left lateral segment volume (Please indicate segments which were included in this measurement):</label>\n                    <span>\n                        <input type=\"number\" step=\"1.0\" data-field-units=\"mL\" id=\"NUMBER_1463544191620\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"PROHIBIT\" value=\"\" />\n                        mL\n                    </span>\n                </p>\n                <section id=\"SECTION_HEADER_1463544191623\" class=\"level2\" data-section-name=\"AP distance:\">\n                    <header class=\"level2\">\n                        AP distance:\n                    </header>\n                </section>\n                <p title=\"\">\n                    <label for=\"NUMBER_1463544191622\">Left lateral segment (segments 2/3):</label>\n                    <span>\n                        <input type=\"number\" step=\"1.0\" data-field-units=\"cm\" id=\"NUMBER_1463544191622\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"PROHIBIT\" value=\"\" />\n                        cm\n                    </span>\n                </p>\n                <p title=\"\">\n                    <label for=\"NUMBER_1463544191624\">Right hepatic lobe (segments 5/6/7/8):</label>\n                    <span>\n                        <input type=\"number\" step=\"1.0\" data-field-units=\"cm\" id=\"NUMBER_1463544191624\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"PROHIBIT\" value=\"\" />\n                        cm\n                    </span>\n                </p>\n            </section>\n            <p title=\"\">\n                <label for=\"TEXT_1463544191625\">Pancreas:</label>\n                <input type=\"text\" id=\"TEXT_1463544191625\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"PROHIBIT\" value=\"Normal.\" />\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1463544191626\">Spleen:</label>\n                <input type=\"text\" id=\"TEXT_1463544191626\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"PROHIBIT\" value=\"\" />\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1463544191627\">Adrenal Glands:</label>\n                <input type=\"text\" id=\"TEXT_1463544191627\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"PROHIBIT\" value=\"\" />\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1463544191628\">Kidneys:</label>\n                <input type=\"text\" id=\"TEXT_1463544191628\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"PROHIBIT\" value=\"Normal.\" />\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1463544191629\">Gastrointestinal:</label>\n                <input type=\"text\" id=\"TEXT_1463544191629\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"PROHIBIT\" value=\"Imaged bowel and mesentery are normal.\" />\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1463544191630\">Free Fluid/Air:</label>\n                <input type=\"text\" id=\"TEXT_1463544191630\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"PROHIBIT\" value=\"None.\" />\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1463544191631\">Vasculature:</label>\n                <input type=\"text\" id=\"TEXT_1463544191631\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"PROHIBIT\" value=\"Visceral arteries and portal venous system are normally patent.\" />\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1463544191632\">Lymph Nodes:</label>\n                <input type=\"text\" id=\"TEXT_1463544191632\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"PROHIBIT\" value=\"No abdominal retroperitoneal or mesenteric lymphadenopathy.\" />\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1463544191633\">Bones:</label>\n                <input type=\"text\" id=\"TEXT_1463544191633\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"PROHIBIT\" value=\"No significant lesion.\" />\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1464273703915\">Other:</label>\n                <input type=\"text\" id=\"TEXT_1464273703915\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\" value=\"\" />\n            </p>\n        </section>\n        <section id=\"impression\" class=\"level1\" data-section-name=\"Impression\">\n            <header class=\"level1\">\n                Impression\n            </header>\n            <p title=\"\">\n                <label for=\"impressionText\">Impression:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"impressionText\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"PROHIBIT\">Live liver donor mapping with measurements, as described in the text of the report.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1464273703916\"></label>\n                <input type=\"text\" id=\"TEXT_1464273703916\" name=\"\" 
    "templateData": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\"/>\n<meta content=\"Pediatric Swallow Study\" name=\"dcterms.title\"/>\n<meta content=\"Pediatric Swallow Study template :: Authored by Meyer JS, et al.\" name=\"dcterms.description\"/>\n<meta content=\"http://www.radreport.org/template/0000108\" name=\"dcterms.identifier\"/>\n<meta content=\"en\" name=\"dcterms.language\"/>\n<meta content=\"IMAGE_REPORT_TEMPLATE\" name=\"dcterms.type\"/>\n<meta content=\"Radiological Society of North America (RSNA)\" name=\"dcterms.publisher\"/>\n<meta content=\"May be used gratis, subject to license agreement\" name=\"dcterms.rights\"/>\n<meta content=\"http://www.radreport.org/license.pdf\" name=\"dcterms.license\"/>\n<meta content=\"2012-07-12\" name=\"dcterms.date\"/>\n<meta content=\"Meyer JS, et al.\" name=\"dcterms.creator\"/>\n<meta content=\"Society for Pediatric Radiology (SPR)\" name=\"dcterms.contributor\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"IHE_Template_Style.css\"/>\n<!-- The absolute link to the CSS file is http://www.radreport.org/html/IHE_Template_Style.css -->\n<script type=\"text/xml\">\n<!--\n<template_attributes>\n<top-level-flag>true</top-level-flag>\n<status>ACTIVE</status>\n<coding_schemes>\n <coding_scheme name=\"RadLex\" designator=\"2.16.840.1.113883.6.256\" />\n <coding_scheme name=\"SNOMEDCT\" designator=\"2.16.840.1.113883.6.96\" />\n <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\" />\n</coding_schemes>\n<term>\n <code meaning=\"child\" value=\"RID5641\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"fluoroscopy\" value=\"RID10361\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"pharynx\" value=\"RID13211\" scheme=\"RadLex\">\n</term>\n<coded_content>\n<entry ORIGTXT=\"T108_2\">\n <term>\n  <code meaning=\"procedure\" value=\"RID1559\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T108_10\">\n <term>\n  <code meaning=\"clinical information\" value=\"RID13166\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T108_13\">\n <term>\n  <code meaning=\"comparison\" value=\"RID28483\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T108_20\">\n <term>\n  <code meaning=\"thorax\" value=\"RID1243\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T108_23\">\n <term>\n  <code meaning=\"oral contrast\" value=\"RID35817\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T108_28\">\n <term>\n  <code meaning=\"deployment technique\" value=\"RID12917\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T108_36\">\n <term>\n  <code meaning=\"function\" value=\"RID28812\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T108_39\">\n <term>\n  <code meaning=\"volume\" value=\"RID28668\" scheme=\"RadLex\">\n </term>\n <term>\n  <code meaning=\"oral contrast\" value=\"RID35817\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T108_49\">\n <term>\n  <code meaning=\"glottis\" value=\"RID7672\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T108_66\">\n <term>\n  <code meaning=\"residual\" value=\"RID5727\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T108_70\">\n <term>\n  <code meaning=\"cricopharyngeus\" value=\"RID7558\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T108_73\">\n <term>\n  <code meaning=\"reflux\" value=\"RID5259\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T108_78\">\n <term>\n  <code meaning=\"esophagus\" value=\"RID95\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T108_182\">\n <term>\n  <code meaning=\"impression section\" value=\"RID13170\" scheme=\"RadLex\">\n </term>\n</entry>\n</coded_content>\n</template_attributes>\n-->\n</script>\n<title>Pediatric Swallow Study</title>\n</head>\n<body>\n<section data-section-name=\"Procedure\">\n<header class=\"level1\">Pediatric Swallow Study</header>\n<p>\n<textarea id=\"T108_2\" name=\"Procedure\"> </textarea>\n</p>\n<!--Modified barium swallow-->\n</section>\n<section data-section-name=\"Clinical information\">\n<header class=\"level1\">Clinical information</header>\n<p>\n<textarea id=\"T108_10\" name=\"Clinical information\">Dysphagia. </textarea>\n</p>\n</section>\n<section data-section-name=\"Comparison\">\n<header class=\"level1\">Comparison</header>\n<p>\n<textarea id=\"T108_13\" name=\"Comparison\">None. </textarea>\n</p>\n</section>\n<section data-section-name=\"Findings\">\n<header class=\"level1\">Findings</header>\n\n<section data-section-name=\"Chest\">\n<header class=\"level2\">Chest</header>\n<p>\n<textarea id=\"T108_20\" name=\"Chest\">Normal. </textarea>\n</p>\n</section>\n<section data-section-name=\"Contrast\">\n<header class=\"level2\">Contrast</header>\n<p>\n<label for=\"T108_23\">Contrast material(s):</label>\n<select id=\"T108_23\" name=\"Contrast material\" multiple=\"multiple\">\n<option id=\"T108_23.1\" name=\"Thin liquid\" value=\"Thin liquid\">Thin liquid</option>\n<option id=\"T108_23.2\" name=\"Nectar consistency\" value=\"Nectar consistency\">Nectar consistency</option>\n<option id=\"T108_23.3\" name=\"Honey consistency\" value=\"Honey consistency\">Honey consistency</option>\n<option id=\"T108_23.4\" name=\"Pudding consistency\" value=\"Pudding consistency\">Pudding consistency</option>\n</select>\n</p>\n<p>\n<label for=\"T108_28\">Source(s):</label>\n<select id=\"T108_28\" name=\"Source\">\n<option id=\"T108_28.1\" name=\"Standard nipple\" value=\"Standard nipple\">Standard nipple</option>\n<option id=\"T108_28.2\" name=\"Low-flow nipple\" value=\"Low-flow nipple\">Low-flow nipple</option>\n<option id=\"T108_28.3\" name=\"High-flow nipple\" value=\"High-flow nipple\">High-flow nipple</option>\n<option id=\"T108_28.4\" name=\"Spoon\" value=\"Spoon\">Spoon</option>\n<option id=\"T108_28.5\" name=\"Straw\" value=\"Straw\">Straw</option>\n<option id=\"T108_28.6\" name=\"Cup\" value=\"Cup\">Cup</option>\n</select>\n</p>\n</section>\n<section data-section-name=\"Oropharynx\">\n<header class=\"level2\">Oropharynx</header>\n<p>\n<label for=\"T108_36\">Motor function:</label>\n<input type=\"text\" id=\"T108_36\" name=\"Motor function\" value=\"Well organized.\"/>\n</p>\n<p>\n<label for=\"T108_39\">Bolus size:</label>\n<input type=\"text\" id=\"T108_39\" name=\"Bolus size\" value=\"Adequate. \"/>\n</p>\n<p>\n<label for=\"T108_42\">Triggering of swallowing reflex:</label>\n<input type=\"text\" id=\"T108_42\" name=\"Triggering of swallowing reflex\" value=\"Prompt. \"/>\n</p>\n<p>\n<label for=\"T108_45\">Coordination:</label>\n<input type=\"text\" id=\"T108_45\" name=\"Coordination\" value=\"Normal. \"/>\n</p>\n<p>\n<label for=\"T108_73\">Nasopharyngeal reflux:</label>\n<input type=\"text\" id=\"T108_73\" name=\"Nasopharyngeal reflux\" value=\"None.\"/>\n</p>\n</section>\n<section data-section-name=\"Hypopharynx\">\n<header class=\"level2\">Hypopharynx</header>\n<p>\n<label for=\"T108_49\">Glottic penetration or aspiration:</label>\n<input type=\"text\" id=\"T108_49\" name=\"Glottic penetration or aspiration\" value=\"None.\"/>\n</p>\n<p>\n<label for=\"T108_66\">Residual:</label>\n<input type=\"text\" id=\"T108_66\" name=\"Residual\" value=\"None.\"/>\n</p>\n<p>\n<label for=\"T108_70\">Cricopharyngeal muscle relaxation:</label>\n<input type=\"text\" id=\"T108_70\" name=\"Cricopharyngeal muscle relaxation\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T108_78\">Upper esophageal motility:</label>\n<input type=\"text\" id=\"T108_78\" name=\"Upper esophageal motility\" value=\"Normal\"/>\n</p>\n</section>\n</section>\n<section data-section-name=\"Impression\">\n<header class=\"level1\">Impression</header>\n<p>\n<textarea id=\"T108_182\" name=\"Impression\">No penetration or aspiration. </textarea>\n</p>\n</section>\n</body>\n</html>\n",

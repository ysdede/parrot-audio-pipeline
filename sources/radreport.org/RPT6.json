erm>\n</entry>\n</coded_content>\n</template_attributes>\n-->\n</script>\n<title>CT Appendicitis</title>\n</head>\n<body>\n<section data-section-name=\"Procedure\">\n<header class=\"level1\">CT Appendicitis</header>\n<p>\n<textarea id=\"T6_2\" name=\"Procedure\"> </textarea>\n</p>\n<p>\n<label for=\"T6_3\">IV contrast:</label>\n<input type=\"text\" id=\"T6_3\" name=\"T6_3\" value=\"None.\"/>\n</p>\n<p>\n<label for=\"T6_5\">Oral contrast:</label>\n<input type=\"text\" id=\"T6_5\" name=\"T6_5\" value=\"None.\"/>\n</p>\n</section>\n<section data-section-name=\"Clinical information\">\n<header class=\"level1\">Clinical information</header>\n<p>\n<textarea id=\"T6_7\" name=\"Clinical information\"> </textarea>\n</p>\n</section>\n<section data-section-name=\"Comparison\">\n<header class=\"level1\">Comparison</header>\n<p>\n<textarea id=\"T6_11\" name=\"Comparison\">None. </textarea>\n</p>\n</section>\n<section data-section-name=\"Findings\">\n<header class=\"level1\">Findings</header>\n<section data-section-name=\"Appendix\">\n<header class=\"level2\">Appendix</header>\n<p>\n<label for=\"T6_17\">Diameter:</label>\n<input type=\"number\" id=\"T6_17\" name=\"T6_17\" data-field-units=\"mm\" min=\"\" max=\"\"/> mm\n</p>\n<p>\n<label for=\"T6_18\">Wall thickness:</label>\n<input type=\"number\" id=\"T6_18\" name=\"T6_18\" data-field-units=\"mm\" min=\"\" max=\"\"/> mm\n</p>\n<p>\n<label for=\"T6_19\">Peri-appendiceal stranding:</label>\n<input type=\"text\" id=\"T6_19\" name=\"T6_19\" value=\"None.\"/>\n</p>\n<p>\n<label for=\"T6_21\">Peri-appendiceal fluid:</label>\n<input type=\"text\" id=\"T6_21\" name=\"T6_21\" value=\"None.\"/>\n</p>\n<p>\n<label for=\"T6_23\">Peri-appendiceal abscess:</label>\n<input type=\"text\" id=\"T6_23\" name=\"T6_23\" value=\"None.\"/>\n</p>\n<p>\n<label for=\"T6_25\">Adjacent bowel wall thickening:</label>\n<input type=\"text\" id=\"T6_25\" name=\"T6_25\" value=\"None.\"/>\n</p>\n<p>\n<label for=\"T6_27\">Appendicolith:</label>\n<input type=\"text\" id=\"T6_27\" name=\"T6_27\" value=\"None.\"/>\n</p>\n</section>\n<section data-section-name=\"Other findings\">\n<header class=\"level2\">Other findings</header>\n<p>\n<label for=\"T6_29\">Mesenteric lymph node enlargement:</label>\n<input type=\"text\" id=\"T6_29\" name=\"T6_29\" value=\"None.\"/>\n</p>\n<p>\n<label for=\"T6_31\">Small bowel and colon:</label>\n<input type=\"text\" id=\"T6_31\" name=\"T6_31\" value=\"Normal in caliber without appreciable wall thickening.\"/>\n</p>\n<p>\n<label for=\"T6_33\">Gallbladder and biliary system:</label>\n<input type=\"text\" id=\"T6_33\" name=\"T6_33\" value=\"No evidence of gallstones or biliary ductal dilatation.\"/>\n</p>\n<p>\n<label for=\"T6_39\">Spleen:</label>\n<input type=\"text\" id=\"T6_39\" name=\"T6_39\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T6_41\">Pancreas:</label>\n<input type=\"text\" id=\"T6_41\" name=\"T6_41\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T6_43\">Adrenals:</label>\n<input type=\"text\" id=\"T6_43\" name=\"T6_43\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T6_45\">Kidneys and ureters:</label>\n<input type=\"text\" id=\"T6_45\" name=\"T6_45\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T6_47\">Abdominal aorta and major branches:</label>\n<input type=\"text\" id=\"T6_47\" name=\"T6_47\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T6_49\">Adenopathy:</label>\n<input type=\"text\" id=\"T6_49\" name=\"T6_49\" value=\"None.\"/>\n</p>\n<p>\n<label for=\"T6_53\">Lung bases:</label>\n<input type=\"text\" id=\"T6_53\" name=\"T6_53\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T6_55\">Reproductive organs:</label>\n<input type=\"text\" id=\"T6_55\" name=\"T6_55\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T6_57\">Bones:</label>\n<input type=\"text\" id=\"T6_57\" name=\"T6_57\" value=\"Normal.\"/>\n</p>\n</section>\n</section>\n<section data-section-name=\"Impression\">\n<header class=\"level1\">Impression</header>\n<p>\n<textarea id=\"T6_60\" name=\"Impression\"> </textarea>\n</p>\n<
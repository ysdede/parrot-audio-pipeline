    "templateData": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\"/>\n<meta content=\"Bone Survey\" name=\"dcterms.title\"/>\n<meta content=\"Bone Survey template :: Authored by Langlotz CP\" name=\"dcterms.description\"/>\n<meta content=\"http://www.radreport.org/template/0000143\" name=\"dcterms.identifier\"/>\n<meta content=\"en\" name=\"dcterms.language\"/>\n<meta content=\"IMAGE_REPORT_TEMPLATE\" name=\"dcterms.type\"/>\n<meta content=\"Radiological Society of North America (RSNA)\" name=\"dcterms.publisher\"/>\n<meta content=\"May be used gratis, subject to license agreement\" name=\"dcterms.rights\"/>\n<meta content=\"http://www.radreport.org/license.pdf\" name=\"dcterms.license\"/>\n<meta content=\"2012-05-03\" name=\"dcterms.date\"/>\n<meta content=\"Langlotz CP\" name=\"dcterms.creator\"/>\n\n<meta content=\"Kahn CE Jr. [editor]\" name=\"dcterms.contributor\"/>\n<meta content=\"Penn Medicine | Hospital of the University of Pennsylvania (Penn)\" name=\"dcterms.contributor\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"IHE_Template_Style.css\"/>\n<!-- The absolute link to the CSS file is http://www.radreport.org/html/IHE_Template_Style.css -->\n<script type=\"text/xml\">\r\n<!--\r\n<template_attributes>\n<top-level-flag>true</top-level-flag>\n<status>ACTIVE</status>\n<coding_schemes>\n <coding_scheme name=\"RadLex\" designator=\"2.16.840.1.113883.6.256\" />\n <coding_scheme name=\"SNOMEDCT\" designator=\"2.16.840.1.113883.6.96\" />\n <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\" />\n</coding_schemes>\n<term>\n <code meaning=\"bone organ\" value=\"RID13197\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"projection radiography\" value=\"RID10345\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"set of bones\" value=\"RID28569\" scheme=\"RadLex\">\n</term>\n<coded_content>\n<entry ORIGTXT=\"T143_2\">\n <term>\n  <code meaning=\"procedure\" value=\"RID1559\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T143_28\">\n  <term>\n  <code meaning=\"Clinical information\" value=\"55752-0\" scheme=\"LOINC\">\n </term>\n</entry>\n<entry ORIGTXT=\"T143_30\">\n <term>\n  <code meaning=\"comparison\" value=\"RID28483\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T143_33\">\n <term>\n  <code meaning=\"set of bones\" value=\"RID28569\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T143_34\">\n <term>\n  <code meaning=\"normal\" value=\"RID13173\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T143_35\">\n <term>\n  <code meaning=\"demineralization\" value=\"RID5387\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T143_36\">\n <term>\n  <code meaning=\"set of joints\" value=\"RID28711\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T143_41\">\n <term>\n  <code meaning=\"intervertebral disc degeneration\" value=\"RID5086\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T143_48\">\n <term>\n  <code meaning=\"impression section\" value=\"RID13170\" scheme=\"RadLex\">\n </term>\n</entry>\n</coded_content>\n</template_attributes>\r\n-->\r\n</script>\n<title>Bone Survey</title>\n</head>\n<body>\n<section data-section-name=\"Procedure\">\n<header class=\"level1\">Bone Survey</header>\n<p>\n<textarea id=\"T143_2\" name=\"Procedure\">22 views of the axial and appendicular skeleton. </textarea>\n</p>\n</section>\n<section data-section-name=\"Clinical information\">\n<header class=\"level1\">Clinical information</header>\n<p>\n<textarea id=\"T143_28\" name=\"Clinical information\">Multiple myeloma. </textarea>\n</p>\n</section>\n<section data-section-name=\"Comparison\">\n<header class=\"level1\">Comparison</header>\n<p>\n<textarea id=\"T143_30\" name=\"Comparison\">None. </textarea>\n</p>\n</section>\n<section data-section-name=\"Findings\">\n<header class=\"level1\">Findings</header>\n<p>\n<label for=\"T143_33\">Lytic lesions:</label>\n<input type=\"text\" id=\"T143_33\" name=\"Lytic lesions\" value=\"None. \"/>\n</p>\n<p>\n<label for=\"T143_34\">Alignment: </label>\n<input type=\"text\" id=\"T143_34\" name=\"Alignment\" value=\"The bones are in normal anatomic alignment. There is no evidence of fracture or dislocation.\"/>\n</p>\n<p>\n<label for=\"T143_35\">Mineralization: </label>\n<input type=\"text\" id=\"T143_35\" name=\"Mineralization\" value=\"Normal.\" />\n</p>\n<p>\n<label for=\"T143_36\">Joints</label>\n<input type=\"text\" id=\"T143_36\" name=\"Joints\" value=\"Normal. No arthritis is present.\"/>\n</p>\n<p>\n<label for=\"T143_41\">Degenerative disc disease: </label>\n<input type=\"text\" id=\"T143_41\" name=\"Degenerative disc disease\" value=\"None.\"/>\n</p>\n<p>\n<label for=\"T143_42\">Other findings: </label>\n<input type=\"text\" id=\"T143_42\" name=\"Other findings\" value=\"None. \"/>\n</p>\n</section>\n<section data-section-name=\"Impression\">\n<header class=\"level1\">Impression</header>\n<p>\n<textarea id=\"T143_48\" name=\"Impression\">Negative examination. No evidence of multiple myeloma. </textarea>\n</p>\n</section>\n</body>\n</html>\n",

    "templateData": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\"/>\n<meta content=\"Gastrostomy Tube Removal\" name=\"dcterms.title\"/>\n<meta content=\"Gastrostomy Tube Removal template\" name=\"dcterms.description\"/>\n<meta content=\"http://www.radreport.org/template/0000256\" name=\"dcterms.identifier\"/>\n<meta content=\"en\" name=\"dcterms.language\"/>\n<meta content=\"IMAGE_REPORT_TEMPLATE\" name=\"dcterms.type\"/>\n<meta content=\"Radiological Society of North America (RSNA)\" name=\"dcterms.publisher\"/>\n<meta content=\"May be used gratis, subject to license agreement\" name=\"dcterms.rights\"/>\n<meta content=\"http://www.radreport.org/license.pdf\" name=\"dcterms.license\"/>\n<meta content=\"2012-12-10\" name=\"dcterms.date\"/>\n<meta content=\"Tolat P\" name=\"dcterms.creator\"/>\n<meta content=\"Kahn CE Jr [editor]\" name=\"dcterms.contributor\"/>\n<meta content=\"Medical College of Wisconsin (MCW)\" name=\"dcterms.contributor\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"IHE_Template_Style.css\"/>\n<!-- The absolute link to the CSS file is http://www.radreport.org/html/IHE_Template_Style.css -->\n<script type=\"text/xml\">\n<!--\n<template_attributes>\n<top-level-flag>true</top-level-flag>\n<status>ACTIVE</status>\n<coding_schemes>\n <coding_scheme name=\"RadLex\" designator=\"2.16.840.1.113883.6.256\" />\n <coding_scheme name=\"SNOMEDCT\" designator=\"2.16.840.1.113883.6.96\" />\n <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\" />\n</coding_schemes>\n<term>\n <code meaning=\"device removal\" value=\"RID10415\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"gastrostomy\" value=\"RID1634\" scheme=\"RadLex\">\n</term>\n<coded_content>\n<entry ORIGTXT=\"T256_2\">\n <term>\n  <code meaning=\"procedure\" value=\"RID1559\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T256_3\">\n  <term>\n  <code meaning=\"Clinical information\" value=\"55752-0\" scheme=\"LOINC\">\n </term>\n</entry>\n<entry ORIGTXT=\"T256_4\">\n <term>\n  <code meaning=\"comparison\" value=\"RID28483\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T256_6\">\n  <term>\n  <code meaning=\"Radiology Study observation (narrative)\" value=\"18782-3\" scheme=\"LOINC\">\n </term>\n</entry>\n<entry ORIGTXT=\"T256_7\">\n <term>\n  <code meaning=\"impression section\" value=\"RID13170\" scheme=\"RadLex\">\n </term>\n</entry>\n</coded_content>\n</template_attributes>\n-->\n</script>\n<title>Gastrostomy Tube Removal</title>\n</head>\n<body>\n<section data-section-name=\"Procedure\">\n<header class=\"level1\">Gastrostomy Tube Removal</header>\n<p>\n<textarea id=\"T256_2\" name=\"Procedure\">After the procedure was explained to the patient, the patient was placed supine on a cart. The retention balloon of the gastrostomy tube was deflated. The area was cleansed with chloroprep. The gastrostomy tube was removed. Pressure was achieved at the entry site of the gastrostomy tube. </textarea>\n</p>\n</section>\n<section data-section-name=\"Clinical information\">\n<header class=\"level1\">Clinical information</header>\n<p>\n<textarea id=\"T256_3\" name=\"Clinical information\">Gastrostomy tube no longer needed. </textarea>\n</p>\n</section>\n<section data-section-name=\"Comparison\">\n<header class=\"level1\">Comparison</header>\n<p>\n<textarea id=\"T256_4\" name=\"Comparison\">None. </textarea>\n</p>\n</section>\n<section data-section-name=\"Findings\">\n<header class=\"level1\">Findings</header>\n<p>\n<textarea id=\"T256_6\" name=\"Findings\">The patient tolerated the procedure well and without complications. </textarea>\n</p>\n</section>\n<section data-section-name=\"Impression\">\n<header class=\"level1\">Impression</header>\n<p>\n<textarea id=\"T256_7\" name=\"Impression\">Gastrostomy tube removed. Education provided.  Written and verbal discharge instructions were given to patient for signs and symptoms to report. Patient also advised if any of the symptoms were severe or life threatening the patient was to call 911 or report to the nearest emergency room. Patient verbalizes understanding and all questions were answered.  </textarea>\n</p>\n</section>\n</body>\n</html>\n",

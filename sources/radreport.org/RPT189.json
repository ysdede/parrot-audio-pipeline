    "templateData": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\"/>\n<meta content=\"PICC Removal\" name=\"dcterms.title\"/>\n<meta content=\"PICC Removal template\" name=\"dcterms.description\"/>\n<meta content=\"http://www.radreport.org/template/0000189\" name=\"dcterms.identifier\"/>\n<meta content=\"en\" name=\"dcterms.language\"/>\n<meta content=\"IMAGE_REPORT_TEMPLATE\" name=\"dcterms.type\"/>\n<meta content=\"Radiological Society of North America (RSNA)\" name=\"dcterms.publisher\"/>\n<meta content=\"May be used gratis, subject to license agreement\" name=\"dcterms.rights\"/>\n<meta content=\"http://www.radreport.org/license.pdf\" name=\"dcterms.license\"/>\n<meta content=\"2012-05-29\" name=\"dcterms.date\"/>\n<meta content=\"Kahn CE Jr\" name=\"dcterms.creator\"/>\n\n<meta content=\"Kahn CE Jr [editor]\" name=\"dcterms.contributor\"/>\n<meta content=\"Medical College of Wisconsin (MCW)\" name=\"dcterms.contributor\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"IHE_Template_Style.css\" />\n<!-- The absolute link to the CSS file is http://www.radreport.org/html/IHE_Template_Style.css -->\n<script type=\"text/xml\">\r\n<!--\r\n<template_attributes>\n<top-level-flag>true</top-level-flag>\n<status>ACTIVE</status>\n<coding_schemes>\n <coding_scheme name=\"RadLex\" designator=\"2.16.840.1.113883.6.256\" />\n <coding_scheme name=\"SNOMEDCT\" designator=\"2.16.840.1.113883.6.96\" />\n <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\" />\n</coding_schemes>\n<term>\n <code meaning=\"catheter\" value=\"RID5576\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"peripheral intravenous central catheter\" value=\"RID5581\" scheme=\"RadLex\">\n</term>\n<coded_content>\n<entry ORIGTXT=\"T189_2\">\n <term>\n  <code meaning=\"procedure\" value=\"RID1559\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T189_3\">\n  <term>\n  <code meaning=\"Clinical information\" value=\"55752-0\" scheme=\"LOINC\">\n </term>\n</entry>\n<entry ORIGTXT=\"T189_4\">\n <term>\n  <code meaning=\"comparison\" value=\"RID28483\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T189_8\">\n <term>\n  <code meaning=\"none\" value=\"RID28454\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T189_9\">\n <term>\n  <code meaning=\"impression section\" value=\"RID13170\" scheme=\"RadLex\">\n </term>\n</entry>\n</coded_content>\n</template_attributes>\r\n-->\r\n</script>\n<title>PICC Removal</title>\n</head>\n<body>\n<section data-section-name=\"Procedure\">\n<header class=\"level1\">PICC Removal</header>\n<p>\n<textarea id=\"T189_2\" name=\"Procedure\">After the procedure was explained to the patient, the patient was placed supine on a cart. The dressing was removed from the PICC line. The area was prepped in sterile fashion. The retention suture was cut. While the patient was holding his breath on inhalation and bearing down, the PICC line was removed. Pressure was held at the site. Hemostasis was achieved. A pressure dressing was applied. </textarea>\n</p>\n</section>\n<section data-section-name=\"Clinical information\">\n<header class=\"level1\">Clinical information</header>\n<p>\n<textarea id=\"T189_3\" name=\"Clinical information\">PICC no longer needed. </textarea>\n</p>\n</section>\n<section data-section-name=\"Comparison\">\n<header class=\"level1\">Comparison</header>\n<p>\n<textarea id=\"T189_4\" name=\"Comparison\" value=\"None\" data-codedcontent-default-val=\"None\" data-codedcontent-default-ref=\"T189_4\">None.</textarea>\n</p>\n</section>\n<section data-section-name=\"Findings\">\n<header class=\"level1\">Findings</header>\n<p>\n<label for=\"T189_8\">Complications:</label>\n<input type=\"text\" id=\"T189_8\" name=\"Complications\" value=\"No immediate complications. \"/>\n</p>\n</section>\n<section data-section-name=\"Impression\">\n<header class=\"level1\">Impression</header>\n<p>\n<textarea id=\"T189_9\" name=\"Impression\">PICC removal. No immediate complication </textarea>\n</p>\n</section>\n</body>\n</html>\n",

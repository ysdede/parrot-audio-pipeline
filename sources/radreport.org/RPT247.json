    "templateData": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\"/>\n<meta content=\"Tc-99m WBC Scan\" name=\"dcterms.title\"/>\n<meta content=\"Tc-99m WBC Scan template :: Authored by Imani F\" name=\"dcterms.description\"/>\n<meta content=\"http://www.radreport.org/template/0000247\" name=\"dcterms.identifier\"/>\n<meta content=\"en\" name=\"dcterms.language\"/>\n<meta content=\"IMAGE_REPORT_TEMPLATE\" name=\"dcterms.type\"/>\n<meta content=\"Radiological Society of North America (RSNA)\" name=\"dcterms.publisher\"/>\n<meta content=\"May be used gratis, subject to license agreement\" name=\"dcterms.rights\"/>\n<meta content=\"http://www.radreport.org/license.pdf\" name=\"dcterms.license\"/>\n<meta content=\"2012-09-17\" name=\"dcterms.date\"/>\n<meta content=\"Imani F\" name=\"dcterms.creator\"/>\n\n<meta content=\"Kahn CE Jr [editor]\" name=\"dcterms.contributor\"/>\n<meta content=\"UCLA Health System (UCLA)\" name=\"dcterms.contributor\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"IHE_Template_Style.css\"/>\n<!-- The absolute link to the CSS file is http://www.radreport.org/html/IHE_Template_Style.css -->\n<script type=\"text/xml\">\r\n<!--\r\n<template_attributes>\n<top-level-flag>true</top-level-flag>\n<status>ACTIVE</status>\n<coding_schemes>\n <coding_scheme name=\"RadLex\" designator=\"2.16.840.1.113883.6.256\" />\n <coding_scheme name=\"SNOMEDCT\" designator=\"2.16.840.1.113883.6.96\" />\n <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\" />\n</coding_schemes>\n<term>\n <code meaning=\"Tc-99m exametazine\" value=\"RID11733\" scheme=\"RadLex\">\n</term>\n<coded_content>\n<entry ORIGTXT=\"T247_6\">\n  <term>\n  <code meaning=\"Clinical information\" value=\"55752-0\" scheme=\"LOINC\">\n </term>\n</entry>\n<entry ORIGTXT=\"T247_7\">\n <term>\n  <code meaning=\"comparison\" value=\"RID28483\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T247_9\">\n  <term>\n  <code meaning=\"Radiology Study observation (narrative)\" value=\"18782-3\" scheme=\"LOINC\">\n </term>\n</entry>\n<entry ORIGTXT=\"T247_12\">\n <term>\n  <code meaning=\"impression section\" value=\"RID13170\" scheme=\"RadLex\">\n </term>\n</entry>\n</coded_content>\n</template_attributes>\r\n-->\r\n</script>\n<title>Tc-99m WBC Scan</title>\n</head>\n<body>\n<section data-section-name=\"Procedure\">\n<header class=\"level1\">Tc-99m WBC Scan</header>\n<p>\n<label for=\"T247_3\">Radiopharmaceutical:</label>\n<input type=\"text\" id=\"T247_3\" name=\"Radiopharmaceutical\" value=\"Autologous Tc-99m HMPAO-labeled white blood cells\"/>\n</p>\n<p>\n<label for=\"T247_4\">Dose:</label>\n<input type=\"number\" id=\"T247_4\" name=\"Dose\" value=\"20\"/> mCi\n</p>\n</section>\n<section data-section-name=\"Clinical information\">\n<header class=\"level1\">Clinical information</header>\n<p>\n<textarea id=\"T247_6\" name=\"Clinical information\"> </textarea>\n</p>\n</section>\n<section data-section-name=\"Comparison\">\n<header class=\"level1\">Comparison</header>\n<p>\n<textarea id=\"T247_7\" name=\"Comparison\">None. </textarea>\n</p>\n</section>\n<section data-section-name=\"Findings\">\n<header class=\"level1\">Findings</header>\n<p>\n<textarea id=\"T247_9\" name=\"Findings\">Normal physiological tracer activity is noted in the liver and spleen and in the bone marrow of the axial and appendicular skeleton. </textarea>\n</p>\n</section>\n<section data-section-name=\"Impression\">\n<header class=\"level1\">Impression</header>\n<p>\n<textarea id=\"T247_12\" name=\"Impression\">Normal white blood cell scan. No evidence for abnormal tracer activity. </textarea>\n</p>\n</section>\n</body>\n</html>\n",

    "templateData": "<!DOCTYPE html>\n<html>\n    <head>\n        <title>Neuro CT Head Trauma</title>\n        <meta charset=\"UTF-8\" />\n        <meta name=\"dcterms.identifier\" content=\"3e279844-5cea-49fa-b5cd-afe0c3b8384a\" />\n        <meta name=\"dcterms.title\" content=\"Neuro CT Head Trauma\" />\n        <meta name=\"dcterms.description\" content=\"\" />\n        <meta name=\"dcterms.type\" content=\"IMAGE_REPORT_TEMPLATE\" />\n        <meta name=\"dcterms.language\" content=\"en\" />\n        <meta name=\"dcterms.publisher\" content=\"University of Utah\" />\n        <meta name=\"dcterms.rights\" content=\"May be used freely, subject to license agreement\" />\n        <meta name=\"dcterms.license\" content=\"http://www.radreport.org/license.pdf\" />\n        <meta name=\"dcterms.date\" content=\"2018-03-12\" />\n        <meta name=\"dcterms.creator\" content=\"Marta E. Heilbrun, MD\" />\n        <script type=\"text/xml\">\n            <template_attributes>\n                <coded_content>\n                    <coding_schemes>\n                        <coding_scheme name=\"RADLEX\" designator=\"2.16.840.1.113883.6.256\"></coding_scheme>\n                        <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\"></coding_scheme>\n                    </coding_schemes>\n                    <entry origtxt=\"TEXT_1520910973738\">\n                        <term>\n                            <code meaning=\"hemorrhage\" value=\"RID4700\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1520910973739\">\n                        <term>\n                            <code meaning=\"ventricular system of neuraxis\" value=\"RID13477\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"findings\">\n                        <term>\n                            <code meaning=\"Procedure Findings\" value=\"59776-5\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476470790511\">\n                        <term>\n                            <code meaning=\"normal\" value=\"RID13173\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459563191791\">\n                        <term>\n                            <code meaning=\"indication\" value=\"RID49442\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1520910973740\">\n                        <term>\n                            <code meaning=\"musculoskeletal system\" value=\"RID13209\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1520910973741\">\n                        <term>\n                            <code meaning=\"paranasal sinuses\" value=\"RID28579\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1520910973742\">\n                        <term>\n                            <code meaning=\"orbits\" value=\"RID28601\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"findingsText\">\n                        <term>\n                            <code meaning=\"postsurgical fluid collection\" value=\"RID49691\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"procedureInformation\">\n                        <term>\n                            <code meaning=\"Current Imaging Procedure Description\" value=\"55111-9\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"comparisons\">\n                        <term>\n                            <code meaning=\"Radiology Comparison Study\" value=\"18834-2\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"impression\">\n                        <term>\n                            <code meaning=\"Impressions\" value=\"19005-8\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"clinicalInformation\">\n                        <term>\n                            <code meaning=\"Clinical Information\" value=\"55752-0\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                </coded_content>\n            </template_attributes>\n        </script>\n    </head>\n    <body>\n        <section id=\"procedureInformation\" class=\"level1\" data-section-name=\"Procedure Information\">\n            <header class=\"level1\">\n                Procedure Information\n            </header>\n            <p title=\"\">\n                <label for=\"TEXT_1459563191790\">Technique:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459563191790\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Axial noncontrast images were obtained from the skull base to the vertex, with no contrast administered.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1459563191792\">Date of Examination:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459563191792\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n        </section>\n        <section id=\"clinicalInformation\" class=\"level1\" data-section-name=\"Clinical Information\">\n            <header class=\"level1\">\n                Clinical Information\n            </header>\n            <p title=\"\">\n                <label for=\"TEXT_1459563191791\">Indication:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459563191791\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">None.</textarea>\n            </p>\n        </section>\n        <section id=\"comparisons\" class=\"level1\" data-section-name=\"Comparison\">\n            <header class=\"level1\">\n                Comparison\n            </header>\n            <p title=\"\">\n                <label for=\"comparisonsText\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"comparisonsText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">None.</textarea>\n            </p>\n        </section>\n        <section id=\"findings\" class=\"level1\" data-section-name=\"Findings\">\n            <header class=\"level1\">\n                Findings\n            </header>\n            <p title=\"\">\n                <label for=\"findingsText\">Fluid Collection:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"findingsText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">There is no evidence of an intra-axial or extra-axial fluid collection.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1520910973738\">Acute Hemorrhage:</label>\n                <input type=\"text\" id=\"TEXT_1520910973738\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\" value=\"No evidence of acute hemorrhage, mass effect or midline shift. \" />\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1520910973739\">Ventricular System:</label>\n                <input type=\"text\" id=\"TEXT_1520910973739\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\" value=\"The ventricular system and basal cisterns are patent.\" />\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1520910973740\">Bone Window:</label>\n                <input type=\"text\" id=\"TEXT_1520910973740\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\" value=\" Bone windows reveal no evidence of acute fracture.\" />\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1520910973741\">Paranasal Sinuses:</label>\n                <input type=\"text\" id=\"TEXT_1520910973741\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\" value=\" The visualized paranasal sinuses are within normal limits. \" />\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1520910973742\">Orbits:</label>\n                <input type=\"text\" id=\"TEXT_1520910973742\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\" value=\"The orbits are grossly unremarkable.\" />\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1520910973743\">Additional Findings:</label>\n                <input type=\"text\" id=\"TEXT_1520910973743\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\" value=\"None.\" />\n            </p>\n        </section>\n        <section id=\"impression\" class=\"level1\" data-section-name=\"Impression\">\n            <header class=\"level1\">\n                Impression\n            </header>\n            <p title=\"\">\n                <label for=\"TEXT_1476470790511\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476470790511\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n            </p>\n        </section>\n    </body>\n</html>\n",

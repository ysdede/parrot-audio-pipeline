1476401433905_1\" value=\"Fallopian tube\" name=\"SELECTION_LIST_1476401433905\">Fallopian tube</option>\n                        <option id=\"SELECTION_LIST_1476401433905_2\" value=\"Parovarian| Peritoneal\" name=\"SELECTION_LIST_1476401433905\">Parovarian| Peritoneal</option>\n                    </select>\n                </p>\n                <p title=\"\">\n                    <label for=\"NUMBER_1476401433909\">Image series, Image number:</label>\n                    <span>\n                        <input type=\"number\" step=\"1.0\" data-field-units=\"\" id=\"NUMBER_1476401433909\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    </span>\n                </p>\n            </section>\n            <section id=\"SECTION_HEADER_1476401433910\" class=\"level2\" data-section-name=\"Solid adnexal mass:\">\n                <header class=\"level2\">\n                    Solid adnexal mass:\n                </header>\n                <p title=\"\">\n                    <label for=\"NUMBER_1476401433911\">Number:</label>\n                    <span>\n                        <input type=\"number\" step=\"1.0\" data-field-units=\"\" id=\"NUMBER_1476401433911\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    </span>\n                </p>\n                <p title=\"\">\n                    <label for=\"NUMBER_1476401433912\">Size (of largest mass):</label>\n                    <span>\n                        <input type=\"number\" step=\"1.0\" data-field-units=\"cm\" id=\"NUMBER_1476401433912\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                        cm\n                    </span>\n                </p>\n                <p title=\"\">\n                    <label for=\"SELECTION_LIST_1476401433913\">Solid tissue components:</label>\n                    <select id=\"SELECTION_LIST_1476401433913\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Fibrosis/smooth muscle\">\n                        <option id=\"SELECTION_LIST_1476401433913_0\" value=\"Fibrosis/smooth muscle\" name=\"SELECTION_LIST_1476401433913\" selected=\"\">Fibrosis/smooth muscle</option>\n                        <option id=\"SELECTION_LIST_1476401433913_1\" value=\"Papillary projections\" name=\"SELECTION_LIST_1476401433913\">Papillary projections</option>\n                        <option id=\"SELECTION_LIST_1476401433913_2\" value=\"Non-specific solid tissue\" name=\"SELECTION_LIST_1476401433913\">Non-specific solid tissue</option>\n                        <option id=\"SELECTION_LIST_1476401433913_3\" value=\"Solid nodular components\" name=\"SELECTION_LIST_1476401433913\">Solid nodular components</option>\n                    </select>\n                </p>\n                <p title=\"\">\n                    <label for=\"SELECTION_LIST_1476401433930\">Enhancement pattern:</label>\n                    <select id=\"SELECTION_LIST_1476401433930\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Homogeneous\">\n                        <option id=\"SELECTION_LIST_1476401433930_0\" value=\"Homogeneous\" name=\"SELECTION_LIST_1476401433930\" selected=\"\">Homogeneous</option>\n                        <option id=\"SELECTION_LIST_1476401433930_1\" value=\"Heterogeneous\" name=\"SELECTION_LIST_1476401433930\">Heterogeneous</option>\n                        <option id=\"SELECTION_LIST_1476401433930_2\" value=\"Absent\" name=\"SELECTION_LIST_1476401433930\">Absent</option>\n                    </select>\n                </p>\n                <p title=\"\">\n                    <label for=\"SELECTION_LIST_1476401433925\">Location:</label>\n                    <select id=\"SELECTION_LIST_1476401433925\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Ovary\">\n                        <option id=\"SELECTION_LIST_1476401433925_0\" value=\"Ovary\" name=\"SELECTION_LIST_1476401433925\" selected=\"\">Ovary</option>\n                        <option id=\"SELECTION_LIST_1476401433925_1\" value=\"Fallopian tube\" name=\"SELECTION_LIST_1476401433925\">Fallopian tube</option>\n                        <option id=\"SELECTION_LIST_1476401433925_2\" value=\"Parovarian| Peritoneal\" name=\"SELECTION_LIST_1476401433925\">Parovarian| Peritoneal</option>\n                    </select>\n                </p>\n            </section>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476401433934\">Uterus:</label>\n                <select id=\"SELECTION_LIST_1476401433934\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Anteverted\">\n                    <option id=\"SELECTION_LIST_1476401433934_0\" value=\"Anteverted\" name=\"SELECTION_LIST_1476401433934\" selected=\"\">Anteverted</option>\n                    <option id=\"SELECTION_LIST_1476401433934_1\" value=\"Retroverted\" name=\"SELECTION_LIST_1476401433934\">Retroverted</option>\n                    <option id=\"SELECTION_LIST_1476401433934_2\" value=\"Retroflexed\" name=\"SELECTION_LIST_1476401433934\">Retroflexed</option>\n                    <option id=\"SELECTION_LIST_1476401433934_3\" value=\"Displaced to left\" name=\"SELECTION_LIST_1476401433934\">Displaced to left</option>\n                    <option id=\"SELECTION_LIST_1476401433934_4\" value=\"Displaced to right\" name=\"SELECTION_LIST_1476401433934\">Displaced to right</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476401433940\">Size:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476401433940\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Normal in size</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476401433946\">Measuring:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"cm\" id=\"NUMBER_1476401433946\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    cm\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476401433947\">Endometrium:</label>\n                <select id=\"SELECTION_LIST_1476401433947\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Normal\">\n                    <option id=\"SELECTION_LIST_1476401433947_0\" value=\"Normal\" name=\"SELECTION_LIST_1476401433947\" selected=\"\">Normal</option>\n                    <option id=\"SELECTION_LIST_1476401433947_1\" value=\"Abnormal\" name=\"SELECTION_LIST_1476401433947\">Abnormal</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476401433950\">The maximum width of the endometrium:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"mm\" id=\"NUMBER_1476401433950\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    mm\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476401433951\">Junctional zone:</label>\n                <select id=\"SELECTION_LIST_1476401433951\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"There is no adenomyosis. \">\n                    <option id=\"SELECTION_LIST_1476401433951_0\" value=\"There is no adenomyosis.\" name=\"SELECTION_LIST_1476401433951\">There is no adenomyosis.</option>\n                    <option id=\"SELECTION_LIST_1476401433951_1\" value=\"There is mild adenomyosis.\" name=\"SELECTION_LIST_1476401433951\">There is mild adenomyosis.</option>\n                    <option id=\"SELECTION_LIST_1476401433951_2\" value=\"There is moderate adenomyosis.\" name=\"SELECTION_LIST_1476401433951\">There is moderate adenomyosis.</option>\n                    <option id=\"SELECTION_LIST_1476401433951_3\" value=\"There is severe adenomyosis.\" name=\"SELECTION_LIST_1476401433951\">There is severe adenomyosis.</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476401433956\">Outer Myometrium:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476401433956\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There are no leiomyomas.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476401433957\">Cervix:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476401433957\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Unremarkable</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476401433958\">Vagina:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476401433958\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Unremarkable</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476401433959\">Bladder wall:</label>\n                <select id=\"SELECTION_LIST_1476401433959\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Invaded\">\n                    <option id=\"SELECTION_LIST_1476401433959_0\" value=\"Invaded\" name=\"SELECTION_LIST_1476401433959\" selected=\"\">Invaded</option>\n                    <option id=\"SELECTION_LIST_1476401433959_1\" value=\"Not Invaded\" name=\"SELECTION_LIST_1476401433959\">Not Invaded</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476401433962\">Rectal wall:</label>\n                <select id=\"SELECTION_LIST_1476401433962\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Invaded\">\n                    <option id=\"SELECTION_LIST_1476401433962_0\" value=\"Invaded\" name=\"SELECTION_LIST_1476401433962\" selected=\"\">Invaded</option>\n                    <option id=\"SELECTION_LIST_1476401433962_1\" value=\"Not invaded\" name=\"SELECTION_LIST_1476401433962\">Not invaded</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476401433965\">Abdominal/Pelvic wall:</label>\n                <select id=\"SELECTION_LIST_1476401433965\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Invaded\">\n                    <option id=\"SELECTION_LIST_1476401433965_0\" value=\"Invaded\" name=\"SELECTION_LIST_1476401433965\" selected=\"\">Invaded</option>\n                    <option id=\"SELECTION_LIST_1476401433965_1\" value=\"Not invaded\" name=\"SELECTION_LIST_1476401433965\">Not invaded</option>\n                </select>\n            </p>\n            <p title=\"There is no surface, subcapsular or parenchymal liver and spleen metastases.\">\n                <label for=\"SELECTION_LIST_1476401433968\">Liver and spleen metastases</label>\n                <select id=\"SELECTION_LIST_1476401433968\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"\">\n                    <option id=\"SELECTION_LIST_1476401433968_0\" value=\"\" name=\"SELECTION_LIST_1476401433968\" selected=\"\"></option>\n                    <option id=\"SELECTION_LIST_1476401433968_1\" value=\"\" name=\"SELECTION_LIST_1476401433968\" selected=\"\"></option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476402700492\">Hydronephrosis:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476402700492\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no hydronephrosis.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476402700493\">Ascites:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476402700493\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no ascites.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476402700494\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476402700494\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no omental metastases/other peritoneal/serosal implants/ supracolic sites of disease including the gastrohepatic, gastrosplenic and splenocolic ligaments.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476402700495\">Lymph nodes:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476402700495\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There are no lymph nodes with a short-axis diameter of &gt;1 cm, or suspicious clusters of smaller lymph nodes.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476402700496\">Venous obstruction/thrombosis:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476402700496\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no venous obstruction/thrombosis.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476402700497\">Bones:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476402700497\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Normal</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476403208762\">Other findings:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476403208762\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n        </section>\n        <section id=\"impression\" class=\"level1\" data-section-name=\"Impression\">\n            <header class=\"level1\">\n                Impression\n            </header>\n            <p title=\"\">\n                <label for=\"impressionText\">Impression:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"impressionText\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n        </section>\n    </body>\n</html>\n",

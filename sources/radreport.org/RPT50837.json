    "templateData": "<!DOCTYPE html>\n<html>\n    <head>\n        <title>Ovarian Cancer Staging MRI</title>\n        <meta charset=\"UTF-8\" />\n        <meta name=\"dcterms.identifier\" content=\"d8e9de6e-7b28-4638-a605-15718959ae12\" />\n        <meta name=\"dcterms.title\" content=\"Ovarian Cancer Staging MRI\" />\n        <meta name=\"dcterms.description\" content=\"\" />\n        <meta name=\"dcterms.type\" content=\"IMAGE_REPORT_TEMPLATE\" />\n        <meta name=\"dcterms.language\" content=\"en\" />\n        <meta name=\"dcterms.publisher\" content=\"ESR\" />\n        <meta name=\"dcterms.rights\" content=\"May be used freely, subject to license agreement\" />\n        <meta name=\"dcterms.license\" content=\"http://www.radreport.org/license.pdf\" />\n        <meta name=\"dcterms.date\" content=\"2017-10-06\" />\n        <meta name=\"dcterms.creator\" content=\"Teresa Margarida Cunha, MD\" />\n        <meta name=\"dcterms.contributor\" content=\"Rita Lucas, MD\" />\n        <script type=\"text/xml\">\n            <template_attributes>\n                <coded_content>\n                    <coding_schemes>\n                        <coding_scheme name=\"RADLEX\" designator=\"2.16.840.1.113883.6.256\"></coding_scheme>\n                    </coding_schemes>\n                    <entry origtxt=\"impressionText\">\n                        <term>\n                            <code meaning=\"impression section\" value=\"RID13170\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1476401433934\">\n                        <term>\n                            <code meaning=\"uterus\" value=\"RID302\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476401433864\">\n                        <term>\n                            <code meaning=\"pleural effusion\" value=\"RID34539\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"comparisonsText\">\n                        <term>\n                            <code meaning=\"comparison\" value=\"RID28483\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1476401433846\">\n                        <term>\n                            <code meaning=\"procedure\" value=\"RID1559\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1476401433947\">\n                        <term>\n                            <code meaning=\"endometrium\" value=\"RID30958\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476402700492\">\n                        <term>\n                            <code meaning=\"hydronephrosis\" value=\"RID34393\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476402700493\">\n                        <term>\n                            <code meaning=\"ascites\" value=\"RID1541\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1476401433959\">\n                        <term>\n                            <code meaning=\"wall of urinary bladder\" value=\"RID30135\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476401433958\">\n                        <term>\n                            <code meaning=\"vagina\" value=\"RID325\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1476401433962\">\n                        <term>\n                            <code meaning=\"wall of rectum\" value=\"RID32936\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476401433850\">\n                        <term>\n                            <code meaning=\"clinical information section\" value=\"RID13166\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                </coded_content>\n            </template_attributes>\n        </script>\n    </head>\n    <body>\n        <section id=\"procedureInformation\" class=\"level1\" data-section-name=\"Procedure Information\">\n            <header class=\"level1\">\n                Procedure Information\n            </header>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476401433846\">Procedure Type:</label>\n                <select id=\"SELECTION_LIST_1476401433846\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Enhanced abdominal and pelvis female MRI\">\n                    <option id=\"SELECTION_LIST_1476401433846_0\" value=\"Enhanced abdominal and pelvis female MRI\" name=\"SELECTION_LIST_1476401433846\" selected=\"\">Enhanced abdominal and pelvis female MRI</option>\n                    <option id=\"SELECTION_LIST_1476401433846_1\" value=\"Unenhanced abdominal and pelvis female MRI\" name=\"SELECTION_LIST_1476401433846\">Unenhanced abdominal and pelvis female MRI</option>\n                </select>\n            </p>\n     <p title=\"\">\n                <label for=\"TEXT_1476401433852\">Technique:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476401433852\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">T1- weighted sequence, T2- weighted sequence of the pelvis in axial, sagittal and coronal planes, and T2W with fat saturation (FS).</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476401433854\">Type of pre and post contrast imaging of the pelvis:</label>\n                <select id=\"SELECTION_LIST_1476401433854\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Dynamic\">\n                    <option id=\"SELECTION_LIST_1476401433854_0\" value=\"Dynamic\" name=\"SELECTION_LIST_1476401433854\" selected=\"\">Dynamic</option>\n                    <option id=\"SELECTION_LIST_1476401433854_1\" value=\"Non-dynamic\" name=\"SELECTION_LIST_1476401433854\">Non-dynamic</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476401433857\">Strength of Tesla scanner:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"\" id=\"NUMBER_1476401433857\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476401433858\">Contrast type:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476401433858\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476401433859\">Contrast dose administered before and after fat suppressed T1-weighted imaging</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"mL\" id=\"NUMBER_1476401433859\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    mL\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476401433860\">DW-MRI study was also performed.</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476401433860\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476401433861\">Image quality:</label>\n                <select id=\"SELECTION_LIST_1476401433861\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Satisfactory\">\n                    <option id=\"SELECTION_LIST_1476401433861_0\" value=\"Satisfactory\" name=\"SELECTION_LIST_1476401433861\" selected=\"\">Satisfactory</option>\n                    <option id=\"SELECTION_LIST_1476401433861_1\" value=\"Degraded by motion/etc\" name=\"SELECTION_LIST_1476401433861\">Degraded by motion/etc</option>\n                </select>\n            </p>\n        </section>\n        <section id=\"clinicalInformation\" class=\"level1\" data-section-name=\"Clinical Information\">\n            <header class=\"level1\">\n                Clinical Information\n            </header>\n            <p title=\"\">\n                <label for=\"TEXT_1476401433850\">Clinical Indication:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476401433850\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Ovarian cancer staging</textarea>\n            </p>\n               </section>\n        <section id=\"comparisons\" class=\"level1\" data-section-name=\"Comparison\">\n            <header class=\"level1\">\n                Comparison\n            </header>\n            <p title=\"\">\n                <label for=\"comparisonsText\">Comparison study:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"comparisonsText\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">None available</textarea>\n            </p>\n        </section>\n        <section id=\"findings\" class=\"level1\" data-section-name=\"Findings\">\n            <header class=\"level1\">\n                Findings\n            </header>\n            <p title=\"\">\n                <label for=\"findingsText\">Cardiophrenic lymph nodes:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"findingsText\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Cardiophrenic lymph nodes with a short-axis diameter of &gt;5 mm.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476401433864\">Pleural effusion:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476401433864\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no pleural effusion.</textarea>\n            </p>\n            <section id=\"SECTION_HEADER_1476401433866\" class=\"level2\" data-section-name=\"Cystic Adnexal  Masses:  \">\n                <header class=\"level2\">\n                    Cystic Adnexal Masses: \n                </header>\n                <p title=\"\">\n                    <label for=\"NUMBER_1476401433867\">Number:</label>\n                    <span>\n                        <input type=\"number\" step=\"1.0\" data-field-units=\"\" id=\"NUMBER_1476401433867\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    </span>\n                </p>\n                <p title=\"\">\n                    <label for=\"NUMBER_1476401433868\">Size (of largest cystic mass):</label>\n                    <span>\n                        <input type=\"number\" step=\"1.0\" data-field-units=\"cm\" id=\"NUMBER_1476401433868\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                        cm\n                    </span>\n                </p>\n                <p title=\"\">\n                    <label for=\"SELECTION_LIST_1476401433869\">Tissue components:</label>\n                    <select id=\"SELECTION_LIST_1476401433869\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Unilocular\">\n                        <option id=\"SELECTION_LIST_147640
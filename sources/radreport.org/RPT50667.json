    "templateData": "<html><head><meta charset=\"UTF-8\"><meta content=\"base mri tmj contrast\" name=\"dcterms.title\"><meta content=\"ba9d720a-a75c-42af-bda6-d50924e135d1\" name=\"dcterms.identifier\"><meta content=\"en\" name=\"dcterms.language\"><meta content=\"2019-01-31\" name=\"dcterms.date\"><meta content=\"Nuance System\" name=\"dcterms.creator\"><title>base mri tmj contrast</title></head><body><section data-section-name=\"MRI TEMPOROMANDIBULAR JOINTS WITH CONTRAST\"><header class=\"Level1\">MRI TEMPOROMANDIBULAR JOINTS WITH CONTRAST</header><p><label>HISTORY:</label><input type=\"text\" name=\"Patient Age\" value=\"Patient Age\"></p><p><label> old </label><input type=\"text\" name=\"Patient Gender\" value=\"Patient Gender\"></p><p><label>, </label><input type=\"text\" name=\"history\" value=\"jaw pain.\"></p></section><section data-section-name=\"TECHNIQUE:\"><header class=\"Level1\">TECHNIQUE:</header><p><label>MR images of the bilateral temporomandibular joints were acquired without and with </label><input type=\"number\" name=\"contrast dose\"><label>mL Gadavist intravenous contrast.</label></p><p><label>COMPARISON: </label><input type=\"text\" name=\"Comparison\" value=\"None available.\"></p></section><section data-section-name=\"FINDINGS:\"><header class=\"Level1\">FINDINGS:</header><p><label>RIGHT TMJ</label><br><label>MANDIBULAR CONDYLE: </label><input type=\"text\" name=\"right condyle\" value=\"Normal morphology and signal. Condyle is well seated within the mandibular fossa on the closed-mouth view and appropriately translates to the level of the articular eminence on the open-mouth view.\"></p><p><label>  </label><input type=\"text\" name=\"right enhancement\" value=\"No abnormal enhancement.\"></p><p><label>ARTICULAR DISC: </label><input type=\"text\" name=\"right articular disc\" value=\"Normal position in closed and open mouth positions with normal capturing. Normal signal and bowtie morphology.\"></p></section><section data-section-name=\"LEFT TMJ\"><header class=\"Level1\">LEFT TMJ</header><p><label>MANDIBULAR CONDYLE: </label><input type=\"text\" name=\"left condyle\" value=\"Normal morphology and signal. Condyle is well seated within the mandibular fossa on the closed-mouth view and appropriately translates to the level of the articular eminence on the open-mouth view.\"></p><p><label>  </label><input type=\"text\" name=\"left enhancement\" value=\"No abnormal enhancement.\"></p><p><label>ARTICULAR DISC: </label><input type=\"text\" name=\"left articular disc\" value=\"Normal position in closed and open mouth positions with normal capturing. Normal signal and bowtie morphology.\"></p><p><label>OTHER: </label><input type=\"text\" name=\"other\" value=\"None.\"></p></section><section data-section-name=\"IMPRESSION:\"><header class=\"Level1\">IMPRESSION:</header><p><textarea name=\"impression\">Normal MRI temporomandibular joints.</textarea></p></section></body></html>",

me=\"Clinical information\">\n<header class=\"level1\">Clinical information</header>\n<p>\n<!-- <label for=\"T142_7\">Clinical information</label> -->\n<textarea id=\"T142_7\" name=\"Clinical information\"></textarea>\n</p>\n</section>\n<section data-section-name=\"Comparison\">\n<header class=\"level1\">Comparison</header>\n<p>\n<!-- <label for=\"T142_8\">Comparison</label> -->\n<input type=\"text\" id=\"T142_8\" name=\"Comparison\" value=\"None.\" data-codedcontent-default-val=\"None\" data-codedcontent-default-ref=\"T142_9\"/>\n</p>\n</section>\n<section data-section-name=\"Findings\">\n<header class=\"level1\">Findings</header>\n<p>\n<label for=\"T142_11\">Bones:</label>\n<input type=\"text\" id=\"T142_12\" name=\"Bones\" value=\"Normal anatomic alignment. No fracture or dislocation.\"/>\n</p>\n<p>\n<label for=\"T142_13\">Mineralization:</label>\n<input type=\"text\" id=\"T142_13\" name=\"Mineralization\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T142_14\">Joints:</label>\n<input type=\"text\" id=\"T142_14\" name=\"Joints\" value=\"Normal. No arthritis.\"/>\n</p>\n<p>\n<label for=\"T142_19\">Other findings:</label>\n<input type=\"text\" id=\"T142_19\" name=\"Other findings\" value=\"None.\"/>\n</p>\n</section>\n<section data-section-name=\"Impression\">\n<header class=\"level1\">Impression</header>\n<p>\n<textarea id=\"T142_24\" name=\"Impression\">Normal. No fracture or dislocation.</textarea>\n</p>\n</section>\n</body>\n</html>\n",

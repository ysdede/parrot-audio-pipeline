    "templateData": "<!DOCTYPE html>\n<html>\n    <head>\n        <title>Trophoblastic Diseases CT</title>\n        <meta charset=\"UTF-8\" />\n        <meta name=\"dcterms.identifier\" content=\"9a4d05bf-61b4-4643-b65b-b338904b2fe3\" />\n        <meta name=\"dcterms.title\" content=\"Trophoblastic Diseases CT\" />\n        <meta name=\"dcterms.description\" content=\"\" />\n        <meta name=\"dcterms.type\" content=\"IMAGE_REPORT_TEMPLATE\" />\n        <meta name=\"dcterms.language\" content=\"en\" />\n        <meta name=\"dcterms.publisher\" content=\"ESR\" />\n        <meta name=\"dcterms.rights\" content=\"May be used freely, subject to license agreement\" />\n        <meta name=\"dcterms.license\" content=\"http://www.radreport.org/license.pdf\" />\n        <meta name=\"dcterms.date\" content=\"2017-10-06\" />\n        <meta name=\"dcterms.creator\" content=\"Teresa Margarida Cunha, MD\" />\n        <meta name=\"dcterms.contributor\" content=\"Rita Lucas, MD\" />\n        <script type=\"text/xml\">\n            <template_attributes>\n                <coded_content>\n                    <coding_schemes>\n                        <coding_scheme name=\"RADLEX\" designator=\"2.16.840.1.113883.6.256\"></coding_scheme>\n                    </coding_schemes>\n                    <entry origtxt=\"impressionText\">\n                        <term>\n                            <code meaning=\"impression section\" value=\"RID13170\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476402896450\">\n                        <term>\n                            <code meaning=\"clinical information section\" value=\"RID13166\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"comparisonsText\">\n                        <term>\n                            <code meaning=\"comparison\" value=\"RID28483\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1476402896453\">\n                        <term>\n                            <code meaning=\"uterus\" value=\"RID302\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476402896474\">\n                        <term>\n                            <code meaning=\"ascites\" value=\"RID1541\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1476402896467\">\n                        <term>\n                            <code meaning=\"pelvic wall\" value=\"RID30760\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1476402896447\">\n                        <term>\n                            <code meaning=\"procedure\" value=\"RID1559\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476402896462\">\n                        <term>\n                            <code meaning=\"set of ovaries\" value=\"RID39537\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                </coded_content>\n            </template_attributes>\n        </script>\n    </head>\n    <body>\n        <section id=\"procedureInformation\" class=\"level1\" data-section-name=\"Procedure Information\">\n            <header class=\"level1\">\n                Procedure Information\n            </header>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476402896447\">Procedure Type:</label>\n                <select id=\"SELECTION_LIST_1476402896447\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Enhanced CT of the abdomen, thorax and pelvis\">\n                    <option id=\"SELECTION_LIST_1476402896447_0\" value=\"Enhanced CT of the abdomen, thorax and pelvis\" name=\"SELECTION_LIST_1476402896447\" selected=\"\">Enhanced CT of the abdomen, thorax and pelvis</option>\n                    <option id=\"SELECTION_LIST_1476402896447_1\" value=\"Unenhanced CT of the abdomen, thorax and pelvis\" name=\"SELECTION_LIST_1476402896447\">Unenhanced CT of the abdomen, thorax and pelvis</option>\n                </select>\n            </p>\n           <p title=\"\">\n                <label for=\"TEXT_1476402896451\">Technique:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476402896451\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Helical CT of the abdomen, thorax and pelvis Sagittal and coronal reconstructions.</textarea>\n            </p>\n        </section>\n        <section id=\"clinicalInformation\" class=\"level1\" data-section-name=\"Clinical Information\">\n            <header class=\"level1\">\n                Clinical Information\n            </header>\n            <p title=\"\">\n                <label for=\"TEXT_1476402896450\">Clinical Indication:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476402896450\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Trophoblastic disease evaluation</textarea>\n            </p>\n        </section>\n        <section id=\"comparisons\" class=\"level1\" data-section-name=\"Comparison\">\n            <header class=\"level1\">\n                Comparison\n            </header>\n            <p title=\"\">\n                <label for=\"comparisonsText\">Comparison study:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"comparisonsText\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">None available</textarea>\n            </p>\n        </section>\n        <section id=\"findings\" class=\"level1\" data-section-name=\"Findings\">\n            <header class=\"level1\">\n                Findings\n            </header>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476402896453\">Uterus:</label>\n                <select id=\"SELECTION_LIST_1476402896453\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Anteverted\">\n                    <option id=\"SELECTION_LIST_1476402896453_0\" value=\"Anteverted\" name=\"SELECTION_LIST_1476402896453\" selected=\"\">Anteverted</option>\n                    <option id=\"SELECTION_LIST_1476402896453_1\" value=\"Retroverted\" name=\"SELECTION_LIST_1476402896453\">Retroverted</option>\n                    <option id=\"SELECTION_LIST_1476402896453_2\" value=\"Retroflexed\" name=\"SELECTION_LIST_1476402896453\">Retroflexed</option>\n                    <option id=\"SELECTION_LIST_1476402896453_3\" value=\"Displaced to left\" name=\"SELECTION_LIST_1476402896453\">Displaced to left</option>\n                    <option id=\"SELECTION_LIST_1476402896453_4\" value=\"Displaced to right\" name=\"SELECTION_LIST_1476402896453\">Displaced to right</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476402896460\">Size:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476402896460\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Normal in size</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476402896459\">Measuring:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"cm\" id=\"NUMBER_1476402896459\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    cm\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476402896461\">Cervix:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476402896461\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Unremarkable</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476402896462\">Ovaries:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476402896462\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Unremarkable</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476402896463\">Vagina:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476402896463\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Unremarkable</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476402896464\">Tumour:</label>\n                <select id=\"SELECTION_LIST_1476402896464\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Visible\">\n                    <option id=\"SELECTION_LIST_1476402896464_0\" value=\"Visible\" name=\"SELECTION_LIST_1476402896464\" selected=\"\">Visible</option>\n                    <option id=\"SELECTION_LIST_1476402896464_1\" value=\"Not visible confined to the uterus/ extending outside the uterus limited to the genital organs (adnexa, vagina, broad ligament).\" name=\"SELECTION_LIST_1476402896464\">Not visible confined to the uterus/ extending outside the uterus limited to the genital organs (adnexa, vagina, broad ligament).</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476402896467\">Pelvic wall:</label>\n                <select id=\"SELECTION_LIST_1476402896467\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Invaded\">\n                    <option id=\"SELECTION_LIST_1476402896467_0\" value=\"Invaded\" name=\"SELECTION_LIST_1476402896467\" selected=\"\">Invaded</option>\n                    <option id=\"SELECTION_LIST_1476402896467_1\" value=\"Not invaded\" name=\"SELECTION_LIST_1476402896467\">Not invaded</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476402896470\">Lymph nodes:</label>\n                <select id=\"SELECTION_LIST_1476402896470\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Normal in size\">\n                    <option id=\"SELECTION_LIST_1476402896470_0\" value=\"Normal in size\" name=\"SELECTION_LIST_1476402896470\" selected=\"\">Normal in size</option>\n                    <option id=\"SELECTION_LIST_1476402896470_1\" value=\"Enlarged; probably reactive\" name=\"SELECTION_LIST_1476402896470\">Enlarged; probably reactive</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476402896473\">Physiologic pelvic fluid:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476402896473\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no physiologic pelvic fluid.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476402896474\">Ascites:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476402896474\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no ascites.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476402896475\">Liver metastasis:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476402896475\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no liver metastasis.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476402896476\">Lung metastasis:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476402896476\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no lung metastasis.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476402896477\">Pleural metastasis:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476402896477\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no pleural metastasis.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476402896478\">Distant metastasis:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476402896478\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no distant metastasis.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476402896479\">Other findings:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476402896479\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n        </section>\n        <section id=\"impression\" class=\"level1\" data-section-name=\"Impression\">\n            <header class=\"level1\">\n                Impression\n            </header>\n            <p title=\"\">\n                <label for=\"impressionText\">Impression:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"impressionText\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n        </section>\n    </body>\n</html>\n",

\t\t<section data-section-name=\"Procedure\">\n\t\t\t<header class=\"level1\">Esophagogram</header>\n\t\t\t<p>\n\t\t\t\t<!-- <label for=\"T105_2\">Procedure</label> -->\n\t\t\t\t<textarea id=\"T105_2\" name=\"Esophagogram\">Double-contrast examination was performed with barium.</textarea>\n\t\t\t</p>\n\t\t</section>\n\t\t<section data-section-name=\"Clinical information\">\n\t\t\t<header class=\"level1\">Clinical information</header>\n\t\t\t<p>\n\t\t\t\t<!-- <label for=\"T105_9\">Clinical information</label> -->\n\t\t\t\t<textarea id=\"T105_9\" name=\"Clinical information\"></textarea>\n\n\t\t\t</p>\n\t\t</section>\n\t\t<section data-section-name=\"Comparison\">\n\t\t\t<header class=\"level1\">Comparison</header>\n\t\t\t<p>\n\t\t\t\t<!-- <label for=\"T105_21\">Comparison</label> -->\n\t\t\t\t<textarea id=\"T105_21\" name=\"Comparison\" value=\"None\" data-codedcontent-default-val=\"None\" data-codedcontent-default-ref=\"T105_21\" >None.</textarea>\n\t\t\t</p>\n\t\t</section>\n\t\t<section data-section-name=\"Findings\">\n\t\t\t<header class=\"level1\">Findings</header>\n\t\t\t<p>\n\t\t\t\t<label for=\"T105_24\">Preliminary radiograph:</label>\n\t\t\t\t<input type=\"text\" id=\"T105_24\" name=\"Preliminary radiograph\" value=\"Normal.\" data-codedcontent-default-val=\"Normal\" data-codedcontent-default-ref=\"T105_24\" />\n\t\t\t</p>\n\t\t\t<p>\n\t\t\t\t<label for=\"T105_26\">Swallowing:</label>\n\t\t\t\t<input type=\"text\" id=\"T105_26\" name=\"Swallowing\" value=\"Normal.\" data-codedcontent-default-val=\"Normal\" data-codedcontent-default-ref=\"T105_26\" />\n\t\t\t</p>\n\t\t\t<p>\n\t\t\t\t<label for=\"T105_29\">Esophagus:</label>\n\t\t\t\t<input type=\"text\" id=\"T105_29\" name=\"Esophagus\" style=\"width:50em;\" value=\"Normal morphology and motility. No stricture or mass.\" />\n\t\t\t</p>\n\t\t\t<p>\n\t\t\t\t<label for=\"T105_40\">Gastroesophageal reflux:</label>\n\t\t\t\t<input type=\"text\" id=\"T105_40\" name=\"Gastroesophageal reflux\" value=\"None.\" />\n\t\t\t</p>\n\t\t\t<p>\n\t\t\t\t<label for=\"T105_45\">Fluoroscopy time:</label>\n\t\t\t\t<input type=\"number\" id=\"T105_45\" name=\"Fluoroscopy time\" data-field-units=\"minutes\" min=\"0\" max=\"99\" /> minutes </p>\n\t\t</section>\n\t\t<section data-section-name=\"Impression\">\n\t\t\t<header class=\"level1\">Impression</header>\n\t\t\t<p>\n\t\t\t\t<!-- <label for=\"T105_63\">Impression</label> -->\n\t\t\t\t<textarea id=\"T105_63\" name=\"Impression\" value=\"Normal\" data-codedcontent-default-val=\"Normal\" data-codedcontent-default-ref=\"T105_63\" >Normal.</textarea>\n\t\t\t</p>\n\t\t</section>\n\t</body>\n</html>\n",

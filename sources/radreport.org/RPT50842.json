    "templateData": "<!DOCTYPE html>\n<html>\n    <head>\n        <title>Uterine Malformations MRI</title>\n        <meta charset=\"UTF-8\" />\n        <meta name=\"dcterms.identifier\" content=\"db2215aa-8d8b-41d0-821d-6f53d52cb110\" />\n        <meta name=\"dcterms.title\" content=\"Uterine Malformations MRI\" />\n        <meta name=\"dcterms.description\" content=\"\" />\n        <meta name=\"dcterms.type\" content=\"IMAGE_REPORT_TEMPLATE\" />\n        <meta name=\"dcterms.language\" content=\"en\" />\n        <meta name=\"dcterms.publisher\" content=\"ESR\" />\n        <meta name=\"dcterms.rights\" content=\"May be used freely, subject to license agreement\" />\n        <meta name=\"dcterms.license\" content=\"http://www.radreport.org/license.pdf\" />\n        <meta name=\"dcterms.date\" content=\"2017-10-06\" />\n        <meta name=\"dcterms.creator\" content=\"Teresa Margarida Cunha, MD\" />\n        <meta name=\"dcterms.contributor\" content=\"Rita Lucas, MD\" />\n        <script type=\"text/xml\">\n            <template_attributes>\n                <coded_content>\n                    <coding_schemes>\n                        <coding_scheme name=\"RADLEX\" designator=\"2.16.840.1.113883.6.256\"></coding_scheme>\n                    </coding_schemes>\n                    <entry origtxt=\"TEXT_1476403918957\">\n                        <term>\n                            <code meaning=\"vagina\" value=\"RID325\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476403918958\">\n                        <term>\n                            <code meaning=\"urinary bladder\" value=\"RID237\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1476403918941\">\n                        <term>\n                            <code meaning=\"endometrium\" value=\"RID30958\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"comparisonsText\">\n                        <term>\n                            <code meaning=\"comparison image\" value=\"RID13169\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1476403918965\">\n                        <term>\n                            <code meaning=\"impression section\" value=\"RID13170\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476403918963\">\n                        <term>\n                            <code meaning=\"ascites\" value=\"RID1541\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476403918902\">\n                        <term>\n                            <code meaning=\"clinical information section\" value=\"RID13166\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1476403918919\">\n                        <term>\n                            <code meaning=\"uterus\" value=\"RID302\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                </coded_content>\n            </template_attributes>\n        </script>\n    </head>\n    <body>\n        <section id=\"procedureInformation\" class=\"level1\" data-section-name=\"Procedure Information\">\n            <header class=\"level1\">\n                Procedure Information\n            </header>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476403918899\">Procedure Type:</label>\n                <select id=\"SELECTION_LIST_1476403918899\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Enhanced MRI pelvis\">\n                    <option id=\"SELECTION_LIST_1476403918899_0\" value=\"Enhanced MRI pelvis\" name=\"SELECTION_LIST_1476403918899\" selected=\"\">Enhanced MRI pelvis</option>\n                    <option id=\"SELECTION_LIST_1476403918899_1\" value=\"Unenhanced MRI pelvis\" name=\"SELECTION_LIST_1476403918899\">Unenhanced MRI pelvis</option>\n                </select>\n            </p>\n <p title=\"\">\n                <label for=\"SELECTION_LIST_1476403918903\">Technique:</label>\n                <select id=\"SELECTION_LIST_1476403918903\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"T2-weighted images of the pelvis in axial, sagittal and coronal planes.\">\n                    <option id=\"SELECTION_LIST_1476403918903_0\" value=\"T2-weighted images of the pelvis in axial, sagittal and coronal planes.\" name=\"SELECTION_LIST_1476403918903\" selected=\"\">T2-weighted images of the pelvis in axial, sagittal and coronal planes.</option>\n                    <option id=\"SELECTION_LIST_1476403918903_1\" value=\"T1-weighted images of the pelvis in axial plane.\" name=\"SELECTION_LIST_1476403918903\">T1-weighted images of the pelvis in axial plane.</option>\n                    <option id=\"SELECTION_LIST_1476403918903_2\" value=\"Coronal T2-weighted images of the abdomen.\" name=\"SELECTION_LIST_1476403918903\">Coronal T2-weighted images of the abdomen.</option>\n                    <option id=\"SELECTION_LIST_1476403918903_3\" value=\"T2-weighted images in oblique planes were obtained in long and short axis relative to the uterine body.\" name=\"SELECTION_LIST_1476403918903\">T2-weighted images in oblique planes were obtained in long and short axis relative to the uterine body.</option>\n                    <option id=\"SELECTION_LIST_1476403918903_4\" value=\"Survey images that include the region of the kidneys were also abtained.\" name=\"SELECTION_LIST_1476403918903\">Survey images that include the region of the kidneys were also abtained.</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476403918915\">Strength of Tesla scanner:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"\" id=\"NUMBER_1476403918915\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476403918913\">Contrast type:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476403918913\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476403918914\">Contrast dose administered before and after fat suppressed T1-weighted imaging:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"mL\" id=\"NUMBER_1476403918914\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    mL\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476403918916\">Image quality:</label>\n                <select id=\"SELECTION_LIST_1476403918916\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Satisfactory\">\n                    <option id=\"SELECTION_LIST_1476403918916_0\" value=\"Satisfactory\" name=\"SELECTION_LIST_1476403918916\" selected=\"\">Satisfactory</option>\n                    <option id=\"SELECTION_LIST_1476403918916_1\" value=\"Degraded by motion/etc\" name=\"SELECTION_LIST_1476403918916\">Degraded by motion/etc</option>\n                </select>\n            </p>\n        </section>\n        <section id=\"clinicalInformation\" class=\"level1\" data-section-name=\"Clinical Information\">\n            <header class=\"level1\">\n                Clinical Information\n            </header>\n            <p title=\"\">\n                <label for=\"TEXT_1476403918902\">Clinical Indication:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476403918902\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Suspected gynecological anomaly</textarea>\n            </p>\n        </section>\n        <section id=\"comparisons\" class=\"level1\" data-section-name=\"Comparison\">\n            <header class=\"level1\">\n                Comparison\n            </header>\n            <p title=\"\">\n                <label for=\"comparisonsText\">Comparison study:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"comparisonsText\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">None available</textarea>\n            </p>\n        </section>\n        <section id=\"findings\" class=\"level1\" data-section-name=\"Findings\">\n            <header class=\"level1\">\n                Findings\n            </header>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476403918919\">Uterus:</label>\n                <select id=\"SELECTION_LIST_1476403918919\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Anteverted\">\n                    <option id=\"SELECTION_LIST_1476403918919_0\" value=\"Anteverted\" name=\"SELECTION_LIST_1476403918919\" selected=\"\">Anteverted</option>\n                    <option id=\"SELECTION_LIST_1476403918919_1\" value=\"Retroverted\" name=\"SELECTION_LIST_1476403918919\">Retroverted</option>\n                    <option id=\"SELECTION_LIST_1476403918919_2\" value=\"Retroflexed\" name=\"SELECTION_LIST_1476403918919\">Retroflexed</option>\n                    <option id=\"SELECTION_LIST_1476403918919_3\" value=\"Displaced to left\" name=\"SELECTION_LIST_1476403918919\">Displaced to left</option>\n                    <option id=\"SELECTION_LIST_1476403918919_4\" value=\"Displaced to right\" name=\"SELECTION_LIST_1476403918919\">Displaced to right</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476403918925\">Size:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476403918925\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Normal in size</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476403918926\">Measuring:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"cm\" id=\"NUMBER_1476403918926\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    cm\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476403918927\">The external uterine fundal contour is:</label>\n                <select id=\"SELECTION_LIST_1476403918927\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Convex\">\n                    <option id=\"SELECTION_LIST_1476403918927_0\" value=\"Convex\" name=\"SELECTION_LIST_1476403918927\" selected=\"\">Convex</option>\n                    <option id=\"SELECTION_LIST_1476403918927_1\" value=\"Flat\" name=\"SELECTION_LIST_1476403918927\">Flat</option>\n                    <option id=\"SELECTION_LIST_1476403918927_2\" value=\"Concave\" name=\"SELECTION_LIST_1476403918927\">Concave</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476403918931\">The uterine cavity width measuring between the interstitial portion of both fallopian tubes is:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"mm\" id=\"NUMBER_1476403918931\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    mm\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476403918932\">The thickness of the fundal endometrial indentation as measured from the midpoint of the line joining the interstitial portion of both fallopian tubes to the apex of the fundal indentation is:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"mm\" id=\"NUMBER_1476403918932\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    mm\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476403918933\">The angle of the apex of the fundal indentation is:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"\" id=\"NUMBER_1476403918933\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476403918934\">Uterine Configuration:</label>\n                <select id=\"SELECTION_LIST_1476403918934\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Normal\">\n                    <option id=\"SELECTION_LIST_1476403918934_0\" value=\"Normal\" name=\"SELECTION_LIST_1476403918934\" selected=\"\">Normal</option>\n                    <option id=\"SELECTION_LIST_1476403918934_1\" value=\"Arcuate\" name=\"SELECTION_LIST_1476403918934\">Arcuate</option>\n                    <option id=\"SELECTION_LIST_1476403918934_2\" value=\"Septate\" name=\"SELECTION_LIST_1476403918934\">Septate</option>\n                    <option id=\"SELECTION_LIST_1476403918934_3\" value=\"Bicornuate\" name=\"SELECTION_LIST_1476403918934\">Bicornuate</option>\n                    <option id=\"SELECTION_LIST_1476403918934_4\" value=\"Unicornuate\" name=\"SELECTION_LIST_1476403918934\">Unicornuate</option>\n                    <option id=\"SELECTION_LIST_1476403918934_5\" value=\"Didephysis\" name=\"SELECTION_LIST_1476403918934\">Didephysis</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476403918941\">Endometrium:</label>\n                <select id=\"SELECTION_LIST_1476403918941\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Normal\">\n                    <option id=\"SELECTION_LIST_1476403918941_0\" value=\"Normal\" name=\"SELECTION_LIST_1476403918941\" selected=\"\">Normal</option>\n                    <option id=\"SELECTION_LIST_1476403918941_1\" value=\"Abnormal\" name=\"SELECTION_LIST_1476403918941\">Abnormal</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476403918944\">The maximum width of the endometrium is:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"mm\" id=\"NUMBER_1476403918944\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    mm\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476403918945\">Junctional zone:</label>\n                <select id=\"SELECTION_LIST_1476403918945\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"There is no adenomyosis.\">\n                    <option id=\"SELECTION_LIST_1476403918945_0\" value=\"There is no adenomyosis.\" name=\"SELECTION_LIST_1476403918945\" selected=\"\">There is no adenomyosis.</option>\n                    <option id=\"SELECTION_LIST_1476403918945_1\" value=\"There is mild adenomyosis.\" name=\"SELECTION_LIST_1476403918945\">There is mild adenomyosis.</option>\n                    <option id=\"SELECTION_LIST_1476403918945_2\" value=\"There is moderate adenomyosis.\" name=\"SELECTION_LIST_1476403918945\">There is moderate adenomyosis.</option>\n                    <option id=\"SELECTION_LIST_1476403918945_3\" value=\"There is severe adenomyosis\" name=\"SELECTION_LIST_1476403918945\">There is severe adenomyosis</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476403918950\">The maximum Junctional zone thickness is:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"mm\" id=\"NUMBER_1476403918950\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    mm\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476403918951\">Outer myometrium:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476403918951\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There are no leiomyomas.</textarea>\n            </p>\n            <section id=\"SECTION_HEADER_1476403918952\" class=\"level2\" data-section-name=\"Right Ovary:\">\n                <header class=\"level2\">\n                    Right Ovary:\n                </header>\n                <p title=\"\">\n                    <label for=\"NUMBER_1476403918953\">Size:</label>\n                    <span>\n                        <input type=\"number\" step=\"1.0\" data-field-units=\"cm\" id=\"NUMBER_1476403918953\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                        cm\n                    </span>\n                </p>\n            </section>\n            <section id=\"SECTION_HEADER_1476403918954\" class=\"level2\" data-section-name=\"Left Ovary:\">\n                <header class=\"level2\">\n                    Left Ovary:\n                </header>\n                <p title=\"\">\n                    <label for=\"NUMBER_1476403918955\">Size:</label>\n                    <span>\n                        <input type=\"number\" step=\"1.0\" data-field-units=\"cm\" id=\"NUMBER_1476403918955\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                        cm\n                    </span>\n                </p>\n            </section>\n            <p title=\"\">\n                <label for=\"TEXT_1476403918956\">Cervix:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476403918956\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Unremarkable</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476403918957\">Vagina:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476403918957\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Unremarkable</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476403918958\">Bladder:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476403918958\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Unremarkable</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476403918959\">Lymph nodes:</label>\n                <select id=\"SELECTION_LIST_1476403918959\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Normal in size\">\n                    <option id=\"SELECTION_LIST_1476403918959_0\" value=\"Normal in size\" name=\"SELECTION_LIST_1476403918959\" selected=\"\">Normal in size</option>\n                    <option id=\"SELECTION_LIST_1476403918959_1\" value=\"Enlarged; probably reactive\" name=\"SELECTION_LIST_1476403918959\">Enlarged; probably reactive</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476403918962\">Physiologic pelvic fluid:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476403918962\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no physiologic pelvic fluid.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476403918963\">Ascites:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476403918963\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no ascites.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476403918964\">Kidneys:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476403918964\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">On survey images, the kidneys are normally positioned bilaterally without hydronephrosis.]</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1506699322694\">Other Findings:</label>\n                <input type=\"text\" id=\"TEXT_1506699322694\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\" value=\"\" />\n            </p>\n        </section>\n        <section id=\"impression\" class=\"level1\" data-section-name=\"Impression\">\n            <header class=\"level1\">\n                Impression\n            </header>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476403918965\">Impression:</label>\n                <input list=\"SELECTION_LIST_1476403918965_LIST\" id=\"SELECTION_LIST_1476403918965\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Normal appearing uterus\" />\n                <datalist id=\"SELECTION_LIST_1476403918965_LIST\">\n                    <option id=\"SELECTION_LIST_1476403918965_0\" value=\"Bicoruate uterus\" name=\"SELECTION_LIST_1476403918965\">Bicoruate uterus</option>\n                    <option id=\"SELECTION_LIST_1476403918965_1\" value=\"Septate uterus\" name=\"SELECTION_LIST_1476403918965\">Septate uterus</option>\n                    <option id=\"SELECTION_LIST_1476403918965_2\" value=\"Subseptate uterus\" name=\"SELECTION_LIST_1476403918965\">Subseptate uterus</option>\n                    <option id=\"SELECTION_LIST_1476403918965_3\" value=\"Arcuate uterus\" name=\"SELECTION_LIST_1476403918965\">Arcuate uterus</option>\n                    <option id=\"SELECTION_LIST_1476403918965_4\" value=\"Uterine didelphis\" name=\"SELECTION_LIST_1476403918965\">Uterine didelphis</option>\n                    <option id=\"SELECTION_LIST_1476403918965_5\" value=\"Normal appearing uterus\" name=\"SELECTION_LIST_1476403918965\" selected=\"\">Normal appearing uterus</option>\n                    <option id=\"SELECTION_LIST_1476403918965_6\" value=\"Otherwise normal exam\" name=\"SELECTION_LIST_1476403918965\">Otherwise normal exam</option>\n                </datalist>\n            </p>\n        </section>\n    </body>\n</html>\n",

    "templateData": "<!DOCTYPE html>\n<html>\n    <head>\n        <title>Gastrostomy tube exchange</title>\n        <meta charset=\"UTF-8\" />\n        <meta name=\"dcterms.identifier\" content=\"01d49cbc-d441-4226-bb37-5d158d5e7b96\" />\n        <meta name=\"dcterms.title\" content=\"Gastrostomy tube exchange\" />\n        <meta name=\"dcterms.description\" content=\"Gastrostomy tube exchange\" />\n        <meta name=\"dcterms.type\" content=\"IMAGE_REPORT_TEMPLATE\" />\n        <meta name=\"dcterms.language\" content=\"en\" />\n        <meta name=\"dcterms.publisher\" content=\"Template Library Advisory Panel (TLAP) of the Radiological Society of North America (RSNA)\" />\n        <meta name=\"dcterms.rights\" content=\"May be used gratis, subject to license agreement\" />\n        <meta name=\"dcterms.license\" content=\"http://www.radreport.org/license.pdf\" />\n        <meta name=\"dcterms.date\" content=\"2015-11-30\" />\n        <meta name=\"dcterms.creator\" content=\"Tolat PP\" />\n        <meta name=\"dcterms.contributor\" content=\"Medical College of Wisconsin (MCW)\" />\n        <script type=\"text/xml\">\n            <template_attributes>\n                <coded_content>\n                    <coding_schemes>\n                        <coding_scheme name=\"RADLEX\" designator=\"2.16.840.1.113883.6.256\"></coding_scheme>\n                    </coding_schemes>\n                    <entry origtxt=\"DATE_1448943182484\">\n                        <term>\n                            <code meaning=\"comparison\" value=\"RID28483\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1448944648714\">\n                        <term>\n                            <code meaning=\"attestation\" value=\"RID49439\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SECTION_HEADER_1448943182471\">\n                        <term>\n                            <code meaning=\"gastrostomy-jejunostomy tube exchange\" value=\"RID49663\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1448944648673\">\n                        <term>\n                            <code meaning=\"deployment technique\" value=\"RID12917\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"T269_5\">\n                        <term>\n                            <code meaning=\"fluoroscopy time\" value=\"RID49440\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1448943182472_0\">\n                        <term>\n                            <code meaning=\"obstructed\" value=\"RID5893\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1448943182472_1\">\n                        <term>\n                            <code meaning=\"gastrostomy-jejunostomy tube placement\" value=\"RID49628\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1448943182472_2\">\n                        <term>\n                            <code meaning=\"gastrostomy-jejunostomy tube exchange\" value=\"RID49663\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                </coded_content>\n            </template_attributes>\n        </script>\n    </head>\n    <body>\n        <section id=\"Procedure\" class=\"level1\" data-section-name=\"Procedure\">\n            <header class=\"level1\">\n                Procedure\n            </header>\n            <section id=\"SECTION_HEADER_1448943182471\" class=\"level2\" data-section-name=\"Fluoroscopic-guided gastrostomy tube exchange.\">\n                <header class=\"level2\">\n                    Fluoroscopic-guided gastrostomy tube exchange.\n                </header>\n            </section>\n        </section>\n        <section id=\"Clinical_information\" class=\"level1\" data-section-name=\"Clinical information\">\n            <header class=\"level1\">\n                Clinical information\n            </header>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1448943182472\"></label>\n                <select multiple=\"multiple\" id=\"SELECTION_LIST_1448943182472\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"PROHIBIT\" value=\"Clogged gastrostomy tube.\">\n                    <option id=\"SELECTION_LIST_1448943182472_0\" value=\"Clogged gastrostomy tube.\" name=\"SELECTION_LIST_1448943182472\" selected=\"\">Clogged gastrostomy tube.</option>\n                    <option id=\"SELECTION_LIST_1448943182472_1\" value=\"New gastrostomy tube requiring confirmation of placement.\" name=\"SELECTION_LIST_1448943182472\">New gastrostomy tube requiring confirmation of placement.</option>\n                    <option id=\"SELECTION_LIST_1448943182472_2\" value=\"Routine exchange.\" name=\"SELECTION_LIST_1448943182472\">Routine exchange.</option>\n                    <option id=\"SELECTION_LIST_1448943182472_3\" value=\"\" name=\"SELECTION_LIST_1448943182472\"></option>\n                </select>\n            </p>\n        </section>\n        <section id=\"Comparison\" class=\"level1\" data-section-name=\"Comparison\">\n            <header class=\"level1\">\n                Comparison\n            </header>\n            <p title=\"\">\n                <label for=\"DATE_1448943182484\"></label>\n                <input type=\"date\" id=\"DATE_1448943182484\" name=\"\" data-field-type=\"DATE\" data-field-completion-action=\"NONE\" value=\"\" />\n            </p>\n        </section>\n        <section id=\"Findings\" class=\"level1\" data-section-name=\"Findings\">\n            <header class=\"level1\">\n                Findings\n            </header>\n            <section id=\"SECTION_HEADER_1448944648685\" class=\"level2\" data-section-name=\"Pre-procedure Information:\">\n                <header class=\"level2\">\n                    Pre-procedure Information:\n                </header>\n                <p title=\"\">\n                    <label for=\"TEXT_1448944388796\">Informed consent</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1448944388796\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">The risks, benefits, and alternatives of the procedure including procedural sedation were discussed with the patient. Verbal and written consent was obtained.</textarea>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1448943182486\">Time-out:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1448943182486\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"ALERT\">Time-out performed to confirm the correct patient, procedure, and site. </textarea>\n                </p>\n            </section>\n            <section id=\"SECTION_HEADER_1448944648686\" class=\"level2\" data-section-name=\"Intra-procedure Information:\">\n                <header class=\"level2\">\n                    Intra-procedure Information:\n                </header>\n                <p title=\"\">\n                    <label for=\"TEXT_1448944648673\">Technique:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1448944648673\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Using image guidance, the existing gastrotomy tube was exchanged for new gastrotomy tube.  A small amount of water soluable contrast was used to confirm appropriate placement within the stomach.</textarea>\n                </p>\n                <p title=\"\">\n                    <label for=\"NUMBER_1448944388798\">Old gastrostomy tube size:</label>\n                    <span>\n                        <input type=\"number\" step=\"2.0\" data-field-units=\"French\" id=\"NUMBER_1448944388798\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"16\" />\n                        French\n                    </span>\n                </p>\n                <p title=\"\">\n                    <label for=\"NUMBER_1448944648672\">New gastrostomy tube size:</label>\n                    <span>\n                        <input type=\"number\" step=\"2.0\" data-field-units=\"French\" id=\"NUMBER_1448944648672\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"16\" />\n                        French\n                    </span>\n                </p>\n                <p title=\"\">\n                    <label for=\"NUMBER_1448944648674\">Balloon fill:</label>\n                    <span>\n                        <input type=\"number\" step=\"1.0\" data-field-units=\"mL\" id=\"NUMBER_1448944648674\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"7\" />\n                        mL\n                    </span>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1448944648689\">Additional intra-procedural information:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1448944648689\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">None.</textarea>\n                </p>\n            </section>\n            <section id=\"SECTION_HEADER_1448944648687\" class=\"level2\" data-section-name=\"Post-procedure Information:\">\n                <header class=\"level2\">\n                    Post-procedure Information:\n                </header>\n                <p title=\"\">\n                    <label for=\"SELECTION_LIST_1448944648675\">Procedural sedation:</label>\n                    <select id=\"SELECTION_LIST_1448944648675\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"ALERT\" value=\"None.\">\n                        <option id=\"SELECTION_LIST_1448944648675_0\" value=\"None.\" name=\"SELECTION_LIST_1448944648675\" selected=\"\">None.</option>\n                        <option id=\"SELECTION_LIST_1448944648675_1\" value=\"Administered by the radiology nurse, who monitored the patient continuously throughout the procedure. \" name=\"SELECTION_LIST_1448944648675\">Administered by the radiology nurse, who monitored the patient continuously throughout the procedure. </option>\n                        <option id=\"SELECTION_LIST_1448944648675_2\" value=\"Administered by the anesthesia department.  Please see anesthesia notes for sedation details.\" name=\"SELECTION_LIST_1448944648675\">Administered by the anesthesia department. Please see anesthesia notes for sedation details.</option>\n                    </select>\n                </p>\n                <p title=\"\">\n                    <label for=\"SELECTION_LIST_1448944648679\">Complications:</label>\n                    <input list=\"SELECTION_LIST_1448944648679_LIST\" id=\"SELECTION_LIST_1448944648679\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"None.\" />\n                    <datalist id=\"SELECTION_LIST_1448944648679_LIST\">\n                        <option id=\"SELECTION_LIST_1448944648679_0\" value=\"None.\" name=\"SELECTION_LIST_1448944648679\" selected=\"\">None.</option>\n                        <option id=\"SELECTION_LIST_1448944648679_1\" value=\"\" name=\"SELECTION_LIST_1448944648679\"></option>\n                    </datalist>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1448944648694\">Patient disposition:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1448944648694\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"ALERT\">Discharged from the department in stable condition.</textarea>\n                </p>\n                <p title=\"\">\n                    <label for=\"T269_5\">Fluoroscopy time:</label>\n                    <span>\n                        <input type=\"number\" step=\"0.1\" data-field-units=\"minutes\" id=\"T269_5\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"PROHIBIT\" value=\"5\" />\n                        minutes\n                    </span>\n                </p>\n            </section>\n            <section id=\"SECTION_HEADER_1448944648700\" class=\"level2\" data-section-name=\"Operators:\">\n                <header class=\"level2\">\n                    Operators:\n                </header>\n                <p title=\"\">\n                    <label for=\"TEXT_1448944648712\">Performing provider(s):</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1448944648712\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"PROHIBIT\">Dr. ***</textarea>\n                </p>\n                <p title=\"\">\n                    <label for=\"TEXT_1448944648708\">Attending (supervising) radiologist:</label>\n                    <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1448944648708\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Dr. @@@</textarea>\n                </p>\n                <p title=\"\">\n                    <label for=\"SELECTION_LIST_1448944648714\">Attestation:</label>\n                    <select id=\"SELECTION_LIST_1448944648714\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"PROHIBIT\" value=\"Dr. *** dictated this invasive procedure. Dr. @@@ was present for the key and critical  procedural components of this case. Images were reviewed and reported findings were edited and confirmed by Dr.  @@@.\">\n                        <option id=\"SELECTION_LIST_1448944648714_0\" value=\"Not applicable.\" name=\"SELECTION_LIST_1448944648714\">Not applicable.</option>\n                        <option id=\"SELECTION_LIST_1448944648714_1\" value=\"Dr. *** dictated this invasive procedure. Dr. @@@ was present for the key and critical  procedural components of this case. Images were reviewed and reported findings were edited and confirmed by Dr.  @@@.\" name=\"SELECTION_LIST_1448944648714\" selected=\"\">Dr. *** dictated this invasive procedure. Dr. @@@ was present for the key and critical procedural components of this case. Images were reviewed and reported findings were edited and confirmed by Dr. @@@.</option>\n                    </select>\n                </p>\n            </section>\n        </section>\n        <section id=\"Impression\" class=\"level1\" data-section-name=\"Impression\">\n            <header class=\"level1\">\n                Impression\n            </header>\n            <p title=\"\">\n                <label for=\"T269_6\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"T269_6\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"PROHIBIT\">Fluoroscopic-guided percutaneous gastrostomy tube exchange. The new gastrostomy tube is ready for immediate use.</textarea>\n            </p>\n        </section>\n    </body>\n</html>\n",

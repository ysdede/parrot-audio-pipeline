    "templateData": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\"/>\n<meta content=\"Gastrostomy tube exchange\" name=\"dcterms.title\"/>\n<meta content=\"Gastrostomy tube exchange report template\" name=\"dcterms.description\"/>\n<meta content=\"http://www.radreport.org/template/0000269\" name=\"dcterms.identifier\"/>\n<meta content=\"en\" name=\"dcterms.language\"/>\n<meta content=\"IMAGE_REPORT_TEMPLATE\" name=\"dcterms.type\"/>\n<meta content=\"Radiological Society of North America (RSNA)\" name=\"dcterms.publisher\"/>\n<meta content=\"May be used gratis, subject to license agreement\" name=\"dcterms.rights\"/>\n<meta content=\"http://www.radreport.org/license.pdf\" name=\"dcterms.license\"/>\n<meta content=\"2013-12-27\" name=\"dcterms.date\"/>\n<meta content=\"Tolat P, Kahn CE Jr\" name=\"dcterms.creator\"/>\n\n<meta content=\"Kahn CE Jr [editor]\" name=\"dcterms.contributor\"/>\n<meta content=\"Medical College of Wisconsin (MCW)\" name=\"dcterms.contributor\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"IHE_Template_Style.css\" />\n<!-- The absolute link to the CSS file is http://www.radreport.org/html/IHE_Template_Style.css -->\n<script type=\"text/xml\">\r\n<!--\r\n<template_attributes>\n<top-level-flag>true</top-level-flag>\n<status>ACTIVE</status>\n<coding_schemes>\n <coding_scheme name=\"RadLex\" designator=\"2.16.840.1.113883.6.256\" />\n <coding_scheme name=\"SNOMEDCT\" designator=\"2.16.840.1.113883.6.96\" />\n <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\" />\n</coding_schemes>\n<coded_content>\n</coded_content>\n</template_attributes>\r\n-->\r\n</script>\n<title>Gastrostomy tube exchange</title>\n</head>\n<body>\n<section data-section-name=\"Procedure\">\n<header class=\"level1\">Fluoroscopically-guided gastrostomy tube replacement</header>\n</section>\n<section data-section-name=\"Clinical information\">\n<header class=\"level1\">Clinical information</header>\n<p>\n<textarea id=\"T269_1\" name=\"Clinical information\"></textarea>\n</p>\n</section>\n<section data-section-name=\"Comparison\">\n<header class=\"level1\">Comparison</header>\n<p>\n<textarea id=\"T269_2\" name=\"Comparison\">None. </textarea>\n</p>\n</section>\n<section data-section-name=\"Findings\">\n<header class=\"level1\">Findings</header>\n<p>\n<label for=\"T269_3\">The patient was placed supine on the fluoroscopy table. The balloon of the </label>\n<input type=\"number\" id=\"T269_3\" name=\"Old tube size\" value=\"\" />\n<label for=\"T269_3\">French gastrostomy tube was deflated and the tube was removed.</label>\n</p>\n<p>\n<label for=\"T269_4\">A new </label>\n<input type=\"number\" id=\"T269_4\" name=\"New tube size\" value=\"\" />\n<label for=\"T269_4\">French gastrostomy tube was inserted to the percutaneous tract. The new gastrostomy tube balloon was inflated with dilute contrast material and pulled firmly up against the anterior abdominal wall. Contrast was then injected through the tube to confirm tube placement within the stomach. The external rubber bumper was then adjusted to approximately 3 mm from the skin surface and secured with a cable tie. The tube was flushed with water.</label> \n</p>\n<p>\n<label for=\"T269_5\">Fluoroscopy time:</label>\n<input type=\"number\" id=\"T269_5\" name=\"Fluoro time\" value=\"\" min=\"0\" max=\"99\" step=\"0.1\"/> minutes\n</p>\n</section>\n<section data-section-name=\"Impression\">\n<header class=\"level1\">Impression</header>\n<p>\n<textarea id=\"T269_6\" name=\"Impression\">Fluoroscopically-guided exchange of percutaneous gastrostomy tube. The tube is ready for immediate use.</textarea>\n</p>\n</section>\n</body>\n</html>",

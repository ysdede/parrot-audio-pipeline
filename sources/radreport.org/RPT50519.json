    "templateData": "<!DOCTYPE html>\n<html>\n    <head>\n        <title>CT Renal Donor</title>\n        <meta charset=\"UTF-8\" />\n        <meta name=\"dcterms.identifier\" content=\"89302af6-e48c-4f07-ab5a-cd754581f91f\" />\n        <meta name=\"dcterms.title\" content=\"CT Renal Donor\" />\n        <meta name=\"dcterms.description\" content=\"\" />\n        <meta name=\"dcterms.type\" content=\"IMAGE_REPORT_TEMPLATE\" />\n        <meta name=\"dcterms.language\" content=\"en\" />\n        <meta name=\"dcterms.publisher\" content=\"University of Utah\" />\n        <meta name=\"dcterms.rights\" content=\"May be used freely, subject to license agreement\" />\n        <meta name=\"dcterms.license\" content=\"http://www.radreport.org/license.pdf\" />\n        <meta name=\"dcterms.date\" content=\"2018-02-20\" />\n        <meta name=\"dcterms.creator\" content=\"Marta E. Heilbrun, MD\" />\n        <script type=\"text/xml\">\n            <template_attributes>\n                <coded_content>\n                    <coding_schemes>\n                        <coding_scheme name=\"RADLEX\" designator=\"2.16.840.1.113883.6.256\"></coding_scheme>\n                        <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\"></coding_scheme>\n                    </coding_schemes>\n                    <entry origtxt=\"TEXT_1476468748385\">\n                        <term>\n                            <code meaning=\"set of renal arteries\" value=\"RID49729\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476468748392\">\n                        <term>\n                            <code meaning=\"abdomen\" value=\"RID56\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"findings\">\n                        <term>\n                            <code meaning=\"Procedure Findings\" value=\"59776-5\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476468748386\">\n                        <term>\n                            <code meaning=\"renal vein\" value=\"RID1184\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476468748387\">\n                        <term>\n                            <code meaning=\"vasculature\" value=\"RID15989\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"findingsText\">\n                        <term>\n                            <code meaning=\"kidney\" value=\"RID205\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459553571591\">\n                        <term>\n                            <code meaning=\"indication\" value=\"RID49442\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"procedureInformation\">\n                        <term>\n                            <code meaning=\"Current Imaging Procedure Description\" value=\"55111-9\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"comparisons\">\n                        <term>\n                            <code meaning=\"Radiology Comparison Study\" value=\"18834-2\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"impression\">\n                        <term>\n                            <code meaning=\"Impressions\" value=\"19005-8\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"clinicalInformation\">\n                        <term>\n                            <code meaning=\"Clinical Information\" value=\"55752-0\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                </coded_content>\n            </template_attributes>\n        </script>\n    </head>\n    <body>\n        <section id=\"procedureInformation\" class=\"level1\" data-section-name=\"Procedure Information\">\n            <header class=\"level1\">\n                Procedure Information\n            </header>\n            <p title=\"\">\n                <label for=\"TEXT_1459553571592\">Technique:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459553571592\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Noncontrast CT images were obtained through the kidneys. Following the intravenous administration of contrast, contiguous axial CT images were obtained through the kidneys in the arterial and nephrographic phases. Coronal reconstructions were prepared. Renal volumes were calculated, as well as 3-D vascular reconstructions were prepared on a separate workstation.</textarea>\n            </p>\n        </section>\n        <section id=\"clinicalInformation\" class=\"level1\" data-section-name=\"Clinical Information\">\n            <header class=\"level1\">\n                Clinical Information\n            </header>\n            <p title=\"\">\n                <label for=\"TEXT_1459553571591\">Indication:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459553571591\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Evaluate for kidney donation.</textarea>\n            </p>\n        </section>\n        <section id=\"comparisons\" class=\"level1\" data-section-name=\"Comparison\">\n            <header class=\"level1\">\n                Comparison\n            </header>\n            <p title=\"\">\n                <label for=\"comparisonsText\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"comparisonsText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">None.</textarea>\n            </p>\n        </section>\n        <section id=\"findings\" class=\"level1\" data-section-name=\"Findings\">\n            <header class=\"level1\">\n                Findings\n            </header>\n            <p title=\"\">\n                <label for=\"findingsText\">Kidneys:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"findingsText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">There is no solid or cystic renal cortical mass. There are no calculi in the kidneys. There is no hydronephrosis.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476468748388\">Right kidney total volume:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"mL\" id=\"NUMBER_1476468748388\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    mL\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476468748389\">Right kidney cortical volume:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"mL\" id=\"NUMBER_1476468748389\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    mL\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476468748390\">Left kidney total volume:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"mL\" id=\"NUMBER_1476468748390\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    mL\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476468748391\">Left kidney cortical volume:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"mL\" id=\"NUMBER_1476468748391\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    mL\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476468748385\">Renal arteries:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476468748385\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476468748386\">Renal veins:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476468748386\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476468748387\">Other vasculature:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476468748387\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476468748392\">Remainder of the abdomen:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476468748392\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1519185096863\">Additional Findings:</label>\n                <input type=\"text\" id=\"TEXT_1519185096863\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\" value=\"None.\" />\n            </p>\n        </section>\n        <section id=\"impression\" class=\"level1\" data-section-name=\"Impression\">\n            <header class=\"level1\">\n                Impression\n            </header>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1459553571593\"></label>\n                <select multiple=\"multiple\" id=\"SELECTION_LIST_1459553571593\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"No renal calculi or hydronephrosis. No renal cortical mass.\">\n                    <option id=\"SELECTION_LIST_1459553571593_0\" value=\"No renal calculi or hydronephrosis. No renal cortical mass.\" name=\"SELECTION_LIST_1459553571593\" selected=\"\">No renal calculi or hydronephrosis. No renal cortical mass.</option>\n                    <option id=\"SELECTION_LIST_1459553571593_1\" value=\"Single bilateral renal arteries and veins.\" name=\"SELECTION_LIST_1459553571593\">Single bilateral renal arteries and veins.</option>\n                </select>\n            </p>\n        </section>\n    </body>\n</html>\n",

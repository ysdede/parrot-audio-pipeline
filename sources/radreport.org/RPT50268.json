    "templateData": "<!DOCTYPE html>\n<html>\n    <head>\n        <title>Vulvar Cancer MRI</title>\n        <meta charset=\"UTF-8\" />\n        <meta name=\"dcterms.identifier\" content=\"a94d2e75-1120-46f8-bffa-bf1294707429\" />\n        <meta name=\"dcterms.title\" content=\"Vulvar Cancer MRI\" />\n        <meta name=\"dcterms.description\" content=\"\" />\n        <meta name=\"dcterms.type\" content=\"IMAGE_REPORT_TEMPLATE\" />\n        <meta name=\"dcterms.language\" content=\"en\" />\n        <meta name=\"dcterms.publisher\" content=\"ESR\" />\n        <meta name=\"dcterms.rights\" content=\"May be used freely, subject to license agreement\" />\n        <meta name=\"dcterms.license\" content=\"http://www.radreport.org/license.pdf\" />\n        <meta name=\"dcterms.date\" content=\"2017-10-06\" />\n        <meta name=\"dcterms.creator\" content=\"Teresa Margarida Cunha, MD\" />\n        <meta name=\"dcterms.contributor\" content=\"Rita Lucas, MD\" />\n        <script type=\"text/xml\">\n            <template_attributes>\n                <coded_content>\n                    <coding_schemes>\n                        <coding_scheme name=\"RADLEX\" designator=\"2.16.840.1.113883.6.256\"></coding_scheme>\n                    </coding_schemes>\n                    <entry origtxt=\"impressionText\">\n                        <term>\n                            <code meaning=\"impression section\" value=\"RID13170\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1476405440903\">\n                        <term>\n                            <code meaning=\"wall of rectum\" value=\"RID32936\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"comparisonsText\">\n                        <term>\n                            <code meaning=\"comparison\" value=\"RID28483\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1476405440900\">\n                        <term>\n                            <code meaning=\"wall of urinary bladder\" value=\"RID30135\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1476405440885\">\n                        <term>\n                            <code meaning=\"endometrium\" value=\"RID30958\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1476405440879\">\n                        <term>\n                            <code meaning=\"uterus\" value=\"RID302\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1476405440858\">\n                        <term>\n                            <code meaning=\"procedure\" value=\"RID1559\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476405440892\">\n                        <term>\n                            <code meaning=\"vulva\" value=\"RID272\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476405440890\">\n                        <term>\n                            <code meaning=\"set of ovaries\" value=\"RID39537\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476405440891\">\n                        <term>\n                            <code meaning=\"vagina\" value=\"RID325\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                </coded_content>\n            </template_attributes>\n        </script>\n    </head>\n    <body>\n        <section id=\"procedureInformation\" class=\"level1\" data-section-name=\"Procedure Information\">\n            <header class=\"level1\">\n                Procedure Information\n            </header>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476405440858\">Procedure Type:</label>\n                <select id=\"SELECTION_LIST_1476405440858\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Enhanced MRI pelvis\">\n                    <option id=\"SELECTION_LIST_1476405440858_0\" value=\"Enhanced MRI pelvis\" name=\"SELECTION_LIST_1476405440858\" selected=\"\">Enhanced MRI pelvis</option>\n                    <option id=\"SELECTION_LIST_1476405440858_1\" value=\"Unenhanced MRI pelvis\" name=\"SELECTION_LIST_1476405440858\">Unenhanced MRI pelvis</option>\n                </select>\n            </p>\n<p title=\"\">\n                <label for=\"SELECTION_LIST_1476405440862\">Technique:</label>\n                <select multiple=\"multiple\" id=\"SELECTION_LIST_1476405440862\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"T1-weighted images of the pelvis in axial plane.\">\n                    <option id=\"SELECTION_LIST_1476405440862_0\" value=\"T1-weighted images of the pelvis in axial plane.\" name=\"SELECTION_LIST_1476405440862\" selected=\"\">T1-weighted images of the pelvis in axial plane.</option>\n                    <option id=\"SELECTION_LIST_1476405440862_1\" value=\"T2-weighted images of the pelvis in axial, sagittal and coronal planes.\" name=\"SELECTION_LIST_1476405440862\">T2-weighted images of the pelvis in axial, sagittal and coronal planes.</option>\n                    <option id=\"SELECTION_LIST_1476405440862_2\" value=\"Axial T2-weighted images of the abdomen were also obtained from the renal hilum to the iliac crests.\" name=\"SELECTION_LIST_1476405440862\">Axial T2-weighted images of the abdomen were also obtained from the renal hilum to the iliac crests.</option>\n                    <option id=\"SELECTION_LIST_1476405440862_3\" value=\"Axial DW-MRI study was also performed in the pelvis and in the abdomen from the renal hilum to the iliac crests.\" name=\"SELECTION_LIST_1476405440862\">Axial DW-MRI study was also performed in the pelvis and in the abdomen from the renal hilum to the iliac crests.</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476405440868\">Type of pre and post contrast imaging of the pelvis in the sagittal plane and in axial plane in late phase:</label>\n                <select id=\"SELECTION_LIST_1476405440868\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Dynamic\">\n                    <option id=\"SELECTION_LIST_1476405440868_0\" value=\"Dynamic\" name=\"SELECTION_LIST_1476405440868\" selected=\"\">Dynamic</option>\n                    <option id=\"SELECTION_LIST_1476405440868_1\" value=\"Non-dynamic\" name=\"SELECTION_LIST_1476405440868\">Non-dynamic</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476405440871\">Strength of Tesla scanner:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"\" id=\"NUMBER_1476405440871\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476405440872\">Contrast type:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476405440872\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476405440873\">Contrast dose</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"mL\" id=\"NUMBER_1476405440873\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    mL\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476405440874\">Image quality:</label>\n                <select id=\"SELECTION_LIST_1476405440874\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Satisfactory\">\n                    <option id=\"SELECTION_LIST_1476405440874_0\" value=\"Satisfactory\" name=\"SELECTION_LIST_1476405440874\" selected=\"\">Satisfactory</option>\n                    <option id=\"SELECTION_LIST_1476405440874_1\" value=\"Degraded by motion/etc.\" name=\"SELECTION_LIST_1476405440874\">Degraded by motion/etc.</option>\n                </select>\n            </p>\n        </section>\n        <section id=\"clinicalInformation\" class=\"level1\" data-section-name=\"Clinical Information\">\n            <header class=\"level1\">\n                Clinical Information\n            </header>\n            <p title=\"\">\n                <label for=\"TEXT_1476405440861\">Clinical Indication:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476405440861\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Vulvar Cancer Staging</textarea>\n            </p>\n                    </section>\n        <section id=\"comparisons\" class=\"level1\" data-section-name=\"Comparison\">\n            <header class=\"level1\">\n                Comparison\n            </header>\n            <p title=\"\">\n                <label for=\"comparisonsText\">Comparison study:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"comparisonsText\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">None available</textarea>\n            </p>\n        </section>\n        <section id=\"findings\" class=\"level1\" data-section-name=\"Findings\">\n            <header class=\"level1\">\n                Findings\n            </header>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476405440879\">Uterus:</label>\n                <select id=\"SELECTION_LIST_1476405440879\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Anteverted\">\n                    <option id=\"SELECTION_LIST_1476405440879_0\" value=\"Anteverted\" name=\"SELECTION_LIST_1476405440879\" selected=\"\">Anteverted</option>\n                    <option id=\"SELECTION_LIST_1476405440879_1\" value=\"Retroverted\" name=\"SELECTION_LIST_1476405440879\">Retroverted</option>\n                    <option id=\"SELECTION_LIST_1476405440879_2\" value=\"Retroflexed\" name=\"SELECTION_LIST_1476405440879\">Retroflexed</option>\n                    <option id=\"SELECTION_LIST_1476405440879_3\" value=\"Displaced to left\" name=\"SELECTION_LIST_1476405440879\">Displaced to left</option>\n                    <option id=\"SELECTION_LIST_1476405440879_4\" value=\"Displaced to right\" name=\"SELECTION_LIST_1476405440879\">Displaced to right</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"findingsText\">Size:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"findingsText\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Normal in size</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476405440878\">Measuring:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"cm\" id=\"NUMBER_1476405440878\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    cm\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476405440885\">Endometrium:</label>\n                <select id=\"SELECTION_LIST_1476405440885\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Normal\">\n                    <option id=\"SELECTION_LIST_1476405440885_0\" value=\"Normal\" name=\"SELECTION_LIST_1476405440885\" selected=\"\">Normal</option>\n                    <option id=\"SELECTION_LIST_1476405440885_1\" value=\"Abnormal\" name=\"SELECTION_LIST_1476405440885\">Abnormal</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476405440888\">The maximum width of the endometrium is:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"mm\" id=\"NUMBER_1476405440888\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    mm\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476405440889\">Cervix:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476405440889\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Unremarkable</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476405440890\">Ovaries:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476405440890\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Unremarkable</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476405440891\">Vagina:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476405440891\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Unremarkable</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476405440892\">Vulva:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476405440892\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476405440893\">Tumour measuring (of larger axis):</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"cm\" id=\"NUMBER_1476405440893\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    cm\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476405440894\">Tumour invasion:</label>\n                <select id=\"SELECTION_LIST_1476405440894\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Confined to the vulva\">\n                    <option id=\"SELECTION_LIST_1476405440894_0\" value=\"Confined to the vulva\" name=\"SELECTION_LIST_1476405440894\" selected=\"\">Confined to the vulva</option>\n                    <option id=\"SELECTION_LIST_1476405440894_1\" value=\"Invading lower urethra\" name=\"SELECTION_LIST_1476405440894\">Invading lower urethra</option>\n                    <option id=\"SELECTION_LIST_1476405440894_2\" value=\"Invading vagina\" name=\"SELECTION_LIST_1476405440894\">Invading vagina</option>\n                    <option id=\"SELECTION_LIST_1476405440894_3\" value=\"Invading perineum\" name=\"SELECTION_LIST_1476405440894\">Invading perineum</option>\n                    <option id=\"SELECTION_LIST_1476405440894_4\" value=\"Invading anus\" name=\"SELECTION_LIST_1476405440894\">Invading anus</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476405440900\">Bladder wall:</label>\n                <select id=\"SELECTION_LIST_1476405440900\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Invaded\">\n                    <option id=\"SELECTION_LIST_1476405440900_0\" value=\"Invaded\" name=\"SELECTION_LIST_1476405440900\" selected=\"\">Invaded</option>\n                    <option id=\"SELECTION_LIST_1476405440900_1\" value=\"Not invaded\" name=\"SELECTION_LIST_1476405440900\">Not invaded</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476405440903\">Rectal wall:</label>\n                <select id=\"SELECTION_LIST_1476405440903\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Invaded\">\n                    <option id=\"SELECTION_LIST_1476405440903_0\" value=\"Invaded\" name=\"SELECTION_LIST_1476405440903\" selected=\"\">Invaded</option>\n                    <option id=\"SELECTION_LIST_1476405440903_1\" value=\"Not invaded\" name=\"SELECTION_LIST_1476405440903\">Not invaded</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476405440906\">Inguinofemoral lymph nodes:</label>\n                <select id=\"SELECTION_LIST_1476405440906\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Normal in size\">\n                    <option id=\"SELECTION_LIST_1476405440906_0\" value=\"Normal in size\" name=\"SELECTION_LIST_1476405440906\" selected=\"\">Normal in size</option>\n                    <option id=\"SELECTION_LIST_1476405440906_1\" value=\"Enlarged; probably reactive\" name=\"SELECTION_LIST_1476405440906\">Enlarged; probably reactive</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476405440909\">Pelvic lymph nodes:</label>\n                <select id=\"SELECTION_LIST_1476405440909\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Normal in size\">\n                    <option id=\"SELECTION_LIST_1476405440909_0\" value=\"Normal in size\" name=\"SELECTION_LIST_1476405440909\" selected=\"\">Normal in size</option>\n                    <option id=\"SELECTION_LIST_1476405440909_1\" value=\"Enlarged; probably reactive\" name=\"SELECTION_LIST_1476405440909\">Enlarged; probably reactive</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476405440912\">Distant metastasis:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476405440912\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no distant metastasis:</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476405440913\">Physiologic pelvic fluid:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476405440913\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no physiologic pelvic fluid.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476405440914\">Other findings:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476405440914\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n        </section>\n        <section id=\"impression\" class=\"level1\" data-section-name=\"Impression\">\n            <header class=\"level1\">\n                Impression\n            </header>\n            <p title=\"\">\n                <label for=\"impressionText\">Impression:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"impressionText\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n        </section>\n    </body>\n</html>\n",

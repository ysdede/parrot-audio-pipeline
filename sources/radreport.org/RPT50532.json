    "templateData": "<!DOCTYPE html>\n<html>\n    <head>\n        <title>US Scrotum</title>\n        <meta charset=\"UTF-8\" />\n        <meta name=\"dcterms.identifier\" content=\"e29219f5-7b20-4a99-81ca-fd74bac005eb\" />\n        <meta name=\"dcterms.title\" content=\"US Scrotum\" />\n        <meta name=\"dcterms.description\" content=\"\" />\n        <meta name=\"dcterms.type\" content=\"IMAGE_REPORT_TEMPLATE\" />\n        <meta name=\"dcterms.language\" content=\"en\" />\n        <meta name=\"dcterms.publisher\" content=\"University of Utah\" />\n        <meta name=\"dcterms.rights\" content=\"May be used freely, subject to license agreement\" />\n        <meta name=\"dcterms.license\" content=\"http://www.radreport.org/license.pdf\" />\n        <meta name=\"dcterms.date\" content=\"2018-03-12\" />\n        <meta name=\"dcterms.creator\" content=\"Marta E. Heilbrun, MD\" />\n        <script type=\"text/xml\">\n            <template_attributes>\n                <coded_content>\n                    <coding_schemes>\n                        <coding_scheme name=\"RADLEX\" designator=\"2.16.840.1.113883.6.256\"></coding_scheme>\n                        <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\"></coding_scheme>\n                    </coding_schemes>\n                    <entry origtxt=\"TEXT_1459370873463\">\n                        <term>\n                            <code meaning=\"indication\" value=\"RID49442\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459370873468\">\n                        <term>\n                            <code meaning=\"epididymis\" value=\"RID371\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459370873467\">\n                        <term>\n                            <code meaning=\"set of testicles\" value=\"RID39541\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459370873469\">\n                        <term>\n                            <code meaning=\"scrotum\" value=\"RID365\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"findings\">\n                        <term>\n                            <code meaning=\"Procedure Findings\" value=\"59776-5\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"impressionText\">\n                        <term>\n                            <code meaning=\"normal\" value=\"RID13173\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"findingsText\">\n                        <term>\n                            <code meaning=\"set of testicles\" value=\"RID39541\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"procedureInformation\">\n                        <term>\n                            <code meaning=\"Current Imaging Procedure Description\" value=\"55111-9\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"comparisons\">\n                        <term>\n                            <code meaning=\"Radiology Comparison Study\" value=\"18834-2\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"impression\">\n                        <term>\n                            <code meaning=\"Impressions\" value=\"19005-8\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"clinicalInformation\">\n                        <term>\n                            <code meaning=\"Clinical Information\" value=\"55752-0\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                </coded_content>\n            </template_attributes>\n        </script>\n    </head>\n    <body>\n        <section id=\"procedureInformation\" class=\"level1\" data-section-name=\"Procedure Information\">\n            <header class=\"level1\">\n                Procedure Information\n            </header>\n            <p title=\"\">\n                <label for=\"TEXT_1459370873464\">Technique:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459370873464\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">The scrotum was evaluated with a high frequency transducer using both grey-scale and Doppler technology.</textarea>\n            </p>\n        </section>\n        <section id=\"clinicalInformation\" class=\"level1\" data-section-name=\"Clinical Information\">\n            <header class=\"level1\">\n                Clinical Information\n            </header>\n            <p title=\"\">\n                <label for=\"TEXT_1459370873463\">Indication:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459370873463\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">None.</textarea>\n            </p>\n        </section>\n        <section id=\"comparisons\" class=\"level1\" data-section-name=\"Comparison\">\n            <header class=\"level1\">\n                Comparison\n            </header>\n            <p title=\"\">\n                <label for=\"comparisonsText\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"comparisonsText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">None.</textarea>\n            </p>\n        </section>\n        <section id=\"findings\" class=\"level1\" data-section-name=\"Findings\">\n            <header class=\"level1\">\n                Findings\n            </header>\n            <p title=\"\">\n                <label for=\"findingsText\">Testicles:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"findingsText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Both testicles are present in expected location. There is no intratesticular mass on either side, with a normal homogeneous appearance to both testicles.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1459370873465\">The right testicle measures:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"cm\" id=\"NUMBER_1459370873465\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    cm\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1459370873466\">The left testicle measures:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"cm\" id=\"NUMBER_1459370873466\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    cm\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1459370873467\">Blood flow within the Testicles:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459370873467\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Color Doppler imaging demonstrates symmetric, normal flow throughout both testicles. Normal pulsed Doppler arterial waveforms were obtained from each testicle.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1459370873468\">Epididymides:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459370873468\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">The epididymides bilaterally are normal without evidence for focal mass or hyperemia on Doppler imaging.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1459370873469\">Scrotum:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459370873469\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">No abnormal intrascrotal fluid collections.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1520912445586\">Additional Findings:</label>\n                <input type=\"text\" id=\"TEXT_1520912445586\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\" value=\"None.\" />\n            </p>\n        </section>\n        <section id=\"impression\" class=\"level1\" data-section-name=\"Impression\">\n            <header class=\"level1\">\n                Impression\n            </header>\n            <p title=\"\">\n                <label for=\"impressionText\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"impressionText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n            </p>\n        </section>\n    </body>\n</html>\n",

    "templateData": "<html><head><meta charset=\"UTF-8\"><meta content=\"base mri lumbar spine\" name=\"dcterms.title\"><meta content=\"9375b88f-127e-43f1-9149-8233442d361c\" name=\"dcterms.identifier\"><meta content=\"en\" name=\"dcterms.language\"><meta content=\"2019-01-31\" name=\"dcterms.date\"><meta content=\"Nuance System\" name=\"dcterms.creator\"><title>base mri lumbar spine</title></head><body><section data-section-name=\"MRI LUMBAR SPINE WITHOUT CONTRAST\"><header class=\"Level1\">MRI LUMBAR SPINE WITHOUT CONTRAST</header><p><label>HISTORY:</label><input type=\"text\" name=\"Patient Age\" value=\"Patient Age\"></p><p><label> old </label><input type=\"text\" name=\"Patient Gender\" value=\"Patient Gender\"></p><p><label>, </label><select name=\"history\"><option name=\"\" value=\"\" selected=\"\">chronic low back pain.</option><option name=\"\" value=\"\" selected=\"\">lumbar radiculopathy.</option><option name=\"\" value=\"\" selected=\"\">low back contusion.</option></select></p></section><section data-section-name=\"TECHNIQUE:\"><header class=\"Level1\">TECHNIQUE:</header><p><label>MR images of the lumbar spine were acquired without intravenous contrast.</label><br><label>COMPARISON: </label><input type=\"text\" name=\"Comparison\" value=\"None available.\"></p></section><section data-section-name=\"FINDINGS:\"><header class=\"Level1\">FINDINGS:</header><p><label>NUMBERING: </label><input type=\"text\" name=\"numbering\" value=\"Last fully formed disc space is designated L5-S1.\"></p><p><label>SPINAL CORD: </label><input type=\"text\" name=\"conus\" value=\"Normal conus.\"></p><p><label> Conus terminates at the </label><select name=\"conus level\"><option name=\"\" value=\"\" selected=\"\">T12-L1</option><option name=\"\" value=\"\" selected=\"\">L1</option><option name=\"\" value=\"\" selected=\"\">L1-L2</option></select><label>level.</label></p><p><label>DISCS: </label><select name=\"discs\"><option name=\"\" value=\"\">Normal.</option><option name=\"\" value=\"\">Multilevel disc dessication.</option></select></p><p><label>BONES: </label><input type=\"text\" name=\"height/alignment\" value=\"Vertebral body height and alignment are normal.\"></p><p><label> </label><input type=\"text\" name=\"marrow\" value=\"Marrow signal is normal.\"></p><p><label>SOFT TISSUES: </label><input type=\"text\" name=\"soft tissues\" value=\"Normal.\"></p><p><label>T12-L1: </label><input type=\"text\" name=\"T12-L1\" value=\"No canal or foraminal stenosis.\"></p><p><label>L1-L2: </label><input type=\"text\" name=\"L1-L2\" value=\"No canal or foraminal stenosis.\"></p><p><label>L2-L3: </label><input type=\"text\" name=\"L2-L3\" value=\"No canal or foraminal stenosis.\"></p><p><label>L3-L4: </label><input type=\"text\" name=\"L3-L4\" value=\"No canal or foraminal stenosis.\"></p><p><label>L4-L5: </label><input type=\"text\" name=\"L4-L5\" value=\"No canal or foraminal stenosis.\"></p><p><label>L5-S1: </label><input type=\"text\" name=\"L5-S1\" value=\"No canal or foraminal stenosis.\"></p><p><label>OTHER: </label><input type=\"text\" name=\"other\" value=\"None.\"></p></section><section data-section-name=\"IMPRESSION:\"><header class=\"Level1\">IMPRESSION:</header><p><textarea name=\"impression\">Normal MRI lumbar spine.</textarea></p></section></body></html>",

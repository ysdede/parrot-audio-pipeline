    "templateData": "<!DOCTYPE html>\n<html>\n    <head>\n        <title>MRI Brachial Plexus</title>\n        <meta charset=\"UTF-8\" />\n        <meta name=\"dcterms.identifier\" content=\"586a84db-b103-41ed-9011-e09b828eb749\" />\n        <meta name=\"dcterms.title\" content=\"MRI Brachial Plexus\" />\n        <meta name=\"dcterms.description\" content=\"\" />\n        <meta name=\"dcterms.type\" content=\"IMAGE_REPORT_TEMPLATE\" />\n        <meta name=\"dcterms.language\" content=\"en\" />\n        <meta name=\"dcterms.publisher\" content=\"\" />\n        <meta name=\"dcterms.rights\" content=\"May be used freely, subject to license agreement\" />\n        <meta name=\"dcterms.license\" content=\"http://www.radreport.org/license.pdf\" />\n        <meta name=\"dcterms.date\" content=\"2020-06-23\" />\n        <meta name=\"dcterms.creator\" content=\"Brian Gilcrease-Garcia\" />\n        <script type=\"text/xml\">\n            <template_attributes>\n                <coded_content>\n                    <coding_schemes>\n                        <coding_scheme name=\"RADLEX\" designator=\"2.16.840.1.113883.6.256\"></coding_scheme>\n                        <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\"></coding_scheme>\n                    </coding_schemes>\n                    <entry origtxt=\"SECTION_HEADER_1587053151573\">\n                        <term>\n                            <code meaning=\"brachial plexus\" value=\"http://radlex.org/RID/RID7202\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"findings\">\n                        <term>\n                            <code meaning=\"Procedure Findings\" value=\"59776-5\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1587053151581\">\n                        <term>\n                            <code meaning=\"shoulder girdle\" value=\"http://radlex.org/RID/RID1852\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1587053151580\">\n                        <term>\n                            <code meaning=\"scalene muscle\" value=\"http://radlex.org/RID/RID7495\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1587053151585\">\n                        <term>\n                            <code meaning=\"spine\" value=\"http://radlex.org/RID/RID7741\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1587053151583\">\n                        <term>\n                            <code meaning=\"costovertebral joint\" value=\"http://radlex.org/RID/RID2478\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1587053151584\">\n                        <term>\n                            <code meaning=\"clavicle\" value=\"http://radlex.org/RID/RID1854\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1587053151578\">\n                        <term>\n                            <code meaning=\"branch of brachial artery\" value=\"http://radlex.org/RID/RID35875\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1587053151577\">\n                        <term>\n                            <code meaning=\"set of cords of brachial nerve plexus\" value=\"http://radlex.org/RID/RID16503\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"CHECKBOX_1588611066117\">\n                        <term>\n                            <code meaning=\"laterality\" value=\"http://radlex.org/RID/RID5821\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"CHECKBOX_1588611066117_0\">\n                        <term>\n                            <code meaning=\"left\" value=\"http://radlex.org/RID/RID5824\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"CHECKBOX_1588611066117_1\">\n                        <term>\n                            <code meaning=\"right\" value=\"http://radlex.org/RID/RID5825\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"impressionText\">\n                        <term>\n                            <code meaning=\"impression\" value=\"http://radlex.org/RID/RID49895\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1587053151571\">\n                        <term>\n                            <code meaning=\"intravenous contrast\" value=\"http://radlex.org/RID/RID49553\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"clinicalInformationText\">\n                        <term>\n                            <code meaning=\"indication\" value=\"http://radlex.org/RID/RID49442\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1587053151574\">\n                        <term>\n                            <code meaning=\"trunk of brachial nerve plexus\" value=\"http://radlex.org/RID/RID7207\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1587053151572\">\n                        <term>\n                            <code meaning=\"brachial plexus\" value=\"http://radlex.org/RID/RID7202\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"findingsText\">\n                        <term>\n                            <code meaning=\"spinal cord\" value=\"http://radlex.org/RID/RID7361\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1587053151587\">\n                        <term>\n                            <code meaning=\"incidental imaging finding\" value=\"http://radlex.org/RID/RID50142\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"procedureInformation\">\n                        <term>\n                            <code meaning=\"Current Imaging Procedure Description\" value=\"55111-9\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"comparisons\">\n                        <term>\n                            <code meaning=\"Radiology Comparison Study\" value=\"18834-2\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"impression\">\n                        <term>\n                            <code meaning=\"Impressions\" value=\"19005-8\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"clinicalInformation\">\n                        <term>\n                            <code meaning=\"Clinical Information\" value=\"55752-0\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"CHECKBOX_1588611066120\">\n                        <term>\n                            <code meaning=\"laterality\" value=\"http://radlex.org/RID/RID5821\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"CHECKBOX_1588611066120_0\">\n                        <term>\n                            <code meaning=\"left\" value=\"http://radlex.org/RID/RID5824\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"CHECKBOX_1588611066120_1\">\n                        <term>\n                            <code meaning=\"right\" value=\"http://radlex.org/RID/RID5825\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                </coded_content>\n            </template_attributes>\n        </script>\n    </head>\n    <body>\n        <section id=\"procedureInformation\" class=\"level1\" data-section-name=\"Procedure Information\">\n            <header class=\"level1\">\n                Procedure Information\n            </header>\n            <p title=\"\">\n                <label for=\"procedureInformationText\">Exam</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"procedureInformationText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">MRI brachial plexus without and with contrast, left or right</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"CHECKBOX_1588611066117\">Exam laterality</label>\n                <span id=\"CHECKBOX_1588611066117\" name=\"\" data-field-type=\"CHECKBOX\" data-field-completion-action=\"NONE\" value=\"\">\n                    <br />\n                    <input id=\"CHECKBOX_1588611066117_0\" type=\"checkbox\" name=\"CHECKBOX_1588611066117\" value=\"left\" checked=\"\">left</input>\n                    <br />\n                    <input id=\"CHECKBOX_1588611066117_1\" type=\"checkbox\" name=\"CHECKBOX_1588611066117\" value=\"right\">right</input>\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1587053151570\">Technique</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1587053151570\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">MRI examination of the brachial plexus was performed according to a brachial plexus protocol which included multiplanar anatomic and 3-D fluid-sensitive sequences. </textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"CHECKBOX_1588611066120\">Technique laterality</label>\n                <span id=\"CHECKBOX_1588611066120\" name=\"\" data-field-type=\"CHECKBOX\" data-field-completion-action=\"NONE\" value=\"\">\n                    <br />\n                    <input id=\"CHECKBOX_1588611066120_0\" type=\"checkbox\" name=\"CHECKBOX_1588611066120\" value=\"left\" checked=\"\">left</input>\n                    <br />\n                    <input id=\"CHECKBOX_1588611066120_1\" type=\"checkbox\" name=\"CHECKBOX_1588611066120\" value=\"right\">right</input>\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1587053151571\">IV Contrast</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1587053151571\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n        </section>\n        <section id=\"clinicalInformation\" class=\"level1\" data-section-name=\"Clinical Information\">\n            <header class=\"level1\">\n                Clinical Information\n            </header>\n            <p title=\"\">\n                <label for=\"clinicalInformationText\">Indication</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"clinicalInformationText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n        </section>\n        <section id=\"comparisons\" class=\"level1\" data-section-name=\"Comparison\">\n            <header class=\"level1\">\n                Comparison\n            </header>\n            <p title=\"\">\n                <label for=\"comparisonsText\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"comparisonsText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n        </section>\n        <section id=\"findings\" class=\"level1\" data-section-name=\"Findings\">\n            <header class=\"level1\">\n                Findings\n            </header>\n            <p title=\"\">\n                <label for=\"findingsText\">Spinal cord</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"findingsText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal caliber and signal of the visualized cord.</textarea>\n            </p>\n            <section id=\"SECTION_HEADER_1587053151573\" class=\"level2\" data-section-name=\"Brachial plexus\">\n                <header class=\"level2\">\n                    Brachial plexus\n                </header>\n            </section>\n            <p title=\"\">\n                <label for=\"TEXT_1587053151572\">Roots</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1587053151572\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1587053151574\">Trunks</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1587053151574\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1587053151576\">Divisions</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1587053151576\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1587053151577\">Cords</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1587053151577\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1587053151578\">Branches</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1587053151578\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal</textarea>\n            </p>\n            <section id=\"SECTION_HEADER_1587053151579\" class=\"level2\" data-section-name=\"Muscles\">\n                <header class=\"level2\">\n                    Muscles\n                </header>\n            </section>\n            <p title=\"\">\n                <label for=\"TEXT_1587053151580\">Scalenes</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1587053151580\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1587053151581\">Shoulder girdle</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1587053151581\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Visualized portions of rotator cuff muscles and chest wall are normal.</textarea>\n            </p>\n            <section id=\"SECTION_HEADER_1587053151582\" class=\"level2\" data-section-name=\"Bones\">\n                <header class=\"level2\">\n                    Bones\n                </header>\n            </section>\n            <p title=\"\">\n                <label for=\"TEXT_1587053151583\">Costovertebral anomaly</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1587053151583\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">No cervical rib, anomalous first rib, or elongated C7 transverse process.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1587053151584\">Clavicle</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1587053151584\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1587053151585\">Spine</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1587053151585\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Limited view of the cervicothoracic spine is unremarkable.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1587053151586\">Thoracic outlet</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1587053151586\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal scalene triangle, costoclavicular space, and pectoralis minor space. No evidence of fibrous band or mass lesion.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1587053151587\">Other findings</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1587053151587\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">No evidence of vascular abnormality. Limited view of the upper thorax is unremarkable.</textarea>\n            </p>\n        </section>\n        <section id=\"impression\" class=\"level1\" data-section-name=\"Impression\">\n            <header class=\"level1\">\n                Impression\n            </header>\n            <p title=\"\">\n                <label for=\"impressionText\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"impressionText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal appearance of the brachial plexus.</textarea>\n            </p>\n        </section>\n    </body>\n</html>\n",

    "templateData": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\"/>\n<meta content=\"Pediatric Upper GI Exam\" name=\"dcterms.title\"/>\n<meta content=\"Pediatric Upper GI Exam template :: Authored by Meyer JS, et al.\" name=\"dcterms.description\"/>\n<meta content=\"http://www.radreport.org/template/0000109\" name=\"dcterms.identifier\"/>\n<meta content=\"en\" name=\"dcterms.language\"/>\n<meta content=\"IMAGE_REPORT_TEMPLATE\" name=\"dcterms.type\"/>\n<meta content=\"Radiological Society of North America (RSNA)\" name=\"dcterms.publisher\"/>\n<meta content=\"May be used gratis, subject to license agreement\" name=\"dcterms.rights\"/>\n<meta content=\"http://www.radreport.org/license.pdf\" name=\"dcterms.license\"/>\n<meta content=\"2012-07-18\" name=\"dcterms.date\"/>\n<meta content=\"Meyer JS, et al.\" name=\"dcterms.creator\"/>\n<meta content=\"Society for Pediatric Radiology (SPR)\" name=\"dcterms.contributor\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"IHE_Template_Style.css\"/>\n<!-- The absolute link to the CSS file is http://www.radreport.org/html/IHE_Template_Style.css -->\n<script type=\"text/xml\">\n<!--\n<template_attributes>\n<top-level-flag>true</top-level-flag>\n<status>ACTIVE</status>\n<coding_schemes>\n <coding_scheme name=\"RadLex\" designator=\"2.16.840.1.113883.6.256\" />\n <coding_scheme name=\"SNOMEDCT\" designator=\"2.16.840.1.113883.6.96\" />\n <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\" />\n</coding_schemes>\n<term>\n <code meaning=\"child\" value=\"RID5641\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"duodenum\" value=\"RID134\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"esophagus\" value=\"RID95\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"fluoroscopy\" value=\"RID10361\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"stomach\" value=\"RID114\" scheme=\"RadLex\">\n</term>\n<coded_content>\n<entry ORIGTXT=\"T109_6\">\n <term>\n  <code meaning=\"oral contrast\" value=\"RID35817\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T109_9\">\n <term>\n  <code meaning=\"route of administration\" value=\"RID11087\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T109_13\">\n <term>\n  <code meaning=\"imaging technique\" value=\"RID28482\" scheme=\"RadLex\">\n </term>\n <term>\n  <code meaning=\"imaging technique modifier\" value=\"RID28642\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T109_14\">\n <term>\n  <code meaning=\"clinical information\" value=\"RID13166\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T109_20\">\n <term>\n  <code meaning=\"comparison\" value=\"RID28483\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T109_36\">\n <term>\n  <code meaning=\"pulmonary aspiration\" value=\"RID5321\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T109_38\">\n <term>\n  <code meaning=\"esophagus\" value=\"RID95\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T109_47\">\n <term>\n  <code meaning=\"stomach\" value=\"RID114\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T109_48\">\n <term>\n  <code meaning=\"normal\" value=\"RID13173\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T109_49\">\n <term>\n  <code meaning=\"size descriptor\" value=\"RID5772\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T109_60\">\n <term>\n  <code meaning=\"duodenum\" value=\"RID134\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T109_64\">\n <term>\n  <code meaning=\"duodenum\" value=\"RID134\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T109_76\">\n <term>\n  <code meaning=\"duodenojejunal junction\" value=\"RID32232\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T109_79\">\n <term>\n  <code meaning=\"gastroesophageal reflux\" value=\"RID5260\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T109_127\">\n <term>\n  <code meaning=\"impression section\" value=\"RID13170\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T109_128\">\n <term>\n  <code meaning=\"gastroesophageal reflux\" value=\"RID5260\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T109_134\">\n <term>\n  <code meaning=\"intestine\" value=\"RID130\" scheme=\"RadLex\">\n </term>\n <term>\n  <code meaning=\"malrotation\" value=\"RID4812\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T109_137\">\n <term>\n  <code meaning=\"duodenum\" value=\"RID134\" scheme=\"RadLex\">\n </term>\n <term>\n  <code meaning=\"obstruction\" value=\"RID4962\" scheme=\"RadLex\">\n </term>\n</entry>\n</coded_content>\n</template_attributes>\n-->\n</script>\n<title>Pediatric Upper GI Exam</title>\n</head>\n<body>\n<section data-section-name=\"Procedure\">\n<header class=\"level1\">Pediatric Upper GI Exam</header>\n<p>\n<label for=\"T109_6\">Contrast:</label>\n<input type=\"text\" id=\"T109_6\" name=\"Contrast\" value=\"barium sulfate suspension\"/>\n<label for=\"T109_9\">given by</label>\n<input type=\"text\" id=\"T109_9\" name=\"given by\" value=\"mouth\"/>\n</p>\n<p>\n<textarea id=\"T109_13\" name=\"Procedure\">Images of the esophagus, stomach, duodenum, and proximal mesenteric bowel were obtained.</textarea>\n</p>\n</section>\n<section data-section-name=\"Clinical information\">\n<header class=\"level1\">Clinical information</header>\n<p>\n<textarea id=\"T109_14\" name=\"Clinical information\"> </textarea>\n</p>\n</section>\n<section data-section-name=\"Comparison\">\n<header class=\"level1\">Comparison</header>\n<p>\n<textarea id=\"T109_20\" name=\"Comparison\">None. </textarea>\n</p>\n</section>\n<section data-section-name=\"Findings\">\n<header class=\"level1\">Findings</header>\n<p>\n<label for=\"T109_31\">Preliminary view:</label>\n<input type=\"text\" id=\"T109_31\" name=\"Preliminary view\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T109_33\">Swallowing:</label>\n<input type=\"text\" id=\"T109_33\" name=\"Swallowing\" value=\"Normal\"/>\n</p>\n<p>\n<label for=\"T109_36\">Aspiration:</label>\n<input type=\"text\" id=\"T109_36\" name=\"Aspiration\" value=\"None.\"/>\n</p>\n<p>\n<label for=\"T109_38\">Esophagus:</label>\n<input type=\"text\" id=\"T109_38\" name=\"Esophagus\" value=\"Normal caliber and motility.\"/>\n</p>\n<p>\n<label for=\"T109_47\">Stomach:</label>\n<input type=\"text\" id=\"T109_47\" name=\"Stomach\" value=\"Normal size \"/>\n</p>\n<p>\n<label for=\"T109_48\">Normal</label>\n<input type=\"text\" id=\"T109_48\" name=\"Normal\" value=\"\"/>\n</p>\n<p>\n<label for=\"T109_49\">Size</label>\n<input type=\"text\" id=\"T109_49\" name=\"Size\" value=\"Normal size. Normal gastric mucosa. No penetratic ulcer. \"/>\n</p>\n<p>\n<label for=\"T109_60\">Emptying into duodenum:</label>\n<input type=\"text\" id=\"T109_60\" name=\"Emptying into duodenum\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T109_64\">Duodenum:</label>\n<input type=\"text\" id=\"T109_64\" name=\"Duodenum\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T109_76\">Duodenojejunal junction</label>\n<input type=\"text\" id=\"T109_76\" name=\"Duodenojejunal junction\" value=\"Normal and located in the left upper quadrant of the abdomen\"/>\n</p>\n<p>\n<label for=\"T109_79\">Gastroesophageal reflux:</label>\n<input type=\"text\" id=\"T109_79\" name=\"Gastroesophageal reflux\" value=\"None observed.\"/>\n</p>\n<p>\n<label>Fluoroscopy time:</label>\n<input type=\"number\" name=\"Fluoroscopy time\" data-field-units=\"minutes\" /> minutes\n</p>\n</section>\n<section data-section-name=\"Impression\">\n<header class=\"level1\">Impression</header>\n<p>\n<textarea id=\"T109_127\" name=\"Impression\">Normal. </textarea>\n</p>\n<p>\n<label for=\"T109_128\">Gastroesophageal reflux:</label>\n<input type=\"text\" id=\"T109_128\" name=\"Gastroesophageal reflux\" value=\"Absent.\"/>\n</p>\n<p>\n<label for=\"T109_131\">Gastric emptying:</label>\n<input type=\"text\" id=\"T109_131\" name=\"Gastric emptying\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T109_134\">Intestinal malrotation:</label>\n<input type=\"text\" id=\"T109_134\" name=\"Intestinal malrotation\" value=\"None.\"/>\n</p>\n<p>\n<label for=\"T109_137\">Duodenal obstruction:</label>\n<input type=\"text\" id=\"T109_137\" name=\"Duodenal obstruction\" value=\"None. \"/>\n</p>\n</section>\n</body>\n</html>\n",

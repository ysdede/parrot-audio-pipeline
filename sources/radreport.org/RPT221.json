    "templateData": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\"/>\n<meta content=\"CT Renal Stones\" name=\"dcterms.title\"/>\n<meta content=\"CT Renal Stones template :: Authored by Kahn CE Jr\" name=\"dcterms.description\"/>\n<meta content=\"http://www.radreport.org/template/0000221\" name=\"dcterms.identifier\"/>\n<meta content=\"en\" name=\"dcterms.language\"/>\n<meta content=\"IMAGE_REPORT_TEMPLATE\" name=\"dcterms.type\"/>\n<meta content=\"Radiological Society of North America (RSNA)\" name=\"dcterms.publisher\"/>\n<meta content=\"May be used gratis, subject to license agreement\" name=\"dcterms.rights\"/>\n<meta content=\"http://www.radreport.org/license.pdf\" name=\"dcterms.license\"/>\n<meta content=\"2012-06-08\" name=\"dcterms.date\"/>\n<meta content=\"Kahn CE Jr\" name=\"dcterms.creator\"/>\n<meta content=\"Kahn CE Jr [editor]\" name=\"dcterms.contributor\"/>\n<meta content=\"Medical College of Wisconsin (MCW)\" name=\"dcterms.contributor\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"IHE_Template_Style.css\"/>\n<!-- The absolute link to the CSS file is http://www.radreport.org/html/IHE_Template_Style.css -->\n<script type=\"text/xml\">\n<!--\n<template_attributes>\n<top-level-flag>true</top-level-flag>\n<status>ACTIVE</status>\n<coding_schemes>\n <coding_scheme name=\"RadLex\" designator=\"2.16.840.1.113883.6.256\" />\n <coding_scheme name=\"SNOMEDCT\" designator=\"2.16.840.1.113883.6.96\" />\n <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\" />\n</coding_schemes>\n<term>\n <code meaning=\"computed tomography\" value=\"RID10321\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"kidney\" value=\"RID205\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"renal calculus\" value=\"RID38586\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"ureter\" value=\"RID229\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"urinary bladder\" value=\"RID237\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"urolithiasis\" value=\"RID4996\" scheme=\"RadLex\">\n</term>\n<coded_content>\n<entry ORIGTXT=\"T221_2\">\n <term>\n  <code meaning=\"procedure\" value=\"RID1559\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T221_3\">\n  <term>\n  <code meaning=\"Clinical information\" value=\"55752-0\" scheme=\"LOINC\">\n </term>\n</entry>\n<entry ORIGTXT=\"T221_6\">\n <term>\n  <code meaning=\"comparison\" value=\"RID28483\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T221_12\">\n <term>\n  <code meaning=\"normal\" value=\"RID13173\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T221_13\">\n <term>\n  <code meaning=\"impression section\" value=\"RID13170\" scheme=\"RadLex\">\n </term>\n</entry>\n</coded_content>\n</template_attributes>\n-->\n</script>\n<title>CT Renal Stones</title>\n</head>\n<body>\n<section data-section-name=\"Procedure\">\n<header class=\"level1\">CT Renal Stones</header>\n<p>\n<textarea id=\"T221_2\" name=\"Procedure\"> </textarea>\n</p>\n</section>\n<section data-section-name=\"Clinical information\">\n<header class=\"level1\">Clinical information</header>\n<p>\n<textarea id=\"T221_3\" name=\"Clinical information\"> </textarea>\n</p>\n</section>\n<section data-section-name=\"Comparison\">\n<header class=\"level1\">Comparison</header>\n<p>\n<textarea id=\"T221_6\" name=\"Comparison\">None. </textarea>\n</p>\n</section>\n<section data-section-name=\"Findings\">\n<header class=\"level1\">Findings</header>\n<p>\n<label>Kidneys:</label>\n<input type=\"text\" value=\"Normal. No calculus or hydronephrosis.\" />\n</p>\n<p>\n<label>Ureters:</label>\n<input type=\"text\" value=\"Normal. No calculus or hydroureter.\" />\n</p>\n<p>\n<label>Bladder:</label>\n<input type=\"text\" value=\"Normal. No calculus.\" />\n</p>\n<p>\n<label>Lung bases:</label>\n<input type=\"text\" value=\"Clear.\" />\n</p>\n<p>\n<label for=\"T221_11\">Other findings:</label><br>\n<textarea id=\"T221_12\" name=\"T221_12\">The lung bases are clear. The visualized portions of liver, pancreas, and spleen are normal on this noncontrast study. The adrenals are normal. The bowel is normal in caliber and wall thickness. No adenopathy is seen. No abnormalities are seen within the pelvis.</textarea>\n</p>\n</section>\n<section data-section-name=\"Impression\">\n<header class=\"level1\">Impression</header>\n<p>\n<textarea id=\"T221_13\" name=\"Impression\">Normal. No urinary tract calculus or obstruction. </textarea>\n</p>\n</section>\n</body>\n</html>",

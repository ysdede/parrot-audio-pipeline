    "templateData": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\"/>\n<meta content=\"NM Hepatobiliary\" name=\"dcterms.title\"/>\n<meta content=\"NM Hepatobiliary template :: Authored by Pryma DA, et al.\" name=\"dcterms.description\"/>\n<meta content=\"http://www.radreport.org/template/0000080\" name=\"dcterms.identifier\"/>\n<meta content=\"en\" name=\"dcterms.language\"/>\n<meta content=\"IMAGE_REPORT_TEMPLATE\" name=\"dcterms.type\"/>\n<meta content=\"Radiological Society of North America (RSNA)\" name=\"dcterms.publisher\"/>\n<meta content=\"May be used gratis, subject to license agreement\" name=\"dcterms.rights\"/>\n<meta content=\"http://www.radreport.org/license.pdf\" name=\"dcterms.license\"/>\n<meta content=\"2012-07-10\" name=\"dcterms.date\"/>\n<meta content=\"Pryma DA, et al.\" name=\"dcterms.creator\"/>\n<meta content=\"Hong Y [coder]\" name=\"dcterms.contributor\"/>\n<meta content=\"Kahn CE Jr [editor]\" name=\"dcterms.contributor\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"IHE_Template_Style.css\"/>\n<!-- The absolute link to the CSS file is http://www.radreport.org/html/IHE_Template_Style.css -->\n<script type=\"text/xml\">\n<!--\n<template_attributes>\n<top-level-flag>true</top-level-flag>\n<status>ACTIVE</status>\n<coding_schemes>\n <coding_scheme name=\"RadLex\" designator=\"2.16.840.1.113883.6.256\" />\n <coding_scheme name=\"SNOMEDCT\" designator=\"2.16.840.1.113883.6.96\" />\n <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\" />\n</coding_schemes>\n<term>\n <code meaning=\"biliary system\" value=\"RID28753\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"liver\" value=\"RID58\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"scintigraphy\" value=\"RID34428\" scheme=\"RadLex\">\n</term>\n<coded_content>\n<entry ORIGTXT=\"T80_10\">\n <term>\n  <code meaning=\"treatment\" value=\"RID8\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T80_14\">\n <term>\n  <code meaning=\"Tc-99m mebrofenin\" value=\"RID11738\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T80_34\">\n <term>\n  <code meaning=\"treatment\" value=\"RID8\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T80_39\">\n <term>\n  <code meaning=\"none\" value=\"RID28454\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T80_40\">\n <term>\n  <code meaning=\"therapeutic response\" value=\"RID11510\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T80_41\">\n <term>\n  <code meaning=\"therapeutic response\" value=\"RID11510\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T80_43\">\n <term>\n  <code meaning=\"clinical information\" value=\"RID13166\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T80_47\">\n <term>\n  <code meaning=\"comparison\" value=\"RID28483\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T80_95\">\n <term>\n  <code meaning=\"gallbladder\" value=\"RID187\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T80_107\">\n <term>\n  <code meaning=\"impression section\" value=\"RID13170\" scheme=\"RadLex\">\n </term>\n</entry>\n</coded_content>\n</template_attributes>\n-->\n</script>\n<title>NM Hepatobiliary</title>\n</head>\n<body>\n<section data-section-name=\"Procedure\">\n<header class=\"level1\">NM Hepatobiliary Scan</header>\n<p>\n<label for=\"T80_10\">Pre-treatment:</label>\n<input type=\"text\" id=\"T80_10\" name=\"Pre-treatment\" value=\"None. \"/>\n</p>\n<p>\n<label for=\"T80_12\">Cholecystokinin:</label>\n<input type=\"number\" id=\"T80_12\" name=\"Cholecystokinin\" data-field-units=\"mcg\" min=\"0\" max=\"\"/> mcg IV\n</p>\n<p>\n<label for=\"T80_14\">Radiopharmaceutical: Tc-99m mebrofenin</label>\n<input type=\"number\" id=\"T80_14\" name=\"Radiopharmaceutical Tc-99m mebrofenin\" data-field-units=\"mCi\" min=\"0\" max=\"\"/> mCi IV\n</p>\n<p>\n<label for=\"T80_17\">Injection site:</label>\n<input type=\"text\" id=\"T80_17\" name=\"Injection site\" value=\"\"/>\n</p>\n<p>\n<label for=\"T80_33\">Initial dynamic images:</label>\n<input type=\"text\" id=\"T80_33\" name=\"Initial dynamic images\" value=\"60 minutes\"/>\n</p>\n<p>\n<label for=\"T80_34\">Post-treatment:</label>\n<input type=\"text\" id=\"T80_34\" name=\"Post-treatment\" value=\"None. \"/>\n</p>\n<p>\n<label for=\"T80_38\">Additional images:</label>\n<select id=\"T80_38\" name=\"Additional images\">\n<option id=\"T80_39\" name=\"None\" value=\"None\">None</option>\n<option id=\"T80_40\" name=\"Morphine response\" value=\"Morphine response\">30 minute dynamic after morphine administration</option>\n<option id=\"T80_41\" name=\"CCK response\" value=\"CCK response\">30 minute dynamic during CCK administration</option>\n<option id=\"T80_42\" name=\"Delayed\" value=\"Delayed\">4 hour delayed static</option>\n</select>\n</p>\n</section>\n<section data-section-name=\"Clinical information\">\n<header class=\"level1\">Clinical information</header>\n<p>\n<textarea id=\"T80_43\" name=\"Clinical information\">Right upper quadrant pain. </textarea>\n</p>\n</section>\n<section data-section-name=\"Comparison\">\n<header class=\"level1\">Comparison</header>\n<p>\n<textarea id=\"T80_47\" name=\"Comparison\">None. </textarea>\n</p>\n</section>\n<section data-section-name=\"Findings\">\n<header class=\"level1\">Findings</header>\n<p>\n<label for=\"T80_89\">Hepatic transit time:</label>\n<input type=\"text\" id=\"T80_89\" name=\"Hepatic transit time\" value=\"Normal. \"/>\n</p>\n<p>\n<label for=\"T80_92\">Excretion into small bowel:</label>\n<input type=\"text\" id=\"T80_92\" name=\"Excretion into small bowel\" value=\"Normal. \"/>\n</p>\n<p>\n<label for=\"T80_95\">Gallbladder:</label>\n<input type=\"text\" id=\"T80_95\" name=\"Gallbladder\" value=\"Normal. \"/>\n</p>\n<p>\n<label for=\"T80_103\">Ejection fraction:</label>\n<input type=\"number\" id=\"T80_103\" name=\"Ejection fraction\" data-field-units=\"%\" min=\"0\" max=\"100\"/> %\n</p>\n<p>\n<label for=\"T80_106\">Other findings:</label>\n<input type=\"text\" id=\"T80_106\" name=\"Other findings\" value=\"None.\"/>\n</p>\n</section>\n<section data-section-name=\"Impression\">\n<header class=\"level1\">Impression</header>\n<p>\n<textarea id=\"T80_107\" name=\"Impression\">Normal. No evidence of cholecystitis or gallbladder dyskinesia. </textarea>\n</p>\n</section>\n</body>\n</html>\n",

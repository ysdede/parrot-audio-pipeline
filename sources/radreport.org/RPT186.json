    "templateData": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\"/>\n<meta content=\"MR Temporomandibular Joint\" name=\"dcterms.title\"/>\n<meta content=\"MR Temporomandibular Joint template :: Authored by Kahn CE Jr\" name=\"dcterms.description\"/>\n<meta content=\"http://www.radreport.org/template/0000186\" name=\"dcterms.identifier\"/>\n<meta content=\"en\" name=\"dcterms.language\"/>\n<meta content=\"IMAGE_REPORT_TEMPLATE\" name=\"dcterms.type\"/>\n<meta content=\"Radiological Society of North America (RSNA)\" name=\"dcterms.publisher\"/>\n<meta content=\"May be used gratis, subject to license agreement\" name=\"dcterms.rights\"/>\n<meta content=\"http://www.radreport.org/license.pdf\" name=\"dcterms.license\"/>\n<meta content=\"2012-06-19\" name=\"dcterms.date\"/>\n<meta content=\"Kahn CE Jr\" name=\"dcterms.creator\"/>\n\n<meta content=\"Kahn CE Jr [editor]\" name=\"dcterms.contributor\"/>\n<meta content=\"Medical College of Wisconsin (MCW)\" name=\"dcterms.contributor\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"IHE_Template_Style.css\"/>\n<!-- The absolute link to the CSS file is http://www.radreport.org/html/IHE_Template_Style.css -->\n<script type=\"text/xml\">\r\n<!--\r\n<template_attributes>\n<top-level-flag>true</top-level-flag>\n<status>ACTIVE</status>\n<coding_schemes>\n <coding_scheme name=\"RadLex\" designator=\"2.16.840.1.113883.6.256\" />\n <coding_scheme name=\"SNOMEDCT\" designator=\"2.16.840.1.113883.6.96\" />\n <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\" />\n</coding_schemes>\n<term>\n <code meaning=\"magnetic resonance imaging\" value=\"RID10312\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"temporomandibular joint\" value=\"RID9779\" scheme=\"RadLex\">\n</term>\n<coded_content>\n<entry ORIGTXT=\"T186_2\">\n <term>\n  <code meaning=\"procedure\" value=\"RID1559\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T186_3\">\n  <term>\n  <code meaning=\"Clinical information\" value=\"55752-0\" scheme=\"LOINC\">\n </term>\n</entry>\n<entry ORIGTXT=\"T186_6\">\n <term>\n  <code meaning=\"comparison\" value=\"RID28483\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T186_15\">\n <term>\n  <code meaning=\"impression section\" value=\"RID13170\" scheme=\"RadLex\">\n </term>\n</entry>\n</coded_content>\n</template_attributes>\r\n-->\r\n</script>\n<title>MR Temporomandibular Joint</title>\n</head>\n<body>\n<section data-section-name=\"Procedure\">\n<header class=\"level1\">MR Temporomandibular Joint</header>\n<p>\n<textarea id=\"T186_2\" name=\"Procedure\">Sagittal T2-weighted fat-saturation images were obtained with the jaw in open and closed positions. Coronal T2-weighted images images were obtained as well. </textarea>\n</p>\n</section>\n<section data-section-name=\"Clinical information\">\n<header class=\"level1\">Clinical information</header>\n<p>\n<textarea id=\"T186_3\" name=\"Clinical information\">Arthralgia. Joint popping. </textarea>\n</p>\n</section>\n<section data-section-name=\"Comparison\">\n<header class=\"level1\">Comparison</header>\n<p>\n<textarea id=\"T186_6\" name=\"Comparison\">None. </textarea>\n</p>\n</section>\n<section data-section-name=\"Findings\">\n<header class=\"level1\">Findings</header>\n<p>\n<label for=\"T186_9\">Right temporomandibular joint:</label>\n<input type=\"text\" id=\"T186_9\" name=\"Right temporomandibular joint\" value=\"The articular disc is normally positioned between the mandibular condyle and the temporal bone in both open and closed positions. There is normal anterior translation of the mandibular condyle with jaw opening.\"/>\n</p>\n<p>\n<label for=\"T186_12\">Left temporomandibular joint:</label>\n<input type=\"text\" id=\"T186_12\" name=\"Left temporomandibular joint\" value=\"The articular disc is normally positioned between the mandibular condyle and the temporal bone in both open and closed positions. There is normal anterior translation of the mandibular condyle with jaw opening.\"/>\n</p>\n</section>\n<section data-section-name=\"Impression\">\n<header class=\"level1\">Impression</header>\n<p>\n<textarea id=\"T186_15\" name=\"Impression\">Normal temporomandibular joints. </textarea>\n</p>\n</section>\n</body>\n</html>\n",

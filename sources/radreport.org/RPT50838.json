    "templateData": "<!DOCTYPE html>\n<html>\n    <head>\n        <title>Ovarian Cancer Follow-Up MRI</title>\n        <meta charset=\"UTF-8\" />\n        <meta name=\"dcterms.identifier\" content=\"c6dacfa1-d306-4d8c-9bf0-047d698012c5\" />\n        <meta name=\"dcterms.title\" content=\"Ovarian Cancer Follow-Up MRI\" />\n        <meta name=\"dcterms.description\" content=\"\" />\n        <meta name=\"dcterms.type\" content=\"IMAGE_REPORT_TEMPLATE\" />\n        <meta name=\"dcterms.language\" content=\"en\" />\n        <meta name=\"dcterms.publisher\" content=\"ESR\" />\n        <meta name=\"dcterms.rights\" content=\"May be used freely, subject to license agreement\" />\n        <meta name=\"dcterms.license\" content=\"http://www.radreport.org/license.pdf\" />\n        <meta name=\"dcterms.date\" content=\"2017-10-06\" />\n        <meta name=\"dcterms.creator\" content=\"Teresa Margarida Cunha, MD\" />\n        <meta name=\"dcterms.contributor\" content=\"Rita Lucas, MD\" />\n        <script type=\"text/xml\">\n            <template_attributes>\n                <coded_content>\n                    <coding_schemes>\n                        <coding_scheme name=\"RADLEX\" designator=\"2.16.840.1.113883.6.256\"></coding_scheme>\n                    </coding_schemes>\n                    <entry origtxt=\"SELECTION_LIST_1476399598620\">\n                        <term>\n                            <code meaning=\"procedure\" value=\"RID1559\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"impressionText\">\n                        <term>\n                            <code meaning=\"impression section\" value=\"RID13170\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476399598642\">\n                        <term>\n                            <code meaning=\"rectum\" value=\"RID163\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476399598640\">\n                        <term>\n                            <code meaning=\"vagina\" value=\"RID325\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476399598635\">\n                        <term>\n                            <code meaning=\"set of ovaries\" value=\"RID39537\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476399598634\">\n                        <term>\n                            <code meaning=\"pleural effusion\" value=\"RID34539\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476399598638\">\n                        <term>\n                            <code meaning=\"endometrium\" value=\"RID30958\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476399598637\">\n                        <term>\n                            <code meaning=\"uterus\" value=\"RID302\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"comparisonsText\">\n                        <term>\n                            <code meaning=\"comparison\" value=\"RID28483\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476399598619\">\n                        <term>\n                            <code meaning=\"clinical information section\" value=\"RID13166\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476399598646\">\n                        <term>\n                            <code meaning=\"liver\" value=\"RID58\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476399598648\">\n                        <term>\n                            <code meaning=\"hydronephrosis\" value=\"RID34393\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476399598649\">\n                        <term>\n                            <code meaning=\"ascites\" value=\"RID1541\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                </coded_content>\n            </template_attributes>\n        </script>\n    </head>\n    <body>\n        <section id=\"procedureInformation\" class=\"level1\" data-section-name=\"Procedure Information\">\n            <header class=\"level1\">\n                Procedure Information\n            </header>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476399598620\">Procedure Description:</label>\n                <select id=\"SELECTION_LIST_1476399598620\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Enhanced abdomen and pelvis MRI\">\n                    <option id=\"SELECTION_LIST_1476399598620_0\" value=\"Enhanced abdomen and pelvis MRI\" name=\"SELECTION_LIST_1476399598620\" selected=\"\">Enhanced abdomen and pelvis MRI</option>\n                    <option id=\"SELECTION_LIST_1476399598620_1\" value=\"Unenhanced abdomen and pelvis MRI\" name=\"SELECTION_LIST_1476399598620\">Unenhanced abdomen and pelvis MRI</option>\n                </select>\n            </p>\n  <p title=\"\">\n                <label for=\"TEXT_1476399598623\">Technique:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476399598623\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">T1- weighted sequence, T2- weighted sequence of the pelvis in axial, sagittal and coronal planes, and T2W with fat saturation (FS).</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476399598624\">Type of pre and post contrast imaging of the pelvis:</label>\n                <select id=\"SELECTION_LIST_1476399598624\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Dynamic\">\n                    <option id=\"SELECTION_LIST_1476399598624_0\" value=\"Dynamic\" name=\"SELECTION_LIST_1476399598624\" selected=\"\">Dynamic</option>\n                    <option id=\"SELECTION_LIST_1476399598624_1\" value=\"Non-dynamic\" name=\"SELECTION_LIST_1476399598624\">Non-dynamic</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476399598627\">Strength of Tesla scanner:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"\" id=\"NUMBER_1476399598627\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476399598628\">Contrast agent:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476399598628\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476399598630\">Contrast dose administered before and after fat suppressed T1-weighted imaging:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"mL\" id=\"NUMBER_1476399598630\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    mL\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476399598631\">Image quality:</label>\n                <select id=\"SELECTION_LIST_1476399598631\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Satisfactory\">\n                    <option id=\"SELECTION_LIST_1476399598631_0\" value=\"Satisfactory\" name=\"SELECTION_LIST_1476399598631\" selected=\"\">Satisfactory</option>\n                    <option id=\"SELECTION_LIST_1476399598631_1\" value=\"Degraded by motion/etc\" name=\"SELECTION_LIST_1476399598631\">Degraded by motion/etc</option>\n                </select>\n            </p>\n        </section>\n        <section id=\"clinicalInformation\" class=\"level1\" data-section-name=\"Clinical Information\">\n            <header class=\"level1\">\n                Clinical Information\n            </header>\n            <p title=\"\">\n                <label for=\"TEXT_1476399598619\">Clinical Indication:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476399598619\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Ovarian cancer follow-up</textarea>\n            </p>\n                  </section>\n        <section id=\"comparisons\" class=\"level1\" data-section-name=\"Comparison\">\n            <header class=\"level1\">\n                Comparison\n            </header>\n            <p title=\"\">\n                <label for=\"comparisonsText\">Comparison study:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"comparisonsText\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">None available</textarea>\n            </p>\n        </section>\n        <section id=\"findings\" class=\"level1\" data-section-name=\"Findings\">\n            <header class=\"level1\">\n                Findings\n            </header>\n            <p title=\"\">\n                <label for=\"findingsText\">Cardiophrenic lymph nodes:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"findingsText\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Cardiophrenic lymph nodes with a short-axis diameter of &gt;5 mm.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476399598634\">Pleural effusion:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476399598634\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no pleural effusion.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476399598635\">Ovaries:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476399598635\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Unremarkable</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476399598636\">Residual tumor measuring:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"cm\" id=\"NUMBER_1476399598636\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    cm\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476399598637\">Uterus:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476399598637\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Unremarkable</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476399598638\">Endometrium:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476399598638\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Unremarkable</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476399598639\">Cervix:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476399598639\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Unremarkable</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476399598640\">Vagina:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476399598640\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Unremarkable</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476399598641\">Bladder:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476399598641\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Unremarkable</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476399598642\">Rectum:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476399598642\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Unremarkable</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476399598643\">Abdominal/Pelvic wall:</label>\n                <select id=\"SELECTION_LIST_1476399598643\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Invaded\">\n                    <option id=\"SELECTION_LIST_1476399598643_0\" value=\"Invaded\" name=\"SELECTION_LIST_1476399598643\" selected=\"\">Invaded</option>\n                    <option id=\"SELECTION_LIST_1476399598643_1\" value=\"Not Invaded\" name=\"SELECTION_LIST_1476399598643\">Not Invaded</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476399598646\">Liver:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476399598646\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Unremarkable</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476399598647\">Bowel:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476399598647\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Unremarkable</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476399598648\">Hydronephrosis:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476399598648\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no hydronephrosis.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476399598649\">Ascites:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476399598649\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no ascites.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476399598650\">Label - not sure:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476399598650\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is [   ] omental metastases/other peritoneal/serosal implants/ supracolic sites of disease including the gastrohepatic, gastrosplenic and splenocolic ligaments</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476399598651\">Lymph nodes:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476399598651\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There are no lymph nodes with a short-axis diameter of &gt;1 cm, or suspicious clusters of smaller lymph nodes</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476399598652\">Venous obstruction/thrombosis:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476399598652\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no venous obstruction/thrombosis.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476399598653\">Bones:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476399598653\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Unremarkable</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1506699456216\">Other findings:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1506699456216\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n        </section>\n        <section id=\"impression\" class=\"level1\" data-section-name=\"Impression\">\n            <header class=\"level1\">\n                Impression\n            </header>\n            <p title=\"\">\n                <label for=\"impressionText\">Impression:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"impressionText\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n        </section>\n    </body>\n</html>\n",

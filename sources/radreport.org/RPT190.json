    "templateData": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\"/>\n<meta content=\"Small Bowel\" name=\"dcterms.title\"/>\n<meta content=\"Small Bowel template :: Authored by Kahn CE Jr\" name=\"dcterms.description\"/>\n<meta content=\"http://www.radreport.org/template/0000190\" name=\"dcterms.identifier\"/>\n<meta content=\"en\" name=\"dcterms.language\"/>\n<meta content=\"IMAGE_REPORT_TEMPLATE\" name=\"dcterms.type\"/>\n<meta content=\"Radiological Society of North America (RSNA)\" name=\"dcterms.publisher\"/>\n<meta content=\"May be used gratis, subject to license agreement\" name=\"dcterms.rights\"/>\n<meta content=\"http://www.radreport.org/license.pdf\" name=\"dcterms.license\"/>\n<meta content=\"2012-05-29\" name=\"dcterms.date\"/>\n<meta content=\"Kahn CE Jr\" name=\"dcterms.creator\"/>\n\n<meta content=\"Kahn CE Jr [editor]\" name=\"dcterms.contributor\"/>\n<meta content=\"Medical College of Wisconsin (MCW)\" name=\"dcterms.contributor\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"IHE_Template_Style.css\" />\n<!-- The absolute link to the CSS file is http://www.radreport.org/html/IHE_Template_Style.css -->\n<script type=\"text/xml\">\r\n<!--\r\n<template_attributes>\n<top-level-flag>true</top-level-flag>\n<status>ACTIVE</status>\n<coding_schemes>\n <coding_scheme name=\"RadLex\" designator=\"2.16.840.1.113883.6.256\" />\n <coding_scheme name=\"SNOMEDCT\" designator=\"2.16.840.1.113883.6.96\" />\n <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\" />\n</coding_schemes>\n<term>\n <code meaning=\"barium sulfate suspension\" value=\"RID11588\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"projection radiography\" value=\"RID10345\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"small intestine\" value=\"RID132\" scheme=\"RadLex\">\n</term>\n<coded_content>\n<entry ORIGTXT=\"T190_2\">\n <term>\n  <code meaning=\"procedure\" value=\"RID1559\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T190_3\">\n  <term>\n  <code meaning=\"Clinical information\" value=\"55752-0\" scheme=\"LOINC\">\n </term>\n</entry>\n<entry ORIGTXT=\"T190_4\">\n <term>\n  <code meaning=\"comparison\" value=\"RID28483\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T190_17\">\n <term>\n  <code meaning=\"impression section\" value=\"RID13170\" scheme=\"RadLex\">\n </term>\n</entry>\n</coded_content>\n</template_attributes>\r\n-->\r\n</script>\n<title>Small Bowel</title>\n<!-- <style>header {display:none;} label {display: block;}</style> -->\n</head>\n<body>\n<section data-section-name=\"Procedure\">\n<header class=\"level1\">Small Bowel Examination</header>\n<p>\n<!-- <label for=\"T190_2\">Procedure</label> -->\n<textarea id=\"T190_2\" name=\"Procedure\"></textarea>\n</p>\n</section>\n<section data-section-name=\"Clinical information\">\n<header class=\"level1\">Clinical information</header>\n<p>\n<!-- <label for=\"T190_3\">Clinical information</label> -->\n<textarea id=\"T190_3\" name=\"Clinical information\"></textarea>\n</p>\n</section>\n<section data-section-name=\"Comparison\">\n<header class=\"level1\">Comparison</header>\n<p>\n<!-- <label for=\"T190_4\">Comparison</label> -->\n<textarea id=\"T190_4\" name=\"Comparison\">None.</textarea>\n</p>\n</section>\n<section data-section-name=\"Findings\">\n<header class=\"level1\">Findings</header>\n\n<section data-section-name=\"Initial radiograph\">\n\t<header class=\"level2\">Initial abdomen radiograph</header>\n\t<p>\n\t<textarea id=\"T190_7\" name=\"Initial abdomen radiograph\">Normal bowel gas pattern. No abnormal calcification.</textarea>\n\t</p>\n</section>\n\n<section data-section-name=\"Small bowel\">\n\t<header class=\"level2\">Small bowel</header>\n\t<p>\n\t<label for=\"T190_10\">Contrast material:</label>\n\t<input type=\"text\" id=\"T190_10\" name=\"Contrast material\" value=\"50/50 thin barium sulfate suspension.\" />\n\t</p>\n\t<p>\n\t<label for=\"T190_15\">Transit time:</label>\n\t<input type=\"number\" id=\"T190_15\" name=\"Transit time\" data-field-units=\"min\" step=\"1\" min=\"0\" max=\"900\" /> \n\t<label for=\"T190_15\">minutes (normal, 30 - 240 minutes)</label>\n\t</p>\n\t<p>\n\t<textarea id=\"T190_13\" name=\"Small bowel text\">Normal.  No small bowel stricture, dilatation, adhesion, or mass. The terminal ileum is normal.</textarea>\n\t</p>\n</section>\n\n<section data-section-name=\"Fluoroscopy time\">\n\t<header class=\"level2\">Fluoroscopy time</header>\n\t<p>\n\t<!-- <label for=\"Fluoro_time\">Fluoroscopy time</label> -->\n\t<input type=\"number\" id=\"Fluoro_time\" name=\"Fluoro_time\" data-field-units=\"min\" step=\"0.1\" min=\"0\" max=\"999\"/> minutes\n\t</p>\n</section>\n\n</section>\n<section data-section-name=\"Impression\">\n<header class=\"level1\">Impression</header>\n<p>\n<!-- <label for=\"T190_17\">Impression</label> -->\n<textarea id=\"T190_17\" name=\"Impression\">Normal small bowel.</textarea>\n</p>\n</section>\n</body>\n</html>\n",

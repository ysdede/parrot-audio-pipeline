    "templateData": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\"/>\n<meta content=\"Ga-67 SPECT\" name=\"dcterms.title\"/>\n<meta content=\"Ga-67 SPECT template :: Authored by Imani F\" name=\"dcterms.description\"/>\n<meta content=\"http://www.radreport.org/template/0000170\" name=\"dcterms.identifier\"/>\n<meta content=\"en\" name=\"dcterms.language\"/>\n<meta content=\"IMAGE_REPORT_TEMPLATE\" name=\"dcterms.type\"/>\n<meta content=\"Radiological Society of North America (RSNA)\" name=\"dcterms.publisher\"/>\n<meta content=\"May be used gratis, subject to license agreement\" name=\"dcterms.rights\"/>\n<meta content=\"http://www.radreport.org/license.pdf\" name=\"dcterms.license\"/>\n<meta content=\"2012-05-29\" name=\"dcterms.date\"/>\n<meta content=\"Imani F\" name=\"dcterms.creator\"/>\n<meta content=\"Kahn CE Jr [editor]\" name=\"dcterms.contributor\"/>\n<meta content=\"UCLA Health System (UCLA)\" name=\"dcterms.contributor\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"IHE_Template_Style.css\" />\n<script type=\"text/xml\">\n<!--\n<template_attributes>\n<top-level-flag>true</top-level-flag>\n<status>ACTIVE</status>\n<coding_schemes>\n <coding_scheme name=\"RadLex\" designator=\"2.16.840.1.113883.6.256\" />\n <coding_scheme name=\"SNOMEDCT\" designator=\"2.16.840.1.113883.6.96\" />\n <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\" />\n</coding_schemes>\n<term>\n <code meaning=\"Gallium-67\" value=\"RID11703\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"inflammation\" value=\"RID3382\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"neoplasm\" value=\"RID3957\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"single photon emission computed tomography\" value=\"RID10334\" scheme=\"RadLex\">\n</term>\n<coded_content>\n<entry ORIGTXT=\"T170_2\">\n <term>\n  <code meaning=\"procedure\" value=\"RID1559\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T170_6\">\n <term>\n  <code meaning=\"clinical information\" value=\"RID13166\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T170_7\">\n <term>\n  <code meaning=\"comparison\" value=\"RID28483\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T170_9\">\n <term>\n  <code meaning=\"observations section\" value=\"RID28486\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T170_11\">\n <term>\n  <code meaning=\"impression section\" value=\"RID13170\" scheme=\"RadLex\">\n </term>\n</entry>\n</coded_content>\n</template_attributes>\n-->\n</script>\n<title>Ga-67 SPECT</title>\n</head>\n<body>\n<section data-section-name=\"Procedure\">\n<header class=\"level1\">Ga-67 SPECT</header>\n<p>\n<textarea id=\"T170_2\" name=\"Procedure\" style=\"height:4em;\" >Anterior and posterior images of the chest, lower cervical region and upper abdomen were obtained following the intravenous injection of Gallium-67 citrate. Emission tomographic images of the same area were obtained. </textarea>\n</p>\n<p>\n<label for=\"T170_4\">Ga-67 citrate</label>\n<input type=\"number\" id=\"T170_4\" name=\"Ga-67 citrate\" value=\"10\" data-field-units=\"mCi\" min=\"0\" max=\"20\" /> mCi\n</p>\n<p>\n<label for=\"T170_5\">Scan delay</label>\n<input type=\"number\" id=\"T170_5\" name=\"Scan delay\" data-field-units=\"hr\" min=\"0\"/> hr\n</p>\n</section>\n<section data-section-name=\"Clinical information\">\n<header class=\"level1\">Clinical information</header>\n<p>\n<textarea id=\"T170_6\" name=\"Clinical information\"></textarea>\n</p>\n</section>\n<section data-section-name=\"Comparison\">\n<header class=\"level1\">Comparison</header>\n<p>\n<textarea id=\"T170_7\" name=\"Comparison\">None. </textarea>\n</p>\n</section>\n<section data-section-name=\"Findings\">\n<header class=\"level1\">Findings</header>\n<p>\n<textarea id=\"T170_9\" name=\"Findings\">No abnormal concentration of Gallium is demonstrated in the chest, lower neck, or upper abdomen. </textarea>\n</p>\n</section>\n<section data-section-name=\"Impression\">\n<header class=\"level1\">Impression</header>\n<p>\n<textarea id=\"T170_11\" name=\"Impression\">Negative examination. No evidence for inflammation, infection, or tumor. </textarea>\n</p>\n</section>\n</body>\n</html>\n",

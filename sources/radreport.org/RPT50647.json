    "templateData": "<html><head><meta charset=\"UTF-8\"><meta content=\"base mri brain pulsatile tinnitus\" name=\"dcterms.title\"><meta content=\"94b085ba-c534-401d-aa3f-5b254231f04b\" name=\"dcterms.identifier\"><meta content=\"en\" name=\"dcterms.language\"><meta content=\"2019-01-31\" name=\"dcterms.date\"><meta content=\"Nuance System\" name=\"dcterms.creator\"><title>base mri brain pulsatile tinnitus</title></head><body><section data-section-name=\"MRI BRAIN WITHOUT AND WITH CONTRAST, MRA HEAD WITHOUT CONTRAST\"><header class=\"Level1\">MRI BRAIN WITHOUT AND WITH CONTRAST, MRA HEAD WITHOUT CONTRAST</header><p><label>HISTORY:</label><input type=\"text\" name=\"Patient Age\" value=\"Patient Age\"></p><p><label> old </label><input type=\"text\" name=\"Patient Gender\" value=\"Patient Gender\"></p><p><label>, </label><input type=\"text\" name=\"history\" value=\"pulsatile tinnitus\"></p></section><section data-section-name=\"TECHNIQUE:\"><header class=\"Level1\">TECHNIQUE:</header><p><label>MR images of the brain were acquired without and with </label><input type=\"number\" name=\"contrast dose\"><label>mL Gadavist intravenous contrast. MRA images of the head were acquired without contrast.</label></p><p><label>COMPARISON: </label><input type=\"text\" name=\"Comparison\" value=\"None available.\"></p></section><section data-section-name=\"FINDINGS:\"><header class=\"Level1\">FINDINGS:</header><p><label>SKULL BASE: </label><input type=\"text\" name=\"skull base\" value=\"No evidence of mass within the skull base (glomus jugulare), temporal bone, posterior fossa, or internal auditory canal.\"></p><p><label>MRA HEAD: </label><input type=\"text\" name=\"MRA\" value=\"No evidence of dural arteriovenous fistula, arteriovenous malformation, or aneurysm.\"></p><p><label>VENOUS SYSTEM: </label><input type=\"text\" name=\"jugular bulb\" value=\"No evidence of high-riding jugular bulb or diverticulum.\"></p><p><label>  </label><select name=\"dominance\"><option name=\"\" value=\"\" selected=\"\">Right</option><option name=\"\" value=\"\" selected=\"\">Left</option></select></p><p><label> jugular venous system is dominant. </label><input type=\"text\" name=\"transverse sinus\" value=\"No transverse sinus stenoses.\"></p><p><label>SIGNS OF INTRACRANIAL HYPERTENSION: </label><input type=\"text\" name=\"intracranial hypertension?\" value=\"None. No empty/partially empty sella or dilated optic nerve sheath complexes.\"></p><p><label>REMAINING BRAIN PARENCHYMA: </label><input type=\"text\" name=\"infarct-hemorrhage\" value=\"No acute infarct or hemorrhage. No mass effect or herniation.\"></p><p><label>  </label><input type=\"text\" name=\"chiari 1?\" value=\"No Chiari 1 malformation.\"></p><p><label> </label><select name=\"white matter\"><option name=\"Normal\" value=\"Normal\" selected=\"\">Signal intensities are within normal limits for age.</option><option name=\"Mild\" value=\"Mild\">Mild white matter chronic small vessel ischemic changes.</option><option name=\"Moderate\" value=\"Moderate\">Moderate white matter chronic small vessel ischemic changes.</option><option name=\"Severe\" value=\"Severe\">Severe white matter chronic small vessel ischemic changes.</option></select></p><p><label> </label><input type=\"text\" name=\"enhancement?\" value=\"No abnormal enhancement.\"></p><p><label>VENTRICLES/EXTRA-AXIAL SPACES: </label><input type=\"text\" name=\"ventricles-extra-axial\" value=\"No hydrocephalus or extra-axial fluid collections.\"></p><p><label>EXTRACRANIAL STRUCTURES: </label><input type=\"text\" name=\"sinuses/mastoids\" value=\"Sinuses and mastoids are clear.\"></p><p><label>OTHER: </label><input type=\"text\" name=\"other\" value=\"None.\"></p></section><section data-section-name=\"IMPRESSION:\"><header class=\"Level1\">IMPRESSION:</header><p><textarea name=\"impression\">No MRI/MRA etiology for pulsatile tinnitus within the head.</textarea></p></section></body></html>",

    "templateData": "<!DOCTYPE html>\n<html>\n    <head>\n        <title>MRA Neck Neuroradiology</title>\n        <meta charset=\"UTF-8\" />\n        <meta name=\"dcterms.identifier\" content=\"ee597421-c224-47ff-845a-b6b10ff7f222\" />\n        <meta name=\"dcterms.title\" content=\"MRA Neck Neuroradiology\" />\n        <meta name=\"dcterms.description\" content=\"\" />\n        <meta name=\"dcterms.type\" content=\"IMAGE_REPORT_TEMPLATE\" />\n        <meta name=\"dcterms.language\" content=\"en\" />\n        <meta name=\"dcterms.publisher\" content=\"University of Utah\" />\n        <meta name=\"dcterms.rights\" content=\"May be used freely, subject to license agreement\" />\n        <meta name=\"dcterms.license\" content=\"http://www.radreport.org/license.pdf\" />\n        <meta name=\"dcterms.date\" content=\"2018-03-12\" />\n        <meta name=\"dcterms.creator\" content=\"Marta E. Helibrun, MD\" />\n        <script type=\"text/xml\">\n            <template_attributes>\n                <coded_content>\n                    <coding_schemes>\n                        <coding_scheme name=\"RADLEX\" designator=\"2.16.840.1.113883.6.256\"></coding_scheme>\n                        <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\"></coding_scheme>\n                    </coding_schemes>\n                    <entry origtxt=\"findings\">\n                        <term>\n                            <code meaning=\"Procedure Findings\" value=\"59776-5\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"findingsText\">\n                        <term>\n                            <code meaning=\"vasculature\" value=\"RID15989\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"procedureInformation\">\n                        <term>\n                            <code meaning=\"Current Imaging Procedure Description\" value=\"55111-9\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459562789502\">\n                        <term>\n                            <code meaning=\"indication\" value=\"RID49442\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"comparisons\">\n                        <term>\n                            <code meaning=\"Radiology Comparison Study\" value=\"18834-2\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"impression\">\n                        <term>\n                            <code meaning=\"Impressions\" value=\"19005-8\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"clinicalInformation\">\n                        <term>\n                            <code meaning=\"Clinical Information\" value=\"55752-0\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                </coded_content>\n            </template_attributes>\n        </script>\n    </head>\n    <body>\n        <section id=\"procedureInformation\" class=\"level1\" data-section-name=\"Procedure Information\">\n            <header class=\"level1\">\n                Procedure Information\n            </header>\n            <p title=\"\">\n                <label for=\"procedureInformationText\">Technique:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"procedureInformationText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">MR angiogram of the neck.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1459562789498\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459562789498\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">MR angiogram of the neck was performed with 1 mm axial images, coronal and sagittal reformats, and 3D maximum intensity projections. Intravenous contrast was administered. Carotid stenosis measurements were made using NASCET criteria.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1459562789499\">The following sequences were obtained:</label>\n                <select multiple=\"multiple\" id=\"SELECTION_LIST_1459562789499\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Axial TOF and MPRAGE.\">\n                    <option id=\"SELECTION_LIST_1459562789499_0\" value=\"Axial TOF and MPRAGE.\" name=\"SELECTION_LIST_1459562789499\" selected=\"\">Axial TOF and MPRAGE.</option>\n                    <option id=\"SELECTION_LIST_1459562789499_1\" value=\"Coronal precontrast, arterial and venous phase images with multiplanar reformats and 3D maximum intensity projections\" name=\"SELECTION_LIST_1459562789499\">Coronal precontrast, arterial and venous phase images with multiplanar reformats and 3D maximum intensity projections</option>\n                </select>\n            </p>\n        </section>\n        <section id=\"clinicalInformation\" class=\"level1\" data-section-name=\"Clinical Information\">\n            <header class=\"level1\">\n                Clinical Information\n            </header>\n            <p title=\"\">\n                <label for=\"TEXT_1459562789502\">Indication:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459562789502\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">None.</textarea>\n            </p>\n        </section>\n        <section id=\"comparisons\" class=\"level1\" data-section-name=\"Comparison\">\n            <header class=\"level1\">\n                Comparison\n            </header>\n            <p title=\"\">\n                <label for=\"comparisonsText\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"comparisonsText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">None.</textarea>\n            </p>\n        </section>\n        <section id=\"findings\" class=\"level1\" data-section-name=\"Findings\">\n            <header class=\"level1\">\n                Findings\n            </header>\n            <p title=\"\">\n                <label for=\"findingsText\">Vasculature:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"findingsText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">There is a normal anatomic configuration of the aortic arch.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1459562789503\">Additional Findings:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459562789503\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">There is mild atherosclerotic plaque at the bilateral carotid bifurcations with &lt;50% stenosis by NASCET criteria.</textarea>\n            </p>\n        </section>\n        <section id=\"impression\" class=\"level1\" data-section-name=\"Impression\">\n            <header class=\"level1\">\n                Impression\n            </header>\n            <p title=\"\">\n                <label for=\"impressionText\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"impressionText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">There is no MPRAGE positive plaque, ulceration or intraluminal thrombus.</textarea>\n            </p>\n        </section>\n    </body>\n</html>\n",

    "templateData": "<!DOCTYPE html>\n<html>\n    <head>\n        <title>Endometrial Cancer Staging MRI</title>\n        <meta charset=\"UTF-8\" />\n        <meta name=\"dcterms.identifier\" content=\"03774c65-49d1-425f-ab6e-6776363a403e\" />\n        <meta name=\"dcterms.title\" content=\"Endometrial Cancer Staging MRI\" />\n        <meta name=\"dcterms.description\" content=\"\" />\n        <meta name=\"dcterms.type\" content=\"IMAGE_REPORT_TEMPLATE\" />\n        <meta name=\"dcterms.language\" content=\"en\" />\n        <meta name=\"dcterms.publisher\" content=\"ESR\" />\n        <meta name=\"dcterms.rights\" content=\"May be used freely, subject to license agreement\" />\n        <meta name=\"dcterms.license\" content=\"http://www.radreport.org/license.pdf\" />\n        <meta name=\"dcterms.date\" content=\"2017-10-06\" />\n        <meta name=\"dcterms.creator\" content=\"Teresa Margarida Cunha, MD\" />\n        <meta name=\"dcterms.contributor\" content=\"Rita Lucas, MD\" />\n        <script type=\"text/xml\">\n            <template_attributes>\n                <coded_content>\n                    <coding_schemes>\n                        <coding_scheme name=\"RADLEX\" designator=\"2.16.840.1.113883.6.256\"></coding_scheme>\n                    </coding_schemes>\n                    <entry origtxt=\"TEXT_1476397383026\">\n                        <term>\n                            <code meaning=\"clinical information section\" value=\"RID13166\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"impressionText\">\n                        <term>\n                            <code meaning=\"impression section\" value=\"RID13170\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476397766129\">\n                        <term>\n                            <code meaning=\"ascites\" value=\"RID1541\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1476397383020\">\n                        <term>\n                            <code meaning=\"procedure\" value=\"RID1559\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476397766115\">\n                        <term>\n                            <code meaning=\"set of ovaries\" value=\"RID39537\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476397766114\">\n                        <term>\n                            <code meaning=\"vagina\" value=\"RID325\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1476397766099\">\n                        <term>\n                            <code meaning=\"uterus\" value=\"RID302\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                </coded_content>\n            </template_attributes>\n        </script>\n    </head>\n    <body>\n        <section id=\"procedureInformation\" class=\"level1\" data-section-name=\"Procedure Information\">\n            <header class=\"level1\">\n                Procedure Information\n            </header>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476397383020\">Procedure Description</label>\n                <select id=\"SELECTION_LIST_1476397383020\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Enhanced MRI pelvis\">\n                    <option id=\"SELECTION_LIST_1476397383020_0\" value=\"Enhanced MRI pelvis\" name=\"SELECTION_LIST_1476397383020\" selected=\"\">Enhanced MRI pelvis</option>\n                    <option id=\"SELECTION_LIST_1476397383020_1\" value=\"Unenhanced MRI pelvis\" name=\"SELECTION_LIST_1476397383020\">Unenhanced MRI pelvis</option>\n                </select>\n            </p>\n           <p title=\"\">\n                <label for=\"SELECTION_LIST_1476397383027\">Technique:</label>\n                <select id=\"SELECTION_LIST_1476397383027\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"T2-weighted images of the pelvis in axial, sagittal, axial oblique (perpendicular to the endometrial cavity long axis)] and coronal oblique (parallel to the endometrial cavity long axis.\">\n                    <option id=\"SELECTION_LIST_1476397383027_0\" value=\"T2-weighted images of the pelvis in axial, sagittal, axial oblique (perpendicular to the endometrial cavity long axis)] and coronal oblique (parallel to the endometrial cavity long axis.\" name=\"SELECTION_LIST_1476397383027\" selected=\"\">T2-weighted images of the pelvis in axial, sagittal, axial oblique (perpendicular to the endometrial cavity long axis)] and coronal oblique (parallel to the endometrial cavity long axis.</option>\n                    <option id=\"SELECTION_LIST_1476397383027_1\" value=\"T1-weighted images of the pelvis in axial plane.\" name=\"SELECTION_LIST_1476397383027\">T1-weighted images of the pelvis in axial plane.</option>\n                    <option id=\"SELECTION_LIST_1476397383027_2\" value=\"Axial T2-weighted images of the abdomen were also obtained.\" name=\"SELECTION_LIST_1476397383027\">Axial T2-weighted images of the abdomen were also obtained.</option>\n                    <option id=\"SELECTION_LIST_1476397383027_3\" value=\"Axial DW-MRI study was also performed in the pelvis and in the abdomen.\" name=\"SELECTION_LIST_1476397383027\">Axial DW-MRI study was also performed in the pelvis and in the abdomen.</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476397630351\">Type of pre and post contrast imaging of the pelvis:</label>\n                <select id=\"SELECTION_LIST_1476397630351\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Non-dynamic\">\n                    <option id=\"SELECTION_LIST_1476397630351_0\" value=\"Non-dynamic\" name=\"SELECTION_LIST_1476397630351\" selected=\"\">Non-dynamic</option>\n                    <option id=\"SELECTION_LIST_1476397630351_1\" value=\"Dynamic\" name=\"SELECTION_LIST_1476397630351\">Dynamic</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476397766093\">Strength of Tesla Scanner:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"\" id=\"NUMBER_1476397766093\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476397766094\">Type of contrast agent:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476397766094\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476397766095\">Amount of contrast administered before and after fat suppressed T1-weighted imaging:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"mL\" id=\"NUMBER_1476397766095\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    mL\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476397766096\">Image quality:</label>\n                <select id=\"SELECTION_LIST_1476397766096\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Satisfactory\">\n                    <option id=\"SELECTION_LIST_1476397766096_0\" value=\"Satisfactory\" name=\"SELECTION_LIST_1476397766096\" selected=\"\">Satisfactory</option>\n                    <option id=\"SELECTION_LIST_1476397766096_1\" value=\"Degraded by motion/etc.\" name=\"SELECTION_LIST_1476397766096\">Degraded by motion/etc.</option>\n                </select>\n            </p>\n        </section>\n        <section id=\"clinicalInformation\" class=\"level1\" data-section-name=\"Clinical Information\">\n            <header class=\"level1\">\n                Clinical Information\n            </header>\n            <p title=\"\">\n                <label for=\"TEXT_1476397383026\">Clinical Indication:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476397383026\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Endometrial cancer staging</textarea>\n            </p>\n         </section>\n        <section id=\"comparisons\" class=\"level1\" data-section-name=\"Comparison\">\n            <header class=\"level1\">\n                Comparison\n            </header>\n            <p title=\"\">\n                <label for=\"comparisonsText\">Comparison study:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"comparisonsText\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">None available</textarea>\n            </p>\n        </section>\n        <section id=\"findings\" class=\"level1\" data-section-name=\"Findings\">\n            <header class=\"level1\">\n                Findings\n            </header>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476397766099\">Uterus:</label>\n                <select id=\"SELECTION_LIST_1476397766099\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Anteverted\">\n                    <option id=\"SELECTION_LIST_1476397766099_0\" value=\"Anteverted\" name=\"SELECTION_LIST_1476397766099\" selected=\"\">Anteverted</option>\n                    <option id=\"SELECTION_LIST_1476397766099_1\" value=\"Retroverted\" name=\"SELECTION_LIST_1476397766099\">Retroverted</option>\n                    <option id=\"SELECTION_LIST_1476397766099_2\" value=\"Retroflexed\" name=\"SELECTION_LIST_1476397766099\">Retroflexed</option>\n                    <option id=\"SELECTION_LIST_1476397766099_3\" value=\"Displaced to left\" name=\"SELECTION_LIST_1476397766099\">Displaced to left</option>\n                    <option id=\"SELECTION_LIST_1476397766099_4\" value=\"Displaced to right\" name=\"SELECTION_LIST_1476397766099\">Displaced to right</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"findingsText\">Size:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"findingsText\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Normal in size</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476397766105\">Measuring:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"cm\" id=\"NUMBER_1476397766105\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    cm\n                </span>\n            </p>\n            <section id=\"SECTION_HEADER_1476397766106\" class=\"level2\" data-section-name=\"Endometrium:\">\n                <header class=\"level2\">\n                    Endometrium:\n                </header>\n                <p title=\"\">\n                    <label for=\"NUMBER_1476397766107\">Tumor measuring:</label>\n                    <span>\n                        <input type=\"number\" step=\"1.0\" data-field-units=\"cm\" id=\"NUMBER_1476397766107\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                        cm\n                    </span>\n                </p>\n                <p title=\"\">\n                    <label for=\"SELECTION_LIST_1476397766108\">Invading:</label>\n                    <select id=\"SELECTION_LIST_1476397766108\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"&gt; 50% of myometrium thickness\">\n                        <option id=\"SELECTION_LIST_1476397766108_0\" value=\"&gt; 50% of myometrium thickness\" name=\"SELECTION_LIST_1476397766108\" selected=\"\">&gt; 50% of myometrium thickness</option>\n                        <option id=\"SELECTION_LIST_1476397766108_1\" value=\"&lt; 50% of myometrium thickness\" name=\"SELECTION_LIST_1476397766108\">&lt; 50% of myometrium thickness</option>\n                    </select>\n                </p>\n            </section>\n            <p title=\"\">\n                <label for=\"TEXT_1476397766111\">Cervical stroma:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476397766111\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no invasion of the cervical stroma.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476397766112\">Serosa invasion:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476397766112\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no transmyometrial extension.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476397766113\">Parametria:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476397766113\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no parametria invasion.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476397766114\">Vagina:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476397766114\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no vaginal invasion.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476397766115\">Ovaries:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476397766115\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no adnexal invasion.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476397766116\">Bladder wall:</label>\n                <select id=\"SELECTION_LIST_1476397766116\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Invaded\">\n                    <option id=\"SELECTION_LIST_1476397766116_0\" value=\"Invaded\" name=\"SELECTION_LIST_1476397766116\" selected=\"\">Invaded</option>\n                    <option id=\"SELECTION_LIST_1476397766116_1\" value=\"Not invaded\" name=\"SELECTION_LIST_1476397766116\">Not invaded</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476397766119\">Rectal wall:</label>\n                <select id=\"SELECTION_LIST_1476397766119\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Invaded\">\n                    <option id=\"SELECTION_LIST_1476397766119_0\" value=\"Invaded\" name=\"SELECTION_LIST_1476397766119\" selected=\"\">Invaded</option>\n                    <option id=\"SELECTION_LIST_1476397766119_1\" value=\"Not invaded\" name=\"SELECTION_LIST_1476397766119\">Not invaded</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476397766122\">Pelvic wall:</label>\n                <select id=\"SELECTION_LIST_1476397766122\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Invaded\">\n                    <option id=\"SELECTION_LIST_1476397766122_0\" value=\"Invaded\" name=\"SELECTION_LIST_1476397766122\" selected=\"\">Invaded</option>\n                    <option id=\"SELECTION_LIST_1476397766122_1\" value=\"Not invaded\" name=\"SELECTION_LIST_1476397766122\">Not invaded</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476397766125\">Lymph nodes:</label>\n                <select id=\"SELECTION_LIST_1476397766125\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Normal in size.\">\n                    <option id=\"SELECTION_LIST_1476397766125_0\" value=\"Normal in size.\" name=\"SELECTION_LIST_1476397766125\" selected=\"\">Normal in size.</option>\n                    <option id=\"SELECTION_LIST_1476397766125_1\" value=\"Enlarged; probably reactive.\" name=\"SELECTION_LIST_1476397766125\">Enlarged; probably reactive.</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476397766128\">Physiologic pelvic fluid:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476397766128\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no physiologic pelvic fluid.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476397766129\">Ascites:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476397766129\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no ascites.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476397766130\">Peritoneal implants:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476397766130\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There are no peritoneal implants.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476397766131\">Liver metastasis:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476397766131\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no liver metastasis.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476397766132\">Distant metastasis:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476397766132\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no distant metastasis.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476397766133\">Other findings:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476397766133\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n        </section>\n        <section id=\"impression\" class=\"level1\" data-section-name=\"Impression\">\n            <header class=\"level1\">\n                Impression\n            </header>\n            <p title=\"\">\n                <label for=\"impressionText\">Impression:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"impressionText\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n        </section>\n    </body>\n</html>\n",

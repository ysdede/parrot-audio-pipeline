    "templateData": "<!DOCTYPE html>\n<html>\n    <head>\n        <title>MR Rectal Cancer</title>\n        <meta charset=\"UTF-8\" />\n        <meta name=\"dcterms.identifier\" content=\"91d6f578-e56c-4fa5-b9a3-faea8848c792\" />\n        <meta name=\"dcterms.title\" content=\"MR Rectal Cancer\" />\n        <meta name=\"dcterms.description\" content=\"\" />\n        <meta name=\"dcterms.type\" content=\"IMAGE_REPORT_TEMPLATE\" />\n        <meta name=\"dcterms.language\" content=\"en\" />\n        <meta name=\"dcterms.publisher\" content=\"University of Utah\" />\n        <meta name=\"dcterms.rights\" content=\"May be used freely, subject to license agreement\" />\n        <meta name=\"dcterms.license\" content=\"http://www.radreport.org/license.pdf\" />\n        <meta name=\"dcterms.date\" content=\"2018-03-12\" />\n        <meta name=\"dcterms.creator\" content=\"Marta E. Heilbrun, MD\" />\n        <script type=\"text/xml\">\n            <template_attributes>\n                <coded_content>\n                    <coding_schemes>\n                        <coding_scheme name=\"RADLEX\" designator=\"2.16.840.1.113883.6.256\"></coding_scheme>\n                        <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\"></coding_scheme>\n                    </coding_schemes>\n                    <entry origtxt=\"findings\">\n                        <term>\n                            <code meaning=\"Procedure Findings\" value=\"59776-5\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459356835840\">\n                        <term>\n                            <code meaning=\"inguinal lymph node\" value=\"RID465\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459356835838\">\n                        <term>\n                            <code meaning=\"pararectal lymph node\" value=\"RID466\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459356835839\">\n                        <term>\n                            <code meaning=\"internal iliac lymph node group\" value=\"RID463\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459356151057\">\n                        <term>\n                            <code meaning=\"indication\" value=\"RID49442\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459356835850\">\n                        <term>\n                            <code meaning=\"metastasis\" value=\"RID5231\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459356835853\">\n                        <term>\n                            <code meaning=\"normal\" value=\"RID13173\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1459356835822\">\n                        <term>\n                            <code meaning=\"rectal\" value=\"RID11181\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"procedureInformation\">\n                        <term>\n                            <code meaning=\"Current Imaging Procedure Description\" value=\"55111-9\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"comparisons\">\n                        <term>\n                            <code meaning=\"Radiology Comparison Study\" value=\"18834-2\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"impression\">\n                        <term>\n                            <code meaning=\"Impressions\" value=\"19005-8\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"clinicalInformation\">\n                        <term>\n                            <code meaning=\"Clinical Information\" value=\"55752-0\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                </coded_content>\n            </template_attributes>\n        </script>\n    </head>\n    <body>\n        <section id=\"procedureInformation\" class=\"level1\" data-section-name=\"Procedure Information\">\n            <header class=\"level1\">\n                Procedure Information\n            </header>\n            <p title=\"\">\n                <label for=\"TEXT_1459356151079\">Technique:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459356151079\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Multiplanar, multisequence MRI of the pelvis was performed using a phased-array surface coil</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1459356151073\"></label>\n                <select id=\"SELECTION_LIST_1459356151073\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"With and without contrast.\">\n                    <option id=\"SELECTION_LIST_1459356151073_0\" value=\"With and without contrast.\" name=\"SELECTION_LIST_1459356151073\" selected=\"\">With and without contrast.</option>\n                    <option id=\"SELECTION_LIST_1459356151073_1\" value=\"Without contrast.\" name=\"SELECTION_LIST_1459356151073\">Without contrast.</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1459356835820\">Amount of warm gel inserted in the rectum:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"cc\" id=\"NUMBER_1459356835820\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    cc\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1459356835821\">Sequences included:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459356835821\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n        </section>\n        <section id=\"clinicalInformation\" class=\"level1\" data-section-name=\"Clinical Information\">\n            <header class=\"level1\">\n                Clinical Information\n            </header>\n            <p title=\"\">\n                <label for=\"TEXT_1459356151057\">Indication:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459356151057\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Rectal Tumor Staging.</textarea>\n            </p>\n        </section>\n        <section id=\"comparisons\" class=\"level1\" data-section-name=\"Comparison\">\n            <header class=\"level1\">\n                Comparison\n            </header>\n            <p title=\"\">\n                <label for=\"comparisonsText\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"comparisonsText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">None.</textarea>\n            </p>\n        </section>\n        <section id=\"findings\" class=\"level1\" data-section-name=\"Findings\">\n            <header class=\"level1\">\n                Findings\n            </header>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1459356835822\">A rectal tumor is:</label>\n                <select id=\"SELECTION_LIST_1459356835822\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Present.\">\n                    <option id=\"SELECTION_LIST_1459356835822_0\" value=\"Present.\" name=\"SELECTION_LIST_1459356835822\" selected=\"\">Present.</option>\n                    <option id=\"SELECTION_LIST_1459356835822_1\" value=\"Nonvisualized.\" name=\"SELECTION_LIST_1459356835822\">Nonvisualized.</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1459356835825\">This mass measures:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"\" id=\"NUMBER_1459356835825\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1459356835826\">Appearance on the T2-weighted images:</label>\n                <select id=\"SELECTION_LIST_1459356835826\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Predominately solid lesion with intermediate signal intensity (SI), between that of skeletal muscle and fluid.\">\n                    <option id=\"SELECTION_LIST_1459356835826_0\" value=\"Predominately solid lesion with intermediate signal intensity (SI), between that of skeletal muscle and fluid.\" name=\"SELECTION_LIST_1459356835826\" selected=\"\">Predominately solid lesion with intermediate signal intensity (SI), between that of skeletal muscle and fluid.</option>\n                    <option id=\"SELECTION_LIST_1459356835826_1\" value=\"Predominately fluid-like lesion with singal intensity similar to or higher than fluid suggesting a mucinous tumor.\" name=\"SELECTION_LIST_1459356835826\">Predominately fluid-like lesion with singal intensity similar to or higher than fluid suggesting a mucinous tumor.</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1459356835829\">Distance of the lower edge of the tumor to the anal verge (lower edge of the anal canal):</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"\" id=\"NUMBER_1459356835829\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1459356835830\">Distance of the lower edge of the tumor to the pelvic floor (to define the relationship of the tumor to the anal sphincter complex):</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"\" id=\"NUMBER_1459356835830\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1459356835831\">Circumference of the rectum involved:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"\" id=\"NUMBER_1459356835831\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1459356835832\">Imaging T-stage of the Tumor:</label>\n                <select id=\"SELECTION_LIST_1459356835832\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"T1 (Tumor invades submucosa)\">\n                    <option id=\"SELECTION_LIST_1459356835832_0\" value=\"T1 (Tumor invades submucosa)\" name=\"SELECTION_LIST_1459356835832\" selected=\"\">T1 (Tumor invades submucosa)</option>\n                    <option id=\"SELECTION_LIST_1459356835832_1\" value=\"T2 (Tumor invades muscularis propia)\" name=\"SELECTION_LIST_1459356835832\">T2 (Tumor invades muscularis propia)</option>\n                    <option id=\"SELECTION_LIST_1459356835832_2\" value=\"T3 (Tumor invades the perirectal fat)\" name=\"SELECTION_LIST_1459356835832\">T3 (Tumor invades the perirectal fat)</option>\n                    <option id=\"SELECTION_LIST_1459356835832_3\" value=\"T4a (Tumor penetrates to the surface of the visceral peritoneum)\" name=\"SELECTION_LIST_1459356835832\">T4a (Tumor penetrates to the surface of the visceral peritoneum)</option>\n                    <option id=\"SELECTION_LIST_1459356835832_4\" value=\"T4b (Tumor directly invades or is adherent to other organs or structures)\" name=\"SELECTION_LIST_1459356835832\">T4b (Tumor directly invades or is adherent to other organs or structures)</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1459356835838\">Lymph Nodes:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459356835838\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">There are no concerning or enlarged lymph nodes  perirectal lymph nodes.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1459356835839\">External iliac nodes:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459356835839\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1459356835840\">Superficial inguinal nodes:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459356835840\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1459356835841\">Imaging N-stage of tumor:</label>\n                <select id=\"SELECTION_LIST_1459356835841\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"N0 (No regional lymph node metastasis)\">\n                    <option id=\"SELECTION_LIST_1459356835841_0\" value=\"N0 (No regional lymph node metastasis)\" name=\"SELECTION_LIST_1459356835841\" selected=\"\">N0 (No regional lymph node metastasis)</option>\n                    <option id=\"SELECTION_LIST_1459356835841_1\" value=\"N1 (Metastasis in 1-3 regional lymph nodes)\" name=\"SELECTION_LIST_1459356835841\">N1 (Metastasis in 1-3 regional lymph nodes)</option>\n                    <option id=\"SELECTION_LIST_1459356835841_2\" value=\"N1a (Metastasis in 1 regional lymph node)\" name=\"SELECTION_LIST_1459356835841\">N1a (Metastasis in 1 regional lymph node)</option>\n                    <option id=\"SELECTION_LIST_1459356835841_3\" value=\"N1b (Metastasis in 2-3 regional lymph nodes)\" name=\"SELECTION_LIST_1459356835841\">N1b (Metastasis in 2-3 regional lymph nodes)</option>\n                    <option id=\"SELECTION_LIST_1459356835841_4\" value=\"N1c (Tumor deposit(s) in the subserosa, mesentery, or nonperitonealized pericolic or perirectal tissues without regional nodal metastasis)\" name=\"SELECTION_LIST_1459356835841\">N1c (Tumor deposit(s) in the subserosa, mesentery, or nonperitonealized pericolic or perirectal tissues without regional nodal metastasis)</option>\n                    <option id=\"SELECTION_LIST_1459356835841_5\" value=\"N2 (Metastases in =4 regional lymph nodes)\" name=\"SELECTION_LIST_1459356835841\">N2 (Metastases in =4 regional lymph nodes)</option>\n                    <option id=\"SELECTION_LIST_1459356835841_6\" value=\"N2a (Metastases in 4-6 regional lymph nodes)\" name=\"SELECTION_LIST_1459356835841\">N2a (Metastases in 4-6 regional lymph nodes)</option>\n                    <option id=\"SELECTION_LIST_1459356835841_7\" value=\"N2b (Metastases in =7 regional lymph nodes)\" name=\"SELECTION_LIST_1459356835841\">N2b (Metastases in =7 regional lymph nodes)</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1459356835850\">Bony Metastases:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459356835850\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1520878542416\">Additional Findings:</label>\n                <input type=\"text\" id=\"TEXT_1520878542416\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\" value=\"None.\" />\n            </p>\n        </section>\n        <section id=\"impression\" class=\"level1\" data-section-name=\"Impression\">\n            <header class=\"level1\">\n                Impression\n            </header>\n            <p title=\"\">\n                <label for=\"TEXT_1459356835853\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459356835853\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1459356835852\">Rectal cancer is present. By imaging criteria this has a stage of:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459356835852\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476457520348\">Reference:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476457520348\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">This staging is based on AJCC cancer staging manual 7th ed.</textarea>\n            </p>\n        </section>\n    </body>\n</html>\n",

    "templateData": "<html><head><meta charset=\"UTF-8\"><meta content=\"base mri brain headache\" name=\"dcterms.title\"><meta content=\"3d30acf0-67f4-40cf-99af-6b852859cbbc\" name=\"dcterms.identifier\"><meta content=\"en\" name=\"dcterms.language\"><meta content=\"2019-01-31\" name=\"dcterms.date\"><meta content=\"Nuance System\" name=\"dcterms.creator\"><title>base mri brain headache</title></head><body><section data-section-name=\"MRI BRAIN WITHOUT CONTRAST\"><header class=\"Level1\">MRI BRAIN WITHOUT CONTRAST</header><p><label>HISTORY:</label><input type=\"text\" name=\"Patient Age\" value=\"Patient Age\"></p><p><label> old </label><input type=\"text\" name=\"Patient Gender\" value=\"Patient Gender\"></p><p><label>, </label><input type=\"text\" name=\"history\" value=\"headache\"></p></section><section data-section-name=\"TECHNIQUE:\"><header class=\"Level1\">TECHNIQUE:</header><p><label>MR images of the brain were acquired without intravenous contrast.</label><br><label>COMPARISON: </label><input type=\"text\" name=\"Comparison\" value=\"None available.\"></p></section><section data-section-name=\"FINDINGS:\"><header class=\"Level1\">FINDINGS:</header><p><label>BRAIN PARENCHYMA: </label><input type=\"text\" name=\"infarct-hemorrhage\" value=\"No acute infarct or hemorrhage. No mass effect or herniation.\"></p><p><label> </label><select name=\"white matter\"><option name=\"\" value=\"\">Signal intensities are within normal limits for age.</option><option name=\"\" value=\"\">Multiple nodular T2 hyperintense foci within the subcortical white matter, which can be associated with migraines but are nonspecific.</option><option name=\"\" value=\"\">Mild white matter chronic small vessel ischemic changes.</option><option name=\"\" value=\"\">Moderate white matter chronic small vessel ischemic changes.</option><option name=\"\" value=\"\">Severe white matter chronic small vessel ischemic changes.</option></select></p><p><textarea name=\"headache\">No cerebellar tonsillar ectopia. No brainstem sag or other secondary signs of intracranial hypotension. No empty sella or other secondary signs of elevated intracranial pressure.</textarea></p><p><label>VENTRICLES/EXTRA-AXIAL SPACES: </label><input type=\"text\" name=\"ventricles-extra-axial\" value=\"No hydrocephalus or extra-axial fluid collections.\"></p><p><label>FLOW VOIDS: </label><select name=\"flow voids\"><option name=\"\" value=\"\">Intact.</option><option name=\"\" value=\"\">Not well assessed.</option></select></p><p><label>SINUSES/MASTOIDS: </label><input type=\"text\" name=\"sinuses/mastoids\" value=\"Clear.\"></p><p><label>OTHER EXTRACRANIAL STRUCTURES: </label><input type=\"text\" name=\"extracranial\" value=\"Visualized structures are normal.\"></p></section><section data-section-name=\"IMPRESSION:\"><header class=\"Level1\">IMPRESSION:</header><p><textarea name=\"impression\">Normal MRI brain. No findings to account for headaches.</textarea></p></section></body></html>",

    "templateData": "<!DOCTYPE html>\n<html>\n    <head>\n        <title>CT KUB</title>\n        <meta charset=\"UTF-8\" />\n        <meta name=\"dcterms.identifier\" content=\"c1324d91-2a5a-40ff-bbc3-f3e053a5d424\" />\n        <meta name=\"dcterms.title\" content=\"CT KUB\" />\n        <meta name=\"dcterms.description\" content=\"\" />\n        <meta name=\"dcterms.type\" content=\"IMAGE_REPORT_TEMPLATE\" />\n        <meta name=\"dcterms.language\" content=\"en\" />\n        <meta name=\"dcterms.publisher\" content=\"University of Utah\" />\n        <meta name=\"dcterms.rights\" content=\"May be used freely, subject to license agreement\" />\n        <meta name=\"dcterms.license\" content=\"http://www.radreport.org/license.pdf\" />\n        <meta name=\"dcterms.date\" content=\"2018-02-20\" />\n        <meta name=\"dcterms.creator\" content=\"Marta E. Heilbrun, MD\" />\n        <script type=\"text/xml\">\n            <template_attributes>\n                <coded_content>\n                    <coding_schemes>\n                        <coding_scheme name=\"RADLEX\" designator=\"2.16.840.1.113883.6.256\"></coding_scheme>\n                        <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\"></coding_scheme>\n                    </coding_schemes>\n                    <entry origtxt=\"TEXT_1459353645041\">\n                        <term>\n                            <code meaning=\"urinary bladder\" value=\"RID237\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459353645042\">\n                        <term>\n                            <code meaning=\"pelvis\" value=\"RID2507\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459353645040\">\n                        <term>\n                            <code meaning=\"left ureter\" value=\"RID30845\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"findings\">\n                        <term>\n                            <code meaning=\"Procedure Findings\" value=\"59776-5\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"findingsText\">\n                        <term>\n                            <code meaning=\"right kidney\" value=\"RID29662\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"procedureInformation\">\n                        <term>\n                            <code meaning=\"Current Imaging Procedure Description\" value=\"55111-9\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"comparisons\">\n                        <term>\n                            <code meaning=\"Radiology Comparison Study\" value=\"18834-2\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459353645039\">\n                        <term>\n                            <code meaning=\"right ureter\" value=\"RID30844\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"impression\">\n                        <term>\n                            <code meaning=\"Impressions\" value=\"19005-8\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459353645036\">\n                        <term>\n                            <code meaning=\"indication\" value=\"RID49442\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"clinicalInformation\">\n                        <term>\n                            <code meaning=\"Clinical Information\" value=\"55752-0\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459353645037\">\n                        <term>\n                            <code meaning=\"left kidney\" value=\"RID29663\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459353645045\">\n                        <term>\n                            <code meaning=\"musculoskeletal system\" value=\"RID13209\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459353645043\">\n                        <term>\n                            <code meaning=\"lungs\" value=\"RID13437\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459353645044\">\n                        <term>\n                            <code meaning=\"musculoskeletal system\" value=\"RID13209\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                </coded_content>\n            </template_attributes>\n        </script>\n    </head>\n    <body>\n        <section id=\"procedureInformation\" class=\"level1\" data-section-name=\"Procedure Information\">\n            <header class=\"level1\">\n                Procedure Information\n            </header>\n            <p title=\"\">\n                <label for=\"TEXT_1459353645035\">Technique:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459353645035\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Helical images were obtained through the kidneys, ureters, and bladder. Per protocol, no IV nor oral contrast was administered. This protocol is designed to assess for calculi in the kidneys, ureters, and bladder, and any potential associated GU obstruction. However, the limited coverage and lack of IV and oral contrast makes evaluation of the solid visceral organs and other abdominal and pelvic structures suboptimal.</textarea>\n            </p>\n        </section>\n        <section id=\"clinicalInformation\" class=\"level1\" data-section-name=\"Clinical Information\">\n            <header class=\"level1\">\n                Clinical Information\n            </header>\n            <p title=\"\">\n                <label for=\"TEXT_1459353645036\">Indication:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459353645036\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">None.</textarea>\n            </p>\n        </section>\n        <section id=\"comparisons\" class=\"level1\" data-section-name=\"Comparison\">\n            <header class=\"level1\">\n                Comparison\n            </header>\n            <p title=\"\">\n                <label for=\"comparisonsText\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"comparisonsText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">None.</textarea>\n            </p>\n        </section>\n        <section id=\"findings\" class=\"level1\" data-section-name=\"Findings\">\n            <header class=\"level1\">\n                Findings\n            </header>\n            <p title=\"\">\n                <label for=\"findingsText\">Right Kidney:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"findingsText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1459353645037\">Left Kidney:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459353645037\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1459353645039\">Right Ureter:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459353645039\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1459353645040\">Left Ureter:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459353645040\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1459353645041\">Bladder:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459353645041\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1459353645042\">Other abdominal and pelvic findings:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459353645042\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1459353645043\">Lung Windows through the Lung Bases:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459353645043\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1459353645044\">Bone Windows:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459353645044\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1459353645045\">Soft Tissues:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459353645045\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1519185071888\">Additional Findings:</label>\n                <input type=\"text\" id=\"TEXT_1519185071888\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\" value=\"None.\" />\n            </p>\n        </section>\n        <section id=\"impression\" class=\"level1\" data-section-name=\"Impression\">\n            <header class=\"level1\">\n                Impression\n            </header>\n            <p title=\"\">\n                <label for=\"impressionText\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"impressionText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n            </p>\n        </section>\n    </body>\n</html>\n",

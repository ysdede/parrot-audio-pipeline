    "templateData": "<!DOCTYPE html>\n<html>\n    <head>\n        <title>Rad Chest 2 Views</title>\n        <meta charset=\"UTF-8\" />\n        <meta name=\"dcterms.identifier\" content=\"0a3b6af5-d547-4069-a1d7-f8fc5a0e0725\" />\n        <meta name=\"dcterms.title\" content=\"Rad Chest 2 Views\" />\n        <meta name=\"dcterms.description\" content=\"A basic normal template for chest radiographs with pick lists for common abnormalities.\" />\n        <meta name=\"dcterms.type\" content=\"IMAGE_REPORT_TEMPLATE\" />\n        <meta name=\"dcterms.language\" content=\"en\" />\n        <meta name=\"dcterms.publisher\" content=\"Stanford University\" />\n        <meta name=\"dcterms.rights\" content=\"May be used freely, subject to license agreement\" />\n        <meta name=\"dcterms.license\" content=\"http://www.radreport.org/license.pdf\" />\n        <meta name=\"dcterms.date\" content=\"2017-11-14\" />\n        <meta name=\"dcterms.creator\" content=\"Curt Langlotz, MD, PhD\" />\n        <script type=\"text/xml\">\n            <template_attributes>\n                <coded_content>\n                    <coding_schemes>\n                        <coding_scheme name=\"RADLEX\" designator=\"2.16.840.1.113883.6.256\"></coding_scheme>\n                        <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\"></coding_scheme>\n                    </coding_schemes>\n                    <entry origtxt=\"findings\">\n                        <term>\n                            <code meaning=\"Procedure Findings\" value=\"59776-5\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1465171157446\">\n                        <term>\n                            <code meaning=\"heart\" value=\"RID1385\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1465171157446_0\">\n               
    "templateData": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\"/>\n<meta content=\"Zevalin In-111 Imaging\" name=\"dcterms.title\"/>\n<meta content=\"Zevalin In-111 Imaging template :: Authored by Imani F\" name=\"dcterms.description\"/>\n<meta content=\"http://www.radreport.org/template/0000248\" name=\"dcterms.identifier\"/>\n<meta content=\"en\" name=\"dcterms.language\"/>\n<meta content=\"IMAGE_REPORT_TEMPLATE\" name=\"dcterms.type\"/>\n<meta content=\"Radiological Society of North America (RSNA)\" name=\"dcterms.publisher\"/>\n<meta content=\"May be used gratis, subject to license agreement\" name=\"dcterms.rights\"/>\n<meta content=\"http://www.radreport.org/license.pdf\" name=\"dcterms.license\"/>\n<meta content=\"2012-09-17\" name=\"dcterms.date\"/>\n<meta content=\"Imani F\" name=\"dcterms.creator\"/>\n\n<meta content=\"Kahn CE Jr [editor]\" name=\"dcterms.contributor\"/>\n<meta content=\"UCLA Health System (UCLA)\" name=\"dcterms.contributor\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"IHE_Template_Style.css\"/>\n<!-- The absolute link to the CSS file is http://www.radreport.org/html/IHE_Template_Style.css -->\n<script type=\"text/xml\">\r\n<!--\r\n<template_attributes>\n<top-level-flag>true</top-level-flag>\n<status>ACTIVE</status>\n<coding_schemes>\n <coding_scheme name=\"RadLex\" designator=\"2.16.840.1.113883.6.256\" />\n <coding_scheme name=\"SNOMEDCT\" designator=\"2.16.840.1.113883.6.96\" />\n <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\" />\n</coding_schemes>\n<term>\n <code meaning=\"indium\" value=\"RID11858\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"lymphoma\" value=\"RID3840\" scheme=\"RadLex\">\n</term>\n<coded_content>\n<entry ORIGTXT=\"T248_2\">\n <term>\n  <code meaning=\"procedure\" value=\"RID1559\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T248_5\">\n  <term>\n  <code meaning=\"Clinical information\" value=\"55752-0\" scheme=\"LOINC\">\n </term>\n</entry>\n<entry ORIGTXT=\"T248_6\">\n <term>\n  <code meaning=\"comparison\" value=\"RID28483\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T248_13\">\n <term>\n  <code meaning=\"impression section\" value=\"RID13170\" scheme=\"RadLex\">\n </term>\n</entry>\n</coded_content>\n</template_attributes>\r\n-->\r\n</script>\n<title>Zevalin In-111 Imaging</title>\n</head>\n<body>\n<section data-section-name=\"Procedure\">\n<header class=\"level1\">Zevalin In-111 Imaging</header>\n<p>\n<textarea id=\"T248_2\" name=\"Procedure\">Following the IV administration of indium-111 Zevalin, anterior and posterior images of the body were obtained at two hours and 48 hours post injection.  </textarea>\n</p>\n<p>\n<label for=\"T248_4\">Dose</label>\n<input type=\"number\" id=\"T248_4\" name=\"Dose\" value=\"5\"/> mCi\n</p>\n</section>\n<section data-section-name=\"Clinical information\">\n<header class=\"level1\">Clinical information</header>\n<p>\n<textarea id=\"T248_5\" name=\"Clinical information\"> </textarea>\n</p>\n</section>\n<section data-section-name=\"Comparison\">\n<header class=\"level1\">Comparison</header>\n<p>\n<textarea id=\"T248_6\" name=\"Comparison\">None. </textarea>\n</p>\n</section>\n<section data-section-name=\"Findings\">\n<header class=\"level1\">Findings</header>\n<section data-section-name=\"Early images\">\n<header class=\"level2\">Early images</header>\n<p>\n<textarea id=\"T248_11\" name=\"Early images\">The early images obtained at two hours postinjection show normal distribution of indium-111 Zevalin in the blood pool, liver, spleen, and kidneys.</textarea>\n</p>\n</section>\n\n<section data-section-name=\"Delayed images\">\n<header class=\"level2\">Delayed images</header>\n<p>\n<textarea id=\"T248_12\" name=\"Delayed images\">Delayed images obtained at 48 hours after injection show normal uptake in the liver, spleen, and bladder.</textarea>\n</p>\n</section>\n</section>\n<section data-section-name=\"Impression\">\n<header class=\"level1\">Impression</header>\n<p>\n<textarea id=\"T248_13\" name=\"Impression\">Normal tracer activity in the blood pool, liver, spleen and bladder is identified. </textarea>\n</p>\n</section>\n</body>\n</html>\n",

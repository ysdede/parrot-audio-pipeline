    "templateData": "<!DOCTYPE html>\r\n<html>\r\n<head>\r\n<meta charset=\"UTF-8\"/>\r\n<meta content=\"US Pancreas Transplant\" name=\"dcterms.title\"/>\r\n<meta content=\"US Pancreas Transplant report template\" name=\"dcterms.description\"/>\r\n<meta content=\"http://www.radreport.org/template/0000307\" name=\"dcterms.identifier\"/>\r\n<meta content=\"en\" name=\"dcterms.language\"/>\r\n<meta content=\"IMAGE_REPORT_TEMPLATE\" name=\"dcterms.type\"/>\r\n<meta content=\"Radiological Society of North America (RSNA)\" name=\"dcterms.publisher\"/>\r\n<meta content=\"May be used gratis, subject to license agreement\" name=\"dcterms.rights\"/>\r\n<meta content=\"http://www.radreport.org/license.pdf\" name=\"dcterms.license\"/>\r\n<meta content=\"2014-08-08\" name=\"dcterms.date\"/>\r\n<meta content=\"Tolat P, Foley WD, Quiroz FA\" name=\"dcterms.creator\"/>\r\n<meta content=\"Kahn CE Jr [editor]\" name=\"dcterms.contributor\"/>\r\n<meta content=\"Medical College of Wisconsin (MCW)\" name=\"dcterms.contributor\"/>\r\n<link rel=\"stylesheet\" type=\"text/css\" href=\"IHE_Template_Style.css\" />\r\n<!-- The absolute link to the CSS file is http://www.radreport.org/html/IHE_Template_Style.css -->\r\n<script type=\"text/xml\">\r\n<!--\r\n<template_attributes>\r\n<top-level-flag>true</top-level-flag>\r\n<status>ACTIVE</status>\r\n<coded_content>\n</coded_content>\r\n</template_attributes>\r\n-->\r\n</script>\r\n<title>US Pancreas Transplant</title>\r\n</head>\r\n<body>\r\n<section data-section-name=\"Procedure\">\r\n<header class=\"level1\">US Pancreas Transplant</header>\r\n</section>\r\n<section data-section-name=\"Clinical information\">\r\n<header class=\"level1\">Clinical information</header>\r\n<p>\r\n<textarea id=\"T307_1\" name=\"Clinical information\">Elevated glucose. </textarea>\r\n</p>\r\n</section>\r\n<section data-section-name=\"Comparison\">\r\n<header class=\"level1\">Comparison</header>\r\n<p>\r\n<textarea id=\"T307_2\" name=\"Comparison\">None. </textarea>\r\n</p>\r\n</section>\r\n<section data-section-name=\"Findings\">\r\n<header class=\"level1\">Findings</header>\r\n<section data-section-name=\"Transplant pancreas\">\r\n<header class=\"level2\">Transplant pancreas</header>\r\n<p>\r\n<label for=\"T307_3\">Transplant location:</label>\r\n<select id=\"T307_3\" name=\"Transplant location\">\r\n<option id=\"T307_4\" name=\"Right\" value=\"right\">Right mid abdomen.</option>\r\n<option id=\"T307_5\" name=\"Left\" value=\"left\">Left mid abdomen.</option>\r\n</select>\r\n</p>\r\n<p>\r\n<label for=\"T307_6\">Transplant drainage:</label>\r\n<select id=\"T307_6\" name=\"Transplant drainage\">\r\n<option id=\"T307_7\" name=\"portal\" value=\"portal\">Portal venous and enteric drainage.</option>\r\n<option id=\"T307_8\" name=\"systemic\" value=\"systemic\">Systemic venous and enteric drainage.</option>\r\n</select>\r\n</p>\r\n<p>\r\n<label for=\"T307_9\">Transplant morphology:</label>\r\n<input type=\"text\" id=\"T307_9\" name=\"Morphology\" value=\"Normal size and echogenicity without focal lesion.\"/>\r\n</p>\r\n<p>\r\n<label for=\"T307_10\">Pancreatic duct:</label>\r\n<input type=\"text\" id=\"T307_10\" name=\"Pancreatic duct\" value=\"Not dilated.\"/>\r\n</p>\r\n<p>\r\n<label for=\"T307_11\">Peritransplant fluid collections:</label>\r\n<input type=\"text\" id=\"T307_11\" name=\"Fluid collections\" value=\"None.\"/>\r\n</p>\r\n<p>\r\n<textarea id=\"T307_12\" name=\"Blood flow\">With the use of color Doppler, flow is detected throughout the transplant pancreas. </textarea>\r\n</p>\r\n</section>\r\n<section data-section-name=\"Arterial supply\">\r\n<header class=\"level2\">Arterial supply</header>\r\n<p>\r\n<label for=\"T307_13\">Transplant arterial Y-graft, SMA, and splenic arteries:</label>\r\n<input type=\"text\" id=\"T307_13\" name=\"Transplant arteries\" value=\"Patent. Sharp systolic upstroke, continuous diastolic flow, and no perivascular tissue vibration.\"/>\r\n</p>\r\n<p>\r\n<label for=\"T307_14\">Y-graft peak systolic velocity:</label>\r\n<input type=\"number\" id=\"T307_14\" name=\"Y-graft velocity\" value=\"\" />  <label for=\"T307_14\">cm/s.</label>\r\n</p>\r\n<p>\r\n<label for=\"T307_15\">Intra-pancreatic arteries:</label>\r\n<input type=\"text\" id=\"T307_15\" name=\"Intrapancreatic arteries\" value=\"Patent. No tardus-parvus or high-resistance waveform.\"/>\r\n</p>\r\n</section>\r\n<section data-section-name=\"Venous outflow\">\r\n<header class=\"level2\">Venous outflow</header>\r\n<p>\r\n<label for=\"T307_16\">Transplant SMV, splenic vein, and confluence to form the transplant PV:</label>\r\n<input type=\"text\" id=\"T307_16\" name=\"Venous outflow\" value=\"Patent with normal waveforms.\" />\r\n</p>\r\n<p>\r\nAnastomosis of transplant PV to recipient vein:\r\n<select id=\"T307_17\" name=\"Vein anastomosis\">\r\n<option id=\"T307_18\" name=\"Obscured\" value=\"Obscured\">Obscured by bowel gas.</option>\r\n<option id=\"T307_19\" name=\"Patent\" value=\"Patent\">Patent.</option>\r\n<option id=\"T307_20\" name=\"Patent native portal\" value=\"Patent native portal\">Anastomosis obscured by bowel gas. Recipient (native) portal vein at the hepatic hilum is normally patent.</option>\r\n</select>\r\n</p>\r\n</section>\r\n<section data-section-name=\"Abbreviations\">\r\n<header class=\"level2\">Abbreviations</header>\r\n<p>\r\n    SMA = superior mesenteric artery;\r\n    SMV = superior mesenteric vein;\r\n    PV = portal vein\r\n</p>\r\n</section>\r\n</section>\r\n<section data-section-name=\"Impression\">\r\n<header class=\"level1\">Impression</header>\r\n<p>\r\n<textarea id=\"T307_21\" name=\"Impression\">Normal pancreas transplant morphology and hemodynamics. </textarea>\r\n</p>\r\n</section>\r\n</body>\r\n</html>",

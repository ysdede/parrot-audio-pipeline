    "templateData": "<!DOCTYPE html>\n<html>\n    <head>\n        <title>Ovarian Cancer Staging CT</title>\n        <meta charset=\"UTF-8\" />\n        <meta name=\"dcterms.identifier\" content=\"bde8a2d0-9f00-486e-867b-805a4235d1db\" />\n        <meta name=\"dcterms.title\" content=\"Ovarian Cancer Staging CT\" />\n        <meta name=\"dcterms.description\" content=\"\" />\n        <meta name=\"dcterms.type\" content=\"IMAGE_REPORT_TEMPLATE\" />\n        <meta name=\"dcterms.language\" content=\"en\" />\n        <meta name=\"dcterms.publisher\" content=\"ESR\" />\n        <meta name=\"dcterms.rights\" content=\"May be used freely, subject to license agreement\" />\n        <meta name=\"dcterms.license\" content=\"http://www.radreport.org/license.pdf\" />\n        <meta name=\"dcterms.date\" content=\"2017-10-06\" />\n        <meta name=\"dcterms.creator\" content=\"Teresa Margarida Cunha, MD\" />\n        <meta name=\"dcterms.contributor\" content=\"Rita Lucas, MD\" />\n        <script type=\"text/xml\">\n            <template_attributes>\n                <coded_content>\n                    <coding_schemes>\n                        <coding_scheme name=\"RADLEX\" designator=\"2.16.840.1.113883.6.256\"></coding_scheme>\n                    </coding_schemes>\n                    <entry origtxt=\"impressionText\">\n                        <term>\n                            <code meaning=\"impression section\" value=\"RID13170\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476400557858\">\n                        <term>\n                            <code meaning=\"hydronephrosis\" value=\"RID34393\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476400557860\">\n                        <term>\n                            <code meaning=\"ascites\" value=\"RID1541\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"procedureInformationText\">\n                        <term>\n                            <code meaning=\"procedure\" value=\"RID1559\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1476400557844\">\n                        <term>\n                            <code meaning=\"endometrium\" value=\"RID30958\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"comparisonsText\">\n                        <term>\n                            <code meaning=\"comparison\" value=\"RID28483\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1476400557848\">\n                        <term>\n                            <code meaning=\"wall of urinary bladder\" value=\"RID30135\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476400557826\">\n                        <term>\n                            <code meaning=\"intravenous contrast\" value=\"RID49553\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"clinicalInformationText\">\n                        <term>\n                            <code meaning=\"clinical information section\" value=\"RID13166\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476400557827\">\n                        <term>\n                            <code meaning=\"oral contrast\" value=\"RID35817\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476400557829\">\n                        <term>\n                            <code meaning=\"pleural effusion\" value=\"RID34539\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1476400557851\">\n                        <term>\n                            <code meaning=\"wall of rectum\" value=\"RID32936\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1476400557835\">\n                        <term>\n                            <code meaning=\"uterus\" value=\"RID302\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                </coded_content>\n            </template_attributes>\n        </script>\n    </head>\n    <body>\n        <section id=\"procedureInformation\" class=\"level1\" data-section-name=\"Procedure Information\">\n            <header class=\"level1\">\n                Procedure Information\n            </header>\n            <p title=\"\">\n                <label for=\"procedureInformationText\">Procedure Description:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"procedureInformationText\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Helical acquisition from the base of the lungs to the inguinal region. Sagittal and coronal reconstructions.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476400557826\">IV contrast:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476400557826\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476400557827\">Oral contrast:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476400557827\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Oral contrast was administered.</textarea>\n            </p>\n        </section>\n        <section id=\"clinicalInformation\" class=\"level1\" data-section-name=\"Clinical Information\">\n            <header class=\"level1\">\n                Clinical Information\n            </header>\n            <p title=\"\">\n                <label for=\"clinicalInformationText\">Clinical Information:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"clinicalInformationText\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Ovarian cancer staging</textarea>\n            </p>\n        </section>\n        <section id=\"comparisons\" class=\"level1\" data-section-name=\"Comparison\">\n            <header class=\"level1\">\n                Comparison\n            </header>\n            <p title=\"\">\n                <label for=\"comparisonsText\">Comparison study:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"comparisonsText\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">None available</textarea>\n            </p>\n        </section>\n        <section id=\"findings\" class=\"level1\" data-section-name=\"Findings\">\n            <header class=\"level1\">\n                Findings\n            </header>\n            <p title=\"\">\n                <label for=\"findingsText\">Cardiophrenic lymph nodes:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"findingsText\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Cardiophrenic lymph nodes with a short-axis diameter of &gt;5 mm</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476400557829\">Pleural effusion:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476400557829\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no pleural effusion.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476400557830\">Pleural implants:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476400557830\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There are no pleural implants.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476400557831\">Ovarian mass:</label>\n                <select id=\"SELECTION_LIST_1476400557831\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Unilateral\">\n                    <option id=\"SELECTION_LIST_1476400557831_0\" value=\"Unilateral\" name=\"SELECTION_LIST_1476400557831\" selected=\"\">Unilateral</option>\n                    <option id=\"SELECTION_LIST_1476400557831_1\" value=\"Bilateral\" name=\"SELECTION_LIST_1476400557831\">Bilateral</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476400557834\">Measuring:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"cm\" id=\"NUMBER_1476400557834\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    cm\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476400557835\">Uterus:</label>\n                <select id=\"SELECTION_LIST_1476400557835\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Anteverted\">\n                    <option id=\"SELECTION_LIST_1476400557835_0\" value=\"Anteverted\" name=\"SELECTION_LIST_1476400557835\" selected=\"\">Anteverted</option>\n                    <option id=\"SELECTION_LIST_1476400557835_1\" value=\"Retroverted\" name=\"SELECTION_LIST_1476400557835\">Retroverted</option>\n                    <option id=\"SELECTION_LIST_1476400557835_2\" value=\"Retroflexed\" name=\"SELECTION_LIST_1476400557835\">Retroflexed</option>\n                    <option id=\"SELECTION_LIST_1476400557835_3\" value=\"Displaced to left\" name=\"SELECTION_LIST_1476400557835\">Displaced to left</option>\n                    <option id=\"SELECTION_LIST_1476400557835_4\" value=\"Displaced to right\" name=\"SELECTION_LIST_1476400557835\">Displaced to right</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476400557841\">Size:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476400557841\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Normal in size</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476400557843\">Measuring:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"cm\" id=\"NUMBER_1476400557843\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    cm\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476400557844\">Endometrium:</label>\n                <select id=\"SELECTION_LIST_1476400557844\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Normal\">\n                    <option id=\"SELECTION_LIST_1476400557844_0\" value=\"Normal\" name=\"SELECTION_LIST_1476400557844\" selected=\"\">Normal</option>\n                    <option id=\"SELECTION_LIST_1476400557844_1\" value=\"Abnormal\" name=\"SELECTION_LIST_1476400557844\">Abnormal</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476400557847\">Maximum width of the endometrium:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"mm\" id=\"NUMBER_1476400557847\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    mm\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476400557848\">Bladder wall:</label>\n                <select id=\"SELECTION_LIST_1476400557848\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Invaded\">\n                    <option id=\"SELECTION_LIST_1476400557848_0\" value=\"Invaded\" name=\"SELECTION_LIST_1476400557848\" selected=\"\">Invaded</option>\n                    <option id=\"SELECTION_LIST_1476400557848_1\" value=\"Not invaded\" name=\"SELECTION_LIST_1476400557848\">Not invaded</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476400557851\">Rectal wall:</label>\n                <select id=\"SELECTION_LIST_1476400557851\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Invaded\">\n                    <option id=\"SELECTION_LIST_1476400557851_0\" value=\"Invaded\" name=\"SELECTION_LIST_1476400557851\" selected=\"\">Invaded</option>\n                    <option id=\"SELECTION_LIST_1476400557851_1\" value=\"Not invaded\" name=\"SELECTION_LIST_1476400557851\">Not invaded</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476400557854\">Abdominal/Pelvic wall:</label>\n                <select id=\"SELECTION_LIST_1476400557854\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Invaded\">\n                    <option id=\"SELECTION_LIST_1476400557854_0\" value=\"Invaded\" name=\"SELECTION_LIST_1476400557854\" selected=\"\">Invaded</option>\n                    <option id=\"SELECTION_LIST_1476400557854_1\" value=\"Not invaded\" name=\"SELECTION_LIST_1476400557854\">Not invaded</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476400557857\">Liver and spleen metastases:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476400557857\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no surface, subcapsular invasive or parenchymal liver and spleen metastases.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476400557858\">Hydronephrosis:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476400557858\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no hydronephrosis.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476400557859\">Bowel:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476400557859\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no involvement of the small bowel mesentery including contraction or tethering of bowel loops and evidence/no evidence bowel obstruction</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476400557860\">Ascites:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476400557860\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no ascites.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476400557861\">Site and amount of ascites:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476400557861\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476400557862\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476400557862\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no omental metastases/other peritoneal/serosal implants/ supracolic sites of disease including the gastrohepatic, gastrosplenic and splenocolic ligaments</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476400557863\">Lymph nodes:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476400557863\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There are no lymph nodes with a short-axis diameter of &gt;1 cm, or suspicious clusters of smaller lymph nodes</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476400557864\">Venous obstruction/thrombosis.</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476400557864\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no venous obstruction/thrombosis.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476400557865\">Bones:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476400557865\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Normal</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1506699407296\">Other findings:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1506699407296\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n        </section>\n        <section id=\"impression\" class=\"level1\" data-section-name=\"Impression\">\n            <header class=\"level1\">\n                Impression\n            </header>\n            <p title=\"\">\n                <label for=\"impressionText\">Impression:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"impressionText\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n        </section>\n    </body>\n</html>\n",

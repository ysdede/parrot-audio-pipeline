    "templateData": "<html><head><meta charset=\"UTF-8\"><meta content=\"base ct face contrast\" name=\"dcterms.title\"><meta content=\"f37cb6de-8d5c-485b-8022-36c76e20b9b3\" name=\"dcterms.identifier\"><meta content=\"en\" name=\"dcterms.language\"><meta content=\"2019-01-31\" name=\"dcterms.date\"><meta content=\"Nuance System\" name=\"dcterms.creator\"><title>base ct face contrast</title></head><body><section data-section-name=\"CT FACIAL BONES WITH CONTRAST\"><header class=\"Level1\">CT FACIAL BONES WITH CONTRAST</header><p><label>HISTORY:</label><input type=\"text\" name=\"Patient Age\" value=\"Patient Age\"></p><p><label> old </label><input type=\"text\" name=\"Patient Gender\" value=\"Patient Gender\"></p><p><label>, </label><input type=\"text\" name=\"history\" value=\"face pain, evaluate for infection\"></p></section><section data-section-name=\"TECHNIQUE:\"><header class=\"Level1\">TECHNIQUE:</header><p><label>CT images of the facial bones were acquired with </label><input type=\"number\" name=\"contrast dose\"><label>mL Omnipaque 300 intravenous contrast.</label></p><p><label>CTDI: </label><input type=\"number\" name=\"CTDI\"><label>mGy</label></p><p><label>DLP: </label><input type=\"number\" name=\"DLP\"><label>mGy-cm</label></p><p><label>COMPARISON: </label><input type=\"text\" name=\"comparison\" value=\"None available\"></p><p><label> </label><br><label>FINDINGS:</label><br><label>SOFT TISSUES: </label><input type=\"text\" name=\"soft tissues/enhancement\" value=\"Normal. No abnormal enhancement.\"></p><p><label>PARANASAL SINUSES: </label><input type=\"text\" name=\"sinuses\" value=\"Clear.\"></p><p><label>BONES: </label><input type=\"text\" name=\"orbital floor, zygoma, maxillary sinus, nasal bones, pterygoid plate, mandible\" value=\"No acute fracture.\"></p><p><label>OTHER: </label><input type=\"text\" name=\"other\" value=\"None.\"></p></section><section data-section-name=\"IMPRESSION:\"><header class=\"Level1\">IMPRESSION:</header><p><textarea na
    "templateData": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\"/>\n<meta content=\"MR Hip\" name=\"dcterms.title\"/>\n<meta content=\"MR Hip template :: Authored by Carrino JA, Fatehi M\" name=\"dcterms.description\"/>\n<meta content=\"http://www.radreport.org/template/0000055\" name=\"dcterms.identifier\"/>\n<meta content=\"en\" name=\"dcterms.language\"/>\n<meta content=\"IMAGE_REPORT_TEMPLATE\" name=\"dcterms.type\"/>\n<meta content=\"Radiological Society of North America (RSNA)\" name=\"dcterms.publisher\"/>\n<meta content=\"May be used gratis, subject to license agreement\" name=\"dcterms.rights\"/>\n<meta content=\"http://www.radreport.org/license.pdf\" name=\"dcterms.license\"/>\n<meta content=\"2012-07-19\" name=\"dcterms.date\"/>\n<meta content=\"Carrino JA, Fatehi M\" name=\"dcterms.creator\"/>\n<meta content=\"Johns Hopkins Medicine (JHM)\" name=\"dcterms.contributor\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"IHE_Template_Style.css\"/>\n<!-- The absolute link to the CSS file is http://www.radreport.org/html/IHE_Template_Style.css -->\n<script type=\"text/xml\">\n<!--\n<template_attributes>\n<top-level-flag>true</top-level-flag>\n<status>ACTIVE</status>\n<coding_schemes>\n <coding_scheme name=\"RadLex\" designator=\"2.16.840.1.113883.6.256\" />\n <coding_scheme name=\"SNOMEDCT\" designator=\"2.16.840.1.113883.6.96\" />\n <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\" />\n</coding_schemes>\n<term>\n <code meaning=\"hip\" value=\"RID2639\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"magnetic resonance imaging\" value=\"RID10312\" scheme=\"RadLex\">\n</term>\n<coded_content>\n<entry ORIGTXT=\"T55_2\">\n <term>\n  <code meaning=\"procedure\" value=\"RID1559\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T55_3\">\n <term>\n  <code meaning=\"right\" value=\"RID5825\" scheme=\"RadLex\">\n </term>\n <term>\n  <code meaning=\"hip\" value=\"RID2639\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T55_4\">\n <term>\n  <code meaning=\"left\" value=\"RID5824\" scheme=\"RadLex\">\n </term>\n <term>\n  <code meaning=\"hip\" value=\"RID2639\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T55_6\">\n <term>\n  <code meaning=\"clinical information\" value=\"RID13166\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T55_7\">\n <term>\n  <code meaning=\"comparison\" value=\"RID28483\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T55_10\">\n <term>\n  <code meaning=\"location descriptor\" value=\"RID5817\" scheme=\"RadLex\">\n </term>\n <term>\n  <code meaning=\"musculoskeletal region\" value=\"RID6063\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T55_49\">\n <term>\n  <code meaning=\"acetabular labrum\" value=\"RID2644\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T55_56\">\n <term>\n  <code meaning=\"articular cartilage of femoral head\" value=\"RID2643\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T55_61\">\n <term>\n  <code meaning=\"articular cartilage of acetabulum\" value=\"RID2642\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T55_66\">\n <term>\n  <code meaning=\"capsule of hip joint\" value=\"RID2646\" scheme=\"RadLex\">\n </term>\n <term>\n  <code meaning=\"ligament of hip joint\" value=\"RID2648\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T55_69\">\n <term>\n  <code meaning=\"flexor muscle\" value=\"RID6064\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T55_71\">\n <term>\n  <code meaning=\"extensor muscle\" value=\"RID6065\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T55_73\">\n <term>\n  <code meaning=\"abductor hallucis muscle\" value=\"RID3165\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T55_75\">\n <term>\n  <code meaning=\"adductor brevis muscle\" value=\"RID2710\" scheme=\"RadLex\">\n </term>\n <term>\n  <code meaning=\"adductor longus muscle\" value=\"RID2708\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T55_77\">\n <term>\n  <code meaning=\"rotator muscle\" value=\"RID32445\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T55_79\">\n <term>\n  <code meaning=\"hamstring muscle\" value=\"RID2713\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T55_83\">\n <term>\n  <code meaning=\"set of nerves\" value=\"RID16263\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T55_85\">\n <term>\n  <code meaning=\"soft tissue administration\" value=\"RID11185\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T55_87\">\n <term>\n  <code meaning=\"set of viscera\" value=\"RID30969\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T55_106\">\n <term>\n  <code meaning=\"impression section\" value=\"RID13170\" scheme=\"RadLex\">\n </term>\n</entry>\n</coded_content>\n</template_attributes>\n-->\n</script>\n<title>MR Hip</title>\n</head>\n<body>\n<section data-section-name=\"Procedure\">\n<header class=\"level1\">MR Hip</header>\n<p>\n<textarea id=\"T55_2\" name=\"Procedure\">Axial, coronal, and sagittal proton density images of the hip were obtained with and without fat suppression. </textarea>\n</p>\n<p>\n<select id=\"T55_777\" name=\"Side\">\n<option id=\"T55_3\" name=\"Right\" value=\"Right\">Right hip</option>\n<option id=\"T55_4\" name=\"Left\" value=\"Left\">Left hip</option>\n</select>\n</p>\n</section>\n<section data-section-name=\"Clinical information\">\n<header class=\"level1\">Clinical information</header>\n<p>\n<textarea id=\"T55_6\" name=\"Clinical information\"> </textarea>\n</p>\n</section>\n<section data-section-name=\"Comparison\">\n<header class=\"level1\">Comparison</header>\n<p>\n<textarea id=\"T55_7\" name=\"Comparison\">None. </textarea>\n</p>\n</section>\n<section data-section-name=\"Findings\">\n<header class=\"level1\">Findings</header>\n<section data-section-name=\"Alignment\">\n<header class=\"level2\">Alignment</header>\n<p>\n<input type=\"text\" id=\"T55_10\" name=\"Alignment\" value=\"Normal. No subluxation. \"/>\n</p>\n</section>\n<section data-section-name=\"Femoroacetabular impingement anatomy\">\n<header class=\"level2\">Femoroacetabular impingement anatomy</header>\n<section data-section-name=\"Pincer\">\n<header class=\"level3\">Pincer</header>\n<p>\n<label for=\"T55_14\">Retroversion:</label>\n<input type=\"text\" id=\"T55_14_text\" name=\"Retroversion\" value=\"Absent. \"/>\n</p>\n<p>\n<label for=\"T55_17\">Over-coverage:</label>\n<input type=\"text\" id=\"T55_17_text\" name=\"Over-coverage\" value=\"Absent. \"/>\n</p>\n<p>\n<label for=\"T55_20\">Os acetabuli:</label>\n<input type=\"text\" id=\"T55_20_text\" name=\"Os acetabuli\" value=\"Absent. \"/>\n</p>\n</section>\n<section data-section-name=\"Cam\">\n<header class=\"level3\">Cam</header>\n<p>\n<label for=\"T55_24\">Head-neck angle:</label>\n<input type=\"text\" id=\"T55_24_text\" name=\"Head-neck angle\" value=\"Normal. \"/>\n</p>\n<p>\n<label for=\"T55_27\">Fibrocystic lesion of femoral neck:</label>\n<input type=\"text\" id=\"T55_27_text\" name=\"Fibrocystic lesion of femoral neck\" value=\"None. \"/>\n</p>\n</section>\n</section>\n<section data-section-name=\"Dysplasia\">\n<header class=\"level2\">Dysplasia</header>\n<p>\n<input type=\"text\" id=\"T55_30_text\" name=\"Dysplasia\" value=\"None. \"/>\n</p>\n</section>\n<section data-section-name=\"Joint effusion\">\n<header class=\"level2\">Joint effusion</header>\n<p>\n<input type=\"text\" id=\"T55_999\" name=\"Joint effusion\" value=\"None. \"/>\n</p>\n</section>\n<section data-section-name=\"Labrum\">\n<header class=\"level2\">Labrum</header>\n<p>\n<input type=\"text\" id=\"T55_49\" name=\"Labrum\" value=\"Normal. No labral tear. \"/>\n</p>\n</section>\n<section data-section-name=\"Cartilage\">\n<header class=\"level2\">Cartilage</header>\n<p>\n<label for=\"T55_56\">Femoral cartilage:</label>\n<input type=\"text\" id=\"T55_56\" name=\"Femoral cartilage\" value=\"Normal. \"/>\n</p>\n<p>\n<label for=\"T55_61\">Acetabular cartilage:</label>\n<input type=\"text\" id=\"T55_61\" name=\"Acetabular cartilage\" value=\"Normal. \"/>\n</p>\n</section>\n<section data-section-name=\"Capsule and ligaments\">\n<header class=\"level2\">Capsule and ligaments</header>\n<p>\n<input type=\"text\" id=\"T55_66\" name=\"Capsule and ligaments\" value=\"Normal.\"/>\n</p>\n</section>\n<section data-section-name=\"Muscles, tendons, and entheses\">\n<header class=\"level2\">Muscles, tendons, and entheses</header>\n<p>\n<label for=\"T55_69\">Flexors:</label>\n<input type=\"text\" id=\"T55_69\" name=\"Flexors\" value=\"Normal. \"/>\n</p>\n<p>\n<label for=\"T55_71\">Extensors:</label>\n<input type=\"text\" id=\"T55_71\" name=\"Extensors\" value=\"Normal. \"/>\n</p>\n<p>\n<label for=\"T55_73\">Abductors:</label>\n<input type=\"text\" id=\"T55_73\" name=\"Abductors\" value=\"Normal. \"/>\n</p>\n<p>\n<label for=\"T55_75\">Adductors:</label>\n<input type=\"text\" id=\"T55_75\" name=\"Adductors\" value=\"Normal. \"/>\n</p>\n<p>\n<label for=\"T55_77\">Rotators:</label>\n<input type=\"text\" id=\"T55_77\" name=\"Rotators\" value=\"Normal. \"/>\n</p>\n<p>\n<label for=\"T55_79\">Hamstrings:</label>\n<input type=\"text\" id=\"T55_79\" name=\"Hamstrings\" value=\"Normal. \"/>\n</p>\n</section>\n<section data-section-name=\"Other findings\">\n<header class=\"level2\">Other findings</header>\n\n<p>\n<label for=\"T55_81\">Vessels:</label>\n<input type=\"text\" id=\"T55_81\" name=\"Vessels\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T55_83\">Nerves:</label>\n<input type=\"text\" id=\"T55_83\" name=\"Nerves\" value=\"Normal. \"/>\n</p>\n<p>\n<label for=\"T55_85\">Soft tissues:</label>\n<input type=\"text\" id=\"T55_85\" name=\"Soft tissues\" value=\"Normal. \"/>\n</p>\n<p>\n<label for=\"T55_87\">Viscera:</label>\n<input type=\"text\" id=\"T55_87\" name=\"Viscera\" value=\"Normal. No abnormality seen in pelvis. No lymphadenopathy. No free fluid in the pelvis.\"/>\n</p>\n</section>\n</section>\n<section data-section-name=\"Impression\">\n<header class=\"level1\">Impression</header>\n<p>\n<textarea id=\"T55_106\" name=\"Impression\"> </textarea>\n</p>\n</section>\n</body>\n</html>\n",

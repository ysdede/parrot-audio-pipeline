    "templateData": "<!DOCTYPE html>\n<html>\n    <head>\n        <title>Trophoblastic Diseases MRI</title>\n        <meta charset=\"UTF-8\" />\n        <meta name=\"dcterms.identifier\" content=\"9d78c42b-6272-4f56-b65a-5ee5faa016e2\" />\n        <meta name=\"dcterms.title\" content=\"Trophoblastic Diseases MRI\" />\n        <meta name=\"dcterms.description\" content=\"\" />\n        <meta name=\"dcterms.type\" content=\"IMAGE_REPORT_TEMPLATE\" />\n        <meta name=\"dcterms.language\" content=\"en\" />\n        <meta name=\"dcterms.publisher\" content=\"ESR\" />\n        <meta name=\"dcterms.rights\" content=\"May be used freely, subject to license agreement\" />\n        <meta name=\"dcterms.license\" content=\"http://www.radreport.org/license.pdf\" />\n        <meta name=\"dcterms.date\" content=\"2017-10-06\" />\n        <meta name=\"dcterms.creator\" content=\"Teresa Margarida Cunha, MD\" />\n        <meta name=\"dcterms.contributor\" content=\"Rita Lucas, MD\" />\n        <script type=\"text/xml\">\n            <template_attributes>\n                <coded_content>\n                    <coding_schemes>\n                        <coding_scheme name=\"RADLEX\" designator=\"2.16.840.1.113883.6.256\"></coding_scheme>\n                    </coding_schemes>\n                    <entry origtxt=\"SELECTION_LIST_1476403470314\">\n                        <term>\n                            <code meaning=\"uterus\" value=\"RID302\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1476403470296\">\n                        <term>\n                            <code meaning=\"procedure\" value=\"RID1559\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"impressionText\">\n                        <term>\n                            <code meaning=\"impression section\" value=\"RID13170\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"comparisonsText\">\n                        <term>\n                            <code meaning=\"comparison\" value=\"RID28483\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476403470299\">\n                        <term>\n                            <code meaning=\"clinical information section\" value=\"RID13166\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476403470328\">\n                        <term>\n                            <code meaning=\"ascites\" value=\"RID1541\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                </coded_content>\n            </template_attributes>\n        </script>\n    </head>\n    <body>\n        <section id=\"procedureInformation\" class=\"level1\" data-section-name=\"Procedure Information\">\n            <header class=\"level1\">\n                Procedure Information\n            </header>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476403470296\">Procedure Type:</label>\n                <select id=\"SELECTION_LIST_1476403470296\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Enhanced MRI pelvis\">\n                    <option id=\"SELECTION_LIST_1476403470296_0\" value=\"Enhanced MRI pelvis\" name=\"SELECTION_LIST_1476403470296\" selected=\"\">Enhanced MRI pelvis</option>\n                    <option id=\"SELECTION_LIST_1476403470296_1\" value=\"Unenhanced MRI pelvis\" name=\"SELECTION_LIST_1476403470296\">Unenhanced MRI pelvis</option>\n                </select>\n            </p>\n  <p title=\"\">\n                <label for=\"SELECTION_LIST_1476403470301\">Technique:</label>\n                <select multiple=\"multiple\" id=\"SELECTION_LIST_1476403470301\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"T2-weighted images axial, sagittal and in oblique planes were obtained in long and short axis relative to the uterine body.\">\n                    <option id=\"SELECTION_LIST_1476403470301_0\" value=\"T2-weighted images axial, sagittal and in oblique planes were obtained in long and short axis relative to the uterine body.\" name=\"SELECTION_LIST_1476403470301\" selected=\"\">T2-weighted images axial, sagittal and in oblique planes were obtained in long and short axis relative to the uterine body.</option>\n                    <option id=\"SELECTION_LIST_1476403470301_1\" value=\"Axial DW-MRI study was also performed.\" name=\"SELECTION_LIST_1476403470301\">Axial DW-MRI study was also performed.</option>\n                    <option id=\"SELECTION_LIST_1476403470301_2\" value=\"Survey images that include the region of the kidneys were also obtained.\" name=\"SELECTION_LIST_1476403470301\">Survey images that include the region of the kidneys were also obtained.</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476403470305\">Type of pre and post contrast imaging of the pelvis in the sagittal plane and in axial plane in late phase:</label>\n                <select id=\"SELECTION_LIST_1476403470305\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Dynamic\">\n                    <option id=\"SELECTION_LIST_1476403470305_0\" value=\"Dynamic\" name=\"SELECTION_LIST_1476403470305\" selected=\"\">Dynamic</option>\n                    <option id=\"SELECTION_LIST_1476403470305_1\" value=\"Non-dynamic\" name=\"SELECTION_LIST_1476403470305\">Non-dynamic</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476403470308\">Strength of Tesla scanner:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"\" id=\"NUMBER_1476403470308\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476403470309\">Contrast type:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476403470309\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476403470310\">Contrast dose was administered before and after fat suppressed T1-weighted imaging:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"mL\" id=\"NUMBER_1476403470310\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    mL\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476403470311\">Image quality:</label>\n                <select id=\"SELECTION_LIST_1476403470311\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Satisfactory\">\n                    <option id=\"SELECTION_LIST_1476403470311_0\" value=\"Satisfactory\" name=\"SELECTION_LIST_1476403470311\" selected=\"\">Satisfactory</option>\n                    <option id=\"SELECTION_LIST_1476403470311_1\" value=\"Degraded by motion/etc.\" name=\"SELECTION_LIST_1476403470311\">Degraded by motion/etc.</option>\n                </select>\n            </p>\n        </section>\n        <section id=\"clinicalInformation\" class=\"level1\" data-section-name=\"Clinical Information\">\n            <header class=\"level1\">\n                Clinical Information\n            </header>\n            <p title=\"\">\n                <label for=\"TEXT_1476403470299\">Clinical Indication:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476403470299\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Trophoblastic disease evaluation</textarea>\n            </p>\n                  </section>\n        <section id=\"comparisons\" class=\"level1\" data-section-name=\"Comparison\">\n            <header class=\"level1\">\n                Comparison\n            </header>\n            <p title=\"\">\n                <label for=\"comparisonsText\">Comparison study:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"comparisonsText\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">None available</textarea>\n            </p>\n        </section>\n        <section id=\"findings\" class=\"level1\" data-section-name=\"Findings\">\n            <header class=\"level1\">\n                Findings\n            </header>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476403470314\">Uterus:</label>\n                <select id=\"SELECTION_LIST_1476403470314\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Anteverted\">\n                    <option id=\"SELECTION_LIST_1476403470314_0\" value=\"Anteverted\" name=\"SELECTION_LIST_1476403470314\" selected=\"\">Anteverted</option>\n                    <option id=\"SELECTION_LIST_1476403470314_1\" value=\"Retroverted\" name=\"SELECTION_LIST_1476403470314\">Retroverted</option>\n                    <option id=\"SELECTION_LIST_1476403470314_2\" value=\"Retroflexed\" name=\"SELECTION_LIST_1476403470314\">Retroflexed</option>\n                    <option id=\"SELECTION_LIST_1476403470314_3\" value=\"Displaced to left\" name=\"SELECTION_LIST_1476403470314\">Displaced to left</option>\n                    <option id=\"SELECTION_LIST_1476403470314_4\" value=\"Displaced to right\" name=\"SELECTION_LIST_1476403470314\">Displaced to right</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"findingsText\">Size:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"findingsText\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Normal in size</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476403470320\">Measuring:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"cm\" id=\"NUMBER_1476403470320\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    cm\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476403470321\">Tumour:</label>\n                <select id=\"SELECTION_LIST_1476403470321\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Visible\">\n                    <option id=\"SELECTION_LIST_1476403470321_0\" value=\"Visible\" name=\"SELECTION_LIST_1476403470321\" selected=\"\">Visible</option>\n                    <option id=\"SELECTION_LIST_1476403470321_1\" value=\"Not visible confined to the uterus/ extending outside the uterus limited to the genital organs (adnexa, vagina, broad ligament).\" name=\"SELECTION_LIST_1476403470321\">Not visible confined to the uterus/ extending outside the uterus limited to the genital organs (adnexa, vagina, broad ligament).</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476403470324\">Lymph nodes:</label>\n                <select id=\"SELECTION_LIST_1476403470324\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Normal in size\">\n                    <option id=\"SELECTION_LIST_1476403470324_0\" value=\"Normal in size\" name=\"SELECTION_LIST_1476403470324\" selected=\"\">Normal in size</option>\n                    <option id=\"SELECTION_LIST_1476403470324_1\" value=\"Enlarged; probably reactive\" name=\"SELECTION_LIST_1476403470324\">Enlarged; probably reactive</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476403470327\">Physiologic pelvic fluid:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476403470327\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no physiologic pelvic fluid.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476403470328\">Ascites:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476403470328\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no ascites.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476403470329\">Pulmonary lesions:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476403470329\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There are no pulmonary lesions.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476403470330\">Distant mestastasis:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476403470330\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no distant metastasis.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1506699365996\">Other findings:</label>\n                <input type=\"text\" id=\"TEXT_1506699365996\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\" value=\"\" />\n            </p>\n        </section>\n        <section id=\"impression\" class=\"level1\" data-section-name=\"Impression\">\n            <header class=\"level1\">\n                Impression\n            </header>\n            <p title=\"\">\n                <label for=\"impressionText\">Impression:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"impressionText\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n        </section>\n    </body>\n</html>\n",

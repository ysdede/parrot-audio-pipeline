 origtxt=\"SELECTION_LIST_1459555208497_0\">\n                        <term>\n                            <code meaning=\"none\" value=\"RID28454\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1459555208497_1\">\n                        <term>\n                            <code meaning=\"mild\" value=\"RID5671\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1459555208497_2\">\n                        <term>\n                            <code meaning=\"moderate\" value=\"RID5672\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1459555208497_3\">\n                        <term>\n                            <code meaning=\"severe\" value=\"RID5673\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"comparisons\">\n                        <term>\n                            <code meaning=\"Radiology Comparison Study\" value=\"18834-2\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"impression\">\n                        <term>\n                            <code meaning=\"Impressions\" value=\"19005-8\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1459555208494\">\n                        <term>\n                            <code meaning=\"left ureter\" value=\"RID30845\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1459555208494_0\">\n                        <term>\n                            <code meaning=\"none\" value=\"RID28454\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1459555208494_1\">\n                        <term>\n                            <code meaning=\"present\" value=\"RID28472\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"clinicalInformation\">\n                        <term>\n                            <code meaning=\"Clinical Information\" value=\"55752-0\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1459555208471\">\n                        <term>\n                            <code meaning=\"right ureter\" value=\"RID30844\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1459555208471_0\">\n                        <term>\n                            <code meaning=\"none\" value=\"RID28454\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1459555208471_1\">\n                        <term>\n                            <code meaning=\"present\" value=\"RID28472\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1476917486402\">\n                        <term>\n                            <code meaning=\"indication\" value=\"RID49442\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                </coded_content>\n            </template_attributes>\n        </script>\n    </head>\n    <body>\n        <section id=\"procedureInformation\" class=\"level1\" data-section-name=\"Procedure Information\">\n            <header class=\"level1\">\n                Procedure Information\n            </header>\n            <p title=\"\">\n                <label for=\"TEXT_1459554442168\">Technique:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459554442168\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Helical scan mode axial images were obtained from the lung bases through the pubic symphysis without oral or intravenous contrast.  Coronal and sagittal images were created at the CT scanner.</textarea>\n            </p>\n        </section>\n        <section id=\"clinicalInformation\" class=\"level1\" data-section-name=\"Clinical Information\">\n            <header class=\"level1\">\n                Clinical Information\n            </header>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476917486402\">Indication:</label>\n                <select id=\"SELECTION_LIST_1476917486402\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Abdominal pain.\">\n                    <option id=\"SELECTION_LIST_1476917486402_0\" value=\"Abdominal pain.\" name=\"SELECTION_LIST_1476917486402\" selected=\"\">Abdominal pain.</option>\n                    <option id=\"SELECTION_LIST_1476917486402_1\" value=\"Right flank pain.\" name=\"SELECTION_LIST_1476917486402\">Right flank pain.</option>\n                    <option id=\"SELECTION_LIST_1476917486402_2\" value=\"Left flank pain.\" name=\"SELECTION_LIST_1476917486402\">Left flank pain.</option>\n                    <option id=\"SELECTION_LIST_1476917486402_3\" value=\"Back pain.\" name=\"SELECTION_LIST_1476917486402\">Back pain.</option>\n                </select>\n            </p>\n        </section>\n        <section id=\"comparisons\" class=\"level1\" data-section-name=\"Comparison\">\n            <header class=\"level1\">\n                Comparison\n            </header>\n            <p title=\"\">\n                <label for=\"comparisonsText\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"comparisonsText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">None.</textarea>\n            </p>\n        </section>\n        <section id=\"findings\" class=\"level1\" data-section-name=\"Findings\">\n            <header class=\"level1\">\n                Findings\n            </header>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1459554442176\">Lung Bases:</label>\n                <select id=\"SELECTION_LIST_1459554442176\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Clear, without airspace disease.\">\n                    <option id=\"SELECTION_LIST_1459554442176_0\" value=\"Clear, without airspace disease.\" name=\"SELECTION_LIST_1459554442176\" selected=\"\">Clear, without airspace disease.</option>\n                    <option id=\"SELECTION_LIST_1459554442176_1\" value=\"For findings in the chest please see separately dictated report.\" name=\"SELECTION_LIST_1459554442176\">For findings in the chest please see separately dictated report.</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1459554442181\">Liver:</label>\n                <select id=\"SELECTION_LIST_1459554442181\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"No focal mass lesions on this noncontrast study. No intrahepatic biliary ductal dilatation. \">\n                    <option id=\"SELECTION_LIST_1459554442181_0\" value=\"No focal mass lesions on this noncontrast study. No intrahepatic biliary ductal dilatation.\" name=\"SELECTION_LIST_1459554442181\">No focal mass lesions on this noncontrast study. No intrahepatic biliary ductal dilatation.</option>\n                    <option id=\"SELECTION_LIST_1459554442181_1\" value=\"Diffuse low attenuation of hepatic parenchyma. No definite oslid hepatic lesions. No intrahepatic biliary ductal dilatation.\" name=\"SELECTION_LIST_1459554442181\">Diffuse low attenuation of hepatic parenchyma. No definite oslid hepatic lesions. No intrahepatic biliary ductal dilatation.</option>\n                    <option id=\"SELECTION_LIST_1459554442181_2\" value=\"Hypoattenuation adjacent to the falciform ligament is likely pseduomass/focal fat. No definite solid hepatic lesions. No intrahepatic biliary ductal dilatation.\" name=\"SELECTION_LIST_1459554442181\">Hypoattenuation adjacent to the falciform ligament is likely pseduomass/focal fat. No definite solid hepatic lesions. No intrahepatic biliary ductal dilatation.</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1459554442185\">Gallbladder:</label>\n                <select id=\"SELECTION_LIST_1459554442185\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"The CT appearance is normal.\">\n                    <option id=\"SELECTION_LIST_1459554442185_0\" value=\"The CT appearance is normal.\" name=\"SELECTION_LIST_1459554442185\" selected=\"\">The CT appearance is normal.</option>\n                    <option id=\"SELECTION_LIST_1459554442185_1\" value=\"Surgically absent.\" name=\"SELECTION_LIST_1459554442185\">Surgically absent.</option>\n                    <option id=\"SELECTION_LIST_1459554442185_2\" value=\"Cholelithiasis with cholecystitis.\" name=\"SELECTION_LIST_1459554442185\">Cholelithiasis with cholecystitis.</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1459554442189\">Spleen:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459554442189\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1459555208450\">Pancreas:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459555208450\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal CT appearance.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1459555208451\">Adrenals:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459555208451\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Normal.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1459555208452\">Nodes:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459555208452\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">No enlarged retroperitoneal lymph nodes. No enlarged pelvic lymph nodes. No enlarged inguinal lymph nodes.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1459555208453\">Bowel:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459555208453\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Nondilated.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1459555208454\">Appendix:</label>\n                <select id=\"SELECTION_LIST_1459555208454\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"A normal appendix is indentified.\">\n                    <option id=\"SELECTION_LIST_1459555208454_0\" value=\"A normal appendix is indentified.\" name=\"SELECTION_LIST_1459555208454\" selected=\"\">A normal appendix is indentified.</option>\n                    <option id=\"SELECTION_LIST_1459555208454_1\" value=\"The appendix is not identified, but there is no free fluid or stranding in the right lower quadrant.\" name=\"SELECTION_LIST_1459555208454\">The appendix is not identified, but there is no free fluid or stranding in the right lower quadrant.</option>\n                    <option id=\"SELECTION_LIST_1459555208454_2\" value=\"Postoperative changes from appendectomy.\" name=\"SELECTION_LIST_1459555208454\">Postoperative changes from appendectomy.</option>\n                </select>\n            </p>\n            <section id=\"SECTION_HEADER_1459555208458\" class=\"level2\" data-section-name=\"Right Genitourinary\">\n                <header class=\"level2\">\n                    Right Genitourinary\n                </header>\n                <p title=\"\">\n                    <label for=\"SELECTION_LIST_1459555208461\">Kidney:</label>\n                    <select id=\"SELECTION_LIST_1459555208461\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"No renal calculi.\">\n                        <option id=\"SELECTION_LIST_1459555208461_0\" value=\"No renal calculi.\" name=\"SELECTION_LIST_1459555208461\" selected=\"\">No renal calculi.</option>\n                        <option id=\"SELECTION_LIST_1459555208461_1\" value=\"One renal calculus located\" name=\"SELECTION_LIST_1459555208461\">One renal calculus located</option>\n                        <option id=\"SELECTION_LIST_1459555208461_2\" value=\"Multiple renal calculi.\" name=\"SELECTION_LIST_1459555208461\">Multiple renal calculi.</option>\n                    </select>\n                </p>\n                <p title=\"\">\n                    <label for=\"SELECTION_LIST_1459555208471\">Ureter:</label>\n                    <select id=\"SELECTION_LIST_1459555208471\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"No ureteral calculi.\">\n                        <option id=\"SELECTION_LIST_1459555208471_0\" value=\"No ureteral calculi.\" name=\"SELECTION_LIST_1459555208471\" selected=\"\">No ureteral calculi.</option>\n                        <option id=\"SELECTION_LIST_1459555208471_1\" value=\"Present.\" name=\"SELECTION_LIST_1459555208471\">Present.</option>\n                    </select>\n                </p>\n                <p title=\"\">\n                    <label for=\"SELECTION_LIST_1459555208478\">Obstruction/Hydronephrosis:</label>\n                    <select id=\"SELECTION_LIST_1459555208478\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"None.\">\n                        <option id=\"SELECTION_LIST_1459555208478_0\" value=\"None.\" name=\"SELECTION_LIST_1459555208478\" selected=\"\">None.</option>\n                        <option id=\"SELECTION_LIST_1459555208478_1\" value=\"Mild.\" name=\"SELECTION_LIST_1459555208478\">Mild.</option>\n                        <option id=\"SELECTION_LIST_1459555208478_2\" value=\"Moderate.\" name=\"SELECTION_LIST_1459555208478\">Moderate.</option>\n                        <option id=\"SELECTION_LIST_1459555208478_3\" value=\"Severe.\" name=\"SELECTION_LIST_1459555208478\">Severe.</option>\n                    </select>\n                </p>\n            </section>\n            <section id=\"SECTION_HEADER_1459555208483\" class=\"level2\" data-section-name=\"Left Genitourinary\">\n                <header class=\"level2\">\n                    Left Genitourinary\n                </header>\n                <p title=\"\">\n                    <label for=\"SELECTION_LIST_1459555208488\">Kidney:</label>\n                    <select id=\"SELECTION_LIST_1459555208488\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"No renal calculi.\">\n                        <option id=\"SELECTION_LIST_1459555208488_0\" value=\"No renal calculi.\" name=\"SELECTION_LIST_1459555208488\" selected=\"\">No renal calculi.</option>\n                        <option id=\"SELECTION_LIST_1459555208488_1\" value=\"One renal calculus located.\" name=\"SELECTION_LIST_1459555208488\">One renal calculus located.</option>\n                        <option id=\"SELECTION_LIST_1459555208488_2\" value=\"Multiple renal calculi.\" name=\"SELECTION_LIST_1459555208488\">Multiple renal calculi.</option>\n                    </select>\n                </p>\n                <p title=\"\">\n                    <label for=\"SELECTION_LIST_1459555208494\">Ureter:</label>\n                    <select id=\"SELECTION_LIST_1459555208494\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"No ureteral calculi\">\n                        <option id=\"SELECTION_LIST_1459555208494_0\" value=\"No ureteral calculi\" name=\"SELECTION_LIST_1459555208494\" selected=\"\">No ureteral calculi</option>\n                        <option id=\"SELECTION_LIST_1459555208494_1\" value=\"Present.\" name=\"SELECTION_LIST_1459555208494\">Present.</option>\n                    </select>\n                </p>\n                <p title=\"\">\n                    <label for=\"SELECTION_LIST_1459555208497\">Obstruction/Hydronephrosis:</label>\n                    <select id=\"SELECTION_LIST_1459555208497\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"None.\">\n                        <option id=\"SELECTION_LIST_1459555208497_0\" value=\"None.\" name=\"SELECTION_LIST_1459555208497\" selected=\"\">None.</option>\n                        <option id=\"SELECTION_LIST_1459555208497_1\" value=\"Mild.\" name=\"SELECTION_LIST_1459555208497\">Mild.</option>\n                        <option id=\"SELECTION_LIST_1459555208497_2\" value=\"Moderate.\" name=\"SELECTION_LIST_1459555208497\">Moderate.</option>\n                        <option id=\"SELECTION_LIST_1459555208497_3\" value=\"Severe.\" name=\"SELECTION_LIST_1459555208497\">Severe.</option>\n                    </select>\n                </p>\n            </section>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1459555208503\">Urinary Bladder:</label>\n                <input list=\"SELECTION_LIST_1459555208503_LIST\" id=\"SELECTION_LIST_1459555208503\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"No calculi.\" />\n                <datalist id=\"SELECTION_LIST_1459555208503_LIST\">\n                    <option id=\"SELECTION_LIST_1459555208503_0\" value=\"No calculi.\" name=\"SELECTION_LIST_1459555208503\" selected=\"\">No calculi.</option>\n                    <option id=\"SELECTION_LIST_1459555208503_1\" value=\"\" name=\"SELECTION_LIST_1459555208503\"></option>\n                </datalist>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1459555208510\"></label>\n                <select id=\"SELECTION_LIST_1459555208510\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"The bladder is distended adequately and the wall is thin.\">\n                    <option id=\"SELECTION_LIST_1459555208510_0\" value=\"The bladder is distended adequately and the wall is thin.\" name=\"SELECTION_LIST_1459555208510\" selected=\"\">The bladder is distended adequately and the wall is thin.</option>\n                    <option id=\"SELECTION_LIST_1459555208510_1\" value=\"The bladder wall is incompletely distended, limiting evaluation.\" name=\"SELECTION_LIST_1459555208510\">The bladder wall is incompletely distended, limiting evaluation.</option>\n                    <option id=\"SELECTION_LIST_1459555208510_2\" value=\"The bladder wall is thin.\" name=\"SELECTION_LIST_1459555208510\">The bladder wall is thin.</option>\n                    <option id=\"SELECTION_LIST_1459555208510_3\" value=\"The bladder wall is asymmetrically thickened.\" name=\"SELECTION_LIST_1459555208510\">The bladder wall is asymmetrically thickened.</option>\n                    <option id=\"SELECTION_LIST_1459555208510_4\" value=\"Bladder wall appears trabeculated.\" name=\"SELECTION_LIST_1459555208510\">Bladder wall appears trabeculated.</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1459555208517\">Reproductive Organs:</label>\n                <select id=\"SELECTION_LIST_1459555208517\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"The prostate and seminal vesicles are unremarkable.\">\n                    <option id=\"SELECTION_LIST_1459555208517_0\" value=\"The prostate and seminal vesicles are unremarkable.\" name=\"SELECTION_LIST_1459555208517\" selected=\"\">The prostate and seminal vesicles are unremarkable.</option>\n                    <option id=\"SELECTION_LIST_1459555208517_1\" value=\"The uterus is unremarkable. No abnormal adnexal masses.\" name=\"SELECTION_LIST_1459555208517\">The uterus is unremarkable. No abnormal adnexal masses.</option>\n                    <option id=\"SELECTION_LIST_1459555208517_2\" value=\"The prostate is enlarged, a nonspecific finding but one that is typically secondary to BPH.\" name=\"SELECTION_LIST_1459555208517\">The prostate is enlarged, a nonspecific finding but one that is typically secondary to BPH.</option>\n                    <option id=\"SELECTION_LIST_1459555208517_3\" value=\"The uterus is not visualized, consistent with a hysterectomy. No abnormal adnexal masses.\" name=\"SELECTION_LIST_1459555208517\">The uterus is not visualized, consistent with a hysterectomy. No abnormal adnexal masses.</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1459555208523\">Vasculature:</label>\n                <input list=\"SELECTION_LIST_1459555208523_LIST\" id=\"SELECTION_LIST_1459555208523\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Normal.\" />\n                <datalist id=\"SELECTION_LIST_1459555208523_LIST\">\n                    <option id=\"SELECTION_LIST_1459555208523_0\" value=\"Normal.\" name=\"SELECTION_LIST_1459555208523\" selected=\"\">Normal.</option>\n                    <option id=\"SELECTION_LIST_1459555208523_1\" value=\"Scattered atherosclerotic vasculature changes.\" name=\"SELECTION_LIST_1459555208523\">Scattered atherosclerotic vasculature changes.</option>\n                </datalist>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1459555208526\">Soft Tissues:</label>\n                <select id=\"SELECTION_LIST_1459555208526\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Normal.\">\n                    <option id=\"SELECTION_LIST_1459555208526_0\" value=\"Normal.\" name=\"SELECTION_LIST_1459555208526\" selected=\"\">Normal.</option>\n                    <option id=\"SELECTION_LIST_1459555208526_1\" value=\"No subcutaneous or intramuscular enhancing mass lesions.\" name=\"SELECTION_LIST_1459555208526\">No subcutaneous or intramuscular enhancing mass lesions.</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1459555208502\">Additional findings:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459555208502\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">No other significant abnormalities of the upper urinary tract.</textarea>\n            </p>\n        </section>\n        <section id=\"impression\" class=\"level1\" data-section-name=\"Impression\">\n            <header class=\"level1\">\n                Impression\n            </header>\n            <p title=\"\">\n                <label for=\"impressionText\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"impressionText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">No urinary tract calculi.</textarea>\n            </p>\n        </section>\n    </body>\n</html>\n",

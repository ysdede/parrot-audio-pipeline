    "templateData": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\"/>\n<meta content=\"PET-CT Oncologic\" name=\"dcterms.title\"/>\n<meta content=\"PET-CT Oncologic Study template :: Authored by Pryma DA, et al.\" name=\"dcterms.description\"/>\n<meta content=\"http://www.radreport.org/template/0000084\" name=\"dcterms.identifier\"/>\n<meta content=\"en\" name=\"dcterms.language\"/>\n<meta content=\"IMAGE_REPORT_TEMPLATE\" name=\"dcterms.type\"/>\n<meta content=\"Radiological Society of North America (RSNA)\" name=\"dcterms.publisher\"/>\n<meta content=\"May be used gratis, subject to license agreement\" name=\"dcterms.rights\"/>\n<meta content=\"http://www.radreport.org/license.pdf\" name=\"dcterms.license\"/>\n<meta content=\"2012-07-19\" name=\"dcterms.date\"/>\n<meta content=\"Pryma DA, et al.\" name=\"dcterms.creator\"/>\n<meta content=\"Hong Y [coder]\" name=\"dcterms.contributor\"/>\n<meta content=\"Kahn CE Jr [editor]\" name=\"dcterms.contributor\"/>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"IHE_Template_Style.css\"/>\n<!-- The absolute link to the CSS file is http://www.radreport.org/html/IHE_Template_Style.css -->\n<script type=\"text/xml\">\n<!--\n<template_attributes>\n<top-level-flag>true</top-level-flag>\n<status>ACTIVE</status>\n<coding_schemes>\n <coding_scheme name=\"RadLex\" designator=\"2.16.840.1.113883.6.256\" />\n <coding_scheme name=\"SNOMEDCT\" designator=\"2.16.840.1.113883.6.96\" />\n <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\" />\n</coding_schemes>\n<term>\n <code meaning=\"neoplasm\" value=\"RID3957\" scheme=\"RadLex\">\n</term>\n<term>\n <code meaning=\"PET-CT\" value=\"RID10341\" scheme=\"RadLex\">\n</term>\n<coded_content>\n<entry ORIGTXT=\"T84_45\">\n <term>\n  <code meaning=\"clinical information\" value=\"RID13166\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T84_92\">\n <term>\n  <code meaning=\"comparison\" value=\"RID28483\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T84_136\">\n <term>\n  <code meaning=\"foci\" value=\"RID34302\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T84_150\">\n <term>\n  <code meaning=\"heart\" value=\"RID1385\" scheme=\"RadLex\">\n </term>\n <term>\n  <code meaning=\"vasculature of organ\" value=\"RID15990\" scheme=\"RadLex\">\n </term>\n <term>\n  <code meaning=\"heart\" value=\"RID1385\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T84_154\">\n <term>\n  <code meaning=\"lymphadenopathy\" value=\"RID3798\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T84_156\">\n <term>\n  <code meaning=\"pleural effusion\" value=\"RID34539\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T84_163\">\n <term>\n  <code meaning=\"liver\" value=\"RID58\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T84_165\">\n <term>\n  <code meaning=\"spleen\" value=\"RID86\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T84_167\">\n <term>\n  <code meaning=\"pancreas\" value=\"RID170\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T84_169\">\n <term>\n  <code meaning=\"gallbladder\" value=\"RID187\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T84_171\">\n <term>\n  <code meaning=\"aorta\" value=\"RID480\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T84_173\">\n <term>\n  <code meaning=\"kidney\" value=\"RID205\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T84_175\">\n <term>\n  <code meaning=\"anterior abdominal wall\" value=\"RID30008\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T84_177\">\n <term>\n  <code meaning=\"lymph node group\" value=\"RID28847\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T84_180\">\n <term>\n  <code meaning=\"foci\" value=\"RID34302\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T84_182\">\n <term>\n  <code meaning=\"subdivision of pelvis\" value=\"RID30020\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T84_184\">\n <term>\n  <code meaning=\"set of pelvic viscera\" value=\"RID30970\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T84_186\">\n <term>\n  <code meaning=\"pneumoperitoneum\" value=\"RID4803\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T84_188\">\n <term>\n  <code meaning=\"fluid\" value=\"RID1547\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T84_190\">\n <term>\n  <code meaning=\"lymph node\" value=\"RID13296\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T84_201\">\n <term>\n  <code meaning=\"spondylosis deformans\" value=\"RID5121\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T84_204\">\n <term>\n  <code meaning=\"impression section\" value=\"RID13170\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T84_208\">\n <term>\n  <code meaning=\"(unspecified)\" value=\"RID13051\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T84_213\">\n <term>\n  <code meaning=\"response to treatment\" value=\"RID11565\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T84_214\">\n <term>\n  <code meaning=\"complete imaging response\" value=\"RID11511\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T84_215\">\n <term>\n  <code meaning=\"partial response\" value=\"RID11513\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T84_216\">\n <term>\n  <code meaning=\"progressive disease\" value=\"RID11515\" scheme=\"RadLex\">\n </term>\n</entry>\n<entry ORIGTXT=\"T84_217\">\n <term>\n  <code meaning=\"stable disease\" value=\"RID11514\" scheme=\"RadLex\">\n </term>\n</entry>\n</coded_content>\n</template_attributes>\n-->\n</script>\n<title>PET-CT Oncologic</title>\n</head>\n<body>\n<section data-section-name=\"Procedure\">\n<header class=\"level1\">PET-CT Oncologic Study</header>\n<p>\n<label for=\"T82_8\">Duration of fast prior to injection:</label>\n<input type=\"text\" id=\"T82_8\" name=\"Duration of fast prior to injection\" value=\"\"/>\n</p>\n<p>\n<label for=\"T82_10\">Blood glucose prior to injection:</label>\n<input type=\"number\" id=\"T82_10\" name=\"Blood glucose prior to injection\" data-field-units=\"mg/dl\" min=\"\" max=\"\"/> <label for=\"T82_10\">mg/dl</label>\n</p>\n<p>\n<label for=\"T82_11\">Scan region:</label>\n<input type=\"text\" id=\"T82_11\" name=\"Scan region\" value=\"\"/>\n</p>\n<p>\n<label for=\"T82_13\">Radiopharmaceutical:</label>\n<input type=\"text\" id=\"T82_13\" name=\"Radiopharmaceutical\" value=\"F-18 FDG\"/>\n<input type=\"number\" id=\"T82_14\" name=\"Radiopharmaceutical value\" data-field-units=\"mCi\" min=\"0\" max=\"\"/> <label for=\"T82_14\">mCi IV</label>\n</p>\n<p>\n<label for=\"T82_15\">Calibration time:</label>\n<input type=\"date\" id=\"T82_15\" name=\"Calibration date\" data-field-type=\"DATE\"/>\n<input type=\"time\" id=\"T82_15_time\" name=\"Calibration time\" data-field-type=\"TIME\"/>\n</p>\n<p>\n<label for=\"T82_16\">Administration time:</label>\n<input type=\"date\" id=\"T82_16\" name=\"Administration date\" data-field-type=\"DATE\"/>\n<input type=\"time\" id=\"T82_16_time\" name=\"Administration time\" data-field-type=\"TIME\"/>\n</p>\n<p>\n<label for=\"T82_17\">Injection site:</label>\n<input type=\"text\" id=\"T82_17\" name=\"Injection site\" value=\"\"/>\n</p>\n<p>\n<label for=\"T82_33\">Post-injection imaging delay:</label>\n<input type=\"number\" id=\"T82_33\" name=\"Post-injection imaging delay\" data-field-units=\"minutes\" min=\"\" max=\"\"/> <label for=\"T82_33\">minutes</label>\n</p>\n<p>\n<label for=\"T82_34\">Attenuation correction:</label>\n<input type=\"text\" id=\"T82_34\" name=\"Attenuation correction\" value=\"Computed tomography scan. \"/>\n</p>\n</section>\n<section data-section-name=\"Clinical information\">\n<header class=\"level1\">Clinical information</header>\n<p>\n<textarea id=\"T84_45\" name=\"Clinical information\"> </textarea>\n</p>\n</section>\n<section data-section-name=\"Comparison\">\n<header class=\"level1\">Comparison</header>\n<p>\n<textarea id=\"T84_92\" name=\"Comparison\">None. </textarea>\n</p>\n</section>\n<section data-section-name=\"Findings\">\n<header class=\"level1\">Findings</header>\n<section data-section-name=\"Neck\">\n<header class=\"level2\">Neck</header>\n<p>\n<label for=\"T84_136\">Hypermetabolic foci:</label>\n<input type=\"text\" id=\"T84_136\" name=\"Hypermetabolic foci\" value=\"None.\"/>\n</p>\n<p>\n<textarea id=\"T84_999\" name=\"Neck findings\">No mass or lymphadenopathy. </textarea>\n</p>\n</section>\n<section data-section-name=\"Thorax\">\n<header class=\"level2\">Thorax</header>\n<p>\n<label for=\"T84_148\">Hypermetabolic foci:</label>\n<input type=\"text\" id=\"T84_148\" name=\"Hypermetabolic foci\" value=\"None.\"/>\n</p>\n<p>\n<label for=\"T84_150\">Heart and great vessels:</label>\n<input type=\"text\" id=\"T84_150\" name=\"Heart and great vessels\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T84_154\">Adenopathy:</label>\n<input type=\"text\" id=\"T84_154\" name=\"Adenopathy\" value=\"None.\"/>\n</p>\n<p>\n<label for=\"T84_156\">Pleural or pericardial effusion:</label>\n<input type=\"text\" id=\"T84_156\" name=\"Pleural or pericardial effusion\" value=\"None.\"/>\n</p>\n<p>\n<label for=\"T84_158\">Lungs:</label>\n<input type=\"text\" id=\"T84_158\" name=\"Lungs\" value=\"Normal. Adequate lung volumes with satisfactory inflation.\"/>\n</p>\n</section>\n<section data-section-name=\"Abdomen\">\n<header class=\"level2\">Abdomen</header>\n<p>\n<label for=\"T84_161\">Hypermetabolic foci:</label>\n<input type=\"text\" id=\"T84_161\" name=\"Hypermetabolic foci\" value=\"None.\"/>\n</p>\n<p>\n<label for=\"T84_163\">Liver:</label>\n<input type=\"text\" id=\"T84_163\" name=\"Liver\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T84_169\">Gallbladder:</label>\n<input type=\"text\" id=\"T84_169\" name=\"Gallbladder\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T84_165\">Spleen:</label>\n<input type=\"text\" id=\"T84_165\" name=\"Spleen\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T84_167\">Pancreas:</label>\n<input type=\"text\" id=\"T84_167\" name=\"Pancreas\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T84_171\">Great abdominal vessels</label>\n<input type=\"text\" id=\"T84_171\" name=\"Great abdominal vessels\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T84_173\">Kidneys:</label>\n<input type=\"text\" id=\"T84_173\" name=\"Kidneys\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T84_175\">Anterior abdominal wall:</label>\n<input type=\"text\" id=\"T84_175\" name=\"Anterior abdominal wall\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T84_177\">Hypermetabolic lymph nodes:</label>\n<input type=\"text\" id=\"T84_177\" name=\"Hypermetabolic lymph nodes\" value=\"None.\"/>\n</p>\n</section>\n<section data-section-name=\"Pelvis\">\n<header class=\"level2\">Pelvis</header>\n<p>\n<label for=\"T84_180\">Hypermetabolic foci:</label>\n<input type=\"text\" id=\"T84_180\" name=\"Hypermetabolic foci\" value=\"None.\"/>\n</p>\n<p>\n<label for=\"T84_182\">Anterior and inner pelvic walls:</label>\n<input type=\"text\" id=\"T84_182\" name=\"Anterior and inner pelvic walls\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T84_184\">Pelvic viscera:</label>\n<input type=\"text\" id=\"T84_184\" name=\"Pelvic viscera\" value=\"Normal.\"/>\n</p>\n<p>\n<label for=\"T84_186\">Infradiaphragmatic free air:</label>\n<input type=\"text\" id=\"T84_186\" name=\"Infradiaphragmatic free air\" value=\"None.\"/>\n</p>\n<p>\n<label for=\"T84_188\">Free pelvic fluid:</label>\n<input type=\"text\" id=\"T84_188\" name=\"Free pelvic fluid\" value=\"None.\"/>\n</p>\n<p>\n<label for=\"T84_190\">Hypermetabolic lymph nodes:</label>\n<input type=\"text\" id=\"T84_190\" name=\"Hypermetabolic lymph nodes\" value=\"None.\"/>\n</p>\n</section>\n<section data-section-name=\"Bones\">\n<header class=\"level2\">Bones</header>\n<p>\n<label for=\"T84_195\">Hypermetabolic foci:</label>\n<input type=\"text\" id=\"T84_195\" name=\"Hypermetabolic foci\" value=\"None.\"/>\n</p>\n<p>\n<textarea id=\"T84_201\" name=\"lytic or blastic foci\">No lytic or blastic foci.</textarea>\n</p>\n</section>\n</section>\n<section data-section-name=\"Impression\">\n<header class=\"level1\">Impression</header>\n<p>\n<textarea id=\"T84_204\" name=\"Impression\"> </textarea>\n</p>\n<p>\n<label for=\"T84_208\">EORTC response criteria:</label>\n<select id=\"T84_208\" name=\"EORTC response criteria\">\n<option id=\"T84_208.1\" name=\"Complete\" value=\"Complete\">Complete Metabolic Response. MaxSUV &lt; 2.5 or equivalent to background</option>\n<option id=\"T84_208.2\" name=\"Partial\" value=\"Partial\">Partial Metabolic Response. Decrease in MaxSUV >= 25%</option>\n<option id=\"T84_208.3\" name=\"Progressive\" value=\"Progressive\">Progressive Metabolic Disease. Increase in MaxSUV > 25%</option>\n<option id=\"T84_208.4\" name=\"Stable\" value=\"Stable\">Stable Metabolic Disease. Change in MaxSUV &lt; 25%</option>\n</select>\n</p>\n<p>\n<label for=\"T84_213\">Primary tumor response WHO category:</label>\n<select id=\"T84_213\" name=\"Primary tumor response WHO category\">\n<option id=\"T84_214\" name=\"CR\" value=\"CR\">CR - No radiologically detectable residual tumor</option>\n<option id=\"T84_215\" name=\"PR\" value=\"PR\">PR - At least 30% decrease in longest recordable dimension of tumor</option>\n<option id=\"T84_216\" name=\"PD\" value=\"PD\">PD - At least 20% increase in longest recordable dimension of tumor</option>\n<option id=\"T84_217\" name=\"NC\" value=\"NC\">NC - No change</option>\n</select>\n</p>\n</section>\n</body>\n</html>\n",

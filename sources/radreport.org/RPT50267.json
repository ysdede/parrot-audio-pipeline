    "templateData": "<!DOCTYPE html>\n<html>\n    <head>\n        <title>Vaginal Cancer MRI</title>\n        <meta charset=\"UTF-8\" />\n        <meta name=\"dcterms.identifier\" content=\"0e3a89cb-cc80-4ec7-9189-1d5d27e1949e\" />\n        <meta name=\"dcterms.title\" content=\"Vaginal Cancer MRI\" />\n        <meta name=\"dcterms.description\" content=\"\" />\n        <meta name=\"dcterms.type\" content=\"IMAGE_REPORT_TEMPLATE\" />\n        <meta name=\"dcterms.language\" content=\"en\" />\n        <meta name=\"dcterms.publisher\" content=\"ESR\" />\n        <meta name=\"dcterms.rights\" content=\"May be used freely, subject to license agreement\" />\n        <meta name=\"dcterms.license\" content=\"http://www.radreport.org/license.pdf\" />\n        <meta name=\"dcterms.date\" content=\"2017-10-06\" />\n        <meta name=\"dcterms.creator\" content=\"Teresa Margarida Cunha, MD\" />\n        <meta name=\"dcterms.contributor\" content=\"Rita Lucas, MD\" />\n        <script type=\"text/xml\">\n            <template_attributes>\n                <coded_content>\n                    <coding_schemes>\n                        <coding_scheme name=\"RADLEX\" designator=\"2.16.840.1.113883.6.256\"></coding_scheme>\n                    </coding_schemes>\n                    <entry origtxt=\"SELECTION_LIST_1476404765878\">\n                        <term>\n                            <code meaning=\"wall of rectum\" value=\"RID32936\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476404765870\">\n                        <term>\n                            <code meaning=\"vagina\" value=\"RID325\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1476404765875\">\n                        <term>\n                            <code meaning=\"left side of pelvic wall\" value=\"RID32629\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"impressionText\">\n                        <term>\n                            <code meaning=\"impression section\" value=\"RID13170\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1476404765840\">\n                        <term>\n                            <code meaning=\"clinical information section\" value=\"RID13166\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"comparisonsText\">\n                        <term>\n                            <code meaning=\"comparison\" value=\"RID28483\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1476404765855\">\n                        <term>\n                            <code meaning=\"uterus\" value=\"RID302\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1476404765881\">\n                        <term>\n                            <code meaning=\"wall of urinary bladder\" value=\"RID30135\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"SELECTION_LIST_1476404765862\">\n                        <term>\n                            <code meaning=\"endometrium\" value=\"RID30958\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                </coded_content>\n            </template_attributes>\n        </script>\n    </head>\n    <body>\n        <section id=\"procedureInformation\" class=\"level1\" data-section-name=\"Procedure Information\">\n            <header class=\"level1\">\n                Procedure Information\n            </header>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476404765837\">Procedure Type:</label>\n                <select id=\"SELECTION_LIST_1476404765837\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Enhanced MRI Pelvis [Vaginal opacification with ultrasound gel].\">\n                    <option id=\"SELECTION_LIST_1476404765837_0\" value=\"Enhanced MRI Pelvis [Vaginal opacification with ultrasound gel].\" name=\"SELECTION_LIST_1476404765837\" selected=\"\">Enhanced MRI Pelvis [Vaginal opacification with ultrasound gel].</option>\n                    <option id=\"SELECTION_LIST_1476404765837_1\" value=\"Unenhanced MRI Pelvis [Vaginal opacification with ultrasound gel].\" name=\"SELECTION_LIST_1476404765837\">Unenhanced MRI Pelvis [Vaginal opacification with ultrasound gel].</option>\n                </select>\n            </p>\n<p title=\"\">\n                <label for=\"SELECTION_LIST_1476404765841\">Technique:</label>\n                <select multiple=\"multiple\" id=\"SELECTION_LIST_1476404765841\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"T2-weighted images of the pelvis in axial, sagittal planes and coronal oblique (perpendicular o the long axis of the vagina) T1-weighted images of the pelvis in axial plane\">\n                    <option id=\"SELECTION_LIST_1476404765841_0\" value=\"T2-weighted images of the pelvis in axial, sagittal planes and coronal oblique (perpendicular o the long axis of the vagina) T1-weighted images of the pelvis in axial plane\" name=\"SELECTION_LIST_1476404765841\" selected=\"\">T2-weighted images of the pelvis in axial, sagittal planes and coronal oblique (perpendicular o the long axis of the vagina) T1-weighted images of the pelvis in axial plane</option>\n                    <option id=\"SELECTION_LIST_1476404765841_1\" value=\"Axial T2-weighted images of the abdomen were also obtained from the renal hilum to the iliac crests.\" name=\"SELECTION_LIST_1476404765841\">Axial T2-weighted images of the abdomen were also obtained from the renal hilum to the iliac crests.</option>\n                    <option id=\"SELECTION_LIST_1476404765841_2\" value=\"Axial DW-MRI study was also performed in the pelvis and in the abdomen from the renal hilum to the iliac crests.]\" name=\"SELECTION_LIST_1476404765841\">Axial DW-MRI study was also performed in the pelvis and in the abdomen from the renal hilum to the iliac crests.]</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476404765845\">Type of pre and post contrast imaging of the pelvis in the sagittal plane and in axial plane in late phase:</label>\n                <select id=\"SELECTION_LIST_1476404765845\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Dynamic\">\n                    <option id=\"SELECTION_LIST_1476404765845_0\" value=\"Dynamic\" name=\"SELECTION_LIST_1476404765845\" selected=\"\">Dynamic</option>\n                    <option id=\"SELECTION_LIST_1476404765845_1\" value=\"Non-dynamic\" name=\"SELECTION_LIST_1476404765845\">Non-dynamic</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476404765848\">Strength of Tesla scanner:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"\" id=\"NUMBER_1476404765848\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476404765849\">Contrast type:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476404765849\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476404765850\">Contrast dose administered before and after fat suppressed T1-weighted imaging:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"mL\" id=\"NUMBER_1476404765850\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    mL\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476404765851\">Image quality:</label>\n                <select id=\"SELECTION_LIST_1476404765851\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Satisfactory\">\n                    <option id=\"SELECTION_LIST_1476404765851_0\" value=\"Satisfactory\" name=\"SELECTION_LIST_1476404765851\" selected=\"\">Satisfactory</option>\n                    <option id=\"SELECTION_LIST_1476404765851_1\" value=\"Degarded by motion/etc.\" name=\"SELECTION_LIST_1476404765851\">Degarded by motion/etc.</option>\n                </select>\n            </p>\n        </section>\n        <section id=\"clinicalInformation\" class=\"level1\" data-section-name=\"Clinical Information\">\n            <header class=\"level1\">\n                Clinical Information\n            </header>\n            <p title=\"\">\n                <label for=\"TEXT_1476404765840\">Clinical Indication:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476404765840\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Vaginal Cancer Staging</textarea>\n            </p>\n                    </section>\n        <section id=\"comparisons\" class=\"level1\" data-section-name=\"Comparison\">\n            <header class=\"level1\">\n                Comparison\n            </header>\n            <p title=\"\">\n                <label for=\"comparisonsText\">Comparison study:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"comparisonsText\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">None available</textarea>\n            </p>\n        </section>\n        <section id=\"findings\" class=\"level1\" data-section-name=\"Findings\">\n            <header class=\"level1\">\n                Findings\n            </header>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476404765855\">Uterus:</label>\n                <select id=\"SELECTION_LIST_1476404765855\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Anteverted\">\n                    <option id=\"SELECTION_LIST_1476404765855_0\" value=\"Anteverted\" name=\"SELECTION_LIST_1476404765855\" selected=\"\">Anteverted</option>\n                    <option id=\"SELECTION_LIST_1476404765855_1\" value=\"Retroverted\" name=\"SELECTION_LIST_1476404765855\">Retroverted</option>\n                    <option id=\"SELECTION_LIST_1476404765855_2\" value=\"Retroflexed\" name=\"SELECTION_LIST_1476404765855\">Retroflexed</option>\n                    <option id=\"SELECTION_LIST_1476404765855_3\" value=\"Displaced to left\" name=\"SELECTION_LIST_1476404765855\">Displaced to left</option>\n                    <option id=\"SELECTION_LIST_1476404765855_4\" value=\"Displaced to right\" name=\"SELECTION_LIST_1476404765855\">Displaced to right</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"findingsText\">Size:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"findingsText\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Normal in size</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476404765861\">Measuring:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"cm\" id=\"NUMBER_1476404765861\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    cm\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476404765862\">Endometrium:</label>\n                <select id=\"SELECTION_LIST_1476404765862\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Normal\">\n                    <option id=\"SELECTION_LIST_1476404765862_0\" value=\"Normal\" name=\"SELECTION_LIST_1476404765862\" selected=\"\">Normal</option>\n                    <option id=\"SELECTION_LIST_1476404765862_1\" value=\"Abnormal\" name=\"SELECTION_LIST_1476404765862\">Abnormal</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476404765868\">The maximum width of the endometrium is:</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"mm\" id=\"NUMBER_1476404765868\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    mm\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476404765869\">Cervix:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476404765869\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">Unremarkable</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476404765870\">Vagina:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476404765870\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"NUMBER_1476404765874\">Tumour measurement (of larger axis):</label>\n                <span>\n                    <input type=\"number\" step=\"1.0\" data-field-units=\"cm\" id=\"NUMBER_1476404765874\" name=\"\" data-field-type=\"NUMBER\" data-field-completion-action=\"NONE\" value=\"\" />\n                    cm\n                </span>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476404765871\">Tumour:</label>\n                <select id=\"SELECTION_LIST_1476404765871\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Confined to the vagina \">\n                    <option id=\"SELECTION_LIST_1476404765871_0\" value=\"Confined to the vagina\" name=\"SELECTION_LIST_1476404765871\">Confined to the vagina</option>\n                    <option id=\"SELECTION_LIST_1476404765871_1\" value=\"Invading paravaginal tissues\" name=\"SELECTION_LIST_1476404765871\">Invading paravaginal tissues</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476404765875\">Pelvic wall:</label>\n                <select id=\"SELECTION_LIST_1476404765875\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Invaded\">\n                    <option id=\"SELECTION_LIST_1476404765875_0\" value=\"Invaded\" name=\"SELECTION_LIST_1476404765875\" selected=\"\">Invaded</option>\n                    <option id=\"SELECTION_LIST_1476404765875_1\" value=\"Not invaded\" name=\"SELECTION_LIST_1476404765875\">Not invaded</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476404765881\">Bladder wall:</label>\n                <select id=\"SELECTION_LIST_1476404765881\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Invaded\">\n                    <option id=\"SELECTION_LIST_1476404765881_0\" value=\"Invaded\" name=\"SELECTION_LIST_1476404765881\" selected=\"\">Invaded</option>\n                    <option id=\"SELECTION_LIST_1476404765881_1\" value=\"Not invaded\" name=\"SELECTION_LIST_1476404765881\">Not invaded</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476404765878\">Rectal wall:</label>\n                <select id=\"SELECTION_LIST_1476404765878\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Invaded\">\n                    <option id=\"SELECTION_LIST_1476404765878_0\" value=\"Invaded\" name=\"SELECTION_LIST_1476404765878\" selected=\"\">Invaded</option>\n                    <option id=\"SELECTION_LIST_1476404765878_1\" value=\"Not invaded\" name=\"SELECTION_LIST_1476404765878\">Not invaded</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476404765884\">Regional lymph nodes:</label>\n                <select id=\"SELECTION_LIST_1476404765884\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Normal in size\">\n                    <option id=\"SELECTION_LIST_1476404765884_0\" value=\"Normal in size\" name=\"SELECTION_LIST_1476404765884\" selected=\"\">Normal in size</option>\n                    <option id=\"SELECTION_LIST_1476404765884_1\" value=\"Enlarged; probably reactive\" name=\"SELECTION_LIST_1476404765884\">Enlarged; probably reactive</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"SELECTION_LIST_1476404765887\">Pelvic or inguinal lymph nodes:</label>\n                <select id=\"SELECTION_LIST_1476404765887\" name=\"\" data-field-type=\"SELECTION_LIST\" data-field-completion-action=\"NONE\" value=\"Normal in size\">\n                    <option id=\"SELECTION_LIST_1476404765887_0\" value=\"Normal in size\" name=\"SELECTION_LIST_1476404765887\" selected=\"\">Normal in size</option>\n                    <option id=\"SELECTION_LIST_1476404765887_1\" value=\"Enlarged; probably reactive\" name=\"SELECTION_LIST_1476404765887\">Enlarged; probably reactive</option>\n                </select>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476404765890\">Distant metastasis:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476404765890\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no distant metastasis.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476404765891\">Physiologic pelvic fluid:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476404765891\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\">There is no physiologic pelvic fluid.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1476404765892\">Other findings:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1476404765892\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n        </section>\n        <section id=\"impression\" class=\"level1\" data-section-name=\"Impression\">\n            <header class=\"level1\">\n                Impression\n            </header>\n            <p title=\"\">\n                <label for=\"impressionText\">Impression:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"impressionText\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n        </section>\n    </body>\n</html>\n",

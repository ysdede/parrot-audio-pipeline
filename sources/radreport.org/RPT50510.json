    "templateData": "<!DOCTYPE html>\n<html>\n    <head>\n        <title>Fluoro Feeding Tube </title>\n        <meta charset=\"UTF-8\" />\n        <meta name=\"dcterms.identifier\" content=\"2478af9e-78d0-46da-af85-a0f63c453f82\" />\n        <meta name=\"dcterms.title\" content=\"Fluoro Feeding Tube \" />\n        <meta name=\"dcterms.description\" content=\"\" />\n        <meta name=\"dcterms.type\" content=\"IMAGE_REPORT_TEMPLATE\" />\n        <meta name=\"dcterms.language\" content=\"en\" />\n        <meta name=\"dcterms.publisher\" content=\"University of Utah\" />\n        <meta name=\"dcterms.rights\" content=\"May be used freely, subject to license agreement\" />\n        <meta name=\"dcterms.license\" content=\"http://www.radreport.org/license.pdf\" />\n        <meta name=\"dcterms.date\" content=\"2018-03-12\" />\n        <meta name=\"dcterms.creator\" content=\"Marta E. Heilbrun, MD\" />\n        <script type=\"text/xml\">\n            <template_attributes>\n                <coded_content>\n                    <coding_schemes>\n                        <coding_scheme name=\"RADLEX\" designator=\"2.16.840.1.113883.6.256\"></coding_scheme>\n                        <coding_scheme name=\"LOINC\" designator=\"2.16.840.1.113883.6.1\"></coding_scheme>\n                    </coding_schemes>\n                    <entry origtxt=\"findingsText\">\n                        <term>\n                            <code meaning=\"ligament of Treitz\" value=\"RID147\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459354564191\">\n                        <term>\n                            <code meaning=\"indication\" value=\"RID49442\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"procedureInformation\">\n                        <term>\n                            <code meaning=\"Current Imaging Procedure Description\" value=\"55111-9\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"findings\">\n                        <term>\n                            <code meaning=\"Procedure Findings\" value=\"59776-5\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"comparisons\">\n                        <term>\n                            <code meaning=\"Radiology Comparison Study\" value=\"18834-2\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"impression\">\n                        <term>\n                            <code meaning=\"Impressions\" value=\"19005-8\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"clinicalInformation\">\n                        <term>\n                            <code meaning=\"Clinical Information\" value=\"55752-0\" scheme=\"LOINC\"></code>\n                        </term>\n                    </entry>\n                    <entry origtxt=\"TEXT_1459354564192\">\n                        <term>\n                            <code meaning=\"fluoroscopy time\" value=\"RID49440\" scheme=\"RADLEX\"></code>\n                        </term>\n                    </entry>\n                </coded_content>\n            </template_attributes>\n        </script>\n    </head>\n    <body>\n        <section id=\"procedureInformation\" class=\"level1\" data-section-name=\"Procedure Information\">\n            <header class=\"level1\">\n                Procedure Information\n            </header>\n            <p title=\"\">\n                <label for=\"TEXT_1459354564190\">Technique:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459354564190\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Small amount of topical lidocaine gel was placed into the nares. Next, under fluoroscopic guidance, a feeding tube was inserted into the stomach and guided into the proximal small bowel. Small amount of contrast was injected to verify satisfactory positioning.</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1459354564192\">Fluoroscopy Time:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459354564192\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\"></textarea>\n            </p>\n        </section>\n        <section id=\"clinicalInformation\" class=\"level1\" data-section-name=\"Clinical Information\">\n            <header class=\"level1\">\n                Clinical Information\n            </header>\n            <p title=\"\">\n                <label for=\"TEXT_1459354564191\">Indication:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"TEXT_1459354564191\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Requirement for nutritional replacement.</textarea>\n            </p>\n        </section>\n        <section id=\"comparisons\" class=\"level1\" data-section-name=\"Comparison\">\n            <header class=\"level1\">\n                Comparison\n            </header>\n            <p title=\"\">\n                <label for=\"comparisonsText\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"comparisonsText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">None.</textarea>\n            </p>\n        </section>\n        <section id=\"findings\" class=\"level1\" data-section-name=\"Findings\">\n            <header class=\"level1\">\n                Findings\n            </header>\n            <p title=\"\">\n                <label for=\"findingsText\">The tip of the feeding tube terminates:</label>\n                <textarea rows=\"3\" cols=\"100\" id=\"findingsText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">at the ligament of Treitz</textarea>\n            </p>\n            <p title=\"\">\n                <label for=\"TEXT_1520484872613\">Additional Findings:</label>\n                <input type=\"text\" id=\"TEXT_1520484872613\" name=\"\" data-field-type=\"TEXT\" data-field-completion-action=\"NONE\" value=\"None.\" />\n            </p>\n        </section>\n        <section id=\"impression\" class=\"level1\" data-section-name=\"Impression\">\n            <header class=\"level1\">\n                Impression\n            </header>\n            <p title=\"\">\n                <label for=\"impressionText\"></label>\n                <textarea rows=\"3\" cols=\"100\" id=\"impressionText\" name=\"\" data-field-type=\"TEXTAREA\" data-field-completion-action=\"NONE\">Technically successful placement of feeding tube using fluoroscopic guidance.</textarea>\n            </p>\n        </section>\n    </body>\n</html>\n",
